{
  "name": "@flouviahq/elements",
  "version": "0.1.0",
  "description": "Embebe el cotizador B2B de Cord en cualquier sitio — Web Component + wrapper de React. Tu marca, aprobación y pago en línea.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://cord.flouvia.com/elements",
  "keywords": ["cord", "cotizaciones", "b2b", "quote", "embed", "web-component", "react", "mexico", "cfdi"],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./types/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./types/vue.d.ts",
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.cjs"
    },
    "./framer": {
      "types": "./types/framer.d.ts",
      "import": "./dist/framer.mjs",
      "require": "./dist/framer.cjs"
    },
    "./webflow": {
      "browser": "./dist/webflow.js",
      "import": "./dist/webflow.mjs",
      "require": "./dist/webflow.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./types/index.d.ts",
  "files": ["dist", "types", "README.md"],
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "node build.mjs"
  },
  "peerDependencies": {
    "react": ">=17",
    "vue": ">=3",
    "framer": "*"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "vue": { "optional": true },
    "framer": { "optional": true }
  },
  "devDependencies": {
    "esbuild": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
