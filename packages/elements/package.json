{
  "name": "@trato/elements",
  "version": "0.1.0",
  "description": "Embebe el cotizador B2B de Trato en cualquier sitio — Web Component + wrapper de React. Tu marca, aprobación y pago en línea.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://trato.flouvia.com/elements",
  "keywords": ["trato", "cotizaciones", "b2b", "quote", "embed", "web-component", "react", "mexico", "cfdi"],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./types/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./types/index.d.ts",
  "files": ["dist", "types", "README.md"],
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "node build.mjs"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "esbuild": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
