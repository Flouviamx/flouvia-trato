        --color-border: rgba(255, 255, 255, 0.1);
        --surface: #141c28;
        --surface-2: #1a2230;

        /* Sidebar en oscuro → vidrio navy rico (el look anterior, ahora vía variables) */
        --sb-bg: linear-gradient(180deg, rgba(22,30,44,0.85) 0%, rgba(13,19,29,0.72) 100%);
        --sb-border: rgba(255,255,255,0.1);
        --sb-shadow:
            inset 0 1px 0 rgba(255,255,255,0.12),
            inset 0 0 0 0.5px rgba(255,255,255,0.05),
            inset 0 -6px 14px rgba(0,0,0,0.2),
            0 16px 44px -10px rgba(0,0,0,0.55);
        --sb-sheen:
            radial-gradient(135% 55% at 50% -12%, rgba(255,255,255,0.12), transparent 62%),
            radial-gradient(90% 40% at 18% 0%, rgba(120,160,230,0.10), transparent 70%);
        --sb-text: rgba(255,255,255,0.55);
        --sb-text-strong: rgba(255,255,255,0.92);
        --sb-text-active: #ffffff;
        --sb-label: rgba(255,255,255,0.3);
        --sb-divider: rgba(255,255,255,0.1);
        --sb-hover-bg: rgba(255,255,255,0.06);
        --sb-active-bg: rgba(255,255,255,0.1);
        --sb-icon-op: 0.7;
        --sb-indicator-bg: rgba(255,255,255,0.11);
        --sb-indicator-shadow:
            inset 0 1px 1px rgba(255,255,255,0.26),
            inset 0 0 0 0.5px rgba(255,255,255,0.14),
            inset 0 -4px 9px rgba(0,0,0,0.16),
            0 4px 14px -6px rgba(0,0,0,0.5);
        --sb-badge-bg: rgba(255,255,255,0.12);
        --sb-badge-text: rgba(255,255,255,0.85);
        --sb-toggle-bg: rgba(255,255,255,0.045);
        --sb-toggle-shadow: inset 0 0 0 0.5px rgba(255,255,255,0.09), inset 0 1px 0 rgba(255,255,255,0.06);
        --sb-toggle-hover-bg: rgba(255,255,255,0.12);
        --sb-menu-bg: linear-gradient(180deg, #1c2535, #111823);
        --sb-menu-solid-bg: #111823;
        --sb-menu-border: rgba(255,255,255,0.12);
        --sb-menu-shadow: inset 0 1px 0 rgba(255,255,255,0.12), inset 0 0 0 0.5px rgba(255,255,255,0.06), 0 24px 60px -18px rgba(0,0,0,0.75);
        --sb-menu-text: rgba(255,255,255,0.88);
        --sb-menu-muted: rgba(255,255,255,0.45);
        --sb-menu-hover: rgba(255,255,255,0.08);
        --sb-avatar-bg: linear-gradient(135deg, rgba(255,255,255,0.22), rgba(255,255,255,0.08));
        --sb-avatar-text: #ffffff;
    }
    html[data-theme="dark"] body { background: #0b1018; }
    /* Topbar: en oscuro, vidrio navy translúcido (en claro es blanco) */
    html[data-theme="dark"] .topbar {
        background: linear-gradient(180deg, rgba(22,30,44,0.85) 0%, rgba(13,19,29,0.72) 100%);
        border-color: rgba(255,255,255,0.1);
        box-shadow:
            inset 0 1px 0 rgba(255,255,255,0.12),
            inset 0 0 0 0.5px rgba(255,255,255,0.05),
            inset 0 -6px 14px rgba(0,0,0,0.2),
            0 16px 44px -10px rgba(0,0,0,0.55);
    }
    /* Buscador y kbd de la topbar */
    html[data-theme="dark"] .tb-kbd, html[data-theme="dark"] .cmdk-esc { background: rgba(255,255,255,0.06); color: var(--color-text-muted); }
    /* Menú "Crear" → vidrio oscuro */
    html[data-theme="dark"] .tb-create-menu {
        background: linear-gradient(180deg, #1c2535, #111823);
        border-color: rgba(255,255,255,0.12);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.12), inset 0 0 0 0.5px rgba(255,255,255,0.06), 0 24px 60px -18px rgba(0,0,0,0.75);
    }
    html[data-theme="dark"] .tb-create-item kbd { background: rgba(255,255,255,0.08); }
    /* Toggle de tema en la topbar */
    .tb-theme .tb-sun { display: none; }
    .tb-theme .tb-moon { display: inline-flex; }
    html[data-theme="dark"] .tb-theme .tb-sun { display: inline-flex; }
    html[data-theme="dark"] .tb-theme .tb-moon { display: none; }

    *, *::before, *::after { box-sizing: border-box; }
    html, body {
        margin: 0; padding: 0;
        font-family: var(--font-sans);
        color: var(--color-text);
        background: var(--color-bg-soft);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
    }
    ::selection { background: #0a192f; color: #fff; }

    .editorial {
        font-family: var(--font-sans);
        font-style: normal;
        font-weight: 600;
        letter-spacing: -0.03em;
        font-variant-numeric: tabular-nums;
    }

    /* ── Entrada de página (CSS, no GSAP) ── */
    @keyframes app-fadein {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .app-content > * {
        animation: app-fadein 0.55s var(--ease-spring) both;
    }
    .app-content > *:nth-child(2) { animation-delay: 0.06s; }
    .app-content > *:nth-child(3) { animation-delay: 0.12s; }
    .app-content > *:nth-child(4) { animation-delay: 0.18s; }
    @media (prefers-reduced-motion: reduce) {
        .app-content > * { animation: none; }
    }

    /* ── Card base reutilizable ── */
    .card {
        background: var(--surface);
        border: 1px solid var(--color-border);
        border-radius: 14px;
    }

    /* ── Status pill reutilizable ── */
    .status-pill {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 0.7rem; font-weight: 700; letter-spacing: 0.2px;
        padding: 4px 10px; border-radius: 100px; white-space: nowrap;
    }
    .status-pill::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

    /* ════════ Items del Cmd+K (inyectados por JS → globales) ════════ */
    .cmdk-group-label { font-size: 0.58rem; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; color: #99a2af; padding: 10px 12px 5px; }
    .cmdk-item {
        position: relative;
        display: flex; align-items: center; gap: 11px; width: 100%; text-align: left;
        padding: 9px 12px; border-radius: 9px; cursor: pointer; border: none; background: none;
        font-family: var(--font-sans); color: var(--color-text); text-decoration: none;
        transition: background 0.12s ease;
    }
    .cmdk-item.sel { background: var(--color-bg-soft); }
    .cmdk-item.sel::before {
        content: ''; position: absolute; left: 0; top: 7px; bottom: 7px;
        width: 3px; border-radius: 0 3px 3px 0; background: var(--color-blue-deep);
    }
    .cmdk-item.sel::after {
        content: '↵'; position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
        font-size: 0.8rem; color: var(--color-text-muted);
    }
    .cmdk-item.sel .cmdk-hint { margin-right: 1.4rem; }
    .cmdk-ico {
        width: 28px; height: 28px; border-radius: 8px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: var(--color-bg-soft); color: var(--color-blue-deep); font-size: 0.7rem; font-weight: 800;
        transition: background 0.12s ease, color 0.12s ease;
    }
    .cmdk-ico svg { width: 15px; height: 15px; }
    .cmdk-item.sel .cmdk-ico { background: var(--color-blue-deep); color: #fff; }
    .cmdk-item-body { display: flex; flex-direction: column; min-width: 0; flex: 1; }
    .cmdk-item-title { font-size: 0.88rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cmdk-item-sub { font-size: 0.72rem; color: var(--color-text-muted); }
    .cmdk-pill { font-size: 0.62rem; font-weight: 700; color: var(--color-text-muted); flex-shrink: 0; }
    .cmdk-hint { font-size: 0.74rem; color: #99a2af; flex-shrink: 0; margin-left: auto; padding-left: 1rem; white-space: nowrap; }
    .cmdk-empty {
        display: flex; flex-direction: column; align-items: center; gap: 4px;
        padding: 2.4rem 1rem; text-align: center; color: var(--color-text-muted);
    }
    .cmdk-empty svg { width: 26px; height: 26px; color: #c4cad3; margin-bottom: 6px; }
    .cmdk-empty p { font-size: 0.88rem; font-weight: 600; color: var(--color-text); margin: 0; }
    .cmdk-empty span { font-size: 0.76rem; color: #99a2af; }
    /* Atajo de teclado de un item del Cmd+K (ej. "Nueva cotización  C") */
    .cmdk-kbd { font-size: 0.62rem; font-weight: 700; color: var(--color-text-muted); background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 5px; padding: 2px 6px; flex-shrink: 0; }
    .cmdk-item.sel .cmdk-kbd { margin-right: 1.4rem; }

    /* ════════ Notificaciones (campana) ════════ */
    .tb-notif-wrap { position: relative; }
    .tb-notif-dot {
        position: absolute; top: 6px; right: 6px; width: 8px; height: 8px; border-radius: 50%;
        background: var(--color-danger); border: 1.5px solid #fff;
    }
    .tb-notif-dot[hidden] { display: none; }
    .notif-panel {
        position: absolute; top: calc(100% + 8px); right: 0; z-index: 60; width: 340px;
        background: var(--surface); border: 1px solid var(--color-border); border-radius: 14px;
        box-shadow: 0 24px 60px -18px rgba(10,25,47,0.45);
        overflow: hidden; animation: cmdk-pop 0.18s var(--ease-spring);
    }
    .notif-panel[hidden] { display: none; }
    .notif-head { display: flex; align-items: center; justify-content: space-between; padding: 12px 14px; border-bottom: 1px solid var(--color-border); }
    .notif-head strong { font-size: 0.9rem; }
    .notif-mark { border: none; background: none; cursor: pointer; font-family: var(--font-sans); font-size: 0.72rem; font-weight: 600; color: var(--color-text-muted); }
    .notif-mark:hover { color: var(--color-blue-deep); }
    .notif-list { max-height: 56vh; overflow-y: auto; padding: 6px; }
    .notif-item {
        display: flex; align-items: flex-start; gap: 10px; padding: 9px 10px; border-radius: 10px;
        text-decoration: none; color: var(--color-text); transition: background 0.14s ease;
    }
    .notif-item:hover { background: var(--color-bg-soft); }
    .notif-item.unread { background: rgba(10,25,47,0.035); }
    .notif-ico {
        width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: var(--color-bg-soft); color: var(--color-blue-deep);
    }
    .notif-ico svg { width: 15px; height: 15px; }
    .notif-ico.ok { background: rgba(16,185,129,0.12); color: #059669; }
    .notif-ico.warn { background: rgba(245,158,11,0.12); color: #b45309; }
    .notif-ico.danger { background: rgba(239,68,68,0.12); color: #dc2626; }
    .notif-body { display: flex; flex-direction: column; min-width: 0; flex: 1; gap: 1px; }
    .notif-title { font-size: 0.82rem; font-weight: 600; }
    .notif-sub { font-size: 0.74rem; color: var(--color-text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .notif-when { font-size: 0.68rem; color: #99a2af; }
    .notif-foot { display: block; text-align: center; padding: 10px; border-top: 1px solid var(--color-border); font-size: 0.78rem; font-weight: 600; color: var(--color-blue-deep); text-decoration: none; }
    .notif-foot:hover { background: var(--color-bg-soft); }
    .notif-empty { padding: 2rem 1rem; text-align: center; font-size: 0.82rem; color: var(--color-text-muted); }

    /* ════════ "Fijados" en el sidebar (localStorage, inyectado por JS → global) ════════ */
    .sb-pins[hidden] { display: none; }
    /* El contenido de los pins se inyecta por JS, así que SUS estilos van aquí (global)
       — los .sb-item scopeados no aplican al HTML dinámico. */
    .sb-pins .sb-group-label {
        font-size: 0.6rem; font-weight: 800; letter-spacing: 1.4px; text-transform: uppercase;
        color: var(--sb-label); padding: 2px 11px 5px;
    }
    .sb-pin-row { position: relative; display: flex; align-items: center; }
    .sb-pin-row .sb-item {
        flex: 1; display: flex; align-items: center; gap: 11px;
        padding: 8px 11px; border-radius: 9px;
        font-size: 0.86rem; font-weight: 500; color: var(--sb-text); text-decoration: none;
        transition: color 0.25s, background 0.25s;
    }
    .sb-pin-row .sb-item svg { width: 16px; height: 16px; opacity: var(--sb-icon-op); flex-shrink: 0; }
    .sb-pin-row .sb-item-label { flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sb-pin-row .sb-item:hover { color: var(--sb-text-strong); background: var(--sb-hover-bg); }
    .sb-pin-row .sb-item.active { color: var(--sb-text-active); background: var(--sb-active-bg); }
    .sb-collapsed .sb-pins .sb-group-label { display: none; }
    .sb-collapsed .sb-pin-row .sb-item { justify-content: center; padding: 0; width: 44px; height: 40px; }
    .sb-collapsed .sb-pin-row .sb-item-label { display: none; }
    .sb-pin-x {
        position: absolute; right: 6px; opacity: 0; border: none; background: none; cursor: pointer;
        color: var(--sb-label); padding: 3px; border-radius: 6px; line-height: 0;
        transition: opacity 0.15s, color 0.15s, background 0.15s;
    }
    .sb-pin-x svg { width: 13px; height: 13px; }
    .sb-pin-row:hover .sb-pin-x { opacity: 1; }
    .sb-pin-x:hover { color: var(--sb-text-strong); background: var(--sb-active-bg); }
    .sb-collapsed .sb-pin-x { display: none; }

    /* Botón de fijar en el page-head */
    .ph-title-row { display: flex; align-items: center; gap: 8px; }
    .ph-pin {
        display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
        border: none; background: none; cursor: pointer; color: #aab2bd;
        transition: color 0.18s, background 0.18s, transform 0.18s var(--ease-spring);
    }
    .ph-pin svg { width: 17px; height: 17px; }
    .ph-pin:hover { color: var(--color-blue-deep); background: var(--color-bg-soft); transform: translateY(-1px); }
    .ph-pin.pinned { color: var(--color-blue-deep); }
    .ph-pin.pinned svg { fill: rgba(10,25,47,0.12); }

    /* Breadcrumbs + tabs del page-head */
    .ph-crumbs { display: flex; align-items: center; gap: 6px; font-size: 0.76rem; margin-bottom: 2px; flex-wrap: wrap; }
    .ph-crumbs a, .ph-crumbs > span { color: var(--color-text-muted); text-decoration: none; }
    .ph-crumbs a:hover { color: var(--color-blue-deep); }
    .ph-crumbs a::after, .ph-crumbs > span:not(.ph-crumb-here)::after { content: '/'; margin-left: 6px; color: #c4cad3; }
    .ph-crumb-here { color: var(--color-text); font-weight: 600; }
    .ph-tabs-row { max-width: var(--content-max); }
    .ph-tabs-row:not(:empty) { margin-top: 1rem; border-bottom: 1px solid var(--color-border); display: flex; gap: 2px; }
    /* Helper para que las páginas pinten tabs consistentes (slot page-tabs) */
    .ph-tab {
        position: relative; padding: 9px 12px; font-size: 0.85rem; font-weight: 550;
        color: var(--color-text-muted); text-decoration: none; background: none; border: none;
        cursor: pointer; font-family: var(--font-sans); white-space: nowrap;
    }
    .ph-tab:hover { color: var(--color-text); }
    .ph-tab.active { color: var(--color-blue-deep); font-weight: 650; }
    .ph-tab.active::after { content: ''; position: absolute; left: 8px; right: 8px; bottom: -1px; height: 2px; border-radius: 2px 2px 0 0; background: var(--color-blue-deep); }

    /* ════════ Barra de progreso de navegación ════════ */
    .nav-progress {
        position: fixed; top: 0; left: 0; height: 2.5px; width: 0; z-index: 999;
        background: linear-gradient(90deg, #1e40af, #3b82f6); border-radius: 0 3px 3px 0;
        opacity: 0; transition: width 0.2s ease, opacity 0.3s ease;
        box-shadow: 0 0 8px rgba(59,130,246,0.6);
    }
    .nav-progress.active { opacity: 1; }

    /* ════════ Toasts globales (window.cordToast) ════════ */
    .toast-stack { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); z-index: 800; display: flex; flex-direction: column; gap: 8px; align-items: center; pointer-events: none; }
    .toast {
        display: flex; align-items: center; gap: 9px; pointer-events: auto;
        background: var(--color-blue-deep); color: #fff;
