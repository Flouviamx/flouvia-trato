---
// AppLayout — layout de la app de Cord (estilo Linear: compacto, hairlines, sobrio).
// La app usa CSS animations (NO GSAP) para entradas — regla del proyecto.
// Datos reales desde Neon; la org se resuelve desde la sesión de Clerk (src/lib/db.ts).

import { getOrg, getSetupProgress, getSidebarBadges } from '../lib/queries';
import { SignOutButton, OrganizationSwitcher } from '@clerk/astro/components';
import OnboardingWidget from '../components/app/OnboardingWidget.astro';
import Analytics from '@vercel/analytics/astro';
const ORG = await getOrg();

// Avance de configuración (Fase 3). Si la cuenta ya está 100% lista no montamos
// el widget de onboarding ni la píldora de la topbar.
const setup = await getSetupProgress();
const pillDash = `${(setup.pct * 0.9739).toFixed(2)} 100`;

// Contadores en vivo de la sidebar (estilo Linear): seguimiento + cartera vencida.
const badges = await getSidebarBadges();

interface Props {
    title: string;        // título del documento
    page: string;         // id de la página activa en el sidebar
    heading?: string;     // título visible en la topbar
    crumbs?: { label: string; href?: string }[]; // migajas opcionales (páginas anidadas)
}

const { title, page, heading, crumbs = [] } = Astro.props;

// Nav agrupada por secciones (estilo Linear/Notion). `badge` = clave de getSidebarBadges();
// `tone` colorea el contador (neutral / danger). Ajustes vive en el engrane de la topbar.
const NAV_GROUPS = [
    {
        label: 'Principal',
        items: [
            { id: 'dashboard',    href: '/app',              label: 'Dashboard',    icon: 'M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z' },
            { id: 'cotizaciones', href: '/app/cotizaciones', label: 'Cotizaciones', icon: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zM14 3.5L18.5 8H14V3.5z', badge: badges.seguimiento, tone: 'neutral' },
        ],
    },
    {
        label: 'Dinero',
        items: [
            { id: 'cobranza',  href: '/app/cobranza',  label: 'Cobranza',  icon: 'M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z', badge: badges.vencidas, tone: 'danger' },
            { id: 'analitica', href: '/app/analitica', label: 'Analítica', icon: 'M4 13h3v7H4v-7zm6.5-5h3v12h-3V8zM17 11h3v9h-3v-9z' },
        ],
    },
    {
        label: 'Catálogo',
        items: [
            { id: 'clientes',  href: '/app/clientes',  label: 'Clientes',  icon: 'M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5C15 14.17 10.33 13 8 13zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z' },
            { id: 'productos', href: '/app/productos', label: 'Productos', icon: 'M20 7h-4V5l-2-2h-4L8 5v2H4c-1.1 0-2 .9-2 2v5c0 .75.4 1.38 1 1.73V19c0 1.11.89 2 2 2h14c1.11 0 2-.89 2-2v-3.28c.59-.35 1-.99 1-1.72V9c0-1.1-.9-2-2-2zM10 5h4v2h-4V5z' },
        ],
    },
];
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="robots" content="noindex, nofollow" />

        <!-- Favicons -->
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
        <link rel="manifest" href="/manifest.webmanifest" />
        <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
        <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0a192f" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-status-bar-style" content="default" />
        <meta name="apple-mobile-web-app-title" content="Cord" />

        <title>{title}</title>
        <script is:inline>
            // Restaura el estado colapsado de la sidebar antes del primer paint (sin flash).
            try { if (localStorage.getItem('cord.sb.collapsed') === '1') document.documentElement.classList.add('sb-collapsed'); } catch (e) {}
        </script>
    </head>
    <body>
        <div class="app-shell">
            <div class="sb-backdrop" id="sbBackdrop" aria-hidden="true"></div>
            <!-- ── SIDEBAR ── -->
            <aside class="sidebar">
                <!-- Cuenta — arriba -->
                <div class="sb-account">
                    <button class="sb-org-switch" id="orgSwitch" type="button" aria-haspopup="menu" aria-expanded="false" title={ORG.nombre}>
                        <span class="sb-org-avatar">{ORG.inicial}</span>
                        <span class="sb-org-info">
                            <span class="sb-org-name">{ORG.nombre}</span>
                            <span class="sb-org-plan">Plan {ORG.plan}</span>
                        </span>
                        <svg class="sb-org-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>

                    <div class="sb-org-menu" id="orgMenu" role="menu" hidden>
                        <div class="sb-org-menu-head">
                            <span class="sb-org-avatar">{ORG.inicial}</span>
                            <div class="sb-org-menu-id">
                                <strong>{ORG.nombre}</strong>
                                <span>Plan {ORG.plan}</span>
                            </div>
                        </div>
                        <a href="/app/ajustes" class="sb-menu-item" role="menuitem">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                            Ajustes
                        </a>
                        <a href="/app/ajustes/equipo" class="sb-menu-item" role="menuitem">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            Equipo y roles
                        </a>
                        <a href="/" class="sb-menu-item" role="menuitem">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                            Ver sitio público
                        </a>
                        <div class="sb-menu-sep"></div>
                        <SignOutButton redirectUrl="/" class="sb-menu-item sb-menu-danger" role="menuitem">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                            Cerrar sesión
                        </SignOutButton>
                    </div>

                    <!-- Org switcher de Clerk Organizations (cambiar / crear org).
                         Clerk es la fuente de verdad de identidad; el webhook
                         /api/clerk/webhook sincroniza orgs/miembros hacia Neon. -->
                    <div class="sb-clerk-orgs">
                        <OrganizationSwitcher
                            hidePersonal
                            afterSelectOrganizationUrl="/app"
                            afterCreateOrganizationUrl="/app"
                            afterLeaveOrganizationUrl="/app"
                            appearance={{
                                variables: {
                                    colorBackground: '#0d1f38',
                                    colorText: '#ffffff',
                                    colorTextSecondary: 'rgba(255,255,255,0.55)',
                                    colorInputBackground: '#0d1f38',
                                    colorInputText: '#ffffff',
                                    borderRadius: '10px',
                                },
                                elements: { rootBox: { width: '100%' }, organizationSwitcherTrigger: { width: '100%', justifyContent: 'flex-start', color: '#fff' } },
                            }}
                        />
                    </div>
                </div>

                <!-- Acciones móviles (solo en drawer) — crear / ayuda / config -->
                <div class="sb-mobile-actions">
                    <div class="sb-create-wrap">
                        <button class="sb-create" id="sbCreate" type="button" aria-haspopup="menu" aria-expanded="false">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            <span>Crear</span>
                        </button>
                        <div class="sb-create-menu" id="sbCreateMenu" role="menu" hidden>
                            <a href="/app/cotizaciones/nueva" class="sb-menu-item" role="menuitem">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                                Cotización
                            </a>
                            <a href="/app/clientes?nuevo=1" class="sb-menu-item" role="menuitem">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                                Cliente
                            </a>
                            <a href="/app/productos?nuevo=1" class="sb-menu-item" role="menuitem">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                                Producto
                            </a>
                        </div>
                    </div>
                    <button class="sb-action-row" id="sbHelp" type="button">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.1 9a2.9 2.9 0 0 1 5.6 1c0 2-2.9 2.9-2.9 2.9"/><line x1="12" y1="17" x2="12" y2="17"/></svg>
                        <span>Ayuda</span>
                    </button>
                    <a href="/app/ajustes" class="sb-action-row">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                        <span>Configuración</span>
                    </a>
                </div>

                <nav class="sb-nav">
                    <div class="sb-group sb-pins" id="sbPins" hidden></div>
                    {NAV_GROUPS.map((group) => (
                        <div class="sb-group">
                            <span class="sb-group-label">{group.label}</span>
                            {group.items.map((item) => (
                                <a href={item.href} class:list={['sb-item', { active: page === item.id }]} title={item.label}>
                                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={item.icon} /></svg>
                                    <span class="sb-item-label">{item.label}</span>
                                    {!!item.badge && item.badge > 0 && (
                                        <span class:list={['sb-badge', { danger: item.tone === 'danger' }]}>{item.badge > 99 ? '99+' : item.badge}</span>
                                    )}
                                </a>
                            ))}
                        </div>
                    ))}
                </nav>

                <div class="sb-footer">
                    <img class="sb-foot-logo" src="/imgs/logo-cord-white.png" alt="Cord" />
                    <button class="sb-expand" id="sbExpand" type="button" aria-label="Expandir menú" title="Expandir menú">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
                    </button>
                    <button class="sb-collapse" id="sbCollapse" type="button" aria-label="Colapsar menú" title="Colapsar menú">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
                    </button>
                </div>
            </aside>

            <!-- ── MAIN ── -->
            <div class="app-main">
                <header class="topbar">
                    <button class="tb-burger" id="navBurger" type="button" aria-label="Abrir menú">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                    </button>

                    <button class="tb-search" id="cmdkOpen" type="button" aria-label="Buscar — Command K">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        <span class="tb-search-label">Buscar cotizaciones, clientes…</span>
                        <kbd class="tb-kbd">⌘K</kbd>
                    </button>

                    <div class="tb-right">
                        {!setup.complete && (
                            <button class="onb-pill" id="onbPill" type="button" hidden aria-label="Abrir guía de configuración">
                                <span class="onb-pill-ring" aria-hidden="true">
                                    <svg viewBox="0 0 36 36">
                                        <circle class="onb-ring-bg" cx="18" cy="18" r="15.5"></circle>
                                        <circle class="onb-ring-fg" cx="18" cy="18" r="15.5" style={`stroke-dasharray:${pillDash}`}></circle>
                                    </svg>
                                    <b data-pill-pct>{setup.pct}%</b>
                                </span>
                                <span class="onb-pill-label">Guía de configuración</span>
                            </button>
                        )}
                        <div class="tb-notif-wrap">
                            <button class="tb-icon tb-activity" id="notifBtn" type="button" title="Actividad" aria-label="Notificaciones" aria-haspopup="menu" aria-expanded="false">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                                <span class="tb-notif-dot" id="notifDot" hidden></span>
                            </button>
                            <div class="notif-panel" id="notifPanel" role="menu" hidden>
                                <div class="notif-head">
                                    <strong>Notificaciones</strong>
                                    <button type="button" id="notifMarkAll" class="notif-mark">Marcar como leídas</button>
                                </div>
                                <div class="notif-list" id="notifList"></div>
                                <a class="notif-foot" href="/app">Ver toda la actividad</a>
                            </div>
                        </div>
                        <button class="tb-icon tb-help" id="helpBtn" type="button" title="Ayuda" aria-label="Ayuda" aria-haspopup="dialog" aria-expanded="false">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/><path d="M9.1 9a2.9 2.9 0 0 1 5.6 1c0 2-2.9 2.9-2.9 2.9"/><line x1="12" y1="17" x2="12" y2="17"/></svg>
                        </button>
                        <a class:list={['tb-icon', 'tb-gear', { active: page === 'ajustes' }]} href="/app/ajustes" title="Ajustes" aria-label="Ajustes">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                        </a>
                    </div>
                </header>

                <div class="page-head">
                    <div class="ph-inner">
                        <div class="ph-titles">
                            {crumbs.length > 0 && (
                                <nav class="ph-crumbs" aria-label="Ruta">
                                    {crumbs.map((c) => (
                                        c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>
                                    ))}
                                    <span class="ph-crumb-here">{heading ?? title}</span>
                                </nav>
                            )}
                            <div class="ph-title-row">
                                <h1 class="ph-title">{heading ?? title}</h1>
                                <button class="ph-pin" id="phPin" type="button" aria-label="Fijar página" title="Fijar en el menú">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 17v5"/><path d="M5 17h14l-1.5-4.5a2 2 0 0 1-.1-.6V6a2 2 0 0 1 2-2H6a2 2 0 0 1 2 2v5.9a2 2 0 0 1-.1.6L5 17z"/></svg>
                                </button>
                            </div>
                            <slot name="page-sub" />
                        </div>
                        <div class="ph-actions"><slot name="topbar-actions" /></div>
                    </div>
                    <div class="ph-tabs-row"><slot name="page-tabs" /></div>
                </div>

                <main class="app-content">
                    <slot />
                </main>
            </div>
        </div>

        <!-- ── MENÚ DE COMANDOS (Cmd+K) ── -->
        <div class="cmdk" id="cmdk" hidden>
            <div class="cmdk-backdrop" id="cmdkBackdrop"></div>
            <div class="cmdk-panel" role="dialog" aria-modal="true" aria-label="Menú de comandos">
                <div class="cmdk-input-row">
                    <svg class="cmdk-search-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input id="cmdkInput" type="text" placeholder="Buscar cotizaciones, clientes, productos… o un comando" autocomplete="off" spellcheck="false" />
                    <kbd class="cmdk-esc">ESC</kbd>
                </div>
                <div class="cmdk-results" id="cmdkResults"></div>
