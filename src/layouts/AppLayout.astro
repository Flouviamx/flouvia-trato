                    <div class="kbd-row"><span>Ir a Cotizaciones</span><span><kbd>G</kbd> <kbd>C</kbd></span></div>
                    <div class="kbd-row"><span>Ir a Clientes</span><span><kbd>G</kbd> <kbd>L</kbd></span></div>
                    <div class="kbd-row"><span>Ir a Productos</span><span><kbd>G</kbd> <kbd>P</kbd></span></div>
                    <div class="kbd-row"><span>Ir a Cobranza</span><span><kbd>G</kbd> <kbd>B</kbd></span></div>
