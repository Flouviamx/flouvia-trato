---
// AppLayout — layout de la app de Trato (estilo Linear: compacto, hairlines, sobrio).
// La app usa CSS animations (NO GSAP) para entradas — regla del proyecto.
// Datos reales desde Neon; la org se resuelve desde la sesión de Clerk (src/lib/db.ts).

import { getOrg } from '../lib/queries';
import { SignOutButton } from '@clerk/astro/components';
const ORG = await getOrg();

interface Props {
    title: string;        // título del documento
    page: string;         // id de la página activa en el sidebar
    heading?: string;     // título visible en la topbar
}

const { title, page, heading } = Astro.props;

const NAV = [
    { id: 'dashboard',    href: '/app',              label: 'Dashboard',    icon: 'M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z' },
    { id: 'cotizaciones', href: '/app/cotizaciones', label: 'Cotizaciones', icon: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zM14 3.5L18.5 8H14V3.5z' },
    { id: 'cobranza',     href: '/app/cobranza',     label: 'Cobranza',     icon: 'M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z' },
    { id: 'clientes',     href: '/app/clientes',     label: 'Clientes',     icon: 'M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5C15 14.17 10.33 13 8 13zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z' },
    { id: 'productos',    href: '/app/productos',    label: 'Productos',    icon: 'M20 7h-4V5l-2-2h-4L8 5v2H4c-1.1 0-2 .9-2 2v5c0 .75.4 1.38 1 1.73V19c0 1.11.89 2 2 2h14c1.11 0 2-.89 2-2v-3.28c.59-.35 1-.99 1-1.72V9c0-1.1-.9-2-2-2zM10 5h4v2h-4V5z' },
    { id: 'analitica',    href: '/app/analitica',    label: 'Analítica',    icon: 'M4 13h3v7H4v-7zm6.5-5h3v12h-3V8zM17 11h3v9h-3v-9z' },
    { id: 'ajustes',      href: '/app/ajustes',      label: 'Ajustes',      icon: 'M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.488.488 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6A3.61 3.61 0 0 1 8.4 12c0-1.98 1.62-3.6 3.6-3.6s3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z' },
];
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="robots" content="noindex, nofollow" />
        <meta name="theme-color" content="#0a192f" />
        <title>{title}</title>
    </head>
    <body>
        <div class="app-shell">
            <div class="sb-backdrop" id="sbBackdrop" aria-hidden="true"></div>
            <!-- ── SIDEBAR ── -->
            <aside class="sidebar">
                <a href="/app" class="sb-brand">
                    <img src="/imgs/logo-trato-white.png" alt="Trato" />
                </a>

                <nav class="sb-nav">
                    {NAV.map((item) => (
                        <a href={item.href} class:list={['sb-item', { active: page === item.id }]}>
                            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={item.icon} /></svg>
                            <span>{item.label}</span>
                        </a>
                    ))}
                </nav>

                <div class="sb-footer">
                    <a href="/" class="sb-landing-link">← Ver sitio</a>
                    <div class="sb-org">
                        <div class="sb-org-avatar">{ORG.inicial}</div>
                        <div class="sb-org-info">
                            <span class="sb-org-name">{ORG.nombre}</span>
                            <span class="sb-org-plan">Plan {ORG.plan}</span>
                        </div>
                        <SignOutButton redirectUrl="/" class="sb-logout" aria-label="Cerrar sesión">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        </SignOutButton>
                    </div>
                </div>
            </aside>

            <!-- ── MAIN ── -->
            <div class="app-main">
                <header class="topbar">
                    <div class="tb-left">
                        <button class="tb-burger" id="navBurger" type="button" aria-label="Abrir menú">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                        </button>
                        <h1 class="tb-heading">{heading ?? title}</h1>
                    </div>

                    <button class="tb-search" id="cmdkOpen" type="button" aria-label="Buscar — Command K">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        <span class="tb-search-label">Buscar cotizaciones, clientes…</span>
                        <kbd class="tb-kbd">⌘K</kbd>
                    </button>

                    <div class="tb-right">
                        <a class="tb-icon" href="/app" title="Actividad" aria-label="Actividad">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                        </a>
                        <a class="tb-icon" href="/app/ajustes" title="Ajustes" aria-label="Ajustes">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                        </a>
                        <slot name="topbar-actions" />
                    </div>
                </header>

                <main class="app-content">
                    <slot />
                </main>
            </div>
        </div>

        <!-- Nav mobile inferior -->
        <nav class="mobile-tabs">
            {NAV.map((item) => (
                <a href={item.href} class:list={['mt-item', { active: page === item.id }]}>
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={item.icon} /></svg>
                    <span>{item.label}</span>
                </a>
            ))}
        </nav>

        <!-- ── MENÚ DE COMANDOS (Cmd+K) ── -->
        <div class="cmdk" id="cmdk" hidden>
            <div class="cmdk-backdrop" id="cmdkBackdrop"></div>
            <div class="cmdk-panel" role="dialog" aria-modal="true" aria-label="Menú de comandos">
                <div class="cmdk-input-row">
                    <svg class="cmdk-search-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input id="cmdkInput" type="text" placeholder="Buscar cotizaciones, clientes, productos… o un comando" autocomplete="off" spellcheck="false" />
                    <kbd class="cmdk-esc">ESC</kbd>
                </div>
                <div class="cmdk-results" id="cmdkResults"></div>
                <div class="cmdk-foot">
                    <span><kbd>↑</kbd><kbd>↓</kbd> navegar</span>
                    <span><kbd>↵</kbd> abrir</span>
                    <span><kbd>esc</kbd> cerrar</span>
                </div>
            </div>
        </div>
    </body>
</html>

<style is:global>
    :root {
        --color-bg: #ffffff;
        --color-bg-soft: #fafbfc;
        --color-blue-deep: #0a192f;
        --color-text: #0f1729;
        --color-text-muted: #5b6472;
        --color-border: rgba(10, 25, 47, 0.08);
        --color-ok: #10b981;
        --color-warn: #f59e0b;
        --color-danger: #ef4444;
        /* Tipografía de sistema (estilo Apple): SF Pro en macOS/iOS, Segoe en
           Windows, Roboto en Android. La landing conserva Inter; la app usa
           la fuente nativa — carga cero y se siente "de sistema operativo". */
        --font-sans: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        --ease-ios: cubic-bezier(0.25, 1, 0.5, 1);
        --ease-spring: cubic-bezier(0.22, 1, 0.36, 1);
        --sidebar-w: 232px;
    }

    *, *::before, *::after { box-sizing: border-box; }
    html, body {
        margin: 0; padding: 0;
        font-family: var(--font-sans);
        color: var(--color-text);
        background: var(--color-bg-soft);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
    }
    ::selection { background: #0a192f; color: #fff; }

    .editorial {
        font-family: var(--font-sans);
        font-style: normal;
        font-weight: 600;
        letter-spacing: -0.03em;
        font-variant-numeric: tabular-nums;
    }

    /* ── Entrada de página (CSS, no GSAP) ── */
    @keyframes app-fadein {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .app-content > * {
        animation: app-fadein 0.55s var(--ease-spring) both;
    }
    .app-content > *:nth-child(2) { animation-delay: 0.06s; }
    .app-content > *:nth-child(3) { animation-delay: 0.12s; }
    .app-content > *:nth-child(4) { animation-delay: 0.18s; }
    @media (prefers-reduced-motion: reduce) {
        .app-content > * { animation: none; }
    }

    /* ── Card base reutilizable ── */
    .card {
        background: #fff;
        border: 1px solid var(--color-border);
        border-radius: 14px;
    }

    /* ── Status pill reutilizable ── */
    .status-pill {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 0.7rem; font-weight: 700; letter-spacing: 0.2px;
        padding: 4px 10px; border-radius: 100px; white-space: nowrap;
    }
    .status-pill::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
</style>

<style>
    .app-shell { display: flex; min-height: 100vh; }

    /* ── SIDEBAR ── */
    .sidebar {
        width: var(--sidebar-w);
        flex-shrink: 0;
        background: linear-gradient(180deg, #0c1d37 0%, #0a192f 55%, #081424 100%);
        display: flex; flex-direction: column;
        padding: 1.4rem 0.9rem 1.1rem;
        position: sticky; top: 0; height: 100vh;
    }
    .sb-brand { display: block; padding: 0.2rem 0.7rem 1.5rem; }
    .sb-brand img { height: 18px; width: auto; display: block; opacity: 0.96; }

    .sb-nav { display: flex; flex-direction: column; gap: 2px; }
    .sb-item {
        display: flex; align-items: center; gap: 11px;
        padding: 8px 11px; border-radius: 9px;
        font-size: 0.86rem; font-weight: 500;
        color: rgba(255,255,255,0.55); text-decoration: none;
        transition: color 0.25s var(--ease-ios), background 0.25s var(--ease-ios);
    }
    .sb-item svg { width: 16px; height: 16px; opacity: 0.75; flex-shrink: 0; }
    .sb-item:hover { color: rgba(255,255,255,0.92); background: rgba(255,255,255,0.05); }
    .sb-item.active {
        color: #fff; background: rgba(255,255,255,0.09);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.07);
    }

    .sb-footer { margin-top: auto; display: flex; flex-direction: column; gap: 0.9rem; }
    .sb-landing-link {
        font-size: 0.75rem; font-weight: 600; color: rgba(255,255,255,0.35);
        text-decoration: none; padding: 0 0.7rem;
        transition: color 0.25s;
    }
    .sb-landing-link:hover { color: rgba(255,255,255,0.7); }
    .sb-org {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 11px; border-radius: 11px;
        background: rgba(255,255,255,0.04);
        box-shadow: inset 0 0 0 0.5px rgba(255,255,255,0.07);
    }
    .sb-org-avatar {
        width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
        background: rgba(255,255,255,0.1); color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.72rem; font-weight: 800;
    }
    .sb-org-info { display: flex; flex-direction: column; min-width: 0; flex: 1; }
    .sb-org-name { font-size: 0.78rem; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sb-org-plan { font-size: 0.66rem; color: rgba(255,255,255,0.4); }
    .sb-logout {
        flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 30px; border-radius: 8px;
        background: none; border: none; cursor: pointer;
        color: rgba(255,255,255,0.45); transition: color 0.2s, background 0.2s;
    }
    .sb-logout svg { width: 16px; height: 16px; }
    .sb-logout:hover { color: #fff; background: rgba(255,255,255,0.08); }

    /* ── MAIN ── */
    .app-main { flex: 1; min-width: 0; display: flex; flex-direction: column; }
    .topbar {
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
        padding: 1.1rem 2rem;
        border-bottom: 1px solid var(--color-border);
        background: rgba(255,255,255,0.75);
        backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
        position: sticky; top: 0; z-index: 50;
    }
    .tb-left { display: flex; align-items: center; gap: 0.9rem; min-width: 0; }
    .tb-heading { font-size: 1.05rem; font-weight: 700; letter-spacing: -0.3px; margin: 0; white-space: nowrap; }
    .tb-demo {
        font-size: 0.58rem; font-weight: 800; letter-spacing: 1.2px;
        color: #b45309; background: rgba(245,158,11,0.1);
        padding: 4px 9px; border-radius: 100px; white-space: nowrap;
    }
    .tb-right { display: flex; align-items: center; gap: 0.5rem; }

    /* Buscador de la topbar (abre el menú de comandos) */
    .tb-search {
        flex: 1; max-width: 400px; margin: 0 auto;
        display: flex; align-items: center; gap: 9px;
        font-family: var(--font-sans); font-size: 0.84rem; color: var(--color-text-muted);
        background: var(--color-bg-soft); border: 1px solid var(--color-border);
        border-radius: 10px; padding: 8px 10px 8px 13px; cursor: text; text-align: left;
        transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
    }
    .tb-search:hover { border-color: rgba(10,25,47,0.2); background: #fff; }
    .tb-search svg { width: 15px; height: 15px; color: #99a2af; flex-shrink: 0; }
    .tb-search-label { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .tb-kbd {
        font-family: var(--font-sans); font-size: 0.66rem; font-weight: 700; color: var(--color-text-muted);
        background: #fff; border: 1px solid var(--color-border); border-radius: 6px;
        padding: 2px 6px; box-shadow: 0 1px 0 rgba(10,25,47,0.06);
    }
    .tb-icon {
        display: inline-flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; border-radius: 9px; color: var(--color-text-muted);
        background: transparent; transition: background 0.2s, color 0.2s;
    }
    .tb-icon svg { width: 17px; height: 17px; }
    .tb-icon:hover { background: var(--color-bg-soft); color: var(--color-blue-deep); }

    /* Hamburguesa + backdrop del drawer (solo móvil) */
    .tb-burger { display: none; align-items: center; justify-content: center; width: 38px; height: 38px; margin-left: -6px; border: none; background: none; color: var(--color-text); border-radius: 9px; cursor: pointer; }
    .tb-burger svg { width: 20px; height: 20px; }
    .tb-burger:hover { background: var(--color-bg-soft); }
    .sb-backdrop { display: none; }

    .app-content { padding: 1.8rem 2rem 4rem; max-width: 1240px; width: 100%; }

    /* ════════ MENÚ DE COMANDOS (Cmd+K) ════════ */
    .cmdk { position: fixed; inset: 0; z-index: 500; display: flex; align-items: flex-start; justify-content: center; padding: 12vh 1rem 1rem; }
    .cmdk[hidden] { display: none; }
    .cmdk-backdrop { position: absolute; inset: 0; background: rgba(10,25,47,0.35); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); animation: cmdk-fade 0.2s ease; }
    @keyframes cmdk-fade { from { opacity: 0; } to { opacity: 1; } }
    .cmdk-panel {
        position: relative; width: min(620px, 100%);
        background: #fff; border: 1px solid var(--color-border); border-radius: 16px;
        box-shadow: 0 40px 100px -24px rgba(10,25,47,0.5);
        overflow: hidden; animation: cmdk-pop 0.22s var(--ease-spring);
    }
    @keyframes cmdk-pop { from { opacity: 0; transform: translateY(-10px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .cmdk-input-row { display: flex; align-items: center; gap: 11px; padding: 14px 16px; border-bottom: 1px solid var(--color-border); }
    .cmdk-search-ico { width: 18px; height: 18px; color: #99a2af; flex-shrink: 0; }
    #cmdkInput { flex: 1; border: none; outline: none; background: none; font-family: var(--font-sans); font-size: 1rem; color: var(--color-text); }
    .cmdk-esc { font-size: 0.6rem; font-weight: 700; color: #99a2af; background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 5px; padding: 2px 6px; }
    .cmdk-results { max-height: 52vh; overflow-y: auto; padding: 6px; }
    .cmdk-group-label { font-size: 0.58rem; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; color: #99a2af; padding: 10px 12px 5px; }
    .cmdk-item {
        display: flex; align-items: center; gap: 11px; width: 100%; text-align: left;
        padding: 9px 12px; border-radius: 9px; cursor: pointer; border: none; background: none;
        font-family: var(--font-sans); color: var(--color-text); text-decoration: none;
    }
    .cmdk-item.sel { background: var(--color-blue-deep); }
    .cmdk-item.sel .cmdk-item-title, .cmdk-item.sel .cmdk-ico { color: #fff; }
    .cmdk-item.sel .cmdk-item-sub, .cmdk-item.sel .cmdk-pill { color: rgba(255,255,255,0.7); }
    .cmdk-ico {
        width: 28px; height: 28px; border-radius: 8px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: var(--color-bg-soft); color: var(--color-blue-deep); font-size: 0.7rem; font-weight: 800;
    }
    .cmdk-ico svg { width: 15px; height: 15px; }
    .cmdk-item.sel .cmdk-ico { background: rgba(255,255,255,0.18); }
    .cmdk-item-body { display: flex; flex-direction: column; min-width: 0; flex: 1; }
    .cmdk-item-title { font-size: 0.88rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cmdk-item-sub { font-size: 0.72rem; color: var(--color-text-muted); }
    .cmdk-pill { font-size: 0.62rem; font-weight: 700; color: var(--color-text-muted); flex-shrink: 0; }
    .cmdk-empty { padding: 2rem 1rem; text-align: center; font-size: 0.85rem; color: var(--color-text-muted); }
    .cmdk-foot { display: flex; gap: 1.2rem; padding: 9px 16px; border-top: 1px solid var(--color-border); background: var(--color-bg-soft); }
    .cmdk-foot span { font-size: 0.68rem; color: #99a2af; display: inline-flex; align-items: center; gap: 5px; }
    .cmdk-foot kbd { font-size: 0.62rem; font-weight: 700; background: #fff; border: 1px solid var(--color-border); border-radius: 4px; padding: 1px 5px; color: var(--color-text-muted); }

    /* ── MOBILE ── */
    .mobile-tabs { display: none; }
    @media (max-width: 880px) {
        /* Sidebar como drawer desplegable (se abre con la hamburguesa) */
        .sidebar {
            position: fixed; top: 0; left: 0; height: 100dvh; width: min(284px, 86vw); z-index: 300;
            transform: translateX(-100%); transition: transform 0.34s var(--ease-spring);
            box-shadow: 0 0 60px rgba(0,0,0,0.4);
        }
        .app-shell.nav-open .sidebar { transform: translateX(0); }
        .sb-backdrop {
            display: block; position: fixed; inset: 0; z-index: 290;
            background: rgba(10,25,47,0.45); backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px);
            opacity: 0; visibility: hidden; transition: opacity 0.3s var(--ease-ios), visibility 0s 0.3s;
        }
        .app-shell.nav-open .sb-backdrop { opacity: 1; visibility: visible; transition: opacity 0.3s var(--ease-ios); }
        .tb-burger { display: inline-flex; }
        .app-content { padding: 1.2rem 1rem 6rem; }
        .topbar { padding: 0.9rem 1rem; }
        .tb-demo { display: none; }
        .tb-search { max-width: none; flex: 0 0 auto; padding: 8px; }
        .tb-search-label, .tb-kbd { display: none; }
        .tb-icon { display: none; }
        .mobile-tabs {
            display: flex; position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
            background: rgba(10,25,47,0.97);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            padding: 8px 6px calc(8px + env(safe-area-inset-bottom));
            justify-content: space-around;
        }
        .mt-item {
            display: flex; flex-direction: column; align-items: center; gap: 3px;
            color: rgba(255,255,255,0.45); text-decoration: none;
            font-size: 0.58rem; font-weight: 600; padding: 4px 8px;
        }
        .mt-item svg { width: 18px; height: 18px; }
        .mt-item.active { color: #fff; }
    }
</style>

<script>
    // ── Menú de comandos (Cmd+K) ── buscador global + navegación rápida.
    function initCmdk() {
        const cmdk = document.getElementById('cmdk');
        const input = document.getElementById('cmdkInput') as HTMLInputElement | null;
        const results = document.getElementById('cmdkResults');
        if (!cmdk || !input || !results) return;

        const I = {
            dashboard: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>',
            doc: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>',
            card: '<rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>',
            users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>',
            box: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/>',
            chart: '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
            gear: '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>',
            plus: '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>',
            external: '<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>',
        };
        const NAV: any[] = [
            ['Dashboard', '/app', I.dashboard], ['Cotizaciones', '/app/cotizaciones', I.doc], ['Cobranza', '/app/cobranza', I.card],
            ['Clientes', '/app/clientes', I.users], ['Productos', '/app/productos', I.box], ['Analítica', '/app/analitica', I.chart], ['Ajustes', '/app/ajustes', I.gear],
        ].map(([title, href, icon]) => ({ group: 'Ir a', title, href, icon }));
        const ACTIONS: any[] = [
            { group: 'Acciones', title: 'Nueva cotización', href: '/app/cotizaciones/nueva', icon: I.plus },
            { group: 'Acciones', title: 'Nuevo cliente', href: '/app/clientes', icon: I.plus },
            { group: 'Acciones', title: 'Nuevo producto', href: '/app/productos', icon: I.plus },
            { group: 'Acciones', title: 'Ver sitio público', href: '/', icon: I.external },
        ];
        const norm = (s: string) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
        const esc = (s: string) => String(s).replace(/</g, '&lt;');

        let items: any[] = []; let sel = 0; let seq = 0;

        const staticMatches = (q: string) => {
            const all = [...NAV, ...ACTIONS];
            if (!q.trim()) return all;
            const nq = norm(q);
            return all.filter((c) => norm(c.title).includes(nq));
        };
        const buildItems = (q: string, ent: any) => {
            const list: any[] = [];
            if (ent) {
                (ent.cotizaciones || []).forEach((c: any) => list.push({ group: 'Cotizaciones', title: `${c.folio} · ${c.cliente}`, href: `/app/cotizaciones/${c.id}`, icon: I.doc }));
                (ent.clientes || []).forEach((c: any) => list.push({ group: 'Clientes', title: c.empresa, href: '/app/clientes', icon: I.users }));
                (ent.productos || []).forEach((p: any) => list.push({ group: 'Productos', title: p.sku ? `${p.nombre} · ${p.sku}` : p.nombre, href: '/app/productos', icon: I.box }));
            }
            staticMatches(q).forEach((c) => list.push(c));
            return list;
        };
        const paint = () => {
            if (!items.length) { results.innerHTML = '<div class="cmdk-empty">Sin resultados</div>'; return; }
            let html = ''; let last = '';
            items.forEach((it, i) => {
                if (it.group !== last) { html += `<div class="cmdk-group-label">${it.group}</div>`; last = it.group; }
                html += `<button class="cmdk-item ${i === sel ? 'sel' : ''}" data-i="${i}"><span class="cmdk-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">${it.icon}</svg></span><span class="cmdk-item-body"><span class="cmdk-item-title">${esc(it.title)}</span></span></button>`;
            });
            results.innerHTML = html;
            results.querySelector('.cmdk-item.sel')?.scrollIntoView({ block: 'nearest' });
        };
        const render = async (q: string) => {
            items = buildItems(q, null); sel = 0; paint();
            if (q.trim().length >= 2) {
                const my = ++seq;
                try {
                    const res = await fetch('/api/search?q=' + encodeURIComponent(q.trim()));
                    const data = await res.json();
                    if (my !== seq) return;
                    items = buildItems(q, data); sel = 0; paint();
                } catch { /* ignora */ }
            }
        };
        const activate = (i: number) => { const it = items[i]; if (it?.href) { close(); window.location.href = it.href; } };
        const open = () => { (cmdk as HTMLElement).hidden = false; document.body.style.overflow = 'hidden'; input.value = ''; render(''); setTimeout(() => input.focus(), 20); };
        const close = () => { (cmdk as HTMLElement).hidden = true; document.body.style.overflow = ''; };

        input.addEventListener('input', () => render(input.value));
        results.addEventListener('click', (e) => { const b = (e.target as HTMLElement).closest('.cmdk-item') as HTMLElement; if (b) activate(parseInt(b.dataset.i!, 10)); });
        results.addEventListener('mousemove', (e) => { const b = (e.target as HTMLElement).closest('.cmdk-item') as HTMLElement; if (b) { const i = parseInt(b.dataset.i!, 10); if (i !== sel) { sel = i; paint(); } } });
        input.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowDown') { e.preventDefault(); sel = Math.min(sel + 1, items.length - 1); paint(); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); sel = Math.max(sel - 1, 0); paint(); }
            else if (e.key === 'Enter') { e.preventDefault(); activate(sel); }
        });

        document.getElementById('cmdkOpen')?.addEventListener('click', open);
        document.getElementById('cmdkBackdrop')?.addEventListener('click', close);
        document.addEventListener('keydown', (e) => {
            if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') { e.preventDefault(); (cmdk as HTMLElement).hidden ? open() : close(); }
            else if (e.key === 'Escape' && !(cmdk as HTMLElement).hidden) { close(); }
        });
    }
    // ── Drawer de la sidebar (móvil) ──
    function initDrawer() {
        const shell = document.querySelector('.app-shell');
        const burger = document.getElementById('navBurger');
        const backdrop = document.getElementById('sbBackdrop');
        if (!shell || !burger) return;
        const close = () => { shell.classList.remove('nav-open'); document.body.style.overflow = ''; };
        burger.addEventListener('click', () => {
            const open = shell.classList.toggle('nav-open');
            document.body.style.overflow = open ? 'hidden' : '';
        });
        backdrop?.addEventListener('click', close);
        shell.querySelectorAll('.sidebar a').forEach((a) => a.addEventListener('click', close));
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    }

    function initApp() { initCmdk(); initDrawer(); }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initApp);
    else initApp();
</script>
