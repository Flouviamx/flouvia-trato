---
// AppLayout — layout de la app de Cord (estilo Linear: compacto, hairlines, sobrio).
// La app usa CSS animations (NO GSAP) para entradas — regla del proyecto.
// Datos reales desde Neon; la org se resuelve desde la sesión de Clerk (src/lib/db.ts).

import { getOrg, getSetupProgress } from '../lib/queries';
import OnboardingWidget from '../components/app/OnboardingWidget.astro';
import Sidebar from '../components/app/Sidebar.astro';
import { clerkAppearance } from '../lib/clerk-theme';
import Analytics from '@vercel/analytics/astro';
const ORG = await getOrg();

// Avance de configuración (Fase 3). Si la cuenta ya está 100% lista no montamos
// el widget de onboarding ni la píldora de la topbar.
const setup = await getSetupProgress();
const pillDash = `${(setup.pct * 0.9739).toFixed(2)} 100`;

interface Props {
    title: string;        // título del documento
    page: string;         // id de la página activa en el sidebar
    heading?: string;     // título visible en la topbar
    crumbs?: { label: string; href?: string }[]; // migajas opcionales (páginas anidadas)
}

const { title, page, heading, crumbs = [] } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="robots" content="noindex, nofollow" />

        <!-- Favicons -->
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
        <link rel="manifest" href="/manifest.webmanifest" />
        <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
        <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0a192f" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-status-bar-style" content="default" />
        <meta name="apple-mobile-web-app-title" content="Cord" />

        <title>{title}</title>
        <script is:inline>
            // Restaura estado colapsado de la sidebar + tema antes del primer paint (sin flash).
            try { if (localStorage.getItem('cord.sb.collapsed') === '1') document.documentElement.classList.add('sb-collapsed'); } catch (e) {}
            try { if (localStorage.getItem('cord.theme') === 'dark') document.documentElement.setAttribute('data-theme', 'dark'); } catch (e) {}
        </script>
        <style is:inline>
            /* ASTRO OPTIMIZATION BYPASS: Forced CSS injection */
            
            /* Stacking Context Global (Resuelve translucidez visual en ambos estados) */
            .sidebar { z-index: 800 !important; }
            .sb-account { position: relative !important; z-index: 9999 !important; }
            .custom-org-switcher { position: relative !important; z-index: 9999 !important; }

            /* Estilos específicos del modo colapsado */
            html.sb-collapsed .sidebar { width: 56px !important; padding-left: 0 !important; padding-right: 0 !important; align-items: stretch !important; }
            html.sb-collapsed .sb-item { width: 100% !important; height: 36px !important; justify-content: flex-start !important; padding-left: 18px !important; border-radius: 10px !important; margin: 0 !important; }
            html.sb-collapsed .sb-item svg { width: 20px !important; height: 20px !important; flex-shrink: 0 !important; }
            html.sb-collapsed .sb-indicator { width: calc(100% - 16px) !important; left: 8px !important; margin-left: 0 !important; border-radius: 10px !important; }
            
            /* Centrado de la cuenta / org switcher (solo colapsado) */
            html.sb-collapsed .sb-account { display: flex !important; justify-content: center !important; align-items: center !important; padding: 0 !important; margin-bottom: 0.6rem !important; }
            html.sb-collapsed .custom-org-switcher { display: flex !important; justify-content: center !important; width: 100% !important; }
            html.sb-collapsed .org-switcher-btn { width: 36px !important; height: 36px !important; justify-content: center !important; padding: 0 !important; border-radius: 10px !important; }
            
            /* Nuke de translucidez absoluto para el Dropdown */
            .org-dropdown { background-color: #ffffff !important; background-image: none !important; backdrop-filter: none !important; -webkit-backdrop-filter: none !important; opacity: 1 !important; box-shadow: 0 30px 60px -12px rgba(0,0,0,0.25), 0 0 0 1px rgba(0,0,0,0.05) !important; z-index: 99999 !important; }
            html[data-theme="dark"] .org-dropdown { background-color: #111823 !important; box-shadow: 0 30px 60px -12px rgba(0,0,0,0.8), 0 0 0 1px rgba(255,255,255,0.1) !important; }
            
            /* Microinteracciones Premium (Linear-style) */
            .sb-item { transition: transform 0.15s cubic-bezier(0.16, 1, 0.3, 1), background 0.2s !important; }
            .sb-item:active { transform: scale(0.94) !important; }
            .org-switcher-btn { transition: transform 0.15s cubic-bezier(0.16, 1, 0.3, 1), background 0.2s !important; }
            .org-switcher-btn:active { transform: scale(0.94) !important; }
            .org-list-item { transition: transform 0.15s cubic-bezier(0.16, 1, 0.3, 1), background 0.2s !important; }
            .org-list-item:active { transform: scale(0.98) !important; }
        </style>
    </head>
    <body>
        <div class="app-shell">
            <!-- ── SIDEBAR (componente independiente) ── -->
            <Sidebar page={page} />

            <!-- ── MAIN ── -->
            <div class="app-main">
                <header class="topbar">
                    <button class="tb-burger" id="navBurger" type="button" aria-label="Abrir menú">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                    </button>

                    <button class="tb-search" id="cmdkOpen" type="button" aria-label="Buscar — Command K">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        <span class="tb-search-label">Buscar cotizaciones, clientes…</span>
                        <kbd class="tb-kbd">⌘K</kbd>
                    </button>

                    <div class="tb-right">
                        {!setup.complete && (
                            <button class="onb-pill" id="onbPill" type="button" hidden aria-label="Guía de configuración">
                                <span class="onb-pill-ring" aria-hidden="true">
                                    <svg viewBox="0 0 36 36"><circle class="onb-ring-bg" cx="18" cy="18" r="15.5"></circle><circle class="onb-ring-fg" cx="18" cy="18" r="15.5" style={`stroke-dasharray:${pillDash}`}></circle></svg>
                                    <b class="editorial" data-pill-pct>{setup.pct}%</b>
                                </span>
                                <span class="onb-pill-label">Guía de configuración</span>
                            </button>
                        )}
                        <div class="tb-create-wrap">
                            <button class="tb-create" id="tbCreate" type="button" aria-haspopup="menu" aria-expanded="false">
                                <svg class="tb-create-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                <span>Crear</span>
                                <svg class="tb-create-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                            <div class="tb-create-menu" id="tbCreateMenu" role="menu" hidden>
                                <a href="/app/cotizaciones/nueva" class="tb-create-item" role="menuitem">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                                    <span>Cotización</span><kbd>C</kbd>
                                </a>
                                <a href="/app/clientes?nuevo=1" class="tb-create-item" role="menuitem">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                                    <span>Cliente</span>
                                </a>
                                <a href="/app/productos?nuevo=1" class="tb-create-item" role="menuitem">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                                    <span>Producto</span>
                                </a>
                                <button type="button" class="tb-create-item" id="tbCreateTarea" role="menuitem">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                                    <span>Tarea</span>
                                </button>
                            </div>
                        </div>
                        <div class="tb-notif-wrap">
                            <button class="tb-icon tb-activity" id="notifBtn" type="button" title="Actividad" aria-label="Notificaciones" aria-haspopup="menu" aria-expanded="false">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                                <span class="tb-notif-dot" id="notifDot" hidden></span>
                            </button>
                            <div class="notif-panel" id="notifPanel" role="menu" hidden>
                                <div class="notif-head">
                                    <strong>Notificaciones</strong>
                                    <button type="button" id="notifMarkAll" class="notif-mark">Marcar como leídas</button>
                                </div>
                                <div class="notif-list" id="notifList"></div>
                                <a class="notif-foot" href="/app">Ver toda la actividad</a>
                            </div>
                        </div>
                        <button class="tb-icon tb-help" id="helpBtn" type="button" title="Ayuda" aria-label="Ayuda" aria-haspopup="dialog" aria-expanded="false">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/><path d="M9.1 9a2.9 2.9 0 0 1 5.6 1c0 2-2.9 2.9-2.9 2.9"/><line x1="12" y1="17" x2="12" y2="17"/></svg>
                        </button>
                        <button class="tb-icon tb-theme" id="themeBtn" type="button" title="Tema claro/oscuro" aria-label="Cambiar tema">
                            <svg class="tb-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                            <svg class="tb-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                        </button>
                        <a class:list={['tb-icon', 'tb-gear', { active: page === 'ajustes' }]} href="/app/ajustes" title="Ajustes" aria-label="Ajustes">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                        </a>
                    </div>
                </header>

                <div class="page-head">
                    <div class="ph-inner">
                        <div class="ph-titles">
                            {crumbs.length > 0 && (
                                <nav class="ph-crumbs" aria-label="Ruta">
                                    {crumbs.map((c) => (
                                        c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>
                                    ))}
                                    <span class="ph-crumb-here">{heading ?? title}</span>
                                </nav>
                            )}
                            <div class="ph-title-row">
                                <h1 class="ph-title">{heading ?? title}</h1>
                                <button class="ph-pin" id="phPin" type="button" aria-label="Fijar página" title="Fijar en el menú">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 17v5"/><path d="M5 17h14l-1.5-4.5a2 2 0 0 1-.1-.6V6a2 2 0 0 1 2-2H6a2 2 0 0 1 2 2v5.9a2 2 0 0 1-.1.6L5 17z"/></svg>
                                </button>
                            </div>
                            <slot name="page-sub" />
                        </div>
                        <div class="ph-actions"><slot name="topbar-actions" /></div>
                    </div>
                    <div class="ph-tabs-row"><slot name="page-tabs" /></div>
                </div>

                <main class="app-content">
                    <slot />
                </main>
            </div>
        </div>

        <!-- Drawer de Ayuda (se abre con el icono ? de la topbar) -->
        <div class="help-drawer" id="helpDrawer" hidden>
            <div class="help-backdrop" id="helpBackdrop"></div>
            <aside class="help-panel" role="dialog" aria-modal="true" aria-label="Centro de ayuda">
                <header class="help-head">
                    <strong>Centro de ayuda</strong>
                    <button id="helpClose" class="help-x" type="button" aria-label="Cerrar ayuda">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </header>
                <div class="help-search">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input id="helpSearch" type="search" placeholder="Buscar ayuda…" autocomplete="off" spellcheck="false" />
                </div>
                <div class="help-body">
                    <nav class="help-links">
                        <button type="button" class="help-link" data-help-action="shortcuts">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><line x1="6" y1="10" x2="6" y2="10"/><line x1="10" y1="10" x2="10" y2="10"/><line x1="14" y1="10" x2="14" y2="10"/><line x1="18" y1="10" x2="18" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/></svg>
                            <span>Atajos de teclado</span>
                        </button>
                        <button type="button" class="help-link" data-help-action="guide">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                            <span>Guía de configuración</span>
                        </button>
                        <a class="help-link" href="mailto:soporte@flouvia.com">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
                            <span>Escríbenos por correo</span>
                        </a>
                        <a class="help-link" href="https://wa.me/520000000000" target="_blank" rel="noopener">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></svg>
                            <span>WhatsApp de soporte</span>
                        </a>
                    </nav>
                    <div class="help-faq-head">Preguntas frecuentes</div>
                    <div class="help-faq" id="helpFaq"></div>
                    <div class="help-empty" id="helpEmpty" hidden>Sin resultados para tu búsqueda.</div>
                </div>
                <footer class="help-ai">
                    <div class="help-ai-box" aria-disabled="true">
                        <span class="help-ai-badge">Próximamente</span>
                        <p class="help-ai-title">Pregúntale a la IA sobre tu negocio</p>
                        <div class="help-ai-input">Escribe tu pregunta… (pronto)</div>
                    </div>
                </footer>
            </aside>
        </div>

        <!-- ── MENÚ DE COMANDOS (Cmd+K) ── -->
        <div class="cmdk" id="cmdk" hidden>
            <div class="cmdk-backdrop" id="cmdkBackdrop"></div>
            <div class="cmdk-panel" role="dialog" aria-modal="true" aria-label="Menú de comandos">
                <div class="cmdk-input-row">
                    <svg class="cmdk-search-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input id="cmdkInput" type="text" placeholder="Buscar cotizaciones, clientes, productos… o un comando" autocomplete="off" spellcheck="false" />
                    <kbd class="cmdk-esc">ESC</kbd>
                </div>
                <div class="cmdk-results" id="cmdkResults"></div>
                <div class="cmdk-foot">
                    <span><kbd>↑</kbd><kbd>↓</kbd> navegar</span>
                    <span><kbd>↵</kbd> abrir</span>
                    <span><kbd>esc</kbd> cerrar</span>
                </div>
            </div>
        </div>

        <!-- Quick-add de Tarea (desde el botón "Crear") -->
        <div class="qtask" id="qtask" hidden>
            <div class="qtask-backdrop" id="qtaskBackdrop"></div>
            <form class="qtask-panel" id="qtaskForm" role="dialog" aria-modal="true" aria-label="Nueva tarea">
                <div class="qtask-head">
                    <strong>Nueva tarea</strong>
                    <button type="button" class="qtask-x" id="qtaskClose" aria-label="Cerrar">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <input id="qtaskTitulo" class="qtask-input" placeholder="Ej. Llamar a GAMA para dar seguimiento…" autocomplete="off" required />
                <div class="qtask-row">
                    <input id="qtaskDue" class="qtask-date" type="date" aria-label="Fecha límite" />
                    <button type="submit" class="qtask-btn">Agregar tarea</button>
                </div>
            </form>
        </div>

        <!-- Barra de progreso de navegación (estilo Linear/YouTube) -->
        <div class="nav-progress" id="navProgress" aria-hidden="true"></div>

        <!-- Contenedor de toasts globales (window.cordToast) -->
        <div class="toast-stack" id="toastStack" aria-live="polite" aria-atomic="false"></div>

        <!-- Overlay de atajos de teclado (se abre con ?) -->
        <div class="kbd-help" id="kbdHelp" hidden>
            <div class="kbd-help-backdrop" id="kbdHelpBackdrop"></div>
            <div class="kbd-help-panel" role="dialog" aria-modal="true" aria-label="Atajos de teclado">
                <div class="kbd-help-head"><strong>Atajos de teclado</strong><kbd>esc</kbd></div>
                <div class="kbd-help-body">
                    <div class="kbd-row"><span>Buscar / menú de comandos</span><span><kbd>⌘</kbd><kbd>K</kbd> · <kbd>/</kbd></span></div>
                    <div class="kbd-row"><span>Nueva cotización</span><span><kbd>C</kbd></span></div>
                    <div class="kbd-row"><span>Ir a Dashboard</span><span><kbd>G</kbd> <kbd>D</kbd></span></div>
                    <div class="kbd-row"><span>Ir a Cotizaciones</span><span><kbd>G</kbd> <kbd>C</kbd></span></div>
                    <div class="kbd-row"><span>Ir a Clientes</span><span><kbd>G</kbd> <kbd>L</kbd></span></div>
                    <div class="kbd-row"><span>Ir a Productos</span><span><kbd>G</kbd> <kbd>P</kbd></span></div>
