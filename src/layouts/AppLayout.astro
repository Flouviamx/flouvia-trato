    .cmdk-ico {
        width: 28px; height: 28px; border-radius: 8px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: var(--color-bg-soft); color: var(--color-blue-deep); font-size: 0.7rem; font-weight: 800;
    }
    .cmdk-ico svg { width: 15px; height: 15px; }
    .cmdk-item.sel .cmdk-ico { background: rgba(255,255,255,0.18); }
    .cmdk-item-body { display: flex; flex-direction: column; min-width: 0; flex: 1; }
    .cmdk-item-title { font-size: 0.88rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cmdk-item-sub { font-size: 0.72rem; color: var(--color-text-muted); }
    .cmdk-pill { font-size: 0.62rem; font-weight: 700; color: var(--color-text-muted); flex-shrink: 0; }
    /* Descripción a la derecha (estilo Stripe "filtros sugeridos") */
    .cmdk-hint { font-size: 0.74rem; color: #99a2af; flex-shrink: 0; margin-left: auto; padding-left: 1rem; white-space: nowrap; }
