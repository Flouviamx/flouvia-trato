<style is:global>
    :root {
        --color-bg: #ffffff;
        --color-bg-soft: #fafbfc;
        --color-blue-deep: #0a192f;
        --color-text: #0f1729;
        --color-text-muted: #5b6472;
        --color-border: rgba(10, 25, 47, 0.08);
        --color-ok: #10b981;
        --color-warn: #f59e0b;
        --color-danger: #ef4444;
        /* Superficies (paneles, modales, chips) — para soportar tema oscuro */
        --surface: #ffffff;
        --surface-2: #fafafa;
        /* Tipografía de sistema (estilo Apple): SF Pro en macOS/iOS, Segoe en
           Windows, Roboto en Android. La landing conserva Inter; la app usa
           la fuente nativa — carga cero y se siente "de sistema operativo". */
        --font-sans: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        --ease-ios: cubic-bezier(0.25, 1, 0.5, 1);
        --ease-spring: cubic-bezier(0.22, 1, 0.36, 1);
        --sidebar-w: 232px;
        --content-max: 1240px;
    }
    
    /* Estado colapsado global: afecta la estructura principal */
    html.sb-collapsed {
        --sidebar-w: 56px;
        --content-max: 1440px;

        /* ── Sidebar (espejo de la topbar): vidrio BLANCO en claro, navy en oscuro.
           Todo el contenido de la sidebar lee estas variables, así que cambia de tema
           sin duplicar reglas. Los valores light van aquí; el bloque dark los reescribe. */
        --sb-bg: linear-gradient(180deg, rgba(255,255,255,0.78) 0%, rgba(255,255,255,0.6) 100%);
        --sb-border: rgba(255,255,255,0.6);
        --sb-shadow:
            inset 0 1px 1px rgba(255,255,255,0.95),
            inset 0 0 0 0.5px rgba(255,255,255,0.5),
            inset 0 -6px 14px rgba(255,255,255,0.18),
            0 12px 36px -8px rgba(10,25,47,0.14),
            0 2px 6px rgba(10,25,47,0.06);
        --sb-sheen: radial-gradient(135% 50% at 50% -10%, rgba(10,25,47,0.045), transparent 60%);
        --sb-text: var(--color-text-muted);
        --sb-text-strong: var(--color-text);
        --sb-text-active: var(--color-blue-deep);
        --sb-label: #99a2af;
        --sb-divider: var(--color-border);
        --sb-hover-bg: rgba(10,25,47,0.05);
        --sb-active-bg: rgba(10,25,47,0.07);
        --sb-icon-op: 0.62;
        --sb-indicator-bg: rgba(10,25,47,0.055);
        --sb-indicator-shadow: inset 0 0 0 0.5px rgba(10,25,47,0.08), 0 1px 2px rgba(10,25,47,0.05);
        --sb-badge-bg: rgba(10,25,47,0.07);
        --sb-badge-text: var(--color-text-muted);
        --sb-toggle-bg: rgba(10,25,47,0.04);
        --sb-toggle-shadow: inset 0 0 0 0.5px rgba(10,25,47,0.08);
        --sb-toggle-hover-bg: rgba(10,25,47,0.08);
        /* Dropdowns de la sidebar (cuenta, crear) — SÓLIDO opaco (no debe verse el fondo) */
        --sb-menu-bg: linear-gradient(180deg, #ffffff, #fafbfe);
        --sb-menu-solid-bg: #ffffff;
        --sb-menu-border: rgba(255,255,255,0.7);
        --sb-menu-shadow: inset 0 1px 1px rgba(255,255,255,0.95), inset 0 0 0 0.5px rgba(255,255,255,0.6), 0 24px 60px -18px rgba(10,25,47,0.42), 0 4px 12px rgba(10,25,47,0.1);
        --sb-menu-text: var(--color-text);
        --sb-menu-muted: var(--color-text-muted);
        --sb-menu-hover: rgba(10,25,47,0.06);
        --sb-avatar-bg: linear-gradient(135deg, #1b3a64, #0a192f);
        --sb-avatar-text: #ffffff;
    }

    /* ── Tema oscuro (data-theme="dark" en <html>) ──
       El sidebar y el org switcher ya son navy → no cambian. Aquí remapeamos los
       tokens: el fondo va a navy-negro, el texto aclara, y --color-blue-deep pasa
       a un azul vivo (era invisible sobre fondo oscuro) — sirve de acento para
       montos .editorial, avatares y botones. */
    html[data-theme="dark"] {
        --color-bg: #0b1018;
        --color-bg-soft: #141c28;
        --color-blue-deep: #6b9bf2;
        --color-text: #e8ebf1;
