---
// Navbar de Trato — replica el sistema de flouvia.com:
// top-bar editorial + glass pill con indicador deslizante + wordmark central
// que se transforma en píldora al hacer scroll. Wordmark "trato" en texto (no SVG).
---

<header class="navbar-wrapper" id="navbar">
    <div class="top-bar" id="top-bar">
        <div class="top-bar-inner">
            <span class="top-text">PLATAFORMA DE COTIZACIONES B2B</span>
            <span class="top-dot desktop-only">·</span>
            <span class="top-text desktop-only">UN PRODUCTO DE FLOUVIA</span>
            <span class="top-dot desktop-only">·</span>
            <span class="top-text desktop-only">HECHO EN MÉXICO</span>
        </div>
    </div>

    <nav class="main-nav">
        <div class="nav-container">

            <div class="nav-left desktop-nav">
                <div class="glass-pill" id="glass-pill">
                    <div class="pill-shimmer" aria-hidden="true"></div>
                    <span class="nav-indicator" id="nav-indicator" aria-hidden="true"></span>
                    <div class="pill-row" id="pill-row">
                        <a href="/" class="pill-logo" id="pill-logo">
                            <img src="/imgs/logo-trato-white.png" alt="Trato" class="pill-logo-img" />
                        </a>
                        <a href="/#producto" class="nav-link" data-mega="producto" aria-haspopup="true" aria-expanded="false">PRODUCTO<svg class="nav-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></a>
                        <a href="/soluciones" class="nav-link" data-mega="soluciones" aria-haspopup="true" aria-expanded="false">SOLUCIONES<svg class="nav-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></a>
                        <a href="/#precios" class="nav-link" data-path="#precios">PRECIOS</a>
                        <a href="/#faq" class="nav-link" data-mega="recursos" aria-haspopup="true" aria-expanded="false">RECURSOS<svg class="nav-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></a>
                    </div>

                    <!-- Megamenús: la píldora se expande verticalmente y revela el panel activo -->
                    <div class="pill-mega" data-panel="producto" aria-hidden="true">
                        <div class="mega-inner">
                            <div class="mega-grid">
                                <a href="/producto/editor" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg></span>
                                    <span class="mega-copy"><b>Editor de cotizaciones</b><i>Precios negociados, línea por línea</i></span>
                                </a>
                                <a href="/producto/link-publico" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7l-1.7 1.7"/><path d="M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.7-1.7"/></svg></span>
                                    <span class="mega-copy"><b>Link público</b><i>Tu cliente aprueba en un clic</i></span>
                                </a>
                                <a href="/producto/seguimiento" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/><circle cx="12" cy="12" r="3"/></svg></span>
                                    <span class="mega-copy"><b>Seguimiento en vivo</b><i>Sabes el momento en que la ven</i></span>
                                </a>
                                <a href="/producto/cfdi" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/></svg></span>
                                    <span class="mega-copy"><b>CFDI 4.0</b><i>Timbrado automático ante el SAT</i></span>
                                </a>
                                <a href="/producto/clientes-credito" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                                    <span class="mega-copy"><b>Clientes y crédito</b><i>Net 30/60 y límite por cliente</i></span>
                                </a>
                                <a href="/q/demo" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="3"/><path d="M12 18h.01"/></svg></span>
                                    <span class="mega-copy"><b>Cotización de ejemplo</b><i>Mira lo que recibe tu cliente</i></span>
                                </a>
                            </div>
                            <a href="/#como" class="mega-foot">
                                <span>Ver cómo funciona, en tres pasos</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            </a>
                        </div>
                    </div>

                    <div class="pill-mega" data-panel="soluciones" aria-hidden="true">
                        <div class="mega-inner">
                            <div class="mega-grid">
                                <a href="/soluciones#distribuidoras" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8Z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></span>
                                    <span class="mega-copy"><b>Distribuidoras y mayoristas</b><i>Listas de precios por cliente</i></span>
                                </a>
                                <a href="/soluciones#construccion" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M5 20V8l7-5 7 5v12"/><path d="M9 20v-6h6v6"/></svg></span>
                                    <span class="mega-copy"><b>Construcción y materiales</b><i>Volumen, obra y crédito</i></span>
                                </a>
                                <a href="/soluciones#manufactura" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M4 20V10l5 3V10l5 3V8l6 4v8"/></svg></span>
                                    <span class="mega-copy"><b>Manufactura</b><i>Cotiza especificación y lote</i></span>
                                </a>
                                <a href="/soluciones#servicios" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></span>
                                    <span class="mega-copy"><b>Servicios profesionales</b><i>Propuestas que se aprueban solas</i></span>
                                </a>
                            </div>
                            <a href="/soluciones" class="mega-foot">
                                <span>Ver todas las soluciones</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            </a>
                        </div>
                    </div>

                    <div class="pill-mega" data-panel="recursos" aria-hidden="true">
                        <div class="mega-inner">
                            <div class="mega-grid">
                                <a href="/#como" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg></span>
                                    <span class="mega-copy"><b>Cómo funciona</b><i>El flujo completo, en tres pasos</i></span>
                                </a>
                                <a href="/q/demo" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="3"/><path d="M12 18h.01"/></svg></span>
                                    <span class="mega-copy"><b>Cotización de ejemplo</b><i>Lo que tu cliente recibe</i></span>
                                </a>
                                <a href="/#faq" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg></span>
                                    <span class="mega-copy"><b>Preguntas frecuentes</b><i>Planes, CFDI, seguridad y más</i></span>
                                </a>
                                <a href="mailto:hola@flouvia.com" class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
                                    <span class="mega-copy"><b>Hablar con el equipo</b><i>hola@flouvia.com</i></span>
                                </a>
                            </div>
                            <a href="https://flouvia.com" target="_blank" rel="noopener" class="mega-foot">
                                <span>Conoce Flouvia, la casa de Trato</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="nav-center desktop-nav">
                <a href="/" class="main-logo" id="main-logo">
                    <img src="/imgs/logo-trato-navy.png" alt="Trato" class="main-logo-img" />
                </a>
            </div>

            <div class="nav-right desktop-nav" id="nav-right">
                <a href="/login" class="nav-login-pill" aria-label="Entrar a tu cuenta">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    <span>Entrar</span>
                </a>
                <a href="/registro" class="btn-contact">
                    <span class="btn-contact-label">Empezar gratis</span>
                    <svg class="contact-arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="5" y1="19" x2="19" y2="5"/><polyline points="9 5 19 5 19 15"/></svg>
                </a>
            </div>

            <!-- MOBILE -->
            <div class="mobile-pill-nav">
                <div class="mobile-pill-inner squircle" id="mobile-pill">
                    <div class="pill-left-group">
                        <button class="hamburger-btn" id="menu-toggle" aria-label="Menú">
                            <div class="burger-lines"><span class="l1"></span><span class="l2"></span><span class="l3"></span></div>
                        </button>
                        <a href="/" class="mobile-logo">
                            <img src="/imgs/logo-trato-navy.png" alt="Trato" class="logo-mobile-img default-logo" />
                            <img src="/imgs/logo-trato-white.png" alt="Trato" class="logo-mobile-img scrolled-logo" />
                        </a>
                    </div>
                    <a href="/registro" class="btn-contact-mobile squircle">
                        <span>Empezar gratis</span>
                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="5" y1="19" x2="19" y2="5"/><polyline points="9 5 19 5 19 15"/></svg>
                    </a>
                </div>
            </div>

        </div>
    </nav>

    <div class="mobile-menu-overlay" id="mobile-menu">
        <div class="mobile-menu-content">
            <div class="menu-top-row">
                <a href="/login" class="utility-pill">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Entrar
                </a>
            </div>

            <nav class="mobile-links" id="mobile-links">
                <a href="/#producto" class="m-link">Producto</a>
                <a href="/soluciones" class="m-link">Soluciones</a>
                <a href="/#precios" class="m-link">Precios</a>
                <a href="/#faq" class="m-link">Recursos</a>
            </nav>

            <div class="mobile-menu-footer">
                <p class="m-eyebrow">COTIZACIONES B2B · POR FLOUVIA</p>
                <div class="m-legal">
                    <span>CDMX — OP. GLOBAL</span>
                    <a href="mailto:hola@flouvia.com">hola@flouvia.com</a>
                </div>
            </div>
        </div>
    </div>
</header>

<style is:global>
    .js-anim #navbar { opacity: 0; }
</style>

<style>
    .navbar-wrapper {
        --nb-dark: #0a192f;
        --nb-darker: #061121;
        --ease-expo: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-spring: cubic-bezier(0.22, 1, 0.36, 1);
        position: fixed; top: 0; left: 0; width: 100%;
        z-index: 20000; background: transparent;
    }

    /* ── TOP BAR ── */
    .top-bar {
        background: var(--nb-dark);
        color: rgba(255,255,255,0.55);
        padding: 9px 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .top-bar-inner { display: flex; gap: 12px; align-items: center; justify-content: center; padding: 0 40px; }
    .top-text { font-family: var(--font-sans); font-size: 8px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; }
    .top-dot { opacity: 0.3; font-size: 10px; }

    .main-nav { padding: 22px 0; transition: padding 0.8s var(--ease-expo); }
    .navbar-wrapper.scrolled .main-nav { padding: 13px 0; }
    .nav-container { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 0 40px; }
    .desktop-nav { display: flex; align-items: center; }

    /* ── GLASS PILL ── */
    .glass-pill {
        display: inline-flex; flex-direction: column; align-items: stretch;
        background: linear-gradient(180deg, rgba(255,255,255,0.72) 0%, rgba(255,255,255,0.5) 48%, rgba(255,255,255,0.56) 100%);
        backdrop-filter: blur(30px) saturate(1.9) brightness(1.04);
        -webkit-backdrop-filter: blur(30px) saturate(1.9) brightness(1.04);
        padding: 4px 6px; border-radius: 100px;
        border: 1px solid rgba(255,255,255,0.55);
        box-shadow:
            inset 0 1px 1px rgba(255,255,255,0.95),
            inset 0 0 0 0.5px rgba(255,255,255,0.4),
            inset 0 -6px 14px rgba(255,255,255,0.18),
            0 10px 34px rgba(10,25,47,0.1),
            0 2px 6px rgba(10,25,47,0.06);
        position: relative; overflow: hidden;
        transition: box-shadow 0.7s var(--ease-spring), border-color 0.7s var(--ease-spring), background 0.7s var(--ease-spring), backdrop-filter 0.7s var(--ease-spring), border-radius 0.6s var(--ease-spring);
    }
    .pill-row { display: flex; align-items: center; }

    /* Abierta: la cápsula se vuelve panel — el radio se relaja */
    .glass-pill.mega-open { border-radius: 24px; }
    .glass-pill.mega-open .pill-shimmer { display: none; }

    .nav-caret { width: 11px; height: 11px; margin-left: 5px; opacity: 0.45; transition: transform 0.5s var(--ease-spring); vertical-align: -1px; }
    .nav-link[data-mega] { display: inline-flex; align-items: center; }
    .nav-link[data-mega].mega-active .nav-caret { transform: rotate(180deg); }

    /* ── MEGAMENÚ ── */
    /* Cerrado colapsa en AMBOS ejes para no ensanchar la píldora; GSAP anima
       width/height de la píldora al abrir. */
    .pill-mega { width: 0; height: 0; overflow: hidden; }
    .mega-inner { padding: 10px 8px 8px; min-width: 460px; }
    .mega-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; }
    .mega-item {
        display: flex; align-items: flex-start; gap: 11px;
        padding: 10px 12px; border-radius: 14px;
        text-decoration: none;
        transition: background 0.35s var(--ease-spring);
    }
    .mega-item:hover { background: rgba(10,25,47,0.05); }
    .mega-ico {
        width: 30px; height: 30px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: rgba(10,25,47,0.05); border-radius: 9px;
        color: var(--nb-dark);
        transition: background 0.35s, color 0.35s;
    }
    .mega-ico svg { width: 15px; height: 15px; }
    .mega-item:hover .mega-ico { background: var(--nb-dark); color: #fff; }
    .mega-copy { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .mega-copy b { font-size: 11px; font-weight: 700; letter-spacing: 0.1px; color: rgba(0,0,0,0.85); white-space: nowrap; }
    .mega-copy i { font-style: normal; font-size: 9.5px; font-weight: 500; color: rgba(0,0,0,0.45); line-height: 1.35; }
    .mega-foot {
        display: flex; align-items: center; justify-content: space-between; gap: 10px;
        margin: 8px 4px 2px; padding: 9px 12px;
        border-top: 1px solid rgba(10,25,47,0.07);
        font-size: 9.5px; font-weight: 700; letter-spacing: 0.6px; text-transform: uppercase;
        color: rgba(0,0,0,0.55); text-decoration: none;
        transition: color 0.3s;
    }
    .mega-foot svg { width: 12px; height: 12px; transition: transform 0.4s var(--ease-spring); }
    .mega-foot:hover { color: rgba(0,0,0,0.95); }
    .mega-foot:hover svg { transform: translateX(3px); }

    /* Megamenú en estado scrolled (píldora navy) */
    .navbar-wrapper.scrolled .mega-item:hover { background: rgba(255,255,255,0.07); }
    .navbar-wrapper.scrolled .mega-ico { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.85); }
    .navbar-wrapper.scrolled .mega-item:hover .mega-ico { background: #fff; color: var(--nb-dark); }
    .navbar-wrapper.scrolled .mega-copy b { color: rgba(255,255,255,0.92); }
    .navbar-wrapper.scrolled .mega-copy i { color: rgba(255,255,255,0.45); }
    .navbar-wrapper.scrolled .mega-foot { border-top-color: rgba(255,255,255,0.1); color: rgba(255,255,255,0.5); }
    .navbar-wrapper.scrolled .mega-foot:hover { color: #fff; }
    .glass-pill:hover {
        box-shadow:
            inset 0 1px 1px rgba(255,255,255,0.98),
            inset 0 0 0 0.5px rgba(255,255,255,0.5),
            inset 0 -6px 14px rgba(255,255,255,0.22),
            0 18px 50px rgba(10,25,47,0.14),
            0 3px 8px rgba(10,25,47,0.07);
        border-color: rgba(255,255,255,0.7);
    }
    .pill-shimmer {
        position: absolute; inset: 0; border-radius: inherit;
        background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,0.5) 50%, transparent 70%);
        transform: translateX(-100%); pointer-events: none; z-index: 0; transition: transform 0s;
    }
    .glass-pill:hover .pill-shimmer { transform: translateX(100%); transition: transform 0.55s var(--ease-expo); }

    .navbar-wrapper.scrolled .glass-pill {
        background: linear-gradient(180deg, rgba(24,46,80,0.62) 0%, rgba(10,25,47,0.5) 55%, rgba(8,20,38,0.58) 100%);
        backdrop-filter: blur(34px) saturate(1.9) brightness(1.06);
        -webkit-backdrop-filter: blur(34px) saturate(1.9) brightness(1.06);
        border-color: rgba(255,255,255,0.14);
        box-shadow:
            inset 0 1px 0 rgba(255,255,255,0.22),
            inset 0 0 0 0.5px rgba(255,255,255,0.08),
            inset 0 -8px 18px rgba(0,0,0,0.22),
            0 22px 60px rgba(0,0,0,0.34),
            0 3px 10px rgba(0,0,0,0.18);
    }

    .nav-link {
        color: rgba(0,0,0,0.55); text-decoration: none;
        font-size: 9.5px; font-weight: 700; letter-spacing: 1px;
        padding: 8px 14px; position: relative; z-index: 1;
        transition: color 0.45s var(--ease-spring);
        white-space: nowrap;
    }
    .navbar-wrapper.scrolled .nav-link { color: rgba(255,255,255,0.45); }
    .nav-link:hover { color: rgba(0,0,0,0.95); }
    .navbar-wrapper.scrolled .nav-link:hover { color: rgba(255,255,255,0.95); }

    .nav-indicator {
        position: absolute; top: 0; left: 0;
        width: 0; height: 0; border-radius: 100px;
        background: rgba(0,0,0,0.05);
        box-shadow: inset 0 1px 1px rgba(255,255,255,0.7), inset 0 0 0 0.5px rgba(255,255,255,0.35), inset 0 -3px 8px rgba(255,255,255,0.12);
        opacity: 0; z-index: 0; pointer-events: none;
        transition: background 0.6s var(--ease-spring), box-shadow 0.6s var(--ease-spring);
        will-change: transform, width, height;
    }
    .navbar-wrapper.scrolled .nav-indicator {
        background: rgba(255,255,255,0.12);
        box-shadow: inset 0 1px 1px rgba(255,255,255,0.2), inset 0 0 0 0.5px rgba(255,255,255,0.1), inset 0 -3px 8px rgba(0,0,0,0.12);
    }

    /* pill-logo (logo blanco que aparece al scroll dentro de la pill navy) */
    .pill-logo {
        display: flex; align-items: center;
        max-width: 0; overflow: hidden; opacity: 0;
        text-decoration: none; white-space: nowrap; position: relative; z-index: 1;
        transition: max-width 0.7s var(--ease-expo), opacity 0.5s, margin 0.5s, padding 0.5s;
    }
    .navbar-wrapper.scrolled .pill-logo { max-width: 100px; opacity: 1; margin-right: 8px; padding-left: 12px; }
    .pill-logo-img { height: 17px; width: auto; display: block; }

    /* ── CENTER LOGO ── */
    .nav-center { justify-content: center; }
    .main-logo {
        display: flex; align-items: center;
        text-decoration: none;
        transition: opacity 0.7s var(--ease-expo), transform 0.7s var(--ease-expo);
    }
    .main-logo-img { height: 30px; width: auto; display: block; }
    .navbar-wrapper.scrolled .main-logo { opacity: 0; transform: translateY(-12px) scale(0.94); pointer-events: none; }

    /* ── RIGHT ── */
    .nav-right { justify-content: flex-end; gap: 14px; }
    /* Píldora de login (estilo flouvia.com): glass con ícono de usuario */
    .nav-login-pill {
        display: inline-flex; align-items: center; gap: 7px;
        font-size: 9.5px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
        color: rgba(0,0,0,0.6); text-decoration: none;
        padding: 9px 17px; border-radius: 100px;
        background: linear-gradient(180deg, rgba(255,255,255,0.72) 0%, rgba(255,255,255,0.5) 100%);
        backdrop-filter: blur(30px) saturate(1.9) brightness(1.04);
        -webkit-backdrop-filter: blur(30px) saturate(1.9) brightness(1.04);
        border: 1px solid rgba(255,255,255,0.55);
        box-shadow:
            inset 0 1px 1px rgba(255,255,255,0.95),
            inset 0 0 0 0.5px rgba(255,255,255,0.4),
            0 8px 26px rgba(10,25,47,0.09),
            0 2px 5px rgba(10,25,47,0.05);
        transition: color 0.45s var(--ease-spring), box-shadow 0.6s var(--ease-spring),
                    border-color 0.6s var(--ease-spring), background 0.6s var(--ease-spring),
                    transform 0.4s var(--ease-expo);
    }
    .nav-login-pill svg { width: 12px; height: 12px; opacity: 0.7; transition: opacity 0.3s; }
    .nav-login-pill:hover {
        color: rgba(0,0,0,0.95); transform: translateY(-1px);
        box-shadow:
            inset 0 1px 1px rgba(255,255,255,0.98),
            inset 0 0 0 0.5px rgba(255,255,255,0.5),
            0 14px 38px rgba(10,25,47,0.13),
            0 3px 7px rgba(10,25,47,0.06);
    }
    .nav-login-pill:hover svg { opacity: 1; }
    .navbar-wrapper.scrolled .nav-login-pill {
        color: rgba(255,255,255,0.75);
        background: linear-gradient(180deg, rgba(24,46,80,0.62) 0%, rgba(10,25,47,0.5) 100%);
        border-color: rgba(255,255,255,0.14);
        box-shadow:
            inset 0 1px 0 rgba(255,255,255,0.22),
            inset 0 0 0 0.5px rgba(255,255,255,0.08),
            0 14px 40px rgba(0,0,0,0.28);
    }
    .navbar-wrapper.scrolled .nav-login-pill:hover { color: #fff; }

    .btn-contact {
        display: inline-flex; align-items: center; gap: 7px;
        background: var(--nb-dark); color: #fff;
        padding: 10px 20px; border-radius: 100px;
        text-decoration: none; font-size: 9.5px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 4px 16px rgba(10,25,47,0.2), inset 0 1px 0 rgba(255,255,255,0.08);
        transition: transform 0.4s var(--ease-expo), box-shadow 0.4s var(--ease-expo), background 0.3s;
        position: relative; overflow: hidden;
    }
    .btn-contact::before {
        content: ''; position: absolute; inset: 0;
        background: linear-gradient(105deg, transparent 20%, rgba(255,255,255,0.07) 50%, transparent 80%);
        transform: translateX(-100%); transition: transform 0s;
    }
    .btn-contact:hover::before { transform: translateX(100%); transition: transform 0.55s var(--ease-expo); }
    .btn-contact:hover { transform: translateY(-2px) scale(1.02); box-shadow: 0 12px 32px rgba(10,25,47,0.3), inset 0 1px 0 rgba(255,255,255,0.12); background: #152641; }
    .contact-arrow { transition: transform 0.4s var(--ease-expo); flex-shrink: 0; }
    .btn-contact:hover .contact-arrow { transform: translate(2px,-2px); }

    /* ── MOBILE ── */
    .mobile-pill-nav { display: none; }
    .mobile-menu-overlay { display: none; }

    @media (max-width: 1024px) {
        .desktop-nav, .desktop-only { display: none; }
        .top-text { font-size: 6.5px; letter-spacing: 1.8px; }
        .nav-container { display: flex; justify-content: center; padding: 0 20px; }
        .main-nav { padding: 14px 0; }

        .mobile-pill-nav { display: flex; width: 100%; justify-content: center; z-index: 21000; position: relative; }
        .mobile-pill-inner {
            display: flex; align-items: center; justify-content: space-between; height: 50px;
            background: linear-gradient(180deg, rgba(255,255,255,0.74) 0%, rgba(255,255,255,0.54) 100%);
            backdrop-filter: blur(30px) saturate(1.9) brightness(1.04);
            -webkit-backdrop-filter: blur(30px) saturate(1.9) brightness(1.04);
            border: 1px solid rgba(255,255,255,0.55); border-radius: 100px;
            padding: 0 8px 0 16px; width: 92%; max-width: 380px;
            box-shadow: inset 0 1px 1px rgba(255,255,255,0.95), inset 0 0 0 0.5px rgba(255,255,255,0.4), inset 0 -6px 14px rgba(255,255,255,0.18), 0 16px 44px rgba(10,25,47,0.12);
            transition: background 0.7s var(--ease-spring), border-color 0.7s var(--ease-spring), box-shadow 0.7s var(--ease-spring);
        }
        .navbar-wrapper.scrolled .mobile-pill-inner {
            background: linear-gradient(180deg, rgba(24,46,80,0.66) 0%, rgba(10,25,47,0.56) 100%);
            border-color: rgba(255,255,255,0.16);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), inset 0 0 0 0.5px rgba(255,255,255,0.08), 0 18px 50px rgba(0,0,0,0.3);
        }
        .pill-left-group { display: flex; align-items: center; gap: 14px; height: 100%; }
        .hamburger-btn { background: transparent; border: none; padding: 0; cursor: pointer; display: flex; align-items: center; justify-content: center; height: 100%; }
        .burger-lines { width: 18px; height: 10px; position: relative; }
        .burger-lines span { display: block; width: 100%; height: 1.8px; background: var(--nb-dark); border-radius: 2px; position: absolute; left: 0; transition: transform 0.5s var(--ease-expo), background 0.4s, opacity 0.3s; }
        .burger-lines .l1 { top: 0; } .burger-lines .l2 { top: 4px; } .burger-lines .l3 { top: 8px; }
        .navbar-wrapper.scrolled .burger-lines span { background: #fff; }
        .navbar-wrapper.menu-open .burger-lines span { background: #fff !important; }
        .navbar-wrapper.menu-open .burger-lines .l1 { transform: translateY(4px) rotate(45deg); }
        .navbar-wrapper.menu-open .burger-lines .l2 { opacity: 0; transform: scaleX(0); }
        .navbar-wrapper.menu-open .burger-lines .l3 { transform: translateY(-4px) rotate(-45deg); }

        .mobile-logo { display: block; position: relative; height: 22px; width: max-content; text-decoration: none; }
        .logo-mobile-img { height: 100%; width: auto; display: block; transition: opacity 0.5s var(--ease-expo); }
        .default-logo { position: relative; z-index: 1; }
        .scrolled-logo { position: absolute; left: 0; top: 0; opacity: 0; z-index: 2; }
        .navbar-wrapper.scrolled .default-logo { opacity: 0; }
        .navbar-wrapper.scrolled .scrolled-logo { opacity: 1; }
        .navbar-wrapper.menu-open .default-logo { opacity: 0 !important; }
        .navbar-wrapper.menu-open .scrolled-logo { opacity: 1 !important; }
        .navbar-wrapper.menu-open .mobile-pill-inner { background: rgba(255,255,255,0.04) !important; border-color: rgba(255,255,255,0.1) !important; box-shadow: none !important; }

        .btn-contact-mobile {
            background: var(--nb-dark); color: #fff; height: 34px; padding: 0 16px; border-radius: 100px;
            display: flex; align-items: center; gap: 6px; text-decoration: none; font-size: 8px; font-weight: 800; letter-spacing: 0.5px; text-transform: uppercase;
            transition: all 0.4s var(--ease-expo); box-shadow: 0 4px 14px rgba(10,25,47,0.25);
        }
        .btn-contact-mobile:active { transform: scale(0.95); }
        .navbar-wrapper.scrolled .btn-contact-mobile { background: #fff; color: var(--nb-dark); }
        .navbar-wrapper.menu-open .btn-contact-mobile { background: rgba(255,255,255,0.08) !important; color: #fff !important; box-shadow: none !important; }

        .mobile-menu-overlay {
            display: flex; position: fixed; top: 0; left: 0; width: 100vw; height: 100dvh;
            background: rgba(6,17,33,0.92); backdrop-filter: blur(32px); -webkit-backdrop-filter: blur(32px);
            z-index: 15000; opacity: 0; visibility: hidden; clip-path: circle(0% at 88% 8%);
            transition: clip-path 0.75s var(--ease-expo), opacity 0.3s, visibility 0s 0.75s;
        }
        .navbar-wrapper.menu-open .mobile-menu-overlay { opacity: 1; visibility: visible; clip-path: circle(160% at 88% 8%); transition: clip-path 0.75s var(--ease-expo), opacity 0.2s, visibility 0s 0s; }
        .mobile-menu-content { padding: 120px 9% 44px; display: flex; flex-direction: column; justify-content: space-between; height: 100%; width: 100%; }

        .menu-top-row { display: flex; gap: 10px; opacity: 0; transform: translateY(16px); filter: blur(6px); transition: all 0.55s var(--ease-expo) 0.25s; }
        .navbar-wrapper.menu-open .menu-top-row { opacity: 1; transform: translateY(0); filter: blur(0); }
        .utility-pill {
            background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.8);
            padding: 10px 18px; border-radius: 100px; font-size: 10px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase;
            text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.35s var(--ease-expo);
        }
        .utility-pill:hover { background: rgba(255,255,255,0.12); color: #fff; }

        .mobile-links { display: flex; flex-direction: column; gap: 0.4rem; }
        .m-link {
            font-size: clamp(2.2rem, 8.4vw, 3rem); font-weight: 700;
            font-family: var(--font-sans);
            color: rgba(255,255,255,0.9); text-decoration: none; letter-spacing: -0.045em; line-height: 1.18;
            opacity: 0; transform: translateY(20px); filter: blur(5px);
            transition: all 0.6s var(--ease-expo); display: inline-block; width: max-content;
        }
        .m-link:hover { color: #fff; }
        .navbar-wrapper.menu-open .m-link { opacity: 1; transform: translateY(0); filter: blur(0); }
        .m-link:nth-child(1) { transition-delay: 0.22s; }
        .m-link:nth-child(2) { transition-delay: 0.31s; }
        .m-link:nth-child(3) { transition-delay: 0.40s; }
        .m-link:nth-child(4) { transition-delay: 0.49s; }

        .mobile-menu-footer { border-top: 1px solid rgba(255,255,255,0.07); padding-top: 2rem; opacity: 0; transform: translateY(16px); filter: blur(6px); transition: all 0.65s var(--ease-expo) 0.55s; }
        .navbar-wrapper.menu-open .mobile-menu-footer { opacity: 1; transform: translateY(0); filter: blur(0); }
        .m-eyebrow { font-size: 8px; font-weight: 800; letter-spacing: 2.5px; text-transform: uppercase; color: rgba(255,255,255,0.25); margin-bottom: 1.4rem; }
        .m-legal { display: flex; justify-content: space-between; font-size: 9px; color: rgba(255,255,255,0.3); letter-spacing: 1px; font-weight: 600; }
        .m-legal a { color: rgba(255,255,255,0.6); text-decoration: none; }
    }

    .squircle { border-radius: 100px; transform: translateZ(0); }
</style>

<script>
    import { gsap } from 'gsap';

    document.addEventListener('DOMContentLoaded', () => {
        const navbar = document.getElementById('navbar');
        const toggle = document.getElementById('menu-toggle');
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        let indicatorRelayout: ((animate?: boolean) => void) | null = null;
        let indicatorFollow: ((ms?: number) => void) | null = null;

        // ── ENTRANCE ──
        if (navbar && !reducedMotion) {
            const topBar = document.getElementById('top-bar');
            const pill = document.getElementById('glass-pill');
            const mainLogo = document.getElementById('main-logo');
            const navRight = document.getElementById('nav-right');
            const rightKids = navRight ? Array.from(navRight.children) : [];
            const mobile = document.getElementById('mobile-pill');
            const pieces = [topBar, pill, mainLogo, ...rightKids, mobile].filter(Boolean);

            gsap.set(pieces, { opacity: 0, y: -10 });
            gsap.set(navbar, { opacity: 1 });

            const tl = gsap.timeline({
                defaults: { ease: 'power3.out', duration: 0.95 },
                delay: 0.05,
                onComplete: () => {
                    gsap.set(pieces, { clearProps: 'transform,opacity' });
                    if (indicatorRelayout) indicatorRelayout(false);
                },
            });
            tl.to(topBar, { opacity: 1, y: 0, duration: 0.6 }, 0)
              .to([pill, mobile], { opacity: 1, y: 0, duration: 1.0 }, 0.1)
              .to(mainLogo, { opacity: 1, y: 0, duration: 0.9 }, '<0.07')
              .to(rightKids, { opacity: 1, y: 0, stagger: 0.08, duration: 0.75 }, '<0.05');
        } else if (navbar) {
            gsap.set(navbar, { opacity: 1 });
        }

        // ── NAV INDICATOR (cápsula deslizante) ──
        const glassPill = document.getElementById('glass-pill');
        const indicator = document.getElementById('nav-indicator');
        if (glassPill && indicator && !reducedMotion) {
            const navLinks = Array.from(glassPill.querySelectorAll<HTMLElement>('.nav-link'));
            let visible = false;
            let target: HTMLElement | null = null;

            const rectOf = (el: HTMLElement) => {
                const pr = glassPill.getBoundingClientRect();
                const r = el.getBoundingClientRect();
                return { x: r.left - pr.left, y: r.top - pr.top, width: r.width, height: r.height };
            };
            const snap = (el: HTMLElement | null) => {
                if (!el) return;
                gsap.set(indicator, { ...rectOf(el), opacity: 1 });
                visible = true;
            };
            const slide = (el: HTMLElement | null, animate = true) => {
                target = el;
                if (!el) { gsap.to(indicator, { opacity: 0, duration: animate ? 0.3 : 0, overwrite: true }); visible = false; return; }
                if (!visible) {
                    gsap.set(indicator, rectOf(el));
                    gsap.to(indicator, { opacity: 1, duration: animate ? 0.3 : 0, overwrite: true });
                } else {
                    gsap.to(indicator, { ...rectOf(el), opacity: 1, duration: animate ? 0.5 : 0, ease: 'power3.out', overwrite: true });
                }
                visible = true;
            };

            navLinks.forEach(l => l.addEventListener('mouseenter', () => slide(l)));
            glassPill.addEventListener('mouseleave', () => slide(null));

            indicatorRelayout = (animate = false) => slide(target, animate);

            let followRAF = 0, followUntil = 0;
            const followTick = (now: number) => {
                snap(target);
                if (now < followUntil) { followRAF = requestAnimationFrame(followTick); }
                else { followRAF = 0; }
            };
            indicatorFollow = (ms = 780) => {
                followUntil = performance.now() + ms;
                if (!followRAF) followRAF = requestAnimationFrame(followTick);
            };
            window.addEventListener('resize', () => indicatorRelayout && indicatorRelayout(false), { passive: true });
        }

        // ── MEGAMENÚS (la píldora se expande en vertical; un panel por trigger) ──
        const pillEl = document.getElementById('glass-pill');
        const panels = pillEl ? Array.from(pillEl.querySelectorAll<HTMLElement>('.pill-mega')) : [];
        const triggers = pillEl ? Array.from(pillEl.querySelectorAll<HTMLElement>('.nav-link[data-mega]')) : [];
        if (pillEl && panels.length && triggers.length) {
            const dur = reducedMotion ? 0 : 1;
            const pillRow = document.getElementById('pill-row');
            let current: string | null = null;

            const panelOf = (name: string) => panels.find(p => p.dataset.panel === name) ?? null;
            const triggerOf = (name: string) => triggers.find(t => t.dataset.mega === name) ?? null;
            const piecesOf = (panel: HTMLElement) => Array.from(panel.querySelectorAll<HTMLElement>('.mega-item, .mega-foot'));

            const openMega = (name: string) => {
                if (current === name) return;
                const panel = panelOf(name);
                if (!panel) return;
                const pieces = piecesOf(panel);

                const w0 = pillEl.offsetWidth;

                // si hay otro panel abierto, colápsalo al instante (estamos cambiando de pestaña)
                if (current) {
                    const prev = panelOf(current);
                    const prevTrigger = triggerOf(current);
                    if (prev) {
                        gsap.killTweensOf([prev, ...piecesOf(prev)]);
                        gsap.set(prev, { width: 0, height: 0 });
                        gsap.set(piecesOf(prev), { clearProps: 'opacity,transform,filter' });
                        prev.setAttribute('aria-hidden', 'true');
                    }
                    prevTrigger?.classList.remove('mega-active');
                    prevTrigger?.setAttribute('aria-expanded', 'false');
                }

                current = name;
                pillEl.classList.add('mega-open');
                const trigger = triggerOf(name);
                trigger?.classList.add('mega-active');
                trigger?.setAttribute('aria-expanded', 'true');
                panel.setAttribute('aria-hidden', 'false');
                gsap.killTweensOf([pillEl, panel, ...pieces]);

                // medir: ancho actual → ancho con el panel desplegado
                gsap.set(panel, { width: 'auto', height: 'auto' });
                const w1 = pillEl.offsetWidth;

                gsap.fromTo(pillEl, { width: w0 }, { width: Math.max(w0, w1), duration: 0.62 * dur, ease: 'power3.out', clearProps: 'width' });
                gsap.from(panel, {
                    height: 0, duration: 0.62 * dur, ease: 'power3.out',
                    onComplete: () => gsap.set(panel, { height: 'auto' }),
                });
                gsap.fromTo(pieces,
                    { opacity: 0, y: 9, filter: 'blur(4px)' },
                    { opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.5 * dur, stagger: 0.035 * dur, delay: 0.08 * dur, ease: 'power2.out', clearProps: 'filter,transform' },
                );
            };

            const closeMega = () => {
                if (!current) return;
                const panel = panelOf(current);
                const trigger = triggerOf(current);
                current = null;
                trigger?.classList.remove('mega-active');
                trigger?.setAttribute('aria-expanded', 'false');
                if (!panel) { pillEl.classList.remove('mega-open'); return; }
                const pieces = piecesOf(panel);
                panel.setAttribute('aria-hidden', 'true');
                gsap.killTweensOf([pillEl, panel, ...pieces]);

                const w1 = pillEl.offsetWidth;
                const w0 = (pillRow ? pillRow.offsetWidth : 0) + 12; // + padding horizontal de la píldora

                gsap.to(pieces, { opacity: 0, duration: 0.22 * dur });
                gsap.fromTo(pillEl, { width: w1 }, { width: w0, duration: 0.5 * dur, ease: 'power3.inOut' });
                gsap.to(panel, {
                    height: 0, duration: 0.5 * dur, ease: 'power3.inOut',
                    onComplete: () => {
                        gsap.set(panel, { width: 0 });
                        gsap.set(pieces, { clearProps: 'opacity' });
                        gsap.set(pillEl, { clearProps: 'width' });
                        pillEl.classList.remove('mega-open');
                    },
                });
            };

            triggers.forEach((trigger) => {
                const name = trigger.dataset.mega!;
                trigger.addEventListener('mouseenter', () => openMega(name));
                trigger.addEventListener('click', (e) => {
                    if (current !== name) { e.preventDefault(); openMega(name); }
                    else { closeMega(); } // segundo click: cierra y deja navegar al href
                });
            });
            pillEl.querySelectorAll<HTMLElement>('.nav-link:not([data-mega])').forEach(l => l.addEventListener('mouseenter', closeMega));
            pillEl.addEventListener('mouseleave', closeMega);
            panels.forEach(p => p.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMega)));
            window.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMega(); });
            window.addEventListener('scroll', closeMega, { passive: true });
        }

        // ── SCROLL toggle ──
        if (navbar) {
            let wasScrolled = navbar.classList.contains('scrolled');
            window.addEventListener('scroll', () => {
                const isScrolled = window.scrollY > 50;
                navbar.classList.toggle('scrolled', isScrolled);
                if (isScrolled !== wasScrolled) {
                    wasScrolled = isScrolled;
                    if (indicatorFollow) indicatorFollow();
                }
            }, { passive: true });
        }

        // ── MOBILE MENU ──
        if (navbar && toggle) {
            toggle.addEventListener('click', () => {
                navbar.classList.toggle('menu-open');
                const main = document.querySelector('main');
                if (navbar.classList.contains('menu-open')) {
                    document.body.style.overflow = 'hidden';
                    if (main) gsap.to(main, { scale: 0.96, y: 10, filter: 'blur(4px)', borderRadius: '20px', duration: 0.6, ease: 'expo.out' });
                } else {
                    document.body.style.overflow = '';
                    if (main) gsap.to(main, { scale: 1, y: 0, filter: 'blur(0px)', borderRadius: '0px', duration: 0.5, ease: 'expo.out' });
                }
            });
            document.querySelectorAll('.m-link, .utility-pill').forEach(el => {
                el.addEventListener('click', () => {
                    navbar.classList.remove('menu-open');
                    document.body.style.overflow = '';
                    const main = document.querySelector('main');
                    if (main) gsap.to(main, { scale: 1, y: 0, filter: 'blur(0px)', borderRadius: '0px', duration: 0.45, ease: 'expo.out' });
                });
            });
        }
    });
</script>
