---
// Navbar de Cord — replica el sistema de flouvia.com:
// top-bar editorial + glass pill con indicador deslizante + wordmark central
// que se transforma en píldora al hacer scroll. Wordmark "cord" en texto (no SVG).
import { altLangUrls, useTranslations } from '../../i18n/utils';
const { esUrl, enUrl, lang } = altLangUrls(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);
const l = (p: string) => lang === 'es' ? p : `/en${p === '/' ? '' : p}`;

export interface Props {
    darkHero?: boolean;
}
const { darkHero = false } = Astro.props;
---

<header class="navbar-wrapper" id="navbar">
    <div class="top-bar" id="top-bar">
        <div class="top-bar-inner">
            <span class="top-text">{t("nav.top.plataforma")}</span>
            <span class="top-dot desktop-only">·</span>
            <span class="top-text desktop-only">{t("nav.top.producto_de")}</span>
            <span class="top-dot desktop-only">·</span>
            <span class="top-text desktop-only">{t("nav.top.hecho_en")}</span>
        </div>
    </div>

    <nav class="main-nav">
        <div class="nav-container">

            <div class="nav-left desktop-nav">
                <div class="glass-pill" id="glass-pill">
                    <div class="pill-shimmer" aria-hidden="true"></div>
                    <span class="nav-indicator" id="nav-indicator" aria-hidden="true"></span>
                    <div class="pill-row" id="pill-row">
                        <a href={l("/")} class="pill-logo" id="pill-logo">
                            <img src="/imgs/logo-cord-white.png" alt="Cord" class="pill-logo-img" />
                        </a>
                        <a href="/#producto" class="nav-link" data-mega="producto" aria-haspopup="true" aria-expanded="false">{t("nav.producto")}<svg class="nav-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></a>
                        <a href={l("/soluciones")} class="nav-link" data-mega="soluciones" aria-haspopup="true" aria-expanded="false">{t("nav.soluciones")}<svg class="nav-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></a>
                        <a href={l("/desarrolladores/api")} class="nav-link" data-mega="desarrolladores" aria-haspopup="true" aria-expanded="false">{t("nav.desarrolladores")}<svg class="nav-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></a>
                        <a href="/#faq" class="nav-link" data-mega="recursos" aria-haspopup="true" aria-expanded="false">{t("nav.recursos")}<svg class="nav-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></a>
                        <a href={l("/precios")} class="nav-link" data-path={l("/precios")}>{t("nav.precios")}</a>
                    </div>

                    <!-- Megamenús: la píldora se expande verticalmente y revela el panel activo -->
                    <div class="pill-mega" data-panel="producto" aria-hidden="true">
                        <div class="mega-inner">
                            <div class="mega-grid">
                                <a href={l("/producto/editor")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.prod.1.title")}</b><i>{t("nav.mega.prod.1.desc")}</i></span>
                                </a>
                                <a href={l("/producto/link-publico")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7l-1.7 1.7"/><path d="M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.7-1.7"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.prod.2.title")}</b><i>{t("nav.mega.prod.2.desc")}</i></span>
                                </a>
                                <a href={l("/producto/seguimiento")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/><circle cx="12" cy="12" r="3"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.prod.3.title")}</b><i>{t("nav.mega.prod.3.desc")}</i></span>
                                </a>
                                <a href={l("/producto/cfdi")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.prod.4.title")}</b><i>{t("nav.mega.prod.4.desc")}</i></span>
                                </a>
                                <a href={l("/producto/clientes-credito")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.prod.5.title")}</b><i>{t("nav.mega.prod.5.desc")}</i></span>
                                </a>
                                <a href={l("/producto/cobranza-ia")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M22 12A10 10 0 0 0 12 2v10Z"/><path d="m9 12 2 2 4-4"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.prod.6.title")}</b><i>{t("nav.mega.prod.6.desc")}</i></span>
                                </a>
                                <a href={l("/producto/divisas")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5"/><path d="M21 3l-7 7"/><path d="M8 21H3v-5"/><path d="M3 21l7-7"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.prod.7.title")}</b><i>{t("nav.mega.prod.7.desc")}</i></span>
                                </a>
                                <a href={l("/producto/internacional")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 0 20 15.3 15.3 0 0 1 0-20Z"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.prod.8.title")}</b><i>{t("nav.mega.prod.8.desc")}</i></span>
                                </a>
                                <a href={l("/producto/finanzas")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.prod.9.title")}</b><i>{t("nav.mega.prod.9.desc")}</i></span>
                                </a>
                                <a href={l("/producto/aprobaciones")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m9 12 2 2 4-4"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.prod.10.title")}</b><i>{t("nav.mega.prod.10.desc")}</i></span>
                                </a>
                                <a href={l("/producto/equipo")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.prod.11.title")}</b><i>{t("nav.mega.prod.11.desc")}</i></span>
                                </a>
                            </div>
                            <a href={l("/blog")} class="mega-foot">
                                <span>{t("nav.mega.prod.foot")}</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            </a>
                        </div>
                    </div>

                    <div class="pill-mega" data-panel="soluciones" aria-hidden="true">
                        <div class="mega-inner">
                            <div class="mega-grid">
                                <a href={l("/soluciones/empresas")} class="mega-item">
                                    <span class="mega-ico">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>
                                    </span>
                                    <span class="mega-copy"><b>{isEn ? 'Enterprise' : 'Empresas'}</b><i>{isEn ? 'Scalable B2B quoting' : 'Cotizaciones B2B escalables'}</i></span>
                                </a>
                                <a href={l("/soluciones/startups")} class="mega-item">
                                    <span class="mega-ico">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13a8 8 0 0 1 7 7a6 6 0 0 0 3 -5a9 9 0 0 0 6 -8a3 3 0 0 0 -3 -3a9 9 0 0 0 -8 6a6 6 0 0 0 -5 3" /><path d="M7 14a6 6 0 0 0 -3 6a6 6 0 0 0 6 -3" /><circle cx="14.5" cy="9.5" r="2.5" fill="currentColor" fill-opacity="0.12" /><path d="M5.5 16.5l-2.5 2.5" stroke-width="2" /><path d="M7.5 18.5l-2.5 2.5" stroke-width="2" /></svg>
                                    </span>
                                    <span class="mega-copy"><b>{t("nav.startups") || 'Startups'}</b><i>{isEn ? 'Fast closing and billing' : 'Cierre rápido y facturación'}</i></span>
                                </a>
                                
                                <div class="mega-divider">{isEn ? 'By Use Case' : 'Por caso de uso'}</div>
                                
                                <a href={l("/casos-de-uso/agencias")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></span>
                                    <span class="mega-copy"><b>{isEn ? 'Agencies' : 'Agencias'}</b><i>{isEn ? 'Proposals & Retainers' : 'Propuestas e igualas'}</i></span>
                                </a>
                                <a href={l("/casos-de-uso/saas")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></span>
                                    <span class="mega-copy"><b>{isEn ? 'B2B SaaS' : 'SaaS B2B'}</b><i>{isEn ? 'Subscription billing' : 'Cobros recurrentes'}</i></span>
                                </a>
                                <a href={l("/casos-de-uso/comercializadoras")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg></span>
                                    <span class="mega-copy"><b>{isEn ? 'Wholesalers' : 'Comercializadoras'}</b><i>{isEn ? 'Volume & Tiers' : 'Volumen y Tiers'}</i></span>
                                </a>
                                <a href={l("/casos-de-uso/software-factory")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16c0 1.1.9 2 2 2h12a2 2 0 0 0 2-2V8l-6-6z"></path></svg></span>
                                    <span class="mega-copy"><b>{isEn ? 'Dev Teams' : 'Dev Teams'}</b><i>{isEn ? 'Milestone quotes' : 'Cobro por hitos'}</i></span>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="pill-mega" data-panel="desarrolladores" aria-hidden="true">
                        <div class="mega-inner">
                            <div class="mega-grid">
                                <a href={l("/desarrolladores/api")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.dev.1.title")}</b><i>{t("nav.mega.dev.1.desc")}</i></span>
                                </a>
                                <a href={l("/desarrolladores/mcp")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 4.6L18.5 9l-4.6 1.9L12 15.5l-1.9-4.6L5.5 9l4.6-1.4L12 3z"/><path d="M19 15l.7 1.8L21.5 17.5l-1.8.7L19 20l-.7-1.8L16.5 17.5l1.8-.7L19 15z"/></svg></span>
                                    <span class="mega-copy"><b>MCP y Agentes</b><i>{t("nav.mega.dev.2.desc")}</i></span>
                                </a>
                                <a href={l("/desarrolladores/elements")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.dev.3.title")}</b><i>{t("nav.mega.dev.3.desc")}</i></span>
                                </a>
                                <a href={l("/desarrolladores/status")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.dev.4.title")}</b><i>{t("nav.mega.dev.4.desc")}</i></span>
                                </a>
                            </div>
                            <a href={l("/registro")} class="mega-foot">
                                <span>{t("nav.mega.dev.foot")}</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            </a>
                        </div>
                    </div>

                    <div class="pill-mega" data-panel="recursos" aria-hidden="true">
                        <div class="mega-inner">
                            <div class="mega-grid">
                                <a href={l("/blog")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.rec.1.title")}</b><i>{t("nav.mega.rec.1.desc")}</i></span>
                                </a>
                                <a href={l("/q/demo")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="3"/><path d="M12 18h.01"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.rec.2.title")}</b><i>{t("nav.mega.rec.2.desc")}</i></span>
                                </a>
                                <a href={lang === 'en' ? '/en/support' : '/soporte'} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.rec.3.title")}</b><i>{t("nav.mega.rec.3.desc")}</i></span>
                                </a>
                                <a href={l("/roadmap")} class="mega-item">
                                    <span class="mega-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 12 12 17 22 12"/><polyline points="2 17 12 22 22 17"/></svg></span>
                                    <span class="mega-copy"><b>{t("nav.mega.rec.4.title")}</b><i>{t("nav.mega.rec.4.desc")}</i></span>
                                </a>
                            </div>
                            <a href="https://flouvia.com" target="_blank" rel="noopener" class="mega-foot">
                                <span>{t("nav.mega.rec.foot")}</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="nav-center desktop-nav">
                <a href={l("/")} class="main-logo" id="main-logo">
                    <img src={darkHero ? "/imgs/logo-cord-white.png" : "/imgs/logo-cord-navy.png"} alt="Cord" class="main-logo-img" />
                </a>
            </div>

            <div class="nav-right desktop-nav" id="nav-right">
                <div class="lang-switch">
                    <a href={esUrl} class="lang-option" class:list={[{ active: lang === 'es' }]}>ES</a>
                    <a href={enUrl} class="lang-option" class:list={[{ active: lang === 'en' }]}>EN</a>
                </div>
                <a href={l("/sign-in")} class="nav-login-pill" aria-label={t("nav.entrar")}
                   data-auth-swap data-out-href={l("/sign-in")} data-out-label={t("nav.entrar")}
                   data-in-href={l("/app")} data-in-label={t("nav.dashboard")} data-in-aria={t("nav.dashboard")}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    <span data-auth-label>{t("nav.entrar")}</span>
                </a>
                <a href={l("/registro")} class="btn-contact"
                   data-auth-swap data-out-href={l("/registro")} data-out-label={t("nav.empezar")}
                   data-in-href={l("/precios")} data-in-label={t("nav.mobile.plans")}>
                    <span class="btn-contact-label" data-auth-label>{t("nav.empezar")}</span>
                    <svg class="contact-arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="5" y1="19" x2="19" y2="5"/><polyline points="9 5 19 5 19 15"/></svg>
                </a>
            </div>

            <!-- MOBILE -->
            <div class="mobile-pill-nav">
                <div class="mobile-pill-inner squircle" id="mobile-pill">
                    <div class="pill-left-group">
                        <button class="hamburger-btn" id="menu-toggle" aria-label={t("nav.mobile.menu")}>
                            <div class="burger-lines"><span class="l1"></span><span class="l2"></span><span class="l3"></span></div>
                        </button>
                        <a href={l("/")} class="mobile-logo">
                            <img src="/imgs/logo-cord-navy.png" alt="Cord" class="logo-mobile-img default-logo" />
                            <img src="/imgs/logo-cord-white.png" alt="Cord" class="logo-mobile-img scrolled-logo" />
                        </a>
                    </div>
                    <a href={l("/registro")} class="btn-contact-mobile squircle"
                       data-auth-swap data-out-href={l("/registro")} data-out-label={t("nav.empezar")}
                       data-in-href={l("/app")} data-in-label={t("nav.dashboard")}>
                        <span data-auth-label>{t("nav.empezar")}</span>
                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="5" y1="19" x2="19" y2="5"/><polyline points="9 5 19 5 19 15"/></svg>
                    </a>
                </div>
            </div>

        </div>
    </nav>

        <div class="mobile-menu-overlay" id="mobile-menu">
        <div class="mobile-menu-content">
            <div class="mm-scroll">
                <nav class="mobile-acc" id="mobile-acc">

                    <!-- PRODUCTO -->
                    <div class="m-acc" data-acc>
                        <button class="m-acc-head" aria-expanded="false">
                            <span class="m-acc-title">{t("nav.producto")}</span>
                            <span class="m-acc-chev"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span>
                        </button>
                        <div class="m-acc-body"><div class="m-acc-inner"><div class="m-acc-stack">
                            <a href={l("/producto/editor")} class="m-sub" data-close>
