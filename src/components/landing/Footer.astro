---
// CTA final + footer — dark navy, coherente con el footer de flouvia.com.
// Las subpáginas (/producto/*, /soluciones) pueden personalizar el CTA via props.
interface Props {
    ctaTitle?: string;   // admite <br />
    ctaSub?: string;
}
const {
    ctaTitle = 'Tu próxima cotización<br />merece verse como Cord.',
    ctaSub = 'Crea tu cuenta gratis y manda tu primera cotización en menos de 10 minutos.',
} = Astro.props;
---

<section class="final-cta">
    <div class="fc-glow" aria-hidden="true"></div>
    <div class="fc-inner reveal">
        <p class="fc-eyebrow">EMPIEZA HOY</p>
        <h2 class="fc-title masked-title" set:html={ctaTitle} />
        <p class="fc-sub">{ctaSub}</p>
        <div class="fc-actions">
            <a href="/registro" class="fc-btn">
                <span>Empezar gratis</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
        </div>
        <p class="fc-micro">Sin tarjeta · Plan gratis para siempre</p>
    </div>
</section>

<footer class="footer">
    <div class="footer-inner">
        <div class="footer-top">
            <div class="footer-brand">
                <img src="/imgs/logo-cord-white.png" alt="Cord" class="footer-logo-img" />
                <p class="footer-tagline">Operaciones B2B que cierran ventas. La plataforma moderna para cualquier negocio que vende a otras empresas en México.</p>
                <a href="https://flouvia.com" target="_blank" rel="noopener" class="footer-byflouvia">
                    Un producto de <b>Flouvia</b> →
                </a>
            </div>

            <div class="footer-cols">
                <div class="footer-col">
                    <span class="footer-col-title">Producto</span>
                    <a href="/producto/editor">Editor de cotizaciones</a>
                    <a href="/producto/link-publico">Link público</a>
                    <a href="/producto/seguimiento">Seguimiento en vivo</a>
                    <a href="/producto/cfdi">CFDI 4.0</a>
                    <a href="/producto/clientes-credito">Clientes y crédito</a>
                    <a href="/producto/cobranza-ia">Cobranza con IA</a>
                    <a href="/producto/divisas">Multi-divisa y FX</a>
                    <a href="/producto/internacional">Facturación internacional</a>
                </div>
                <div class="footer-col">
                    <span class="footer-col-title">Soluciones</span>
                    <a href="/soluciones/distribuidoras">Distribuidoras</a>
                    <a href="/soluciones/construccion">Construcción</a>
                    <a href="/soluciones/manufactura">Manufactura</a>
                    <a href="/soluciones/servicios">Servicios</a>
                    <a href="/soluciones">Ver todas →</a>
                </div>
                <div class="footer-col">
                    <span class="footer-col-title">Desarrolladores</span>
                    <a href="/desarrolladores/api">API REST</a>
                    <a href="/desarrolladores/mcp">MCP para IA</a>
                    <a href="/desarrolladores/elements">Cord Elements</a>
                    <a href="/elements">Documentación</a>
                    <a href="/registro">Generar API key</a>
                </div>
                <div class="footer-col">
                    <span class="footer-col-title">Recursos</span>
                    <a href="/soporte">Soporte</a>
                    <a href="/blog">Blog</a>
                    <a href="/q/demo">Cotización de ejemplo</a>
                    <a href="/precios">Precios</a>
                    <a href="/planes-soporte">Planes de soporte</a>
                </div>
                <div class="footer-col">
                    <span class="footer-col-title">Empresa</span>
                    <a href="/registro">Crear cuenta</a>
                    <a href="/sign-in">Entrar</a>
                    <a href="https://flouvia.com" target="_blank" rel="noopener">flouvia.com</a>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <p>&copy; <span class="editorial">2026</span> <span class="editorial">Cord</span> · by Flouvia.</p>
            <div class="footer-bottom-right">
                <div class="footer-social">
                    <a href="https://instagram.com/flouvia" target="_blank" rel="noopener" aria-label="Instagram">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm3.98-10.181a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z"/>
                        </svg>
                    </a>
                    <a href="https://tiktok.com/@flouvia" target="_blank" rel="noopener" aria-label="TikTok">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                            <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                        </svg>
                    </a>
                    <a href="https://x.com/flouvia" target="_blank" rel="noopener" aria-label="X (Twitter)">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                        </svg>
                    </a>
                </div>
                <div class="footer-legal">
                    <a href="/privacidad">Privacidad</a>
                    <span>·</span>
                    <a href="/terminos">Términos</a>
                </div>
            </div>
        </div>
    </div>
</footer>

<style>
    .final-cta {
        position: relative;
        background: radial-gradient(ellipse at 50% 120%, #112240 0%, #0a192f 60%, #050b14 100%);
        color: #fff;
        padding: 7rem 5%;
        text-align: center;
        overflow: clip;
    }
    .fc-glow {
        position: absolute; top: -20%; left: 50%; transform: translateX(-50%);
        width: 700px; height: 500px;
        background: radial-gradient(ellipse at center, rgba(59,130,246,0.1) 0%, transparent 65%);
        pointer-events: none;
    }
    .fc-inner { position: relative; z-index: 2; max-width: 700px; margin: 0 auto; }
    .fc-eyebrow { font-size: 0.65rem; font-weight: 800; letter-spacing: 3px; color: rgba(255,255,255,0.45); margin: 0 0 1.4rem; }
    .fc-title { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800; line-height: 1.08; letter-spacing: -1.4px; margin: 0 0 1.4rem; color: #fff; }
    .fc-sub { font-size: 1.1rem; line-height: 1.6; color: #8892b0; margin: 0 0 2.4rem; }

    .fc-actions { display: flex; gap: 0.9rem; justify-content: center; align-items: center; flex-wrap: wrap; margin-bottom: 1.4rem; }
    .fc-btn {
        display: inline-flex; align-items: center; gap: 10px;
        background: #fff; color: var(--color-blue-deep);
        text-decoration: none; font-size: 1rem; font-weight: 600;
        padding: 15px 30px; border-radius: 13px;
        box-shadow: 0 18px 44px -16px rgba(0,0,0,0.5);
        transition: transform 0.5s var(--ease-spring), box-shadow 0.5s var(--ease-spring);
    }
    .fc-btn svg { width: 16px; height: 16px; transition: transform 0.5s var(--ease-spring); }
    .fc-btn:hover { transform: translateY(-3px); box-shadow: 0 26px 56px -16px rgba(0,0,0,0.6); }
    .fc-btn:hover svg { transform: translateX(4px); }
    .fc-link { color: #cdd5e0; text-decoration: none; font-weight: 600; font-size: 1rem; transition: color 0.3s; }
    .fc-link:hover { color: #fff; }
    .fc-micro { font-size: 0.82rem; color: #66728c; margin: 0; }

    /* Footer */
    .footer {
        position: relative;
        background: #050b14;
        color: #fff;
        padding: 4.5rem 5% 2.5rem;
        overflow: clip;
    }
    .footer-inner { position: relative; z-index: 2; max-width: 1120px; margin: 0 auto; }
    .footer-top {
        display: grid;
        grid-template-columns: 2fr 6fr;
        gap: 4rem;
        padding-bottom: 3.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .footer-logo-img { height: 22px; width: auto; display: block; opacity: 0.9; }
    .footer-tagline { font-size: 0.85rem; line-height: 1.6; color: #8a8f98; margin: 1.2rem 0; max-width: 260px; font-weight: 400; }
    .footer-byflouvia { font-size: 0.85rem; color: #8a8f98; text-decoration: none; transition: color 0.2s ease; display: inline-flex; align-items: center; gap: 0.4rem; }
    .footer-byflouvia b { color: #fff; font-weight: 500; }
    .footer-byflouvia:hover { color: #ededed; }

    .footer-cols { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 2rem; }
    .footer-col { display: flex; flex-direction: column; gap: 1rem; }
    .footer-col-title { font-size: 0.875rem; font-weight: 500; color: #ededed; margin-bottom: 0.5rem; }
    .footer-col a { font-size: 0.875rem; color: #8a8f98; text-decoration: none; transition: color 0.2s ease; width: fit-content; display: inline-block; }
    .footer-col a:hover { color: #ededed; }

    .footer-bottom {
        display: flex; justify-content: space-between; align-items: center;
        padding-top: 2rem; gap: 1.5rem; flex-wrap: wrap;
        font-size: 0.85rem; color: #8a8f98;
    }
    .footer-bottom p { margin: 0; }
    .footer-bottom .editorial { color: #8a8f98; }
    .footer-bottom-right { display: flex; align-items: center; gap: 2.5rem; flex-wrap: wrap; }
    .footer-social { display: flex; align-items: center; gap: 1.2rem; }
    .footer-social a { color: #8a8f98; transition: color 0.2s ease, transform 0.2s ease; display: flex; align-items: center; justify-content: center; }
    .footer-social a:hover { color: #ededed; transform: translateY(-2px); }
    .footer-legal { display: flex; gap: 1rem; align-items: center; }
    .footer-legal a { color: #8a8f98; text-decoration: none; transition: color 0.2s ease; }
    .footer-legal a:hover { color: #ededed; }

    @media (max-width: 1020px) {
        .footer-top { grid-template-columns: 1fr; gap: 2.8rem; }
        .footer-cols { grid-template-columns: repeat(3, 1fr); gap: 2rem 1.5rem; }
    }
    @media (max-width: 620px) {
        .footer-cols { grid-template-columns: 1fr 1fr; }
        .footer-bottom { flex-direction: column; align-items: flex-start; gap: 2rem; }
        .footer-bottom-right { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
    }
</style>
