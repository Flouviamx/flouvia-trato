---
// /src/components/support/SupportCards.astro
---

<section class="support-content">
    <div class="content-wrapper">
        <h2 class="pr-h2 masked-title">Artículos destacados</h2>
        <div class="articles-grid reveal">
            <!-- Article Card 1 -->
            <a href="#" class="article-card">
                <div class="card-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                        <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                </div>
                <div class="card-text">
                    <h3>Crear tu primera cotización</h3>
                    <p>Aprende a generar, enviar y dar seguimiento a cotizaciones profesionales en minutos.</p>
                </div>
            </a>
            <!-- Article Card 2 -->
            <a href="#" class="article-card">
                <div class="card-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="1" x2="12" y2="23"></line>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                    </svg>
                </div>
                <div class="card-text">
                    <h3>Estado de pagos</h3>
                    <p>Entiende los estados de tus pagos, tiempos de procesamiento y transferencias bancarias.</p>
                </div>
            </a>
            <!-- Article Card 3 -->
            <a href="#" class="article-card">
                <div class="card-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path>
                        <path d="M22 12A10 10 0 0 0 12 2v10z"></path>
                    </svg>
                </div>
                <div class="card-text">
                    <h3>Revisar facturación y CFDI</h3>
                    <p>Configura la facturación automática y emite CFDI 4.0 directamente desde Cord.</p>
                </div>
            </a>
        </div>

        <h2 class="pr-h2 masked-title mt-24">Explorar por tema</h2>
        <div class="topics-grid reveal">
            <a href="#" class="topic-pill">
                <span class="topic-icon">💳</span>
                <span class="topic-name">Pagos y transferencias</span>
            </a>
            <a href="#" class="topic-pill">
                <span class="topic-icon">📄</span>
                <span class="topic-name">Cotizaciones</span>
            </a>
            <a href="#" class="topic-pill">
                <span class="topic-icon">🏢</span>
                <span class="topic-name">Gestión de cuenta</span>
            </a>
            <a href="#" class="topic-pill">
                <span class="topic-icon">⚡️</span>
                <span class="topic-name">Facturación (CFDI)</span>
            </a>
            <a href="#" class="topic-pill">
                <span class="topic-icon">👨‍💻</span>
                <span class="topic-name">Desarrolladores y API</span>
            </a>
            <a href="#" class="topic-pill">
                <span class="topic-icon">🔐</span>
                <span class="topic-name">Seguridad y Privacidad</span>
            </a>
        </div>

        <!-- Contact CTA -->
        <div class="contact-cta reveal">
            <div class="cta-content">
                <h2>¿No encuentras lo que buscas?</h2>
                <p>Nuestro equipo de soporte técnico está listo para ayudarte con cualquier duda o problema.</p>
            </div>
            <a href="mailto:soporte@flouvia.com" class="cta-button">Contactar a soporte</a>
        </div>
    </div>
</section>

<style>
    .support-content {
        padding: 5rem 5% 8rem;
        background-color: var(--color-bg);
    }
    .content-wrapper {
        max-width: 1080px;
        margin: 0 auto;
    }
    .pr-h2 {
        font-size: clamp(1.7rem, 3vw, 2.4rem);
        font-weight: 800;
        line-height: 1.12;
        letter-spacing: -0.03em;
        color: var(--color-text);
        margin: 0 0 2rem;
    }
    .mt-24 {
        margin-top: 5rem;
    }

    /* Articles Grid */
    .articles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 20px;
    }
    .article-card {
        display: flex;
        flex-direction: column;
        padding: 2rem;
        background: var(--color-bg-soft);
        border: 1px solid var(--color-border);
        border-radius: 20px;
        text-decoration: none;
        color: inherit;
        transition: all 0.4s var(--ease-spring);
        position: relative;
        overflow: hidden;
    }
    .article-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(145deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.8) 100%);
        opacity: 0;
        transition: opacity 0.4s ease;
        z-index: 0;
    }
    .article-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 40px -10px rgba(10, 25, 47, 0.12);
        border-color: rgba(10, 25, 47, 0.15);
        background: #ffffff;
    }
    .article-card:hover::before {
        opacity: 1;
    }
    .card-icon {
        width: 48px;
        height: 48px;
        background: #f5f7fa;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-blue-deep);
        margin-bottom: 24px;
        position: relative;
        z-index: 1;
        transition: transform 0.4s var(--ease-spring), background 0.4s ease;
    }
    .article-card:hover .card-icon {
        transform: scale(1.05);
        background: #eef2f6;
    }
    .card-icon svg {
        width: 24px;
        height: 24px;
    }
    .card-text {
        position: relative;
        z-index: 1;
    }
    .card-text h3 {
        font-size: 1.15rem;
        font-weight: 700;
        margin: 0 0 10px 0;
        color: var(--color-text);
        letter-spacing: -0.01em;
    }
    .card-text p {
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin: 0;
    }

    /* Topics Grid */
    .topics-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
    }
    .topic-pill {
        display: flex;
        align-items: center;
        padding: 1.25rem 1.5rem;
        background: var(--color-bg-soft);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        text-decoration: none;
        transition: all 0.3s var(--ease-spring);
    }
    .topic-pill:hover {
        background: #ffffff;
        border-color: rgba(10, 25, 47, 0.2);
        box-shadow: 0 8px 24px -8px rgba(10, 25, 47, 0.1);
        transform: translateY(-2px);
    }
    .topic-icon {
        font-size: 1.4rem;
        margin-right: 16px;
    }
    .topic-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-text);
    }

    /* Contact CTA */
    .contact-cta {
        margin-top: 6rem;
        padding: 4rem;
        background: radial-gradient(ellipse at 50% 0%, #112240 0%, #0a192f 80%);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: #ffffff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 30px 60px -20px rgba(10,25,47,0.5);
    }
    .contact-cta::after {
        content: '';
        position: absolute;
        top: -50%; right: -10%;
        width: 500px; height: 500px;
        background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0) 70%);
        border-radius: 50%;
        pointer-events: none;
    }
    .cta-content h2 {
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0 0 16px 0;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }
    .cta-content p {
        font-size: 1.1rem;
        color: rgba(255,255,255,0.7);
        margin: 0;
        max-width: 480px;
        line-height: 1.6;
    }
    .cta-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 16px 32px;
        background: #ffffff;
        color: var(--color-blue-deep);
        font-weight: 700;
        font-size: 1rem;
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.4s var(--ease-spring);
        white-space: nowrap;
        margin-left: 32px;
        box-shadow: 0 12px 28px -10px rgba(0,0,0,0.3);
        position: relative;
        z-index: 1;
    }
    .cta-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 20px 40px -15px rgba(0,0,0,0.4);
    }

    @media (max-width: 900px) {
        .contact-cta {
            flex-direction: column;
            text-align: center;
            padding: 3rem 2rem;
        }
        .cta-content p {
            margin: 0 auto;
        }
        .cta-button {
            margin-left: 0;
            margin-top: 32px;
            width: 100%;
        }
    }
    @media (max-width: 600px) {
        .articles-grid {
            grid-template-columns: 1fr;
        }
        .topics-grid {
            grid-template-columns: 1fr;
        }
        .pr-h2 {
            font-size: 2rem;
        }
    }
</style>
