---
// /src/components/support/SupportCards.astro
import { getCollection } from 'astro:content';

const { isEn = false } = Astro.props;
const allSupport = await getCollection('support');

// Only filter current language articles for counts
const langPrefix = isEn ? 'en/' : 'es/';
const localSupport = allSupport.filter(a => a.id.startsWith(langPrefix));

const categoryMap = [
    {
        name: isEn ? 'Payments & Deposits' : 'Pagos y Depósitos',
        slug: 'pagos',
        icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>'
    },
    {
        name: isEn ? 'Quotes' : 'Cotizaciones',
        slug: 'cotizaciones',
        icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline>'
    },
    {
        name: isEn ? 'Billing & CFDI' : 'Facturación y CFDI',
        slug: 'facturacion',
        icon: '<path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path><path d="M22 12A10 10 0 0 0 12 2v10z"></path>'
    },
    {
        name: isEn ? 'Account & Team' : 'Cuenta y Equipo',
        slug: 'cuenta',
        icon: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>'
    },
    {
        name: isEn ? 'Developers' : 'Desarrolladores',
        slug: 'desarrolladores',
        icon: '<polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline>'
    },
    {
        name: isEn ? 'Security & Privacy' : 'Seguridad y Privacidad',
        slug: 'seguridad',
        icon: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path>'
    }
];

const categoriesWithArticles = categoryMap.map(cat => {
    const articles = localSupport.filter(a => a.data.category === cat.name);
    return {
        ...cat,
        articles: articles.slice(0, 4),
        totalCount: articles.length
    };
});

const faqs = isEn ? [
    { q: "When is the money deposited into my account?", a: "Payments processed by card are deposited into your configured bank account within T+3 to T+7 calendar days, depending on the Payout schedule of your connected Stripe account." },
    { q: "How do I cancel an invoice (CFDI)?", a: "Go to the Billing section in your portal, find the issued invoice, select 'Options' and click 'Generate Expense (Credit Note)'. Cord will automatically link the parent UUID." },
    { q: "Can I charge in dollars (USD)?", a: "Yes. Cord allows you to issue quotes in USD. Stripe will handle the currency conversion if your destination account is in MXN." },
    { q: "What happens if a client doesn't pay on time?", a: "Cord will send automatic reminders based on your account settings, and if you configured late fees, it will calculate them on the overdue balance." },
    { q: "Does Cord charge transaction fees?", a: "No. Cord is a SaaS platform and you only pay your monthly fee. Card charges generate Stripe's standard direct fee, with no intermediaries." },
    { q: "Where can I find my API Keys?", a: "You can find your keys (Test and Live) in Settings > Developers > API Keys. Production keys require the Scale or Developer plan." }
] : [
    { q: "¿Cuándo se deposita el dinero en mi cuenta?", a: "Los pagos procesados con tarjeta se depositan en tu cuenta bancaria configurada en un plazo de T+3 a T+7 días naturales, dependiendo del calendario Payout de tu cuenta conectada de Stripe." },
    { q: "¿Cómo cancelo una factura (CFDI)?", a: "Ve a la sección de Facturación en tu portal, busca la factura emitida, selecciona 'Opciones' y haz clic en 'Generar Egreso (Nota de Crédito)'. Cord vinculará automáticamente el UUID padre." },
    { q: "¿Puedo cobrar en dólares (USD)?", a: "Sí. Cord te permite emitir cotizaciones en USD. Stripe se encargará de hacer la conversión cambiaria si tu cuenta destino está en pesos." },
    { q: "¿Qué pasa si un cliente no paga a tiempo?", a: "Cord enviará recordatorios automáticos según la configuración de tu cuenta y, si configuraste el interés moratorio, lo calculará sobre el saldo vencido." },
    { q: "¿Cord cobra comisiones por transacción?", a: "No. Cord es una plataforma SaaS y solo pagas tu mensualidad. Los cobros con tarjeta generan la comisión estándar directa de Stripe, sin intermediarios." },
    { q: "¿Dónde encuentro mis API Keys?", a: "Puedes encontrar tus llaves (Test y Live) en Ajustes > Desarrolladores > Claves de API. Las llaves de producción requieren el plan Scale o Developer." }
];
---

<section class="support-content">
    <div class="content-wrapper">
        
        <!-- ── RUTAS RÁPIDAS (PREMIUM CARDS) ── -->
        <h2 class="pr-h2 masked-title">{isEn ? 'Quick links' : 'Rutas rápidas'}</h2>
        <div class="quick-links-grid reveal">
            <a href={isEn ? "/en/support/primeros-pasos" : "/soporte/primeros-pasos"} class="ql-card ql-featured">
                <div class="ql-icon-wrapper">
                    <svg class="ql-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M16 6l-4-4-4 4M12 2v13" /></svg>
                </div>
                <div class="ql-content">
                    <h3>{isEn ? 'Cord 101: Getting Started' : 'Cord 101: Primeros Pasos'}</h3>
                    <p>{isEn ? 'Accelerate your integration with Cord. Set up your corporate account, upload your SAT certificates, and issue your first charge in 5 simple steps.' : 'Acelera tu integración con Cord. Configura tu cuenta empresarial, sube tus certificados del SAT (CSD) y emite tu primer cobro en 5 sencillos pasos.'}</p>
                    <div class="ql-actions">
                        <span class="ql-pill">{isEn ? 'Setup Account' : 'Configurar Cuenta'}</span>
                        <span class="ql-pill">{isEn ? 'Issue Charge' : 'Emitir Cobro'}</span>
                    </div>
                </div>
                <div class="ql-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </div>
            </a>
            
            <div class="ql-sub-grid">
                <a href={isEn ? "/en/support/glosario-terminos" : "/soporte/glosario-terminos"} class="ql-card">
                    <div class="ql-icon-wrapper">
                        <svg class="ql-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path></svg>
                    </div>
                    <h3>{isEn ? 'B2B Glossary' : 'Glosario B2B'}</h3>
                    <p>{isEn ? 'The translator between engineers and accountants. Understand CFDI PPD vs PUE.' : 'El traductor entre ingenieros y contadores. Entiende qué es un CFDI PPD vs PUE.'}</p>
                    <span class="ql-cta">{isEn ? 'Read glossary \u2192' : 'Leer glosario \u2192'}</span>
                </a>
                <a href={isEn ? "/en/support/migracion-stripe" : "/soporte/migracion-stripe"} class="ql-card">
                    <div class="ql-icon-wrapper">
                        <svg class="ql-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5"></path></svg>
                    </div>
                    <h3>{isEn ? 'Migrate from Stripe' : 'Migrar desde Stripe'}</h3>
                    <p>{isEn ? 'Guide to export your clients and import your card vault (PCI-DSS).' : 'Guía para exportar clientes e importar tu bóveda de tarjetas.'}</p>
                    <span class="ql-cta">{isEn ? 'View guide \u2192' : 'Ver guía \u2192'}</span>
                </a>
                <a href={isEn ? "/en/support/category/desarrolladores" : "/soporte/categoria/desarrolladores"} class="ql-card">
                    <div class="ql-icon-wrapper">
                        <svg class="ql-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 8 3 12 7 16"/><polyline points="17 8 21 12 17 16"/><line x1="14" y1="4" x2="10" y2="20"/></svg>
                    </div>
                    <h3>{isEn ? 'Dev Portal' : 'Portal Devs'}</h3>
                    <p>{isEn ? 'Technical docs for the REST API, Webhooks, and UI components.' : 'Documentación técnica de API REST, Webhooks y componentes.'}</p>
                    <span class="ql-cta">{isEn ? 'Go to portal \u2192' : 'Ir al portal \u2192'}</span>
                </a>
            </div>
        </div>

        <!-- ── EXPLORAR POR CATEGORÍA (EDITORIAL/HAIRLINES) ── -->
        <h2 class="pr-h2 masked-title mt-32">{isEn ? 'Explore by category' : 'Explorar por categoría'}</h2>
        <div class="editorial-grid reveal">
            {categoriesWithArticles.map(cat => (
                <div class="editorial-block">
                    <div class="eb-header">
                        <svg class="eb-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={cat.icon} />
                        <h3>{cat.name}</h3>
                    </div>
                    <ul class="eb-links">
                        {cat.articles.map((a: any) => (
                            <li>
                                <a href={isEn ? `/en/support/${a.id.replace('en/', '')}` : `/soporte/${a.id.replace('es/', '')}`}>{a.data.title}</a>
                            </li>
                        ))}
                    </ul>
                    <a href={isEn ? `/en/support/category/${cat.slug}` : `/soporte/categoria/${cat.slug}`} class="eb-view-all">{isEn ? `View all (${cat.totalCount}) \u2192` : `Ver todos ({cat.totalCount}) \u2192`}</a>
                </div>
            ))}
        </div>

        <!-- ── PREGUNTAS FRECUENTES (FAQ) ── -->
        <h2 class="pr-h2 masked-title mt-32 text-center">{isEn ? 'Frequently asked questions' : 'Preguntas frecuentes'}</h2>
        <div class="pr-faq-list reveal">
            {faqs.map((f) => (
                <details class="pr-faq-item">
                    <summary>
                        <span>{f.q}</span>
                        <i class="pr-faq-ico" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        </i>
                    </summary>
                    <div class="pr-faq-body"><p>{f.a}</p></div>
                </details>
            ))}
        </div>

        <!-- ── CONTACT CTA PREMIUM (HAIRLINE STYLE) ── -->
        <div class="premium-cta reveal">
            <div class="pcta-content">
                <h2>{isEn ? "Can't find what you're looking for?" : '¿No encuentras lo que buscas?'}</h2>
                <p>{isEn ? 'Advanced technical support is included in all plans. Contact us directly and we will resolve your issue in less than 2 business hours.' : 'El soporte técnico avanzado está incluido en todos los planes. Contáctanos directamente y resolvemos tu duda en menos de 2 horas hábiles.'}</p>
            </div>
            <a href="mailto:soporte@flouvia.com" class="pcta-button">
                {isEn ? 'Talk to an expert' : 'Hablar con un experto'}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
        </div>
    </div>
</section>

<style>
    .support-content {
        padding: 5rem 5% 8rem;
        background-color: var(--color-bg);
    }
    .content-wrapper {
        max-width: 1200px;
        margin: 0 auto;
    }
    .pr-h2 {
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        font-weight: 800;
        line-height: 1.12;
        letter-spacing: -0.03em;
        color: var(--color-text);
        margin: 0 0 3rem;
    }
    .mt-32 {
        margin-top: 6rem;
    }

    /* ── QUICK LINKS PREMIUM CARDS ── */
    .quick-links-grid {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-bottom: 3rem;
    }
    .ql-sub-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }
    .ql-card {
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        padding: 2rem;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }
    .ql-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0) 100%);
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: 0;
    }
    .ql-card:hover {
        transform: translateY(-4px);
        border-color: var(--color-text-muted);
        box-shadow: 0 12px 24px -8px rgba(0,0,0,0.08);
    }
    .ql-card:hover::before {
        opacity: 1;
    }
    .ql-card > * {
        position: relative;
        z-index: 1;
    }
    .ql-featured {
        flex-direction: row;
        align-items: center;
        gap: 2rem;
        padding: 2.5rem;
        background: linear-gradient(to right, var(--color-bg), var(--color-bg-soft));
    }
    .ql-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: var(--color-bg-soft);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        border: 1px solid var(--color-border);
        transition: all 0.3s ease;
    }
    .ql-card:hover .ql-icon-wrapper {
        background: var(--color-text);
        border-color: var(--color-text);
    }
    .ql-featured .ql-icon-wrapper {
        width: 64px;
        height: 64px;
        margin-bottom: 0;
        flex-shrink: 0;
    }
    .ql-icon {
        width: 24px;
        height: 24px;
        color: var(--color-text);
        transition: color 0.3s ease;
    }
    .ql-featured .ql-icon {
        width: 32px;
        height: 32px;
    }
    .ql-card:hover .ql-icon {
        color: var(--color-bg);
    }
    .ql-content {
        flex: 1;
    }
    .ql-card h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--color-text);
        margin: 0 0 0.75rem 0;
        letter-spacing: -0.01em;
    }
    .ql-featured h3 {
        font-size: 1.6rem;
        margin-bottom: 0.5rem;
    }
    .ql-card p {
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin: 0 0 1.5rem 0;
    }
    .ql-featured p {
        font-size: 1.05rem;
        margin-bottom: 1.5rem;
        max-width: 700px;
    }
    .ql-actions {
        display: flex;
        gap: 12px;
    }
    .ql-pill {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-text);
        background: var(--color-bg);
        padding: 6px 16px;
        border-radius: 20px;
        border: 1px solid var(--color-border);
        transition: all 0.2s ease;
    }
    .ql-card:hover .ql-pill {
        border-color: var(--color-text-muted);
    }
    .ql-cta {
        margin-top: auto;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--color-text);
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: gap 0.2s ease;
    }
    .ql-card:hover .ql-cta {
        gap: 8px;
    }
    .ql-arrow {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--color-bg-soft);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-text);
        border: 1px solid var(--color-border);
        transition: all 0.3s ease;
        flex-shrink: 0;
    }
    .ql-arrow svg {
        width: 20px;
        height: 20px;
        transition: transform 0.3s ease;
    }
    .ql-card:hover .ql-arrow {
        background: var(--color-text);
        color: var(--color-bg);
        border-color: var(--color-text);
    }
    .ql-card:hover .ql-arrow svg {
        transform: translateX(4px);
    }

    /* ── CATEGORÍAS (EDITORIAL BLOCK, SIN CARDS) ── */
    .editorial-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 4rem 3rem;
    }
    .editorial-block {
        display: flex;
        flex-direction: column;
    }
    .eb-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.5rem;
    }
    .eb-icon {
        width: 24px;
        height: 24px;
        color: var(--color-text);
        stroke-width: 1.5px;
    }
    .eb-header h3 {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0;
        color: var(--color-text);
        letter-spacing: -0.01em;
    }
    .eb-links {
        list-style: none;
        padding: 0;
        margin: 0 0 1.5rem 0;
        display: flex;
        flex-direction: column;
    }
    .eb-links li {
        border-bottom: 1px solid var(--color-border);
    }
    .eb-links li:last-child {
        border-bottom: none;
    }
    .eb-links li a {
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 0.95rem;
        line-height: 1.4;
        transition: color 0.2s ease, padding-left 0.2s ease;
        display: block;
        padding: 12px 0;
    }
    .eb-links li a:hover {
        color: var(--color-text);
        padding-left: 6px;
    }
    .eb-view-all {
        margin-top: auto;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--color-text);
        text-decoration: none;
        display: inline-block;
        transition: color 0.2s;
    }
    .eb-view-all:hover {
        color: var(--color-blue-deep);
    }

    /* ── FAQ (HAIRLINE STYLE) ── */
    .text-center {
        text-align: center;
    }
    .pr-faq-list {
        display: flex;
        flex-direction: column;
        max-width: 860px;
        margin: 0 auto;
        border-top: 1px solid var(--color-border);
    }
    .pr-faq-item {
        border-bottom: 1px solid var(--color-border);
        overflow: hidden;
    }
    .pr-faq-item summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.5rem 0;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--color-text);
    }
    .pr-faq-item summary::-webkit-details-marker { display: none; }
    .pr-faq-ico {
        flex-shrink: 0;
        color: var(--color-text-muted);
        transition: transform 0.4s var(--ease-spring), color 0.3s;
    }
    .pr-faq-ico svg { width: 20px; height: 20px; }
    .pr-faq-item[open] .pr-faq-ico {
        transform: rotate(135deg);
        color: var(--color-text);
    }
    .pr-faq-body {
        padding: 0 0 1.5rem;
    }
    .pr-faq-body p {
        margin: 0;
        font-size: 1rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        max-width: 700px;
    }

    /* ── PREMIUM CONTACT CTA (HAIRLINE) ── */
    .premium-cta {
        margin-top: 6rem;
        padding: 4rem 0;
        border-top: 1px solid var(--color-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .pcta-content {
        max-width: 500px;
    }
    .pcta-content h2 {
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0 0 16px 0;
        letter-spacing: -0.03em;
        color: var(--color-text);
    }
    .pcta-content p {
        font-size: 1.05rem;
        color: var(--color-text-muted);
        margin: 0;
        line-height: 1.6;
    }
    .pcta-button {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 16px 32px;
        background: var(--color-text);
        color: var(--color-bg);
        font-weight: 600;
        font-size: 1rem;
        border-radius: 12px;
        text-decoration: none;
        transition: transform 0.3s ease;
        white-space: nowrap;
        margin-left: 2rem;
    }
    .pcta-button:hover {
        transform: translateY(-2px);
    }

    @media (max-width: 1024px) {
        .ql-sub-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .ql-featured {
            flex-direction: column;
            align-items: flex-start;
            gap: 1.5rem;
        }
        .ql-featured h3 {
            font-size: 1.5rem;
        }
        .editorial-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .premium-cta {
            flex-direction: column;
            text-align: left;
            align-items: flex-start;
            gap: 2rem;
        }
        .pcta-button {
            margin-left: 0;
        }
    }
    @media (max-width: 768px) {
        .ql-sub-grid {
            grid-template-columns: 1fr;
        }
        .ql-featured .ql-arrow {
            display: none;
        }
        .editorial-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        .pr-h2 {
            font-size: 2rem;
        }
        .ql-actions {
            flex-wrap: wrap;
        }
    }
</style>
