---
// /src/components/support/SupportHero.astro
---

<section class="support-hero">
    <div class="pr-mesh" aria-hidden="true"></div>
    <div class="hero-content">
        <p class="pp-eyebrow reveal">CENTRO DE AYUDA</p>
        <h1 class="pr-h1 masked-title">¿Cómo podemos ayudarte?</h1>
        <div class="search-container reveal">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" id="support-search-input" placeholder="Busca guías, solución de problemas y más..." class="search-input" autocomplete="off" />
            <div id="search-results-dropdown" class="search-dropdown hidden">
                <!-- Resultados de búsqueda inyectados vía JS -->
            </div>
        </div>
        <div class="popular-searches reveal">
            <span class="ps-label">Búsquedas populares:</span>
            <a href="/soporte/emitir-cfdi" class="ps-tag">Emitir CFDI 4.0</a>
            <a href="/soporte/cobro-divisas" class="ps-tag">Pagos internacionales</a>
            <a href="/soporte/cord-elements" class="ps-tag">Cord Elements</a>
            <a href="/soporte/invitar-miembros-roles" class="ps-tag">Invitar equipo</a>
        </div>
    </div>
</section>

<style>
    .support-hero {
        position: relative;
        text-align: center;
        padding: 11.5rem 5% 6rem;
        overflow: clip;
        background: var(--color-bg);
        border-bottom: 1px solid var(--color-border);
    }
    .pr-mesh {
        position: absolute;
        inset: -20% -10% auto;
        height: 100%;
        background:
            radial-gradient(ellipse 50% 60% at 28% 20%, rgba(10,25,47,0.05) 0%, transparent 60%),
            radial-gradient(ellipse 44% 54% at 76% 12%, rgba(10,25,47,0.04) 0%, transparent 60%);
        pointer-events: none;
    }
    .hero-content {
        position: relative;
        z-index: 1;
        max-width: 760px;
        margin: 0 auto;
    }
    .pp-eyebrow {
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #888;
        margin: 0 0 1.4rem;
    }
    .pr-h1 {
        font-size: clamp(2.4rem, 5.4vw, 4.2rem);
        font-weight: 800;
        line-height: 1.04;
        letter-spacing: -0.035em;
        color: var(--color-text);
        margin: 0 0 2.5rem;
    }
    
    .search-container {
        position: relative;
        width: 100%;
        max-width: 640px;
        margin: 0 auto;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
        border-radius: 16px;
        transition: transform 0.4s var(--ease-spring), box-shadow 0.4s var(--ease-spring);
    }
    .search-container:hover, .search-container:focus-within {
        transform: translateY(-4px);
        box-shadow: 0 24px 60px rgba(10, 25, 47, 0.12);
    }
    .search-icon {
        position: absolute;
        left: 24px;
        top: 50%;
        transform: translateY(-50%);
        width: 24px;
        height: 24px;
        color: var(--color-text-muted);
        pointer-events: none;
        transition: color 0.3s ease;
    }
    .search-container:focus-within .search-icon {
        color: var(--color-blue-deep);
    }
    .search-input {
        width: 100%;
        padding: 24px 24px 24px 64px;
        font-size: 1.125rem;
        font-family: var(--font-sans);
        font-weight: 500;
        color: var(--color-text);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        outline: none;
        background: var(--color-surface, #ffffff);
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }
    :global(html[data-theme="dark"]) .search-input {
        background: rgba(10,25,47,0.4);
    }
    .search-input:focus {
        border-color: var(--color-blue-deep);
        box-shadow: 0 0 0 4px rgba(9, 105, 218, 0.1);
    }
    .search-input::placeholder {
        color: var(--color-text-muted);
        opacity: 0.6;
        font-weight: 400;
    }

    @media (max-width: 768px) {
        .support-hero {
            padding-top: 9.5rem;
            padding-bottom: 4rem;
        }
        .search-input {
            font-size: 1rem;
            padding: 20px 20px 20px 56px;
        }
        .search-icon {
            left: 20px;
            width: 20px;
            height: 20px;
        }
    }

    /* ── POPULAR SEARCHES ── */
    .popular-searches {
        margin-top: 1.5rem;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }
    .ps-label {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        font-weight: 500;
        margin-right: 4px;
    }
    .ps-tag {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-blue-deep);
        background: rgba(10, 25, 47, 0.04);
        padding: 6px 14px;
        border-radius: 20px;
        text-decoration: none;
        transition: all 0.3s var(--ease-spring);
        border: 1px solid transparent;
    }
    .ps-tag:hover {
        background: #ffffff;
        color: var(--color-blue-deep);
        border-color: rgba(10, 25, 47, 0.15);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(10, 25, 47, 0.06);
    }

    /* ── SEARCH DROPDOWN STYLES ── */
    .search-dropdown {
        position: absolute;
        top: calc(100% + 12px);
        left: 0;
        right: 0;
        background: var(--color-surface, #ffffff);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
        max-height: 400px;
        overflow-y: auto;
        z-index: 100;
        text-align: left;
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
        transition: all 0.3s var(--ease-spring);
    }
    :global(html[data-theme="dark"]) .search-dropdown {
        background: #0d1117;
    }
    .search-dropdown.hidden {
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        pointer-events: none;
    }
    .search-result-item {
        display: block;
        padding: 16px 24px;
        text-decoration: none;
        color: var(--color-text);
        border-bottom: 1px solid var(--color-border);
        transition: background 0.2s;
    }
    .search-result-item:last-child {
        border-bottom: none;
    }
    .search-result-item:hover, .search-result-item.active {
        background: var(--color-bg-soft);
    }
    .sr-title {
        font-weight: 600;
        font-size: 1.05rem;
        color: var(--color-blue-deep);
        margin-bottom: 4px;
    }
    .sr-title mark {
        background: rgba(9,105,218,0.2);
        color: inherit;
        border-radius: 2px;
    }
    .sr-desc {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .sr-desc mark {
        background: rgba(9,105,218,0.2);
        color: inherit;
        border-radius: 2px;
    }
    .sr-cat {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--color-text-muted);
        margin-bottom: 6px;
        font-weight: 700;
    }
    .sr-header {
        padding: 16px 24px 8px;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-text-muted);
        border-bottom: 1px solid var(--color-border);
    }
    .sr-empty {
        padding: 24px;
        text-align: center;
        color: var(--color-text-muted);
        font-size: 0.95rem;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const input = document.getElementById('support-search-input') as HTMLInputElement;
        const dropdown = document.getElementById('search-results-dropdown');
        if (!input || !dropdown) return;

        let articles: any[] = [];
        let searchTimeout: any;

        function highlightText(text, term) {
            if (!term) return text;
            const regex = new RegExp(`(${term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
            return text.replace(regex, '<mark>$1</mark>');
        }

        function renderArticles(results, term = '', title = '') {
            if (results.length === 0) {
                dropdown.innerHTML = `<div class="sr-empty">No se encontraron artículos para "${term}"</div>`;
                return;
            }

            const headerHtml = title ? `<div class="sr-header">${title}</div>` : '';
            const listHtml = results.map((r: any) => `
                <a href="${r.url}" class="search-result-item">
                    <div class="sr-cat">${r.category}</div>
                    <div class="sr-title">${highlightText(r.title, term)}</div>
                    <div class="sr-desc">${highlightText(r.description, term)}</div>
                </a>
            `).join('');

            dropdown.innerHTML = headerHtml + listHtml;
        }

        // Default suggestions
        const showSuggestions = () => {
            if (articles.length === 0) return;
            // Provide some default suggestions
            const defaultSlugs = ['emitir-cfdi', 'cobro-divisas', 'cord-elements', 'manejo-disputas'];
            const suggestions = articles.filter(a => defaultSlugs.some(slug => a.url.includes(slug)));
            renderArticles(suggestions, '', 'Sugerencias');
            dropdown.classList.remove('hidden');
        };

        // Fetch index on focus
        input.addEventListener('focus', async () => {
            if (articles.length === 0) {
                try {
                    const res = await fetch('/api/support-search.json');
                    articles = await res.json();
                } catch (e) {
                    console.error('Failed to load search index', e);
                }
            }
            if (input.value.trim().length === 0) {
                showSuggestions();
            } else {
                input.dispatchEvent(new Event('input')); // Re-trigger search
            }
        });

        // Filter on input
        input.addEventListener('input', (e) => {
            const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
            clearTimeout(searchTimeout);

            if (query.length === 0) {
                showSuggestions();
                return;
            }

            searchTimeout = setTimeout(() => {
                dropdown.classList.remove('hidden');
                const results = articles.filter(a => 
                    a.title.toLowerCase().includes(query) || 
                    a.description.toLowerCase().includes(query) ||
                    a.category.toLowerCase().includes(query)
                ).slice(0, 6); // Limit to 6 results

                renderArticles(results, query, 'Resultados');
            }, 150); // Debounce
        });

        // Close on click outside
        document.addEventListener('click', (e) => {
            if (!input.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
                dropdown.classList.add('hidden');
            }
        });
    });
</script>
