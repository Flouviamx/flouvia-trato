---
// Sidebar — componente lateral de navegación de la app Cord (estilo Linear).
// Extraído de AppLayout.astro para mantener la separación de responsabilidades.
// Recibe `page` para marcar el ítem activo en la navegación.

import { getSidebarBadges } from '../../lib/queries';
import CustomOrgSwitcher from './CustomOrgSwitcher';

// Contadores en vivo de la sidebar (estilo Linear): seguimiento + cartera vencida.
const badges = await getSidebarBadges();

interface Props {
    page: string;         // id de la página activa en el sidebar
}

const { page } = Astro.props;

// Nav agrupada por secciones (estilo Linear/Notion). `badge` = clave de getSidebarBadges();
// `tone` colorea el contador (neutral / danger). Ajustes vive en el engrane de la topbar.
const NAV_GROUPS = [
    {
        label: 'Principal',
        items: [
            { id: 'dashboard',    href: '/app',              label: 'Dashboard',    icon: 'M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z' },
            { id: 'cotizaciones', href: '/app/cotizaciones', label: 'Cotizaciones', icon: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zM14 3.5L18.5 8H14V3.5z', badge: badges.seguimiento, tone: 'neutral' },
        ],
    },
    {
        label: 'Dinero',
        items: [
            { id: 'cobranza',  href: '/app/cobranza',  label: 'Cobranza',  icon: 'M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z', badge: badges.vencidas, tone: 'danger' },
            { id: 'cfo',       href: '/app/cfo',       label: 'CFO Dashboard', icon: 'M3 3v18h18M7 14l3-3 3 3 5-5' },
            { id: 'analitica', href: '/app/analitica', label: 'Analítica', icon: 'M4 13h3v7H4v-7zm6.5-5h3v12h-3V8zM17 11h3v9h-3v-9z' },
        ],
    },
    {
        label: 'Tesorería IA',
        items: [
            { id: 'flujo-caja', href: '/app/tesoreria/flujo',    label: 'Flujo predictivo', icon: 'M12 3v18M5 10l7-7 7 7M5 14l7 7 7-7' },
            { id: 'ai-ar',      href: '/app/tesoreria/cobranza', label: 'Agentes de cobranza', icon: 'M12 2a5 5 0 0 0-5 5v2a5 5 0 0 0 10 0V7a5 5 0 0 0-5-5zM4 20a8 8 0 0 1 16 0' },
        ],
    },
    {
        label: 'Catálogo',
        items: [
            { id: 'clientes',  href: '/app/clientes',  label: 'Clientes',  icon: 'M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5C15 14.17 10.33 13 8 13zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z' },
            { id: 'productos', href: '/app/productos', label: 'Productos', icon: 'M20 7h-4V5l-2-2h-4L8 5v2H4c-1.1 0-2 .9-2 2v5c0 .75.4 1.38 1 1.73V19c0 1.11.89 2 2 2h14c1.11 0 2-.89 2-2v-3.28c.59-.35 1-.99 1-1.72V9c0-1.1-.9-2-2-2zM10 5h4v2h-4V5z' },
        ],
    },
];
---

<div class="sb-backdrop" id="sbBackdrop" aria-hidden="true"></div>
<!-- ── SIDEBAR ── -->
<aside class="sidebar">
    <!-- Cuenta — arriba -->
    <div class="sb-account">
        <!-- Custom Org Switcher (full custom B2B motor) -->
        <CustomOrgSwitcher client:load />
    </div>

    <!-- Acciones móviles (solo en drawer) — crear / ayuda / config -->
    <div class="sb-mobile-actions">
        <div class="sb-create-wrap">
            <button class="sb-create" id="sbCreate" type="button" aria-haspopup="menu" aria-expanded="false">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                <span>Crear</span>
            </button>
            <div class="sb-create-menu" id="sbCreateMenu" role="menu" hidden>
                <a href="/app/cotizaciones/nueva" class="sb-menu-item" role="menuitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                    Cotización
                </a>
                <a href="/app/clientes?nuevo=1" class="sb-menu-item" role="menuitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                    Cliente
                </a>
                <a href="/app/productos?nuevo=1" class="sb-menu-item" role="menuitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                    Producto
                </a>
            </div>
        </div>
        <button class="sb-action-row" id="sbHelp" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.1 9a2.9 2.9 0 0 1 5.6 1c0 2-2.9 2.9-2.9 2.9"/><line x1="12" y1="17" x2="12" y2="17"/></svg>
            <span>Ayuda</span>
        </button>
        <a href="/app/ajustes" class="sb-action-row">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            <span>Configuración</span>
        </a>
    </div>

    <nav class="sb-nav">
        <div class="sb-indicator" id="sbIndicator" aria-hidden="true"></div>
        <div class="sb-group sb-pins" id="sbPins" hidden></div>
        {NAV_GROUPS.map((group) => (
            <div class="sb-group">
                <span class="sb-group-label">{group.label}</span>
                {group.items.map((item) => (
                    <a href={item.href} class:list={['sb-item', { active: page === item.id }]} title={item.label}>
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={item.icon} /></svg>
                        <span class="sb-item-label">{item.label}</span>
                        {!!(item as any).shortcut && (
                            <kbd class="sb-shortcut">{(item as any).shortcut}</kbd>
                        )}
                        {!!item.badge && item.badge > 0 && (
                            <span class:list={['sb-badge', { danger: item.tone === 'danger' }]}>{item.badge > 99 ? '99+' : item.badge}</span>
                        )}
                    </a>
                ))}
            </div>
        ))}
    </nav>

    <div class="sb-user" style="padding: 1rem; padding-bottom: 0;">
        <!-- Org Switcher and User config are now handled centrally -->
    </div>

    <div class="sb-footer">
        <img class="sb-foot-logo sb-foot-logo-navy" src="/imgs/logo-cord-navy.png" alt="Cord" />
        <img class="sb-foot-logo sb-foot-logo-white" src="/imgs/logo-cord-white.png" alt="Cord" />
        <!-- Toggle estilo panel (Linear/VSCode) — colapsar/expandir -->
        <button class="sb-toggle" id="sbToggleFloating" type="button" aria-label="Alternar menú">
            <svg class="sb-toggle-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4.5" width="18" height="15" rx="2.6"></rect>
                <line class="sb-toggle-div" x1="9.5" y1="4.5" x2="9.5" y2="19.5"></line>
            </svg>
        </button>
    </div>
</aside>

<style>
    /* ── SIDEBAR ── */
    .sidebar {
        width: var(--sidebar-w);
        flex-shrink: 0;
        /* Pill flotante de VIDRIO — espejo de la topbar: blanca en claro, navy en oscuro.
           Todo via variables --sb-* (definidas en :root y reescritas en data-theme="dark"). */
        background: var(--sb-bg);
        backdrop-filter: blur(34px) saturate(1.9) brightness(1.03);
        -webkit-backdrop-filter: blur(34px) saturate(1.9) brightness(1.03);
        border: 1px solid var(--sb-border);
        box-shadow: var(--sb-shadow);
        border-radius: 22px;
        margin: 1rem;
        height: calc(100vh - 2rem);
        /* Fin Estilo Pill */
        display: flex; flex-direction: column;
        padding: 1.2rem 0.7rem 1rem;
        position: sticky; top: 1rem;
        z-index: 130;
        transition: width 0.28s var(--ease-spring), padding 0.28s var(--ease-spring);
    }
    /* Sheen superior (specular highlight tipo liquid glass) — detrás del contenido */
    .sidebar::before {
        content: ''; position: absolute; inset: 0; border-radius: inherit; pointer-events: none; z-index: 0;
        background: var(--sb-sheen);
    }
    .sidebar > * { position: relative; z-index: 1; }

    /* ── Nav agrupada (scroll con fade-out en ambos extremos) ── */
    .sb-nav {
        position: relative;
        display: flex; flex-direction: column; gap: 1rem;
        overflow-y: auto; flex: 1;
        mask-image: linear-gradient(to bottom, transparent 0%, black 18px, black calc(100% - 22px), transparent 100%);
        -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 18px, black calc(100% - 22px), transparent 100%);
        /* Ocultar barra de scroll para evitar que empuje los elementos y rompa el centrado */
        scrollbar-width: none;
    }
    .sb-nav::-webkit-scrollbar { display: none; }
    /* Indicador deslizante (segmented control) — ahora con backdrop-filter vidrio */
    .sb-indicator {
        position: absolute; left: 0; right: 0; top: 0; height: 0;
        border-radius: 12px; opacity: 0; pointer-events: none; z-index: 0;
        background: var(--sb-indicator-bg);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        box-shadow: var(--sb-indicator-shadow);
        transition: top 0.42s var(--ease-spring), height 0.42s var(--ease-spring), opacity 0.3s var(--ease-ios);
        will-change: top, height;
    }
    .sb-group { display: flex; flex-direction: column; gap: 2px; }
    .sb-group-label {
        font-size: 0.58rem; font-weight: 800; letter-spacing: 1.6px; text-transform: uppercase;
        color: var(--sb-label); padding: 4px 11px 6px;
        transition: opacity 0.2s var(--ease-ios), color 0.25s var(--ease-ios);
    }
    @keyframes sb-slide-in {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .sb-item {
        position: relative; z-index: 1;
        display: flex; align-items: center; gap: 11px;
        padding: 8px 11px; border-radius: 12px;
        font-size: 0.86rem; font-weight: 500;
        color: var(--sb-text); text-decoration: none;
        transition: color 0.25s var(--ease-ios), background 0.25s var(--ease-ios), box-shadow 0.25s var(--ease-ios), transform 0.2s var(--ease-ios);
        animation: sb-slide-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) backwards;
    }
    .sb-group:nth-child(1) .sb-item { animation-delay: 0.05s; }
    .sb-group:nth-child(2) .sb-item { animation-delay: 0.1s; }
    .sb-group:nth-child(3) .sb-item { animation-delay: 0.15s; }
    .sb-group:nth-child(4) .sb-item { animation-delay: 0.2s; }
    
    .sb-item svg { width: 16px; height: 16px; opacity: var(--sb-icon-op); flex-shrink: 0; transition: opacity 0.22s var(--ease-ios), transform 0.5s var(--ease-spring); }
    .sb-item:hover svg { opacity: 1; transform: scale(1.12) translateY(-0.5px); }
    .sb-item:active svg { transform: scale(0.9); }
    .sb-item.active svg { opacity: 1; }
    .sb-item-label {
        flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        transition: opacity 0.2s var(--ease-ios);
    }
    /* Hover/active: el color cambia; el realce de "pill" lo da .sb-indicator (vidrio) */
    .sb-item:hover { color: var(--sb-text-strong); }
    .sb-item.active { color: var(--sb-text-active); font-weight: 600; }
    /* Antes de que el indicador de vidrio se posicione (pre-JS): pill sutil en el activo */
    .sb-nav:not(.sb-ind-ready) .sb-item.active { background: var(--sb-active-bg); box-shadow: var(--sb-indicator-shadow); }
    
    /* Drag & Drop Feedback para Fijados */
    .sb-pin-row { position: relative; transition: opacity 0.2s; }
    .sb-pin-row.dragging { opacity: 0.4; }
    .sb-pin-row.drag-over-top::before, .sb-pin-row.drag-over-bottom::after {
        content: ''; position: absolute; left: 0; right: 0; height: 2px;
        background: var(--color-blue-deep, #2563eb); border-radius: 2px; z-index: 10;
        pointer-events: none;
    }
    .sb-pin-row.drag-over-top::before { top: -2px; }
    .sb-pin-row.drag-over-bottom::after { bottom: -2px; }

    .sb-badge {
        flex-shrink: 0; min-width: 18px; height: 18px; padding: 0 5px; border-radius: 100px;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.64rem; font-weight: 700; letter-spacing: -0.01em;
        color: var(--sb-badge-text); background: var(--sb-badge-bg);
    }
    .sb-badge.danger { color: #fff; background: var(--color-danger); }
    .sb-shortcut {
        font-family: var(--font-mono, monospace);
        font-size: 0.65rem; font-weight: 600;
        color: var(--sb-label);
        background: var(--sb-badge-bg);
        padding: 2px 6px;
        border-radius: 5px;
        box-shadow: var(--sb-indicator-shadow);
        transition: opacity 0.2s var(--ease-ios), color 0.2s var(--ease-ios), background 0.2s var(--ease-ios);
    }
    .sb-item:hover .sb-shortcut { color: var(--sb-text-strong); background: var(--sb-hover-bg); }

    /* ── Cuenta — arriba, sin card por defecto ── */
    .sb-account {
        position: relative;
        padding-bottom: 0.5rem;
        margin-bottom: 0.3rem;
    }
    .sb-clerk-orgs { padding: 0.3rem 0.5rem 0; }
    .sb-collapsed .sb-clerk-orgs { display: none; }
    /* Separador con degradado debajo de la cuenta */
    .sb-account::after {
        content: '';
        position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
        background: linear-gradient(to right, transparent, var(--sb-divider) 25%, var(--sb-divider) 75%, transparent);
    }
    .sb-org-switch {
        width: 100%; display: flex; align-items: center; gap: 10px;
        padding: 8px 9px; border-radius: 11px; cursor: pointer;
        background: none; border: none;
        font-family: var(--font-sans); text-align: left;
        transition: background 0.22s var(--ease-ios);
    }
    .sb-org-switch:hover { background: rgba(255,255,255,0.06); }
    .sb-org-switch[aria-expanded="true"] { background: rgba(255,255,255,0.1); }
    .sb-org-avatar {
        width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.22), rgba(255,255,255,0.08)); color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.76rem; font-weight: 800;
    }
    .sb-org-info {
        display: flex; flex-direction: column; min-width: 0; flex: 1;
        transition: opacity 0.2s var(--ease-ios);
    }
    .sb-org-name { font-size: 0.84rem; font-weight: 650; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sb-org-plan { font-size: 0.68rem; color: rgba(255,255,255,0.42); margin-top: 1px; }
    .sb-org-caret {
        width: 15px; height: 15px; flex-shrink: 0; color: rgba(255,255,255,0.45);
        transition: transform 0.25s var(--ease-spring), opacity 0.2s var(--ease-ios);
    }
    .sb-org-switch[aria-expanded="true"] .sb-org-caret { transform: rotate(180deg); }

    /* Dropdown — abre hacia ABAJO (la cuenta está arriba) */
    .sb-org-menu {
        position: absolute; top: calc(100% + 4px); bottom: auto; left: 0; right: 0; z-index: 60;
        background: #11233f; border-radius: 13px; padding: 6px;
        box-shadow: 0 24px 60px -18px rgba(0,0,0,0.7), inset 0 0 0 0.5px rgba(255,255,255,0.1);
        animation: sb-menu-in 0.18s var(--ease-spring);
    }
    .sb-org-menu[hidden] { display: none; }
    @keyframes sb-menu-in { from { opacity: 0; transform: translateY(-6px) scale(0.98); } to { opacity: 1; transform: none; } }
    .sb-org-menu-head { display: flex; align-items: center; gap: 10px; padding: 8px 9px 9px; }
    .sb-org-menu-id { display: flex; flex-direction: column; min-width: 0; }
    .sb-org-menu-id strong { font-size: 0.82rem; font-weight: 650; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sb-org-menu-id span { font-size: 0.66rem; color: rgba(255,255,255,0.42); }
    .sb-menu-sep { height: 1px; background: var(--sb-divider); margin: 5px 4px; }
    .sb-menu-item {
        display: flex; align-items: center; gap: 10px; width: 100%;
        padding: 9px 10px; border-radius: 9px; cursor: pointer;
        background: none; border: none; text-align: left; text-decoration: none;
        font-family: var(--font-sans); font-size: 0.84rem; font-weight: 500;
        color: var(--sb-menu-text); transition: background 0.18s, color 0.18s;
    }
    .sb-menu-item svg { width: 16px; height: 16px; flex-shrink: 0; opacity: 0.8; color: var(--sb-menu-muted); }
    .sb-menu-item:hover { background: var(--sb-menu-hover); color: var(--sb-text-active); }
    .sb-menu-item:hover svg { color: var(--sb-text-active); }
    .sb-menu-danger { color: var(--color-danger); }
    .sb-menu-danger:hover { background: rgba(239,68,68,0.12); color: var(--color-danger); }

    /* ── Acciones móviles del drawer (crear / ayuda / config) — solo móvil ── */
    .sb-mobile-actions { display: none; }
    .sb-create-wrap { position: relative; }
    .sb-create {
        display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%;
        padding: 11px 14px; border: none; border-radius: 11px; cursor: pointer;
        background: #2563eb; color: #fff;
        font-family: var(--font-sans); font-size: 0.9rem; font-weight: 650;
        box-shadow: 0 8px 22px -10px rgba(37,99,235,0.8);
        transition: transform 0.2s var(--ease-spring), background 0.2s;
    }
    .sb-create svg { width: 18px; height: 18px; }
    .sb-create:active { transform: scale(0.98); }
    .sb-create-menu {
        position: absolute; top: calc(100% + 6px); left: 0; right: 0; z-index: 60;
        background: var(--sb-menu-bg);
        backdrop-filter: blur(44px) saturate(1.9);
        -webkit-backdrop-filter: blur(44px) saturate(1.9);
        border: 1px solid var(--sb-menu-border);
        border-radius: 13px; padding: 6px;
        box-shadow: var(--sb-menu-shadow);
        animation: sb-menu-in 0.18s var(--ease-spring);
    }
    .sb-create-menu[hidden] { display: none; }
    .sb-action-row {
        display: flex; align-items: center; gap: 11px; width: 100%;
        padding: 11px 12px; border-radius: 11px; cursor: pointer;
        background: var(--sb-hover-bg); border: none; text-align: left; text-decoration: none;
        font-family: var(--font-sans); font-size: 0.86rem; font-weight: 500;
        color: var(--sb-text-strong); transition: background 0.18s, color 0.18s;
    }
    .sb-action-row svg { width: 17px; height: 17px; flex-shrink: 0; opacity: 0.85; }
    .sb-action-row:hover, .sb-action-row:active { background: var(--sb-active-bg); color: var(--sb-text-active); }

    /* ── Footer (logo + toggle de panel) ── */
    .sb-footer { padding-top: 0.7rem; display: flex; align-items: center; justify-content: flex-start; padding-left: 0.5rem; gap: 0.4rem; }
    .sb-foot-logo { height: 15px; width: auto; opacity: 0.55; transition: opacity 0.2s var(--ease-ios); }
    /* Logo: navy sobre vidrio claro, white sobre vidrio navy (oscuro) */
    .sb-foot-logo-white { display: none; }
    html[data-theme="dark"] .sb-foot-logo-navy { display: none; }
    html[data-theme="dark"] .sb-foot-logo-white { display: inline-block; opacity: 0.5; }

    /* ── Toggle estilo panel (Linear/VSCode), abajo a la derecha junto al logo ── */
    .sb-toggle {
        margin-left: auto; flex-shrink: 0;
        width: 30px; height: 30px; border-radius: 9px;
        display: inline-flex; align-items: center; justify-content: center;
        background: var(--sb-toggle-bg); border: none; cursor: pointer;
        box-shadow: var(--sb-toggle-shadow);
        color: var(--sb-text);
        transition: background 0.22s var(--ease-ios), color 0.22s var(--ease-ios), box-shadow 0.22s var(--ease-ios), transform 0.2s var(--ease-spring);
    }
    .sb-toggle:hover { background: var(--sb-toggle-hover-bg); color: var(--sb-text-strong); }
    .sb-toggle:active { transform: scale(0.9); }
    .sb-toggle:focus-visible { outline: none; box-shadow: 0 0 0 2px var(--sb-text-active); }
    .sb-toggle-ico { width: 17px; height: 17px; transition: transform 0.4s var(--ease-spring); }
    /* La divisoria (el "panel") se desliza sutil al hover = sensación de abrir/cerrar */
    .sb-toggle-div { transition: transform 0.35s var(--ease-spring); transform-origin: center; }
    .sb-toggle:hover .sb-toggle-div { transform: translateX(1.6px); }
    /* Colapsado: el ícono se voltea (el panel mira al otro lado = "expandir") */
    :global(.sb-collapsed) .sb-toggle-ico { transform: scaleX(-1); }
    :global(.sb-collapsed) .sb-toggle { margin-left: 0; }

    @media (min-width: 881px) {
    :global(.sb-collapsed) .sidebar { padding-left: 0; padding-right: 0; align-items: stretch; }
    :global(.sb-collapsed) .sb-nav { gap: 0.9rem; align-items: center; }
    :global(.sb-collapsed) .sb-group { width: 100%; align-items: center; gap: 5px; }
    /* Líneas divisorias de grupos en modo colapsado */
    :global(.sb-collapsed) .sb-group + .sb-group { position: relative; margin-top: 5px; padding-top: 5px; }
    :global(.sb-collapsed) .sb-group + .sb-group::before {
        content: ''; position: absolute; top: 0; left: 20%; right: 20%; height: 1px;
        background: var(--sb-divider); opacity: 0.6;
    }
    /* Fade-out de labels — no display:none para que la transition funcione.
       Los group-labels SÍ colapsan en alto/padding (si no, dejan huecos vacíos). */
    :global(.sb-collapsed) .sb-item-label,
    :global(.sb-collapsed) .sb-shortcut { opacity: 0; pointer-events: none; width: 0; overflow: hidden; }
    :global(.sb-collapsed) .sb-group-label { opacity: 0; height: 0; padding: 0; margin: 0; overflow: hidden; pointer-events: none; }
    :global(.sb-collapsed) .sb-org-info,
    :global(.sb-collapsed) .sb-org-caret { opacity: 0; pointer-events: none; width: 0; overflow: hidden; }
    :global(.sb-collapsed) .sb-foot-logo { opacity: 0; width: 0; overflow: hidden; }
    :global(.sb-collapsed) .sb-collapse { display: none; }
    :global(.sb-collapsed) .sb-account { padding: 0; padding-bottom: 0.4rem; margin-bottom: 0.4rem; }
    :global(.sb-collapsed) .sb-account::after { display: none; }
    :global(.sb-collapsed) .sb-org-switch { justify-content: center; padding: 6px; }
    :global(.sb-collapsed) .sb-org-menu { left: 0; right: auto; width: 210px; top: calc(100% + 4px); bottom: auto; }
    /* Ítems = cuadros uniformes grandes, perfectamente centrados en el rail */
    :global(.sb-collapsed) .sb-item { justify-content: center; gap: 0; padding: 0; width: 36px; height: 36px; border-radius: 10px; }
    :global(.sb-collapsed) .sb-item svg { width: 20px; height: 20px; opacity: 0.85; }
    :global(.sb-collapsed) .sb-item.active svg { opacity: 1; }
    /* Indicador de vidrio → cuadrado centrado detrás del ícono activo */
    :global(.sb-collapsed) .sb-indicator { left: 50%; right: auto; width: 36px; margin-left: -18px; border-radius: 10px; }
    /* Línea vertical izquierda de activo (Notion-style) */
    :global(.sb-collapsed) .sb-item.active::before {
        content: ''; position: absolute; left: 0; top: 25%; bottom: 25%; width: 3px;
        background: var(--color-blue-deep); border-radius: 0 3px 3px 0;
        box-shadow: 1px 0 8px rgba(59,130,246,0.4);
    }
    :global(.sb-collapsed) .sb-pin-row { justify-content: center; }
    :global(.sb-collapsed) .sb-pin-row .sb-item { width: 36px; height: 36px; border-radius: 10px; }
    /* Badge → punto cuando está colapsado (con resplandor) */
    :global(.sb-collapsed) .sb-badge {
        position: absolute; top: 6px; right: 8px; min-width: 0; width: 8px; height: 8px;
        padding: 0; font-size: 0; border: 1.5px solid var(--surface);
    }
    :global(.sb-collapsed) .sb-badge.danger { box-shadow: 0 0 6px var(--color-danger); }
    :global(.sb-collapsed) .sb-expand { display: inline-flex; }
    :global(.sb-collapsed) .sb-footer { justify-content: center; padding-left: 0; }
    /* Tooltip Premium al hover en modo colapsado */
    :global(.sb-collapsed) .sb-item::after {
        content: attr(title); position: absolute; left: calc(100% + 14px); top: 50%; 
        transform: translate(-12px, -50%) scale(0.96);
        background: rgba(17, 35, 63, 0.85);
        backdrop-filter: blur(12px) saturate(1.5);
        -webkit-backdrop-filter: blur(12px) saturate(1.5);
        color: #fff; font-size: 0.78rem; font-weight: 650; white-space: nowrap;
        padding: 7px 12px; border-radius: 10px; pointer-events: none; opacity: 0; z-index: 70;
        box-shadow: 0 12px 34px -8px rgba(0,0,0,0.6), inset 0 0 0 0.5px rgba(255,255,255,0.15);
        transition: opacity 0.15s var(--ease-ios), transform 0.15s var(--ease-ios);
    }
    :global(.sb-collapsed) .sb-item:hover::after { 
        opacity: 1; 
        transform: translate(0, -50%) scale(1); 
        transition: opacity 0.2s var(--ease-ios) 0.15s, transform 0.4s var(--ease-spring) 0.15s; 
    }
    }

    /* Hamburguesa + backdrop del drawer (solo móvil) */
    .sb-backdrop { display: none; }

    /* ── MOBILE ── */
    @media (max-width: 880px) {
        /* Sidebar como drawer desplegable (se abre con la hamburguesa) */
        .sidebar {
            position: fixed; top: 0; left: 0; height: 100dvh; width: min(284px, 86vw); z-index: 300;
            transform: translateX(-100%); transition: transform 0.34s var(--ease-spring);
            box-shadow: 0 0 60px rgba(0,0,0,0.4);
        }
        .app-shell.nav-open .sidebar { transform: translateX(0); }
        .sb-backdrop {
            display: block; position: fixed; inset: 0; z-index: 290;
            background: rgba(10,25,47,0.45); backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px);
            opacity: 0; visibility: hidden; transition: opacity 0.3s var(--ease-ios), visibility 0s 0.3s;
        }
        .app-shell.nav-open .sb-backdrop { opacity: 1; visibility: visible; transition: opacity 0.3s var(--ease-ios); }
        /* En el drawer móvil no aplica colapsar (es ancho fijo) */
        .sb-collapse { display: none; }
        /* Acciones del drawer (crear / ayuda / config) — visibles solo en móvil */
        .sb-mobile-actions { display: flex; flex-direction: column; gap: 8px; margin-bottom: 1rem; }
    }
</style>

<script>
    // ── Drawer de la sidebar (móvil) ──
    function initDrawer() {
        const shell = document.querySelector('.app-shell');
        const burger = document.getElementById('navBurger');
        const backdrop = document.getElementById('sbBackdrop');
        if (!shell || !burger) return;
        const close = () => { shell.classList.remove('nav-open'); document.body.style.overflow = ''; };
        burger.addEventListener('click', () => {
            const open = shell.classList.toggle('nav-open');
            document.body.style.overflow = open ? 'hidden' : '';
        });
        backdrop?.addEventListener('click', close);
        shell.querySelectorAll('.sidebar a').forEach((a) => a.addEventListener('click', close));
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    }

    // ── Colapsar sidebar ──
    function initSidebar() {
        const root = document.documentElement;
        // Colapsar / expandir (persistente).
        const setCollapsed = (v: boolean) => {
            root.classList.toggle('sb-collapsed', v);
            try { localStorage.setItem('cord.sb.collapsed', v ? '1' : '0'); } catch (e) {}
        };
        document.getElementById('sbToggleFloating')?.addEventListener('click', (e) => {
            e.stopPropagation();
            setCollapsed(!root.classList.contains('sb-collapsed'));
        });
    }

    // ── Indicador deslizante del sidebar (segmented control tipo iOS) ──
    function initSidebarIndicator() {
        const nav = document.querySelector('.sb-nav');
        const ind = document.getElementById('sbIndicator');
        if (!nav || !ind) return;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const el = ind as HTMLElement;
        const activeItem = () => nav.querySelector('.sb-item.active') as HTMLElement | null;
        const moveTo = (it: HTMLElement | null, animate = true) => {
            if (!it) { el.style.opacity = '0'; return; }
            if (!animate || reduce) el.style.transition = 'none';
            el.style.top = it.offsetTop + 'px';
            el.style.height = it.offsetHeight + 'px';
            el.style.opacity = '1';
            if (!animate || reduce) { void el.offsetHeight; el.style.transition = ''; }
        };
        const settle = () => moveTo(activeItem(), false);
        // Delegación: cubre también los "Fijados" inyectados después.
        nav.addEventListener('mouseover', (e) => {
            const it = (e.target as HTMLElement).closest('.sb-item') as HTMLElement | null;
            if (it && nav.contains(it)) moveTo(it);
        });
        nav.addEventListener('mouseleave', () => moveTo(activeItem()));
        window.addEventListener('resize', settle);
        document.getElementById('sbToggleFloating')?.addEventListener('click', () => setTimeout(settle, 320));
        // Posición inicial (tras pins + fuentes).
        settle();
        nav.classList.add('sb-ind-ready');
        requestAnimationFrame(settle);
        setTimeout(settle, 120);
    }

    // ── "Fijados" en el sidebar (localStorage) + botón de fijar en el page-head ──
    function initPins() {
        const PIN_KEY = 'cord.pins.v1';
        const PIN_ICON = '<path d="M12 17v5"/><path d="M5 17h14l-1.5-4.5a2 2 0 0 1-.1-.6V6a2 2 0 0 1 2-2H6a2 2 0 0 1 2 2v5.9a2 2 0 0 1-.1.6L5 17z"/>';
        const mount = document.getElementById('sbPins');
        const pinBtn = document.getElementById('phPin');
        const eA = (s: string) => String(s).replace(/"/g, '&quot;');
        const eH = (s: string) => String(s).replace(/</g, '&lt;');
        const getPins = (): any[] => { try { return JSON.parse(localStorage.getItem(PIN_KEY) || '[]'); } catch { return []; } };
        const setPins = (p: any[]) => { try { localStorage.setItem(PIN_KEY, JSON.stringify(p)); } catch (e) {} };
        const current = () => ({ href: location.pathname, label: (document.querySelector('.ph-title')?.textContent || document.title).trim() });
        const isPinned = () => getPins().some((p) => p.href === location.pathname);
        const syncBtn = () => { if (pinBtn) { const on = isPinned(); pinBtn.classList.toggle('pinned', on); pinBtn.setAttribute('title', on ? 'Quitar del menú' : 'Fijar en el menú'); } };
        const renderMount = () => {
            if (!mount) return;
            let pins = getPins();
            if (!pins.length) { (mount as HTMLElement).hidden = true; mount.innerHTML = ''; return; }
            (mount as HTMLElement).hidden = false;
            let html = '<span class="sb-group-label">Fijados</span>';
            pins.forEach((p, idx) => {
                const active = p.href === location.pathname ? ' active' : '';
                html += `<div class="sb-pin-row" draggable="true" data-idx="${idx}"><a href="${eA(p.href)}" class="sb-item${active}" title="${eA(p.label)}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">${PIN_ICON}</svg><span class="sb-item-label">${eH(p.label)}</span></a><button class="sb-pin-x" data-href="${eA(p.href)}" aria-label="Quitar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>`;
            });
            mount.innerHTML = html;
            
            // Lógica de eliminación
            mount.querySelectorAll('.sb-pin-x').forEach((b) => b.addEventListener('click', (e) => {
                e.preventDefault(); e.stopPropagation();
                const href = (b as HTMLElement).dataset.href;
                setPins(getPins().filter((x) => x.href !== href)); renderMount(); syncBtn();
            }));

            // Drag & Drop nativo de HTML5
            let dragSrcEl: HTMLElement | null = null;
            mount.querySelectorAll('.sb-pin-row').forEach((row: Element) => {
                const el = row as HTMLElement;
                el.addEventListener('dragstart', (e) => {
                    dragSrcEl = el;
                    e.dataTransfer!.effectAllowed = 'move';
                    el.classList.add('dragging');
                });
                el.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    e.dataTransfer!.dropEffect = 'move';
                    if (dragSrcEl === el) return;
                    const rect = el.getBoundingClientRect();
                    const mid = rect.top + rect.height / 2;
                    el.classList.remove('drag-over-top', 'drag-over-bottom');
                    el.classList.add(e.clientY < mid ? 'drag-over-top' : 'drag-over-bottom');
                });
                el.addEventListener('dragleave', () => {
                    el.classList.remove('drag-over-top', 'drag-over-bottom');
                });
                el.addEventListener('drop', (e) => {
                    e.stopPropagation();
                    el.classList.remove('drag-over-top', 'drag-over-bottom');
                    if (dragSrcEl !== el && dragSrcEl) {
                        const srcIdx = parseInt(dragSrcEl.dataset.idx || '0');
                        const tgtIdx = parseInt(el.dataset.idx || '0');
                        const rect = el.getBoundingClientRect();
                        const isTop = e.clientY < (rect.top + rect.height / 2);
                        
                        let newPins = [...pins];
                        const [movedItem] = newPins.splice(srcIdx, 1);
                        
                        // Ajustar índice de destino para no off-by-one
                        let finalIdx = tgtIdx;
                        if (srcIdx < tgtIdx && isTop) finalIdx--;
                        if (srcIdx > tgtIdx && !isTop) finalIdx++;
                        
                        newPins.splice(finalIdx, 0, movedItem);
                        setPins(newPins);
                        renderMount();
                        syncBtn();
                    }
                });
                el.addEventListener('dragend', () => {
                    el.classList.remove('dragging');
                    mount.querySelectorAll('.sb-pin-row').forEach(r => r.classList.remove('drag-over-top', 'drag-over-bottom'));
                });
            });
        };
        const toggle = () => {
            const c = current(); const pins = getPins(); const has = pins.some((p) => p.href === c.href);
            if (has) { setPins(pins.filter((p) => p.href !== c.href)); (window as any).cordToast?.('Quitado de fijados'); }
            else { pins.push(c); setPins(pins); (window as any).cordToast?.('Fijado en el menú', 'ok'); }
            renderMount(); syncBtn();
        };
        pinBtn?.addEventListener('click', toggle);
        (window as any).__cordTogglePin = toggle;
        renderMount(); syncBtn();
    }

    // ── Menú "Crear" genérico (botón + popover) — reusado por móvil y desktop ──
    function initCreateMenu(btnId: string, menuId: string) {
        const btn = document.getElementById(btnId);
        const menu = document.getElementById(menuId);
        if (!btn || !menu) return;
        const m = menu as HTMLElement;
        const closeMenu = () => { m.hidden = true; btn.setAttribute('aria-expanded', 'false'); };
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const willOpen = m.hidden;
            m.hidden = !willOpen;
            btn.setAttribute('aria-expanded', String(willOpen));
        });
        document.addEventListener('click', (e) => {
            if (!m.hidden && !menu.contains(e.target as Node) && !btn.contains(e.target as Node)) closeMenu();
        });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
    }

    // ── Acciones móviles del drawer (botón "+" + Ayuda) ──
    function initMobileActions() {
        initCreateMenu('sbCreate', 'sbCreateMenu');   // menú "Crear" del drawer (móvil)
        // Ayuda: cierra el drawer y abre el panel de ayuda (reusa #helpBtn)
        document.getElementById('sbHelp')?.addEventListener('click', () => {
            const shell = document.querySelector('.app-shell');
            shell?.classList.remove('nav-open');
            document.body.style.overflow = '';
            document.getElementById('helpBtn')?.click();
        });
    }

    function initSidebarComponent() {
        initDrawer();
        initSidebar();
        initSidebarIndicator();
        initPins();
        initMobileActions();
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initSidebarComponent);
    else initSidebarComponent();
</script>
