---
// SettingsShell — chasis de las sub-páginas de Ajustes (estilo Stripe).
// Encabezado "Configuración › Categoría" + BARRA DE PESTAÑAS horizontal de la
// categoría (NO rail lateral) + contenido. Si `save`, pinta la barra de guardar
// y corre el guardado genérico que lee los [data-field] → PATCH /api/org.
// Si `perm` está presente, verifica el permiso del usuario y muestra acceso
// denegado inline (sin redirigir) si no lo tiene.
import AppLayout from '../../layouts/AppLayout.astro';
import { categoryOfTab } from '../../lib/settings';
import { getMyMembership } from '../../lib/queries';
import { memberCan, type PermKey } from '../../lib/permissions';

interface Props {
    title: string;       // título del documento
    tab: string;         // id de la pestaña activa (deriva la categoría)
    intro?: string;      // bajada opcional bajo las pestañas
    save?: boolean;      // ¿barra de guardar + guardado genérico?
    perm?: PermKey;      // permiso requerido para ver el contenido
}
const { title, tab, intro, save = false, perm } = Astro.props;
const category = categoryOfTab(tab)!;
const single = category.tabs.length <= 1;

const ME = perm ? await getMyMembership() : null;
const hasAccess = !perm || memberCan(ME!, perm);
---

<AppLayout title={title} page="ajustes" heading="Ajustes">
    <div class="set2">
        <a href="/app/ajustes" class="set2-crumb">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            Configuración
        </a>
        <h2 class="set2-title">{category.label}</h2>
        <p class="set2-desc">{category.desc}</p>

        {!single && (
            <nav class="set2-tabs" aria-label={`Pestañas de ${category.label}`}>
                {category.tabs.map((t) => (
                    <a href={t.href} class:list={['set2-tab', { active: t.id === tab }]}>{t.label}</a>
                ))}
            </nav>
        )}

        <div class="set2-content" data-settings-form>
            {!hasAccess && (
                <div class="access-denied">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <h3>Sin acceso</h3>
                    <p>Tu rol actual no tiene permiso para ver esta sección.<br/>Contacta al administrador de tu organización.</p>
                </div>
            )}
            {hasAccess && intro && <p class="set2-intro">{intro}</p>}
            {hasAccess && <slot />}
            {hasAccess && save && (
                <div class="s-save-row">
                    <button class="s-save" id="sBtn">Guardar cambios</button>
                    <span class="s-saved" id="sMsg">✓ Cambios guardados</span>
                </div>
            )}
        </div>
    </div>
</AppLayout>

<style is:global>
    /* ════════ ESTILOS COMPARTIDOS DE AJUSTES (globales: cruzan el slot) ════════ */
    .set2 { max-width: 760px; }
    .set2-crumb { display: inline-flex; align-items: center; gap: 5px; font-size: 0.78rem; font-weight: 600; color: var(--color-text-muted); text-decoration: none; margin-bottom: 0.7rem; transition: color 0.2s; }
    .set2-crumb svg { width: 14px; height: 14px; }
    .set2-crumb:hover { color: var(--color-blue-deep); }
    .set2-title { font-size: 1.7rem; font-weight: 700; letter-spacing: -0.6px; margin: 0; }
    .set2-desc { font-size: 0.88rem; color: var(--color-text-muted); margin: 0.4rem 0 0; }

    /* Pestañas horizontales con subrayado (estilo Stripe) */
    .set2-tabs { display: flex; gap: 1.4rem; margin: 1.5rem 0 0; border-bottom: 1px solid var(--color-border); overflow-x: auto; }
    .set2-tab { position: relative; font-size: 0.88rem; font-weight: 600; color: var(--color-text-muted); text-decoration: none; padding: 0 0 12px; white-space: nowrap; transition: color 0.2s; }
    .set2-tab::after { content: ''; position: absolute; left: 0; right: 0; bottom: -1px; height: 2px; background: var(--color-blue-deep); border-radius: 2px; transform: scaleX(0); transition: transform 0.25s var(--ease-spring); }
    .set2-tab:hover { color: var(--color-text); }
    .set2-tab.active { color: var(--color-blue-deep); }
    .set2-tab.active::after { transform: scaleX(1); }

    .set2-content { padding-top: 1.8rem; }
    .set2-intro { font-size: 0.86rem; color: var(--color-text-muted); margin: 0 0 1.6rem; line-height: 1.5; max-width: 62ch; }

    /* Bloques y campos (compartidos por todas las sub-páginas) */
    .s-block { margin-bottom: 2.2rem; }
    .s-block > h3 { font-size: 0.7rem; font-weight: 800; letter-spacing: 1.4px; text-transform: uppercase; color: #99a2af; margin: 0 0 1rem; padding-bottom: 0.6rem; border-bottom: 1px solid var(--color-border); }
    .s-body { display: flex; flex-direction: column; gap: 1.1rem; }
    .s-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .s-field { display: flex; flex-direction: column; gap: 0.45rem; }
    .s-field label { font-size: 0.62rem; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; color: #99a2af; }
    .s-input {
        font-family: var(--font-sans); font-size: 0.86rem; font-weight: 500;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px; padding: 10px 12px;
        transition: border-color 0.25s;
    }
    .s-input:focus { outline: none; border-color: var(--color-blue-deep); }
    .s-textarea { resize: vertical; min-height: 70px; line-height: 1.5; }
    .s-hint { font-size: 0.68rem; color: #99a2af; }

    .color-row { display: flex; align-items: center; gap: 9px; }
    .color-row input[type="color"] { width: 40px; height: 40px; padding: 0; border: 1px solid var(--color-border); border-radius: 9px; background: none; cursor: pointer; flex-shrink: 0; }
    .color-row .s-input { flex: 1; }

    /* Toggle */
    .s-toggle { display: flex; align-items: center; gap: 11px; cursor: pointer; user-select: none; }
    .s-toggle input { position: absolute; opacity: 0; pointer-events: none; }
    .s-toggle-track { width: 38px; height: 22px; border-radius: 100px; flex-shrink: 0; background: rgba(10,25,47,0.15); position: relative; transition: background 0.3s var(--ease-ios); }
    .s-toggle-thumb { position: absolute; top: 2px; left: 2px; width: 18px; height: 18px; border-radius: 50%; background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,0.25); transition: transform 0.3s var(--ease-spring); }
    .s-toggle input:checked + .s-toggle-track { background: var(--color-ok); }
    .s-toggle input:checked + .s-toggle-track .s-toggle-thumb { transform: translateX(16px); }
    .s-toggle-text { font-size: 0.82rem; color: var(--color-text); font-weight: 500; }

    /* Barra de guardar */
    .s-save-row { display: flex; align-items: center; gap: 1rem; margin-top: 0.4rem; }
    .s-save {
        font-family: var(--font-sans); font-size: 0.88rem; font-weight: 600;
        background: var(--color-blue-deep); color: #fff; border: none; border-radius: 10px;
        padding: 12px 26px; cursor: pointer; box-shadow: 0 8px 22px -10px rgba(10,25,47,0.5);
        transition: transform 0.4s var(--ease-spring), opacity 0.2s;
    }
    .s-save:hover { transform: translateY(-2px); }
    .s-save:disabled { opacity: 0.6; cursor: wait; transform: none; }
    .s-saved { font-size: 0.8rem; font-weight: 600; color: var(--color-ok); opacity: 0; transition: opacity 0.3s var(--ease-ios); }
    .s-saved.show { opacity: 1; }
    .s-saved.error { color: var(--color-danger); }

    /* Panel de acceso denegado inline */
    .access-denied { display: flex; flex-direction: column; align-items: flex-start; gap: 0.6rem; padding: 2.4rem 0 1rem; }
    .access-denied svg { width: 32px; height: 32px; color: #c9d2de; }
    .access-denied h3 { font-size: 1rem; font-weight: 700; margin: 0; color: var(--color-text); }
    .access-denied p { font-size: 0.84rem; color: var(--color-text-muted); margin: 0; line-height: 1.55; }

    @media (max-width: 600px) {
        .s-row { grid-template-columns: 1fr; }
    }
</style>

<script>
    // Guardado genérico de Ajustes: junta todos los [data-field] del formulario
    // y los manda a PATCH /api/org (que solo toca los campos presentes).
    function initSettingsSave() {
        const btn = document.getElementById('sBtn') as HTMLButtonElement | null;
        const msg = document.getElementById('sMsg');
        const form = document.querySelector('[data-settings-form]');
        if (!btn || !msg || !form) return;

        const cp = document.getElementById('oColorPick') as HTMLInputElement | null;
        const ct = document.getElementById('oColor') as HTMLInputElement | null;
        if (cp && ct) {
            cp.addEventListener('input', () => { ct.value = cp.value; ct.dispatchEvent(new Event('input', { bubbles: true })); });
            ct.addEventListener('input', () => { if (/^#[0-9a-fA-F]{6}$/.test(ct.value)) cp.value = ct.value; });
        }

        btn.addEventListener('click', async () => {
            const body: Record<string, unknown> = {};
            form.querySelectorAll('[data-field]').forEach((node) => {
                const el = node as HTMLInputElement;
                const k = el.dataset.field!;
                if (el.type === 'checkbox') body[k] = el.checked;
                else if (el.type === 'radio') { if (el.checked) body[k] = el.value; }
                else body[k] = el.value;
            });
            btn.disabled = true; msg.className = 's-saved';
            try {
                const res = await fetch('/api/org', { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
                const d = await res.json();
                if (!res.ok) throw new Error(d.error || 'No se pudo guardar');
                msg.textContent = '✓ Cambios guardados'; msg.className = 's-saved show';
                setTimeout(() => msg.classList.remove('show'), 2600);
            } catch (err: any) {
                msg.textContent = err.message || 'No se pudo guardar'; msg.className = 's-saved show error';
            } finally { btn.disabled = false; }
        });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initSettingsSave);
    else initSettingsSave();
</script>
