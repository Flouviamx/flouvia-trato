---
// Página de producto — una por feature (estilo Stripe: hero + mockup que vende,
// stats, bloques de detalle alternados, cross-links y CTA). Mismo lenguaje de
// animación que el index via PageAnims.astro.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import { FEATURES } from '../../lib/producto';

export function getStaticPaths() {
    return FEATURES.map((f) => ({ params: { slug: f.slug }, props: { feature: f } }));
}

const { feature } = Astro.props;
const otros = FEATURES.filter((f) => f.slug !== feature.slug);
const tituloPlano = feature.titulo.replace(/<br\s*\/?>/gi, ' ');

// ── Datos estructurados (JSON-LD) — FAQPage: lo que extraen los AI Overviews.
const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: feature.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};
---

<Layout
    title={feature.metaTitle ?? `${feature.nav} — Cord`}
    description={feature.metaDescription ?? feature.sub}
>
    <script
        slot="head"
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(faqSchema)}
    />
    <Nav />
    <main>
        <!-- ── HERO ── -->
        <section class="pp-hero">
            <div class="pp-hero-mesh" aria-hidden="true"></div>
            <div class="pp-hero-inner">
                <p class="pp-eyebrow reveal">{feature.eyebrow}</p>
                <h1 class="pp-title masked-title" set:html={feature.titulo} />
                <p class="pp-sub reveal">{feature.sub}</p>
                <div class="pp-actions reveal">
                    <a href="/registro" class="pp-btn-primary">
                        <span>Empezar gratis</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                    <a href="/q/demo" class="pp-btn-ghost">Ver una cotización real</a>
                </div>
                <p class="pp-plan reveal">{feature.plan}</p>

                <!-- Mockup específico del feature -->
                <div class="pp-mockup-wrap reveal-mockup">
                    <div class="pp-glow" aria-hidden="true"></div>
                    <div class="pp-mockup">

                        {feature.slug === 'editor' && (
                            <div class="mk-window">
                                <div class="mk-bar">
                                    <span class="mk-dots"><i></i><i></i><i></i></span>
                                    <span class="mk-bar-title">COT-0149 · Distribuidora El Zarco</span>
                                    <span class="mk-badge mk-badge-draft">● Borrador</span>
                                </div>
                                <div class="mk-rows">
                                    <div class="mk-row mk-row-head"><span>Producto</span><span>Cant.</span><span>Precio</span><span>Importe</span></div>
                                    <div class="mk-row"><span>Cemento gris 50kg</span><span>120</span><span class="editorial">$182.00</span><span class="editorial">$21,840.00</span></div>
                                    <div class="mk-row mk-row-edit">
                                        <span>Varilla 3/8" × 12m</span><span>340</span>
                                        <span class="editorial mk-green">$168.50 <i class="mk-chip">−12%</i></span>
                                        <span class="editorial">$57,290.00</span>
                                    </div>
                                    <div class="mk-row"><span>Block hueco 15×20×40</span><span>2,400</span><span class="editorial">$14.20</span><span class="editorial">$34,080.00</span></div>
                                    <div class="mk-row"><span>Malla electrosoldada 6×6</span><span>180</span><span class="editorial">$312.00</span><span class="editorial">$56,160.00</span></div>
                                </div>
                                <div class="mk-totals">
                                    <span>Subtotal <b class="editorial">$169,370.00</b></span>
                                    <span>IVA 16% <b class="editorial">$27,099.20</b></span>
                                    <span class="mk-total-final">Total <b class="editorial">$196,469.20</b></span>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'link-publico' && (
                            <div class="mk-public">
                                <div class="mk-public-head">
                                    <span class="mk-avatar">MV</span>
                                    <div>
                                        <b>Materiales del Valle</b>
                                        <i>te envió una cotización</i>
                                    </div>
                                    <span class="mk-badge mk-badge-sent">● COT-0148</span>
                                </div>
                                <div class="mk-public-total">
                                    <span>Total con IVA</span>
                                    <b class="editorial">$196,469.20</b>
                                    <i>Net 30 · vigente al 24 jun 2026</i>
                                </div>
                                <div class="mk-public-actions">
                                    <span class="mk-approve">Aprobar cotización</span>
                                    <span class="mk-reject">Rechazar</span>
                                </div>
                                <span class="mk-via">vía <b>cord</b></span>
                            </div>
                        )}

                        {feature.slug === 'seguimiento' && (
                            <div class="mk-track">
                                <div class="mk-toast">
                                    <span class="mk-toast-dot"></span>
                                    <span><b>Raúl Mendoza</b> abrió tu cotización · hace 3 min</span>
                                </div>
                                <div class="mk-tl">
                                    <div class="mk-tl-row mk-on"><i class="ok"></i><div><b>Aprobada</b><span>El Zarco aprobó la cotización · hoy, 12:36</span></div></div>
                                    <div class="mk-tl-row mk-on"><i class="warn"></i><div><b>Vista (3 veces)</b><span>Raúl Mendoza abrió el link · hoy, 12:31</span></div></div>
                                    <div class="mk-tl-row"><i></i><div><b>Enviada</b><span>Por correo y WhatsApp · hoy, 11:02</span></div></div>
                                    <div class="mk-tl-row"><i></i><div><b>Creada</b><span>Borrador COT-0148 · hoy, 10:41</span></div></div>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'cfdi' && (
                            <div class="mk-cfdi">
                                <div class="mk-cfdi-head">
                                    <b>Factura CFDI 4.0</b>
                                    <span class="mk-badge mk-badge-ok">● Timbrada</span>
                                </div>
                                <div class="mk-cfdi-rows">
                                    <div><span>UUID</span><b class="editorial">a1b2c3d4-9f01-4e22-b7aa-3c5d8e2f11f9</b></div>
                                    <div><span>Emisor</span><b>Materiales del Valle · MVA240611AB3</b></div>
                                    <div><span>Receptor</span><b>Distribuidora El Zarco · DEZ981123QX1</b></div>
                                    <div><span>Total</span><b class="editorial">$196,469.20 MXN</b></div>
                                </div>
                                <div class="mk-cfdi-stamp">
                                    <span class="mk-check">✓</span>
                                    <span>Timbrada ante el SAT · desde la cotización COT-0148</span>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'clientes-credito' && (
                            <div class="mk-cli">
                                <div class="mk-cli-row">
                                    <span class="mk-avatar">EZ</span>
                                    <div class="mk-cli-info"><b>Distribuidora El Zarco</b><i>Raúl Mendoza · DEZ981123QX1</i></div>
                                    <span class="mk-term">Net 30</span>
                                    <div class="mk-credit"><i style="width: 46%"></i><span class="editorial">$230k / $500k</span></div>
                                </div>
                                <div class="mk-cli-row">
                                    <span class="mk-avatar">CG</span>
                                    <div class="mk-cli-info"><b>Constructora GAMA</b><i>Lucía Ferreira · CGA050617HJ8</i></div>
                                    <span class="mk-term">Net 60</span>
                                    <div class="mk-credit"><i style="width: 72%"></i><span class="editorial">$612k / $850k</span></div>
                                </div>
                                <div class="mk-cli-row">
                                    <span class="mk-avatar">GF</span>
                                    <div class="mk-cli-info"><b>Grupo Ferrex</b><i>Marco Ruiz · GFE120304TR2</i></div>
                                    <span class="mk-term mk-term-cash">Contado</span>
                                    <div class="mk-credit"><i style="width: 0%"></i><span class="editorial">Sin crédito</span></div>
                                </div>
                            </div>
                        )}

                    </div>
                </div>
            </div>
        </section>

        <!-- ── STATS ── -->
        <section class="pp-stats">
            {feature.stats.map((s) => (
                <div class="pp-stat reveal">
                    <span
                        class="pp-stat-num editorial"
                        data-countup={s.countup !== undefined ? String(s.countup) : undefined}
                        data-decimals={s.decimals !== undefined ? String(s.decimals) : undefined}
                        data-prefix={s.prefix}
                        data-suffix={s.suffix}
                    >{s.prefix ?? ''}{s.valor}{s.suffix ?? ''}</span>
                    <span class="pp-stat-label">{s.label}</span>
                </div>
            ))}
        </section>

        <!-- ── BLOQUES DE DETALLE ── -->
        <section class="pp-blocks">
            {feature.blocks.map((b, i) => (
                <article class:list={['pp-block', { 'pp-block-flip': i % 2 === 1 }]}>
                    <div class="pp-block-text">
                        <p class="pp-eyebrow reveal">{b.eyebrow}</p>
                        <h2 class="pp-h2 masked-title" set:html={b.titulo} />
                        <p class="pp-copy reveal">{b.copy}</p>
                        <ul class="pp-bullets">
                            {b.bullets.map((bl) => (
                                <li class="reveal">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    <span>{bl}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="pp-block-visual reveal-mockup">
                        <div class="pp-card-num editorial">/0{i + 1}</div>
                    </div>
                </article>
            ))}
        </section>

        <!-- ── FAQ ── -->
        <section class="pp-faq">
            <div class="pp-faq-head">
                <p class="pp-eyebrow reveal">PREGUNTAS FRECUENTES</p>
                <h2 class="pp-h2 masked-title">Lo que más nos preguntan<br/>sobre {feature.nav.toLowerCase()}.</h2>
            </div>
            <div class="pp-faq-list">
                {feature.faqs.map((f, i) => (
                    <div class="pp-faq-item reveal">
                        <button class="pp-faq-q" aria-expanded="false" aria-controls={`pp-faq-panel-${i}`}>
                            <span>{f.q}</span>
                            <span class="pp-faq-icon" aria-hidden="true"></span>
                        </button>
                        <div class="pp-faq-panel" id={`pp-faq-panel-${i}`} role="region">
                            <p class="pp-faq-a">{f.a}</p>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- ── CROSS-LINKS ── -->
        <section class="pp-more">
            <div class="pp-more-head">
                <p class="pp-eyebrow reveal">MÁS DE CORD</p>
                <h2 class="pp-h2 masked-title">Explora el resto<br/>del producto.</h2>
            </div>
            <div class="pp-more-grid">
                {otros.map((f) => (
                    <a href={`/producto/${f.slug}`} class="pp-more-card reveal">
                        <b>{f.nav}</b>
                        <span>{f.sub.split('.')[0]}.</span>
                        <i class="pp-more-arrow">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </i>
                    </a>
                ))}
            </div>
        </section>
    </main>

    <Footer ctaTitle={feature.cta.titulo.replace(/\. /, '.<br />')} ctaSub={feature.cta.sub} />
    <PageAnims />
</Layout>

<style>
    /* ════════ HERO ════════ */
    .pp-hero {
        position: relative;
        padding: 11.5rem 5% 5rem;
        text-align: center;
        overflow: clip;
        background: var(--color-bg);
    }
    .pp-hero-mesh {
        position: absolute; inset: -20% -10% auto;
        height: 80%;
        background:
            radial-gradient(ellipse 50% 60% at 28% 20%, rgba(10,25,47,0.05) 0%, transparent 60%),
            radial-gradient(ellipse 44% 54% at 76% 12%, rgba(10,25,47,0.04) 0%, transparent 60%);
        pointer-events: none;
    }
    .pp-hero-inner { position: relative; z-index: 1; max-width: 980px; margin: 0 auto; }

    .pp-eyebrow {
        font-size: 0.65rem; font-weight: 800; letter-spacing: 3px;
        text-transform: uppercase; color: #888; margin: 0 0 1.4rem;
    }
    .pp-title {
        font-size: clamp(2.4rem, 5.4vw, 4.4rem);
        font-weight: 800; line-height: 1.04; letter-spacing: -0.035em;
        color: var(--color-text); margin: 0 0 1.6rem;
    }
    .pp-sub {
        font-size: 1.12rem; line-height: 1.65; color: var(--color-text-muted);
        max-width: 640px; margin: 0 auto 2.2rem;
    }
    .pp-actions { display: flex; gap: 0.9rem; justify-content: center; align-items: center; flex-wrap: wrap; }
    .pp-btn-primary {
        display: inline-flex; align-items: center; gap: 10px;
        background: var(--color-blue-deep); color: #fff;
        text-decoration: none; font-size: 0.98rem; font-weight: 600;
        padding: 14px 28px; border-radius: 13px;
        box-shadow: 0 18px 44px -16px rgba(10,25,47,0.55);
        transition: transform 0.5s var(--ease-spring), box-shadow 0.5s var(--ease-spring);
    }
    .pp-btn-primary svg { width: 15px; height: 15px; transition: transform 0.5s var(--ease-spring); }
    .pp-btn-primary:hover { transform: translateY(-3px); box-shadow: 0 26px 56px -16px rgba(10,25,47,0.6); }
    .pp-btn-primary:hover svg { transform: translateX(4px); }
    .pp-btn-ghost {
        color: var(--color-text); text-decoration: none; font-weight: 600; font-size: 0.98rem;
        padding: 14px 10px;
        transition: color 0.3s;
    }
    .pp-btn-ghost:hover { color: var(--color-blue-deep); }
    .pp-plan { font-size: 0.78rem; color: #99a2af; margin: 1.3rem 0 0; font-weight: 600; }

    /* ── Mockup del hero ── */
    .pp-mockup-wrap { position: relative; max-width: 760px; margin: 4.5rem auto 0; }
    .pp-glow {
        position: absolute; inset: 12% -8% -18%;
        background: radial-gradient(ellipse at center, rgba(10,25,47,0.16) 0%, transparent 65%);
        filter: blur(30px);
        pointer-events: none;
    }
    .pp-mockup {
        position: relative;
        background: linear-gradient(165deg, #0e2240 0%, #0a192f 55%, #081424 100%);
        border-radius: 22px;
        padding: 1.6rem;
        text-align: left;
        box-shadow:
            0 50px 100px -36px rgba(5,11,20,0.75),
            inset 0 0 0 0.5px rgba(255,255,255,0.08);
        color: #fff;
    }

    /* badges compartidos */
    .mk-badge {
        font-size: 0.62rem; font-weight: 700; letter-spacing: 0.4px;
        padding: 4px 10px; border-radius: 100px; white-space: nowrap;
    }
    .mk-badge-draft { color: #aab4c4; background: rgba(255,255,255,0.08); }
    .mk-badge-sent  { color: #7eb3ff; background: rgba(59,130,246,0.16); }
    .mk-badge-ok    { color: #4ade80; background: rgba(16,185,129,0.16); }
    .mk-avatar {
        width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
        background: rgba(255,255,255,0.1); color: #fff;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.78rem; font-weight: 800;
    }

    /* editor */
    .mk-bar { display: flex; align-items: center; gap: 12px; padding-bottom: 1rem; }
    .mk-dots { display: inline-flex; gap: 5px; }
    .mk-dots i { width: 9px; height: 9px; border-radius: 50%; background: rgba(255,255,255,0.14); }
    .mk-bar-title { font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.75); flex: 1; }
    .mk-rows { display: flex; flex-direction: column; gap: 4px; }
    .mk-row {
        display: grid; grid-template-columns: 1.6fr 0.5fr 1fr 1fr;
        gap: 8px; align-items: center;
        font-size: 0.78rem; color: rgba(255,255,255,0.82);
        padding: 8px 10px; border-radius: 9px;
        background: rgba(255,255,255,0.03);
    }
    .mk-row span:nth-child(n+2) { text-align: right; }
    .mk-row-head { background: none; font-size: 0.62rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.35); }
    .mk-row-edit { background: rgba(16,185,129,0.1); box-shadow: inset 0 0 0 1px rgba(16,185,129,0.25); }
    .mk-green { color: #4ade80; }
    .mk-chip {
        font-style: normal; font-size: 0.6rem; font-weight: 800;
        color: #052e1f; background: #4ade80;
        padding: 1px 6px; border-radius: 6px; margin-left: 4px;
        vertical-align: 1px;
    }
    .mk-totals {
        display: flex; justify-content: flex-end; gap: 1.6rem; flex-wrap: wrap;
        margin-top: 1rem; padding: 0.9rem 10px 0;
        border-top: 1px solid rgba(255,255,255,0.09);
        font-size: 0.74rem; color: rgba(255,255,255,0.55);
    }
    .mk-totals b { margin-left: 7px; color: #fff; font-weight: 600; }
    .mk-total-final { font-weight: 700; color: rgba(255,255,255,0.85); }
    .mk-total-final b { font-size: 1.05rem; }

    /* link público */
    .mk-public { display: flex; flex-direction: column; gap: 1.1rem; max-width: 430px; margin: 0 auto; padding: 0.5rem 0.3rem; }
    .mk-public-head { display: flex; align-items: center; gap: 12px; }
    .mk-public-head b { display: block; font-size: 0.92rem; }
    .mk-public-head i { display: block; font-style: normal; font-size: 0.74rem; color: rgba(255,255,255,0.5); }
    .mk-public-head .mk-badge { margin-left: auto; }
    .mk-public-total {
        text-align: center; padding: 1.4rem 1rem;
        background: rgba(255,255,255,0.04); border-radius: 16px;
        box-shadow: inset 0 0 0 0.5px rgba(255,255,255,0.07);
    }
    .mk-public-total span { display: block; font-size: 0.68rem; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-bottom: 6px; }
    .mk-public-total b { display: block; font-size: 2rem; font-weight: 600; letter-spacing: -0.03em; }
    .mk-public-total i { display: block; font-style: normal; font-size: 0.74rem; color: rgba(255,255,255,0.45); margin-top: 6px; }
    .mk-public-actions { display: flex; gap: 0.7rem; }
    .mk-approve {
        flex: 1; text-align: center;
        background: #fff; color: var(--color-blue-deep);
        font-size: 0.88rem; font-weight: 700;
        padding: 13px; border-radius: 12px;
    }
    .mk-reject {
        text-align: center; color: rgba(255,255,255,0.6);
        font-size: 0.88rem; font-weight: 600;
        padding: 13px 20px; border-radius: 12px;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.14);
    }
    .mk-via { text-align: center; font-size: 0.68rem; color: rgba(255,255,255,0.35); }
    .mk-via b { color: rgba(255,255,255,0.6); }

    /* seguimiento */
    .mk-track { display: flex; flex-direction: column; gap: 1.2rem; max-width: 520px; margin: 0 auto; padding: 0.4rem 0.2rem; }
    .mk-toast {
        display: flex; align-items: center; gap: 10px;
        background: rgba(255,255,255,0.07); border-radius: 12px;
        padding: 12px 14px; font-size: 0.8rem; color: rgba(255,255,255,0.85);
        box-shadow: inset 0 0 0 0.5px rgba(255,255,255,0.1), 0 14px 30px -14px rgba(0,0,0,0.5);
    }
    .mk-toast-dot {
        width: 9px; height: 9px; border-radius: 50%; background: #4ade80; flex-shrink: 0;
        box-shadow: 0 0 0 4px rgba(74,222,128,0.16);
        animation: mk-pulse 2s infinite;
    }
    @keyframes mk-pulse {
        0% { box-shadow: 0 0 0 0 rgba(74,222,128,0.35); }
        70% { box-shadow: 0 0 0 7px rgba(74,222,128,0); }
        100% { box-shadow: 0 0 0 0 rgba(74,222,128,0); }
    }
    .mk-tl { display: flex; flex-direction: column; gap: 2px; }
    .mk-tl-row {
        display: flex; align-items: center; gap: 12px;
        padding: 10px 12px; border-radius: 10px;
        opacity: 0.55;
    }
    .mk-tl-row.mk-on { opacity: 1; background: rgba(255,255,255,0.04); }
    .mk-tl-row i {
        width: 9px; height: 9px; border-radius: 50%;
        background: rgba(255,255,255,0.25); flex-shrink: 0;
    }
    .mk-tl-row i.ok { background: #4ade80; }
    .mk-tl-row i.warn { background: #fbbf24; }
    .mk-tl-row b { display: block; font-size: 0.82rem; }
    .mk-tl-row span { display: block; font-size: 0.72rem; color: rgba(255,255,255,0.45); }

    /* cfdi */
    .mk-cfdi { display: flex; flex-direction: column; gap: 1rem; max-width: 520px; margin: 0 auto; padding: 0.4rem 0.2rem; }
    .mk-cfdi-head { display: flex; align-items: center; justify-content: space-between; }
    .mk-cfdi-head b { font-size: 0.95rem; }
    .mk-cfdi-rows { display: flex; flex-direction: column; gap: 4px; }
    .mk-cfdi-rows > div {
        display: flex; justify-content: space-between; gap: 1rem; align-items: baseline;
        padding: 9px 12px; border-radius: 9px;
        background: rgba(255,255,255,0.035);
        font-size: 0.76rem;
    }
    .mk-cfdi-rows span { color: rgba(255,255,255,0.45); font-weight: 700; font-size: 0.64rem; letter-spacing: 1px; text-transform: uppercase; }
    .mk-cfdi-rows b { font-weight: 500; color: rgba(255,255,255,0.85); text-align: right; word-break: break-all; }
    .mk-cfdi-stamp {
        display: flex; align-items: center; gap: 10px;
        font-size: 0.78rem; color: rgba(255,255,255,0.7);
        padding-top: 0.4rem;
    }
    .mk-check {
        width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0;
        background: rgba(74,222,128,0.16); color: #4ade80;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.8rem; font-weight: 800;
    }

