        margin: 0; padding: 0 0.2rem;
        font-size: 1rem; line-height: 1.7; color: var(--color-text-muted); max-width: 92%;
        opacity: 0; transform: translateY(-6px);
        transition: opacity 0.45s var(--ease-ios) 0.08s, transform 0.5s var(--ease-spring) 0.08s, padding 0.45s var(--ease-spring);
    }
    .pp-faq-item.open .pp-faq-a { opacity: 1; transform: translateY(0); padding-bottom: 1.6rem; }
    @media (prefers-reduced-motion: reduce) {
        .pp-faq-panel, .pp-faq-a, .pp-faq-icon { transition: none; }
    }

