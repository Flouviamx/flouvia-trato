---
// Página de producto — una por feature (estilo Stripe: hero + mockup que vende,
// stats, bloques de detalle alternados, cross-links y CTA). Mismo lenguaje de
// animación que el index via PageAnims.astro.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import BlockMockup from '../../components/producto/BlockMockup.astro';
import { FEATURES } from '../../lib/producto';
import { FEATURES_EN } from '../../lib/producto.en';
import { getLangFromUrl } from '../../i18n/utils';

export function getStaticPaths() {
    return FEATURES.map((f) => ({ params: { slug: f.slug }, props: { feature: f } }));
}

const lang = getLangFromUrl(Astro.url);
const isEn = Astro.props.isEn || lang === 'en';
const currentFeature = Astro.props.feature || Astro.props.feature;
const feature = isEn && currentFeature ? FEATURES_EN.find((f) => f.slug === currentFeature.slug) || currentFeature : currentFeature;
const otros = (isEn ? FEATURES_EN : FEATURES).filter((f) => f.slug !== feature.slug);
const tituloPlano = feature.titulo.replace(/<br\s*\/?>/gi, ' ');

// ── Datos estructurados (JSON-LD) — FAQPage: lo que extraen los AI Overviews.
const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: feature.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};
---

<Layout
    title={feature.metaTitle ?? `${feature.nav} — Cord`}
    description={feature.metaDescription ?? feature.sub}
>
    <script
        slot="head"
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(faqSchema)}
    />
    <Nav />
    <main>
        <!-- ── HERO ── -->
        <section class="pp-hero">
            <div class="pp-hero-mesh" aria-hidden="true"></div>
            <div class="pp-hero-inner">
                <p class="pp-eyebrow reveal">{feature.eyebrow}</p>
                <h1 class="pp-title masked-title" set:html={feature.titulo} />
                <p class="pp-sub reveal">{feature.sub}</p>
                <div class="pp-actions reveal">
                    <a href="/registro" class="pp-btn-primary">
                        <span>{isEn ? 'Start for free' : 'Empezar gratis'}</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                    <a href="/q/demo" class="pp-btn-ghost">{isEn ? 'See a real quote' : 'Ver una cotización real'}</a>
                </div>
                <p class="pp-plan reveal">{feature.plan}</p>

                <!-- Mockup específico del feature -->
                <div class="pp-mockup-wrap reveal-mockup">
                    <div class="pp-mesh-bg" aria-hidden="true"></div>
                    <div class="pp-glow" aria-hidden="true"></div>

                    <div class="pp-mockup">

                        {feature.slug === 'editor' && (
                            <div class="mk-window">
                                <div class="mk-bar">
                                    <span class="mk-dots"><i></i><i></i><i></i></span>
                                    <span class="mk-bar-title">COT-0149 · {isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'}</span>
                                    <div class="mk-bar-actions">
                                        <span class="mk-avatar-sm">RM</span>
                                        <span class="mk-badge mk-badge-draft">● {isEn ? 'Draft' : 'Borrador'}</span>
                                    </div>
                                </div>
                                <div class="mk-body">
                                    <div class="mk-sidebar">
                                        <div class="mk-sb-item mk-sb-active"><i>📄</i> {isEn ? 'Current quote' : 'Cotización actual'}</div>
                                        <div class="mk-sb-item"><i>👤</i> {isEn ? 'Client details' : 'Datos del cliente'}</div>
                                        <div class="mk-sb-item"><i>⚙️</i> {isEn ? 'Settings' : 'Configuración'}</div>
                                    </div>
                                    <div class="mk-content">
                                        <div class="mk-rows">
                                            <div class="mk-row mk-row-head"><span>{isEn ? 'Product' : 'Producto'}</span><span>{isEn ? 'Qty' : 'Cant.'}</span><span>{isEn ? 'Price' : 'Precio'}</span><span>{isEn ? 'Amount' : 'Importe'}</span></div>
                                            <div class="mk-row"><span>{isEn ? 'Grey cement 50kg' : 'Cemento gris 50kg'}</span><span>120</span><span class="editorial">$182.00</span><span class="editorial">$21,840.00</span></div>
                                            <div class="mk-row mk-row-edit" id="editorTargetRow">
                                                <span>{isEn ? 'Rebar 3/8" × 12m' : 'Varilla 3/8" × 12m'}</span><span>340</span>
                                                <span class="editorial mk-green" id="editorPrice">$191.48 <i class="mk-chip" id="editorChip">−12%</i></span>
                                                <span class="editorial" id="editorImport">$65,103.20</span>
                                            </div>
                                            <div class="mk-row"><span>{isEn ? 'Hollow block 15×20×40' : 'Block hueco 15×20×40'}</span><span>2,400</span><span class="editorial">$14.20</span><span class="editorial">$34,080.00</span></div>
                                            <div class="mk-row"><span>{isEn ? 'Welded wire mesh 6×6' : 'Malla electrosoldada 6×6'}</span><span>180</span><span class="editorial">$312.00</span><span class="editorial">$56,160.00</span></div>
                                        </div>
                                        <div class="mk-totals">
                                            <div class="mk-tot-col"><span>{isEn ? 'Subtotal' : 'Subtotal'}</span><b class="editorial">$169,370.00</b></div>
                                            <div class="mk-tot-col"><span>{isEn ? 'Tax (16%)' : 'IVA 16%'}</span><b class="editorial">$27,099.20</b></div>
                                            <div class="mk-tot-col mk-tot-final"><span>{isEn ? 'Total' : 'Total'}</span><b class="editorial" id="editorTotal">$196,469.20</b></div>
                                        </div>
                                    </div>
                                </div>
                                <!-- Cursor GSAP -->
                                <div class="mk-cursor" id="editorCursor">
                                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 2l12 11.2-5.8.5 3.3 7.3-2.25 1-3.2-7.4-4.4 4.7z"/></svg>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'link-publico' && (
                            <div class="mk-public" id="publicWrap">
                                <div class="mk-public-card" id="publicCard">
                                    <div class="mk-public-head">
                                        <span class="mk-avatar">MV</span>
                                        <div>
                                            <b>{isEn ? 'Valle Materials' : 'Materiales del Valle'}</b>
                                            <i>{isEn ? 'sent you a quote' : 'te envió una cotización'}</i>
                                        </div>
                                        <span class="mk-badge mk-badge-sent">● COT-0148</span>
                                    </div>
                                    <div class="mk-public-total">
                                        <span>{isEn ? 'Total with tax' : 'Total con IVA'}</span>
                                        <b class="editorial">$196,469.20</b>
                                        <i>Net 30 · {isEn ? 'valid until Jun 24, 2026' : 'vigente al 24 jun 2026'}</i>
                                    </div>
                                    <div class="mk-public-actions">
                                        <div class="mk-btn-wrap" id="publicApproveBtn">
                                            <div class="mk-btn-glow" id="publicGlow"></div>
                                            <span class="mk-approve">{isEn ? 'Approve quote' : 'Aprobar cotización'}</span>
                                        </div>
                                        <span class="mk-reject">{isEn ? 'Reject' : 'Rechazar'}</span>
                                    </div>
                                    <span class="mk-via">vía <b>cord</b></span>
                                </div>
                                <div class="mk-success-overlay" id="publicSuccess">
                                    <div class="mk-success-ring"></div>
                                    <i class="mk-success-check">✓</i>
                                    <b>¡{isEn ? 'Successfully approved!' : 'Aprobada exitosamente!'}</b>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'seguimiento' && (
                            <div class="mk-track">
                                <div class="mk-track-head">
                                    <div class="mk-toast" id="trackToast">
                                        <span class="mk-toast-dot"></span>
                                        <div class="mk-toast-content">
                                            <b>Raúl Mendoza</b> {isEn ? 'opened your quote' : 'abrió tu cotización'}
                                            <i>hace 3 min</i>
                                        </div>
                                    </div>
                                </div>
                                <div class="mk-tl">
                                    <div class="mk-tl-row mk-on track-item"><i class="ok">✓</i><div class="mk-tl-info"><b>{isEn ? 'Approved' : 'Aprobada'}</b><span>El Zarco aprobó la cotización · hoy, 12:36</span></div><span class="mk-avatar-sm">EZ</span></div>
                                    <div class="mk-tl-row mk-on track-item"><i class="warn">👁</i><div class="mk-tl-info"><b>Vista (3 veces)</b><span>Raúl Mendoza abrió el link · hoy, 12:31</span></div><span class="mk-avatar-sm">RM</span></div>
                                    <div class="mk-tl-row track-item"><i>✉️</i><div class="mk-tl-info"><b>Enviada</b><span>Por correo y WhatsApp · hoy, 11:02</span></div></div>
                                    <div class="mk-tl-row track-item"><i>📄</i><div class="mk-tl-info"><b>Creada</b><span>{isEn ? 'Draft' : 'Borrador'} COT-0148 · hoy, 10:41</span></div></div>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'cfdi' && (
                            <div class="mk-cfdi">
                                <div class="mk-cfdi-bg-code">
                                    &lt;cfdi:Comprobante Version="4.0" Serie="A" Folio="1048" Fecha="2026-06-24T12:00:00"&gt;<br/>
                                    &nbsp;&nbsp;&lt;cfdi:Emisor Rfc="MVA240611AB3" Nombre="{isEn ? 'Valle Materials' : 'Materiales del Valle'}" RegimenFiscal="601"/&gt;<br/>
                                    &nbsp;&nbsp;&lt;cfdi:Receptor Rfc="DEZ981123QX1" Nombre="{isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'}" UsoCFDI="G03"/&gt;<br/>
                                    &nbsp;&nbsp;&lt;cfdi:Conceptos&gt;<br/>
                                    &nbsp;&nbsp;&nbsp;&nbsp;&lt;cfdi:Concepto ClaveProdServ="30111500" Cantidad="120" ClaveUnidad="H87" Descripcion="{isEn ? 'Grey cement 50kg' : 'Cemento gris 50kg'}"/&gt;<br/>
                                    &nbsp;&nbsp;&lt;/cfdi:Conceptos&gt;<br/>
                                    &lt;/cfdi:Comprobante&gt;
                                </div>
                                <div class="mk-cfdi-front">
                                    <div class="mk-cfdi-head">
                                        <b>Factura CFDI 4.0</b>
                                        <span class="mk-badge mk-badge-ok">● Timbrada</span>
                                    </div>
                                    <div class="mk-cfdi-rows">
                                        <div><span>UUID</span><b class="editorial">a1b2c3d4-9f01-4e22-b7aa-3c5d8e2f11f9</b></div>
                                        <div><span>Emisor</span><b>{isEn ? 'Valle Materials' : 'Materiales del Valle'} · MVA240611AB3</b></div>
                                        <div><span>Receptor</span><b>{isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'} · DEZ981123QX1</b></div>
                                        <div><span>{isEn ? 'Total' : 'Total'}</span><b class="editorial">$196,469.20 MXN</b></div>
                                    </div>
                                    <div class="mk-cfdi-stamp" id="cfdiStamp">
                                        <div class="mk-stamp-ring"></div>
                                        <span class="mk-check">✓</span>
                                        <span>Timbrada ante el SAT · desde COT-0148</span>
                                    </div>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'clientes-credito' && (
                            <div class="mk-cli">
                                <div class="mk-cli-row cli-item">
                                    <span class="mk-avatar mk-avatar-ez">EZ</span>
                                    <div class="mk-cli-info"><b>{isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'}</b><i>Raúl Mendoza · DEZ981123QX1</i></div>
                                    <div class="mk-term-wrap"><span class="mk-term">Net 30</span></div>
                                    <div class="mk-credit">
                                        <div class="mk-credit-bar"><i style="width: 85%" class="warn-bar"></i></div>
                                        <span class="editorial">$425k / $500k</span>
                                    </div>
                                </div>
                                <div class="mk-cli-row cli-item">
                                    <span class="mk-avatar mk-avatar-cg">CG</span>
                                    <div class="mk-cli-info"><b>Constructora GAMA</b><i>Lucía Ferreira · CGA050617HJ8</i></div>
                                    <div class="mk-term-wrap"><span class="mk-term">Net 60</span></div>
                                    <div class="mk-credit">
                                        <div class="mk-credit-bar"><i style="width: 72%"></i></div>
                                        <span class="editorial">$612k / $850k</span>
                                    </div>
                                </div>
                                <div class="mk-cli-row cli-item">
                                    <span class="mk-avatar mk-avatar-gf">GF</span>
                                    <div class="mk-cli-info"><b>Grupo Ferrex</b><i>Marco Ruiz · GFE120304TR2</i></div>
                                    <div class="mk-term-wrap"><span class="mk-term mk-term-cash">Contado</span></div>
                                    <div class="mk-credit">
                                        <div class="mk-credit-bar"><i></i></div>
                                        <span class="editorial">Sin crédito</span>
                                    </div>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'cobranza-ia' && (
                            <div class="mk-ar">
                                <div class="mk-ar-head">
                                    <span class="mk-avatar mk-avatar-ez">EZ</span>
                                    <div>
                                        <b>{isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'}</b>
                                        <i>COT-0131 · $412,300 por cobrar</i>
                                    </div>
                                    <span class="mk-badge mk-ar-overdue">● 47 días vencido</span>
                                </div>
                                <div class="mk-ar-thread" id="arThread">
                                    <div class="mk-ar-bubble mk-ar-ai">
                                        <span class="mk-ar-tag">Agente Cord</span>
                                        Hola Raúl, tu saldo de $412,300 venció hace 47 días. ¿Te ayudo a liquidarlo en 3 pagos mensuales sin recargos?
                                    </div>
                                    <div class="mk-ar-bubble mk-ar-client">Sí, me funciona en 3 partes.</div>
                                    <div class="mk-ar-bubble mk-ar-ai">
                                        <span class="mk-ar-tag">Agente Cord</span>
                                        Perfecto. Plan propuesto — esperando tu visto bueno:
                                    </div>
                                </div>
                                <div class="mk-ar-plan" id="arPlan">
                                    <div class="mk-ar-cuota"><span>Cuota 1 · 15 jul</span><b class="editorial">$137,433</b></div>
                                    <div class="mk-ar-cuota"><span>Cuota 2 · 15 ago</span><b class="editorial">$137,433</b></div>
                                    <div class="mk-ar-cuota"><span>Cuota 3 · 15 sep</span><b class="editorial">$137,434</b></div>
                                    <div class="mk-ar-approve">Aprobar plan de pagos</div>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'divisas' && (
                            <div class="mk-window mk-fx" id="fxHero">
                                <div class="mk-bar">
                                    <span class="mk-dots"><i></i><i></i><i></i></span>
                                    <span class="mk-bar-title">COT-0150 · Acme Imports</span>
                                    <span class="mk-badge mk-badge-sent">● USD</span>
                                </div>
                                <div class="mk-fx-body">
                                    <div class="mk-fx-controls">
                                        <div class="mk-fx-field">
                                            <label>Moneda de presentación</label>
                                            <div class="mk-fx-seg"><span class="on">USD</span><span>EUR</span><span>MXN</span></div>
                                        </div>
                                        <div class="mk-fx-field">
                                            <label>Cobertura (buffer)</label>
                                            <div class="mk-fx-buffer">2.0%</div>
                                        </div>
                                    </div>
                                    <div class="mk-fx-rate">
                                        <span class="mk-fx-rate-line">1 USD = <b class="editorial" id="fxRate">$18.50 MXN</b></span>
                                        <span class="mk-fx-lock" id="fxLock">🔒 lock 30 días</span>
                                    </div>
                                    <div class="mk-fx-totals">
                                        <div class="mk-fx-total"><span>El cliente ve</span><b class="editorial">USD 10,620.50</b></div>
                                        <div class="mk-fx-total mk-fx-total-mxn" id="fxMxn"><span>Se factura</span><b class="editorial">$196,469.20 MXN</b></div>
                                    </div>
                                </div>
                            </div>
                        )}

                        {feature.slug === 'internacional' && (
                            <div class="mk-window mk-intl" id="intlHero">
                                <div class="mk-bar">
                                    <span class="mk-dots"><i></i><i></i><i></i></span>
                                    <span class="mk-bar-title">COT-0151 · Pacific Hardware (US)</span>
                                    <span class="mk-badge mk-badge-sent">● USD → MXN</span>
                                </div>
                                <div class="mk-intl-pill" id="intlPill">🔒 Tasa blindada</div>
                                <div class="mk-intl-body">
                                    <div class="mk-rows mk-rows-intl">
                                        <div class="mk-row mk-row-head"><span>{isEn ? 'Product' : 'Producto'}</span><span>{isEn ? 'Qty' : 'Cant.'}</span><span>{isEn ? 'Price' : 'Precio'} USD</span><span>{isEn ? 'Amount' : 'Importe'}</span></div>
                                        <div class="mk-row"><span>Válvula industrial 4"</span><span>40</span><span class="editorial">$182.00</span><span class="editorial">$7,280.00</span></div>
                                        <div class="mk-row"><span>Acople bridado 6"</span><span>25</span><span class="editorial">$208.02</span><span class="editorial">$5,200.50</span></div>
                                    </div>
                                    <div class="mk-intl-totals">
                                        <div class="mk-intl-tot"><span>{isEn ? 'Total' : 'Total'} (USD) · presentación</span><b class="editorial">USD 12,480.00</b></div>
                                        <div class="mk-intl-tot mk-intl-tot-fiscal" id="intlFiscal"><span>{isEn ? 'Total' : 'Total'} fiscal (MXN) · se factura</span><b class="editorial">$230,880.00</b></div>
                                        <span class="mk-intl-rate">Tasa 18.50 · congelada 30 días</span>
                                    </div>
                                </div>
                            </div>
                        )}

                    </div>
                </div>
            </div>
        </section>

        <!-- ── STATS ── -->
        <section class="pp-stats">
            {feature.stats.map((s) => (
                <div class="pp-stat reveal">
                    <span
                        class="pp-stat-num editorial"
                        data-countup={s.countup !== undefined ? String(s.countup) : undefined}
                        data-decimals={s.decimals !== undefined ? String(s.decimals) : undefined}
                        data-prefix={s.prefix}
                        data-suffix={s.suffix}
                    >{s.prefix ?? ''}{s.valor}{s.suffix ?? ''}</span>
                    <span class="pp-stat-label">{s.label}</span>
                </div>
            ))}
        </section>

        <!-- ── BLOQUES DE DETALLE ── -->
        <section class="pp-blocks">
            {feature.blocks.map((b, i) => (
                <article class:list={['pp-block', { 'pp-block-flip': i % 2 === 1 }]}>
                    <div class="pp-block-text">
                        <p class="pp-eyebrow reveal">{b.eyebrow}</p>
                        <h2 class="pp-h2 masked-title" set:html={b.titulo} />
                        <p class="pp-copy reveal">{b.copy}</p>
                        <ul class="pp-bullets">
                            {b.bullets.map((bl) => (
                                <li class="reveal">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    <span>{bl}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="pp-block-visual" style="align-items: center; justify-content: center; padding: 0;">
                        <BlockMockup slug={feature.slug} index={i} />
                    </div>
                </article>
            ))}
        </section>

        <!-- ── FAQ ── -->
        <section class="pp-faq">
            <div class="pp-faq-head">
                <p class="pp-eyebrow reveal">PREGUNTAS FRECUENTES</p>
                <h2 class="pp-h2 masked-title">{isEn ? 'Most common questions<br/>about' : 'Lo que más nos preguntan<br/>sobre'} {feature.nav.toLowerCase()}.</h2>
            </div>
            <div class="pp-faq-list">
                {feature.faqs.map((f, i) => (
                    <div class="pp-faq-item reveal">
                        <button class="pp-faq-q" aria-expanded="false" aria-controls={`pp-faq-panel-${i}`}>
                            <span>{f.q}</span>
                            <span class="pp-faq-icon" aria-hidden="true"></span>
                        </button>
                        <div class="pp-faq-panel" id={`pp-faq-panel-${i}`} role="region">
                            <p class="pp-faq-a">{f.a}</p>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- ── CROSS-LINKS ── -->
        <section class="pp-more">
            <div class="pp-more-head">
                <p class="pp-eyebrow reveal">MÁS DE CORD</p>
                <h2 class="pp-h2 masked-title">{isEn ? 'Explore the rest<br/>of the product.' : 'Explora el resto<br/>del producto.'}</h2>
            </div>
            <div class="pp-more-grid">
                {otros.map((f) => (
                    <a href={`/producto/${f.slug}`} class="pp-more-card reveal">
                        <b>{f.nav}</b>
                        <span>{f.sub.split('.')[0]}.</span>
                        <i class="pp-more-arrow">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </i>
                    </a>
                ))}
            </div>
        </section>
    </main>

    <Footer ctaTitle={feature.cta.titulo.replace(/\. /, '.<br />')} ctaSub={feature.cta.sub} />
    <PageAnims />
</Layout>

<style>
    /* ════════ HERO ════════ */
    .pp-hero {
        position: relative;
        padding: 11.5rem 5% 5rem;
        text-align: center;
        overflow: clip;
        background: var(--color-bg);
    }
    .pp-hero-mesh {
        position: absolute; inset: -20% -10% auto;
        height: 80%;
        background:
            radial-gradient(ellipse 50% 60% at 28% 20%, rgba(10,25,47,0.05) 0%, transparent 60%),
            radial-gradient(ellipse 44% 54% at 76% 12%, rgba(10,25,47,0.04) 0%, transparent 60%);
        pointer-events: none;
    }
    .pp-hero-inner { position: relative; z-index: 1; max-width: 980px; margin: 0 auto; }

    .pp-eyebrow {
        font-size: 0.65rem; font-weight: 800; letter-spacing: 3px;
        text-transform: uppercase; color: #888; margin: 0 0 1.4rem;
    }
    .pp-title {
        font-size: clamp(2.4rem, 5.4vw, 4.4rem);
        font-weight: 800; line-height: 1.04; letter-spacing: -0.035em;
        color: var(--color-text); margin: 0 0 1.6rem;
    }
    .pp-sub {
        font-size: 1.12rem; line-height: 1.65; color: var(--color-text-muted);
        max-width: 640px; margin: 0 auto 2.2rem;
    }
    .pp-actions { display: flex; gap: 0.9rem; justify-content: center; align-items: center; flex-wrap: wrap; }
    .pp-btn-primary {
        display: inline-flex; align-items: center; gap: 10px;
        background: var(--color-blue-deep); color: #fff;
        text-decoration: none; font-size: 0.98rem; font-weight: 600;
        padding: 14px 28px; border-radius: 13px;
        box-shadow: 0 18px 44px -16px rgba(10,25,47,0.55);
        transition: transform 0.5s var(--ease-spring), box-shadow 0.5s var(--ease-spring);
    }
    .pp-btn-primary svg { width: 15px; height: 15px; transition: transform 0.5s var(--ease-spring); }
    .pp-btn-primary:hover { transform: translateY(-3px); box-shadow: 0 26px 56px -16px rgba(10,25,47,0.6); }
    .pp-btn-primary:hover svg { transform: translateX(4px); }
    .pp-btn-ghost {
        color: var(--color-text); text-decoration: none; font-weight: 600; font-size: 0.98rem;
        padding: 14px 10px;
        transition: color 0.3s;
    }
    .pp-btn-ghost:hover { color: var(--color-blue-deep); }
    .pp-plan { font-size: 0.78rem; color: #99a2af; margin: 1.3rem 0 0; font-weight: 600; }

    /* ── Mockup del hero (EXTREME MOTION GRAPHICS) ── */
    .pp-mockup-wrap { position: relative; max-width: 820px; margin: 4.5rem auto 0; perspective: 1400px; transform-style: preserve-3d; }
    
    .pp-mesh-bg {
        position: absolute;
        top: -100px; left: 50%;
        transform: translateX(-50%);
        width: 1400px; height: 900px;
        background:
            radial-gradient(ellipse 40% 50% at 20% 30%, rgba(59,130,246,0.10), transparent 60%),
            radial-gradient(ellipse 45% 45% at 80% 25%, rgba(16,185,129,0.07), transparent 60%),
            radial-gradient(ellipse 50% 55% at 50% 10%, rgba(10,25,47,0.10), transparent 55%);
        filter: blur(30px);
        pointer-events: none;
        opacity: 0.9;
    }
    
    .pp-glow {
        position: absolute; inset: -8% -4% 12%;
        background: radial-gradient(ellipse at center, rgba(10,25,47,0.18) 0%, transparent 70%);
        filter: blur(40px); z-index: 0;
        pointer-events: none;
    }

    .pp-mockup {
        position: relative;
        text-align: left;
        color: #fff;
        /* Removed background, padding, and backdrop-filter to prevent double-borders and clipping */
    }

    /* badges compartidos */
    .mk-badge {
        font-size: 0.6rem; font-weight: 800; letter-spacing: 0.8px;
        padding: 4px 10px; border-radius: 100px; white-space: nowrap; text-transform: uppercase;
    }
    .mk-badge-draft { color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); }
    .mk-badge-sent  { color: #93c5fd; background: rgba(59,130,246,0.15); border: 1px solid rgba(59,130,246,0.3); }
    .mk-badge-ok    { color: #34d399; background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3); }
    
    .mk-avatar {
        width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
        background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff; 
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 12px rgba(37,99,235,0.3);
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.85rem; font-weight: 800;
    }
    .mk-avatar-ez { background: linear-gradient(135deg, #f59e0b, #d97706); box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 12px rgba(217,119,6,0.3); }
    .mk-avatar-cg { background: linear-gradient(135deg, #10b981, #059669); box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 12px rgba(5,150,105,0.3); }
    .mk-avatar-gf { background: linear-gradient(135deg, #8b5cf6, #6d28d9); box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 12px rgba(109,40,217,0.3); }
    
    .mk-avatar-sm {
        width: 20px; height: 20px; border-radius: 6px; flex-shrink: 0;
        background: #3b82f6; color: #fff;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.55rem; font-weight: 800;
    }

    /* ── EDITOR APP SIMULATION ── */
    .mk-window {
        background: #0a192f;
        border-radius: 14px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.06);
        position: relative; overflow: hidden;
    }
    .mk-bar { 
        display: flex; align-items: center; justify-content: space-between; 
        padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(255,255,255,0.02);
    }
    .mk-dots { display: inline-flex; gap: 6px; }
    .mk-dots i { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.2); }
    .mk-bar-title { font-size: 0.75rem; font-weight: 600; color: rgba(255,255,255,0.6); position: absolute; left: 50%; transform: translateX(-50%); }
    .mk-bar-actions { display: flex; align-items: center; gap: 10px; }
    
    .mk-body { display: flex; height: 320px; }
    .mk-sidebar { width: 180px; background: rgba(255,255,255,0.01); border-right: 1px solid rgba(255,255,255,0.03); padding: 12px; display: flex; flex-direction: column; gap: 4px; }
    .mk-sb-item { padding: 8px 10px; border-radius: 6px; font-size: 0.7rem; color: rgba(255,255,255,0.5); display: flex; align-items: center; gap: 8px; cursor: default; }
    .mk-sb-active { background: rgba(59,130,246,0.1); color: #93c5fd; font-weight: 500; }
    .mk-sb-item i { font-style: normal; opacity: 0.7; }
    
    .mk-content { flex: 1; padding: 1.5rem; display: flex; flex-direction: column; }
    .mk-rows { display: flex; flex-direction: column; gap: 4px; flex: 1; }
    .mk-row {
        display: grid; grid-template-columns: 2fr 0.5fr 1fr 1fr;
        gap: 8px; align-items: center;
        font-size: 0.75rem; color: rgba(255,255,255,0.8); font-weight: 500;
        padding: 8px 12px; border-radius: 8px;
        background: transparent; border: 1px solid transparent;
        transition: background 0.3s, border-color 0.3s;
    }
    .mk-row span:nth-child(n+2) { text-align: right; }
    .mk-row-head { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; color: rgba(255,255,255,0.4); padding-bottom: 8px; border-bottom: 1px solid rgba(255,255,255,0.05); border-radius: 0; }
    .mk-row-edit { background: rgba(16,185,129,0.04); border-color: rgba(16,185,129,0.1); position: relative; }
    .mk-green { color: #34d399; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; justify-content: flex-end; }
    .mk-chip {
        font-style: normal; font-size: 0.55rem; font-weight: 800;
        color: #34d399; background: rgba(16,185,129,0.15); border: 1px solid rgba(52,211,153,0.3);
        padding: 2px 4px; border-radius: 4px;
        opacity: 0; transform: scale(0.5); /* for GSAP */
    }
    .mk-totals {
        display: flex; justify-content: flex-end; gap: 2rem;
        margin-top: auto; padding-top: 1rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }
    .mk-tot-col { display: flex; flex-direction: column; gap: 4px; text-align: right; }
    .mk-tot-col span { font-size: 0.65rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.5px; }
    .mk-tot-col b { font-size: 0.8rem; color: rgba(255,255,255,0.9); font-weight: 600; }
    .mk-tot-final b { font-size: 1.1rem; color: #fff; }

    .mk-cursor {
        position: absolute; top: 0; left: 0; width: 20px; height: 20px; color: #fff;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5)); z-index: 100;
        pointer-events: none; opacity: 0;
    }
    
    /* ── LINK PÚBLICO SIMULATION ── */
    .mk-public { position: relative; max-width: 440px; margin: 0 auto; perspective: 1000px; }
    .mk-public-card { 
        display: flex; flex-direction: column; gap: 1.25rem; padding: 1.5rem;
        background: linear-gradient(145deg, rgba(10,25,47,0.85), rgba(10,25,47,0.95));
        border-radius: 18px; box-shadow: 0 24px 48px -12px rgba(2,6,12,0.8), inset 0 1px 1px rgba(255,255,255,0.1);
        backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,0.08);
    }
    .mk-public-head { display: flex; align-items: center; gap: 12px; }
    .mk-public-head b { display: block; font-size: 0.95rem; font-weight: 600; color: #fff; }
    .mk-public-head i { display: block; font-style: normal; font-size: 0.75rem; color: rgba(255,255,255,0.6); margin-top: 2px; }
    .mk-public-head .mk-badge { margin-left: auto; }
    .mk-public-total {
        text-align: center; padding: 1.75rem 1rem;
        background: rgba(255,255,255,0.02); border-radius: 14px;
        border: 1px solid rgba(255,255,255,0.04);
    }
    .mk-public-total span { display: block; font-size: 0.65rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 8px; }
    .mk-public-total b { display: block; font-size: 2.2rem; font-weight: 800; letter-spacing: -0.5px; color: #fff; }
    .mk-public-total i { display: block; font-style: normal; font-size: 0.7rem; color: rgba(255,255,255,0.4); margin-top: 8px; }
    .mk-public-actions { display: flex; gap: 0.85rem; }
    
    .mk-btn-wrap { position: relative; flex: 1; display: flex; cursor: pointer; }
    .mk-btn-glow { position: absolute; inset: 0; background: #3b82f6; filter: blur(14px); opacity: 0; border-radius: 12px; transition: opacity 0.3s; }
    .mk-approve {
        position: relative; flex: 1; text-align: center; display: flex; align-items: center; justify-content: center;
        background: #fff; color: #0f172a;
        font-size: 0.9rem; font-weight: 700;
        padding: 14px; border-radius: 12px; box-shadow: 0 4px 12px rgba(255,255,255,0.15); z-index: 2;
    }
    .mk-reject {
        text-align: center; color: rgba(255,255,255,0.6); display: flex; align-items: center; justify-content: center;
        font-size: 0.9rem; font-weight: 600;
        padding: 14px 20px; border-radius: 12px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
    }
    .mk-via { text-align: center; font-size: 0.7rem; color: rgba(255,255,255,0.4); margin-top: -0.5rem; }
    .mk-via b { color: rgba(255,255,255,0.7); }
    
    .mk-success-overlay {
        position: absolute; inset: 0; background: rgba(16,185,129,0.9);
        border-radius: 18px; backdrop-filter: blur(8px);
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        opacity: 0; pointer-events: none; z-index: 10; gap: 12px;
    }
    .mk-success-ring { position: absolute; width: 80px; height: 80px; border-radius: 50%; border: 2px solid #fff; opacity: 0; }
    .mk-success-check { font-size: 3rem; font-style: normal; color: #fff; font-weight: 800; }
    .mk-success-overlay b { color: #fff; font-size: 1.2rem; }

    /* ── SEGUIMIENTO TIMELINE ── */
    .mk-track { display: flex; flex-direction: column; gap: 1.25rem; max-width: 520px; margin: 0 auto; }
    .mk-track-head { display: flex; justify-content: center; height: 50px; }
    .mk-toast {
        display: flex; align-items: center; gap: 12px;
        background: rgba(10,25,47,0.85); border-radius: 100px; border: 1px solid rgba(255,255,255,0.1);
        padding: 8px 16px; font-size: 0.75rem; color: #f8fafc;
        box-shadow: 0 12px 24px -8px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.1);
        backdrop-filter: blur(16px);
        opacity: 0; transform: translateY(20px); /* GSAP target */
    }
    .mk-toast-dot {
        width: 8px; height: 8px; border-radius: 50%; background: #38bdf8; flex-shrink: 0;
        box-shadow: 0 0 0 4px rgba(56,189,248,0.2); animation: mk-pulse 2s infinite;
    }
    .mk-toast-content { display: flex; align-items: center; gap: 6px; }
    .mk-toast-content i { color: rgba(255,255,255,0.4); }
    
    .mk-tl { 
        display: flex; flex-direction: column; gap: 4px;
        background: rgba(10,25,47,0.8);
        border-radius: 18px; padding: 1.25rem; border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 24px 48px -12px rgba(2,6,12,0.8);
    }
    .mk-tl-row {
        display: flex; align-items: center; gap: 14px;
        padding: 12px 14px; border-radius: 12px;
        opacity: 0; transform: translateX(-20px); /* GSAP staggered */
    }
    .mk-tl-row.mk-on { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.04); }
    .mk-tl-row i {
        width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
        background: rgba(255,255,255,0.1); flex-shrink: 0; font-style: normal; font-size: 0.7rem; color: #fff;
        box-shadow: inset 0 1px 1px rgba(255,255,255,0.2);
    }
    .mk-tl-row i.ok { background: #10b981; box-shadow: 0 0 12px rgba(16,185,129,0.4); }
    .mk-tl-row i.warn { background: #f59e0b; box-shadow: 0 0 12px rgba(245,158,11,0.4); }
    .mk-tl-info { flex: 1; }
    .mk-tl-info b { display: block; font-size: 0.85rem; color: #fff; margin-bottom: 2px; }
    .mk-tl-info span { display: block; font-size: 0.7rem; color: rgba(255,255,255,0.5); }
    
    /* ── CFDI ── */
    .mk-cfdi { 
        position: relative; display: flex; flex-direction: column; max-width: 520px; margin: 0 auto; 
        background: rgba(10,25,47,0.85);
        border-radius: 18px; box-shadow: 0 24px 48px -12px rgba(2,6,12,0.8), inset 0 1px 1px rgba(255,255,255,0.1);
        backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,0.08);
        overflow: hidden;
    }
    .mk-cfdi-bg-code {
        position: absolute; inset: 0; padding: 1.5rem;
        font-family: var(--font-mono, monospace); font-size: 0.6rem; color: rgba(255,255,255,0.04);
        line-height: 1.6; user-select: none; z-index: 0;
    }
    .mk-cfdi-front { position: relative; z-index: 1; padding: 1.5rem; }
    .mk-cfdi-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
    .mk-cfdi-head b { font-size: 0.95rem; color: #fff; font-weight: 600; }
    .mk-cfdi-rows { display: flex; flex-direction: column; gap: 6px; }
    .mk-cfdi-rows > div {
        display: flex; justify-content: space-between; gap: 1rem; align-items: center;
        padding: 10px 14px; border-radius: 10px;
        background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.03);
        font-size: 0.8rem;
    }
    .mk-cfdi-rows span { color: rgba(255,255,255,0.4); font-weight: 700; font-size: 0.65rem; letter-spacing: 0.8px; text-transform: uppercase; }
    .mk-cfdi-rows b { font-weight: 500; color: #f8fafc; text-align: right; }
    .mk-cfdi-stamp {
        position: relative; display: flex; align-items: center; gap: 12px;
        font-size: 0.75rem; color: rgba(255,255,255,0.6);
        padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.05); margin-top: 1rem;
    }
    .mk-stamp-ring { position: absolute; left: 0; width: 28px; height: 28px; border-radius: 50%; border: 1px solid #34d399; opacity: 0; }
    .mk-check {
        width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0; position: relative; z-index: 2;
        background: #10b981; color: #fff; box-shadow: 0 4px 12px rgba(16,185,129,0.4);
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.9rem; font-weight: 800; transform: scale(0); /* GSAP */
    }

    /* ── CLIENTES Y CRÉDITO ── */
    .mk-cli { 
        display: flex; flex-direction: column; gap: 8px; 
        background: rgba(15,23,42,0.6);
        border-radius: 18px; padding: 1.25rem; border: 1px solid rgba(255,255,255,0.06);
    }
    .mk-cli-row {
        display: grid; grid-template-columns: auto 1.5fr auto 1fr;
        gap: 16px; align-items: center;
        padding: 12px 14px; border-radius: 12px;
        background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.03);
        opacity: 0; transform: translateY(15px); /* GSAP */
    }
    .mk-cli-info b { display: block; font-size: 0.85rem; color: #fff; font-weight: 600; margin-bottom: 2px; }
    .mk-cli-info i { display: block; font-style: normal; font-size: 0.7rem; color: rgba(255,255,255,0.4); }
    .mk-term-wrap { display: flex; justify-content: flex-end; }
    .mk-term {
        font-size: 0.65rem; font-weight: 800; letter-spacing: 0.5px;
        color: #93c5fd; background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.2);
        padding: 4px 10px; border-radius: 100px; text-transform: uppercase;
    }
    .mk-term-cash { color: #cbd5e1; background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); }
    .mk-credit { display: flex; flex-direction: column; gap: 6px; align-items: flex-end; }
    .mk-credit-bar {
        width: 100%; height: 4px; border-radius: 2px; background: rgba(255,255,255,0.05);
        overflow: hidden; display: flex;
    }
    .mk-credit-bar i {
        height: 100%; border-radius: 2px; background: #3b82f6;
        transform-origin: left; transform: scaleX(0); /* GSAP */
    }
    .mk-credit-bar i.warn-bar { background: linear-gradient(90deg, #3b82f6, #f59e0b); }
    .mk-credit span { font-size: 0.7rem; color: rgba(255,255,255,0.5); font-weight: 500; font-family: var(--font-mono, monospace); }

    /* ── COBRANZA IA (agente AR que negocia un plan de pagos) ── */
    .mk-ar {
        max-width: 470px; margin: 0 auto;
        display: flex; flex-direction: column; gap: 1rem; padding: 1.4rem;
        background: linear-gradient(160deg, rgba(14,34,64,0.92), rgba(8,20,36,0.96));
        border-radius: 18px; border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 24px 48px -12px rgba(2,6,12,0.8), inset 0 1px 1px rgba(255,255,255,0.08);
    }
    .mk-ar-head { display: flex; align-items: center; gap: 12px; }
    .mk-ar-head b { display: block; font-size: 0.92rem; color: #fff; font-weight: 600; }
    .mk-ar-head i { display: block; font-style: normal; font-size: 0.72rem; color: rgba(255,255,255,0.5); margin-top: 2px; }
    .mk-ar-overdue { margin-left: auto; color: #fca5a5; background: rgba(239,68,68,0.14); border: 1px solid rgba(239,68,68,0.28); }
    .mk-ar-thread { display: flex; flex-direction: column; gap: 8px; }
    .mk-ar-bubble { font-size: 0.8rem; line-height: 1.5; padding: 10px 13px; border-radius: 13px; max-width: 90%; color: #f1f5f9; }
    .mk-ar-ai { align-self: flex-start; background: rgba(59,130,246,0.12); border: 1px solid rgba(59,130,246,0.2); border-bottom-left-radius: 4px; }
    .mk-ar-client { align-self: flex-end; background: #fff; color: #0f172a; font-weight: 500; border-bottom-right-radius: 4px; }
    .mk-ar-tag { display: block; font-size: 0.55rem; font-weight: 800; letter-spacing: 0.6px; text-transform: uppercase; color: #93c5fd; margin-bottom: 4px; }
    .mk-ar-plan {
        display: flex; flex-direction: column; gap: 6px; padding: 12px; border-radius: 13px;
        background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);
    }
    .mk-ar-cuota { display: flex; justify-content: space-between; align-items: center; font-size: 0.78rem; color: rgba(255,255,255,0.7); }
    .mk-ar-cuota b { color: #fff; font-weight: 600; }
    .mk-ar-approve {
        margin-top: 4px; text-align: center; font-size: 0.82rem; font-weight: 700;
        padding: 11px; border-radius: 11px; background: #34d399; color: #052e1f;
    }

    /* ── MULTI-DIVISA / FX (panel del editor) ── */
    .mk-fx-body { padding: 1.2rem 1.3rem 1.4rem; }
    .mk-fx-controls { display: flex; gap: 1rem; margin-bottom: 1rem; }
    .mk-fx-field { flex: 1; display: flex; flex-direction: column; gap: 6px; }
    .mk-fx-field label { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.6px; text-transform: uppercase; color: rgba(255,255,255,0.4); }
    .mk-fx-seg { display: inline-flex; background: rgba(255,255,255,0.04); border-radius: 9px; padding: 3px; gap: 2px; align-self: flex-start; }
    .mk-fx-seg span { font-size: 0.72rem; font-weight: 600; color: rgba(255,255,255,0.5); padding: 5px 11px; border-radius: 7px; }
    .mk-fx-seg span.on { background: rgba(59,130,246,0.2); color: #93c5fd; box-shadow: inset 0 0 0 1px rgba(59,130,246,0.3); }
    .mk-fx-buffer { font-size: 0.85rem; font-weight: 600; color: #fff; background: rgba(255,255,255,0.04); border-radius: 9px; padding: 8px 12px; align-self: flex-start; }
    .mk-fx-rate { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 11px 13px; border-radius: 11px; background: rgba(59,130,246,0.06); border: 1px solid rgba(59,130,246,0.14); margin-bottom: 1rem; }
    .mk-fx-rate-line { font-size: 0.82rem; color: rgba(255,255,255,0.7); }
    .mk-fx-rate-line b { color: #fff; margin-left: 4px; }
    .mk-fx-lock { font-size: 0.66rem; font-weight: 700; color: #93c5fd; background: rgba(59,130,246,0.14); border: 1px solid rgba(59,130,246,0.25); padding: 4px 9px; border-radius: 100px; white-space: nowrap; }
    .mk-fx-totals { display: flex; flex-direction: column; gap: 6px; }
    .mk-fx-total { display: flex; align-items: center; justify-content: space-between; padding: 11px 13px; border-radius: 11px; background: rgba(255,255,255,0.03); }
    .mk-fx-total span { font-size: 0.66rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; color: rgba(255,255,255,0.4); }
    .mk-fx-total b { font-size: 1.05rem; color: #fff; }
    .mk-fx-total-mxn b { color: #34d399; }

    /* ── FACTURACIÓN INTERNACIONAL (US/MX) ── */
    .mk-intl { position: relative; }
    .mk-intl-body { padding: 1.1rem 1.2rem 1.3rem; }
    .mk-rows-intl { display: flex; flex-direction: column; gap: 4px; }
    .mk-rows-intl .mk-row { grid-template-columns: 1.7fr 0.6fr 1fr 1fr; }
    .mk-intl-totals { display: flex; flex-direction: column; gap: 6px; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.06); }
    .mk-intl-tot { display: flex; align-items: center; justify-content: space-between; padding: 9px 12px; border-radius: 10px; background: rgba(255,255,255,0.03); }
    .mk-intl-tot span { font-size: 0.64rem; font-weight: 700; letter-spacing: 0.4px; text-transform: uppercase; color: rgba(255,255,255,0.4); }
    .mk-intl-tot b { font-size: 0.95rem; color: #fff; }
    .mk-intl-tot-fiscal b { color: #34d399; }
    .mk-intl-rate { font-size: 0.66rem; color: rgba(255,255,255,0.4); text-align: right; padding-right: 4px; }
    .mk-intl-pill { position: absolute; top: 46px; right: 14px; z-index: 3; font-size: 0.64rem; font-weight: 700; color: #93c5fd; background: rgba(10,25,47,0.82); border: 1px solid rgba(59,130,246,0.3); padding: 5px 11px; border-radius: 100px; backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }

    /* ════════ STATS ════════ */
    .pp-stats {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem;
        max-width: 1080px; margin: 0 auto;
        padding: 5.5rem 5%;
        border-bottom: 1px solid var(--color-border);
    }
    .pp-stat { text-align: center; display: flex; flex-direction: column; gap: 0.6rem; }
    .pp-stat-num {
        font-size: clamp(2.4rem, 4.6vw, 3.6rem);
        color: var(--color-blue-deep); line-height: 1;
    }
    .pp-stat-label { font-size: 0.88rem; color: var(--color-text-muted); max-width: 240px; margin: 0 auto; line-height: 1.5; }

    /* ════════ BLOQUES ════════ */
    .pp-blocks {
        max-width: 1080px; margin: 0 auto;
        padding: 8rem 5% 6rem;
        display: flex; flex-direction: column; gap: 14rem;
    }
    .pp-block {
        display: grid; grid-template-columns: 1.1fr 0.9fr;
        gap: 4.5rem; align-items: center;
    }
    .pp-block-text, .pp-block-visual { min-width: 0; }
    .pp-block-flip .pp-block-text { order: 2; }
    .pp-block-flip .pp-block-visual { order: 1; }

    .pp-h2 {
        font-size: clamp(1.7rem, 3vw, 2.4rem);
        font-weight: 800; line-height: 1.12; letter-spacing: -0.03em;
        color: var(--color-text); margin: 0 0 1.1rem;
    }
    .pp-copy { font-size: 1.02rem; line-height: 1.7; color: var(--color-text-muted); margin: 0 0 1.6rem; }
    .pp-bullets { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.8rem; }
    .pp-bullets li { display: flex; align-items: flex-start; gap: 11px; font-size: 0.95rem; color: var(--color-text); font-weight: 500; }
    .pp-bullets svg { width: 16px; height: 16px; color: var(--color-ok); flex-shrink: 0; margin-top: 3px; }

    .pp-block-visual {
        position: relative;
        min-height: 260px;
        display: flex; align-items: center; justify-content: center;
        /* No background, no border, no overflow clip -> transparent stage */
    }
    .pp-card-num {
        font-size: 5rem; line-height: 0.9;
        color: rgba(10,25,47,0.08);
        font-weight: 600;
    }

    /* ════════ CROSS-LINKS ════════ */
    .pp-more {
        max-width: 1080px; margin: 0 auto;
        padding: 6rem 5% 8rem;
    }
    .pp-more-head { text-align: center; margin-bottom: 3.2rem; }
    .pp-more-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.1rem; }
    .pp-more-card {
        position: relative;
        display: flex; flex-direction: column; gap: 0.5rem;
        background: var(--color-bg-soft);
        border: 1px solid var(--color-border);
        border-radius: 20px;
        padding: 1.7rem 1.8rem;
        text-decoration: none;
        transition: transform 0.5s var(--ease-spring), box-shadow 0.5s var(--ease-spring), border-color 0.4s;
    }
    .pp-more-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 30px 70px -30px rgba(10,25,47,0.18);
        border-color: rgba(10,25,47,0.12);
    }
    .pp-more-card b { font-size: 1.05rem; font-weight: 700; letter-spacing: -0.3px; color: var(--color-text); }
    .pp-more-card span { font-size: 0.88rem; line-height: 1.55; color: var(--color-text-muted); padding-right: 2.4rem; }
    .pp-more-arrow {
        position: absolute; right: 1.5rem; top: 1.6rem;
        width: 30px; height: 30px; border-radius: 50%;
        background: rgba(10,25,47,0.05); color: var(--color-blue-deep);
        display: flex; align-items: center; justify-content: center;
        transition: background 0.35s, color 0.35s, transform 0.5s var(--ease-spring);
    }
    .pp-more-arrow svg { width: 13px; height: 13px; }
    .pp-more-card:hover .pp-more-arrow { background: var(--color-blue-deep); color: #fff; transform: translateX(3px); }

    /* ════════ FAQ ════════ */
    .pp-faq {
        max-width: 760px; margin: 0 auto;
        padding: 5rem 5% 2rem;
    }
    .pp-faq-head { text-align: center; margin-bottom: 2.6rem; }
    .pp-faq-head .pp-h2 { margin: 0; }
    .pp-faq-list { display: flex; flex-direction: column; }
    .pp-faq-item { border-bottom: 1px solid var(--color-border); }
    .pp-faq-q {
        display: flex; justify-content: space-between; align-items: center; gap: 1.5rem;
        width: 100%; padding: 1.5rem 0.2rem;
        cursor: pointer; background: none; border: none; text-align: left;
        font-family: var(--font-sans); font-size: 1.08rem; font-weight: 600;
        color: var(--color-text); transition: color 0.3s var(--ease-ios);
    }
    .pp-faq-q:hover, .pp-faq-item.open .pp-faq-q { color: var(--color-blue-deep); }
    .pp-faq-icon { position: relative; width: 16px; height: 16px; flex-shrink: 0; transition: transform 0.5s var(--ease-spring); }
    .pp-faq-icon::before, .pp-faq-icon::after {
        content: ''; position: absolute; top: 50%; left: 50%;
        background: var(--color-text-muted);
        transition: transform 0.4s var(--ease-spring);
    }
    .pp-faq-icon::before { width: 14px; height: 2px; transform: translate(-50%, -50%); }
    .pp-faq-icon::after { width: 2px; height: 14px; transform: translate(-50%, -50%); }
    .pp-faq-item.open .pp-faq-icon { transform: rotate(90deg); }
    .pp-faq-item.open .pp-faq-icon::after { transform: translate(-50%, -50%) scaleY(0); }
    .pp-faq-panel {
        display: grid; grid-template-rows: 0fr;
        transition: grid-template-rows 0.55s var(--ease-spring);
    }
    .pp-faq-panel > .pp-faq-a { overflow: hidden; min-height: 0; }
    .pp-faq-item.open .pp-faq-panel { grid-template-rows: 1fr; }
    .pp-faq-a {
        margin: 0; padding: 0 0.2rem;
        font-size: 1rem; line-height: 1.7; color: var(--color-text-muted); max-width: 92%;
        opacity: 0; transform: translateY(-6px);
        transition: opacity 0.45s var(--ease-ios) 0.08s, transform 0.5s var(--ease-spring) 0.08s, padding 0.45s var(--ease-spring);
    }
    .pp-faq-item.open .pp-faq-a { opacity: 1; transform: translateY(0); padding-bottom: 1.6rem; }
    @media (prefers-reduced-motion: reduce) {
        .pp-faq-panel, .pp-faq-a, .pp-faq-icon { transition: none; }
    }

    /* ════════ RESPONSIVE ════════ */
    @media (max-width: 860px) {
        .pp-hero { padding-top: 9.5rem; }
        .pp-stats { grid-template-columns: 1fr; gap: 2.4rem; padding: 4rem 8%; }
        .pp-blocks { gap: 4.5rem; }
        .pp-block { grid-template-columns: 1fr; gap: 1.8rem; }
        .pp-block-flip .pp-block-text { order: 1; }
        .pp-block-flip .pp-block-visual { order: 2; }
        .pp-block-visual { min-height: 170px; margin-top: 2rem; }
        .pp-more-grid { grid-template-columns: 1fr; }
        .mk-row { grid-template-columns: 1.4fr 0.5fr 1fr; }
        .mk-row span:nth-child(4) { display: none; }
        .mk-cli-row { grid-template-columns: auto 1fr; }
        .mk-credit { display: none; }
        .mk-term { justify-self: end; }
    }
</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    // FAQ: acordeón (un solo abierto a la vez)
    document.addEventListener('DOMContentLoaded', () => {
        const items = Array.from(document.querySelectorAll<HTMLElement>('.pp-faq-item'));
        items.forEach((item) => {
            const btn = item.querySelector<HTMLButtonElement>('.pp-faq-q');
            if (!btn) return;
            btn.addEventListener('click', () => {
                const willOpen = !item.classList.contains('open');
                items.forEach((other) => {
                    other.classList.remove('open');
                    other.querySelector('.pp-faq-q')?.setAttribute('aria-expanded', 'false');
                });
                if (willOpen) {
                    item.classList.add('open');
                    btn.setAttribute('aria-expanded', 'true');
                }
            });
        });

        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!reduced) {
            // Entrada limpia de los BlockMockups: fade + rise (sin rotación 3D — igual al index)
            const blocks = document.querySelectorAll('.pp-block-visual');
            blocks.forEach((block) => {
                const stage = block.querySelector('.bm-stage');
                if (!stage) return;

                const internals = block.querySelectorAll('.bm-card, .bm-floating, .bm-search, .bm-timeline, .bm-board-col, .bm-stage > div');
                const glow = block.querySelector('.bm-glow');

                gsap.set(internals, { y: 28, opacity: 0 });
                if (glow) gsap.set(glow, { opacity: 0, scale: 0.6 });

                ScrollTrigger.create({
                    trigger: block,
                    start: 'top 85%',
                    once: true,
                    onEnter: () => {
                        gsap.to(internals, {
                            y: 0, opacity: 1,
                            duration: 0.9, ease: 'power3.out', stagger: 0.08, clearProps: 'transform',
                        });
                        if (glow) gsap.to(glow, { opacity: 1, scale: 1, duration: 1.6, ease: 'power3.out' });
                    },
                });
            });
            
            // ───────────────────────── HERO MOCKUP ─────────────────────────
            // El "settle" del mockup del hero (perspectiva → plano con el scroll) lo
            // maneja PageAnims.astro, idéntico al index. Aquí solo viven las
            // micro-historias que se auto-reproducen DENTRO del mockup (motion graphics):
            // cursor que negocia el precio, aprobación, timeline, timbrado, crédito.
            const wrap = document.querySelector('.pp-mockup-wrap');
            if (wrap) {
                // Editor Animation
                const editorTarget = document.getElementById('editorTargetRow');
                if (editorTarget) {
                    const cursor = document.getElementById('editorCursor');
                    const chip = document.getElementById('editorChip');
                    const price = document.getElementById('editorPrice');
                    const imp = document.getElementById('editorImport');
                    const total = document.getElementById('editorTotal');
                    
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 3 });
                    tl.set(cursor, { x: 300, y: 250, opacity: 0 })
                      .set(chip, { scale: 0, opacity: 0 })
                      .to(cursor, { opacity: 1, duration: 0.5 })
                      .to(cursor, { x: 280, y: 155, duration: 1, ease: 'power3.inOut' })
                      .to(cursor, { scale: 0.8, duration: 0.1, yoyo: true, repeat: 1 }) // click
                      .to(editorTarget, { backgroundColor: 'rgba(16,185,129,0.16)', duration: 0.3 })
                      .to(chip, { scale: 1, opacity: 1, duration: 0.4, ease: 'back.out(1.5)' })
                      .to(editorTarget, { backgroundColor: 'rgba(16,185,129,0.04)', duration: 0.3 })
                      .to(cursor, { x: 100, y: 350, opacity: 0, duration: 1, ease: 'power2.inOut' }, '+=0.5')
                      .to([price, imp, total], { color: '#34d399', duration: 0.2 }, '-=1')
                      .to([price, imp, total], { color: '', duration: 0.4 }, '-=0.5');
                }

                // Public Link Animation
                const pubWrap = document.getElementById('publicWrap');
                if (pubWrap) {
                    const btn = document.getElementById('publicApproveBtn');
                    const glow = document.getElementById('publicGlow');
                    const card = document.getElementById('publicCard');
                    const success = document.getElementById('publicSuccess');
                    const ring = document.querySelector('.mk-success-ring');
                    const check = document.querySelector('.mk-success-check');
                    
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 2 });
                    tl.to(glow, { opacity: 0.8, duration: 0.8, yoyo: true, repeat: 3 })
                      .to(btn, { scale: 0.95, duration: 0.1 }) // click
                      .to(btn, { scale: 1, duration: 0.1 })
                      .to(card, { scale: 0.95, opacity: 0, duration: 0.4, ease: 'power2.in' })
                      .to(success, { opacity: 1, duration: 0.3 })
                      .fromTo(ring, { scale: 0.5, opacity: 1 }, { scale: 1.5, opacity: 0, duration: 0.8, ease: 'power2.out' }, '<')
                      .fromTo(check, { scale: 0, rotation: -45 }, { scale: 1, rotation: 0, duration: 0.6, ease: 'back.out(2)' }, '<0.1')
                      .to(success, { opacity: 0, duration: 0.5 }, '+=2')
                      .to(card, { scale: 1, opacity: 1, duration: 0.5 }, '<');
                }

                // Seguimiento Animation
                const trackItems = document.querySelectorAll('.track-item');
                if (trackItems.length) {
                    const toast = document.getElementById('trackToast');
                    gsap.to(trackItems, { 
                        opacity: 1, x: 0, duration: 0.8, stagger: 0.15, ease: 'power2.out',
                        scrollTrigger: { trigger: '.mk-track', start: 'top 80%', once: true }
                    });
                    gsap.to(toast, { 
                        opacity: 1, y: 0, duration: 0.6, ease: 'back.out(1.2)', delay: 0.8,
                        scrollTrigger: { trigger: '.mk-track', start: 'top 80%', once: true }
                    });
                }
                
                // CFDI Animation
                const cfdiStamp = document.getElementById('cfdiStamp');
                if (cfdiStamp) {
                    const check = cfdiStamp.querySelector('.mk-check');
                    const ring = cfdiStamp.querySelector('.mk-stamp-ring');
                    gsap.to(check, { 
                        scale: 1, duration: 0.6, ease: 'back.out(1.5)',
                        scrollTrigger: { trigger: '.mk-cfdi', start: 'top 80%', once: true }
                    });
                    gsap.fromTo(ring, { scale: 0.5, opacity: 1 }, { scale: 2, opacity: 0, duration: 1,
                        scrollTrigger: { trigger: '.mk-cfdi', start: 'top 80%', once: true }
                    });
                }
                
                // Clientes Animation
                const cliItems = document.querySelectorAll('.cli-item');
                if (cliItems.length) {
                    const bars = document.querySelectorAll('.mk-credit-bar i');
                    gsap.to(cliItems, {
                        opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out',
                        scrollTrigger: { trigger: '.mk-cli', start: 'top 80%', once: true }
                    });
                    gsap.to(bars, {
                        scaleX: 1, duration: 1, stagger: 0.1, ease: 'power3.out', delay: 0.4,
                        scrollTrigger: { trigger: '.mk-cli', start: 'top 80%', once: true }
                    });
                }

                // Cobranza IA Animation (agente que negocia un plan de pagos en cuotas)
                const arThread = document.getElementById('arThread');
                if (arThread) {
                    const bubbles = arThread.querySelectorAll('.mk-ar-bubble');
                    const plan = document.getElementById('arPlan');
                    const cuotas = plan ? plan.querySelectorAll('.mk-ar-cuota') : [];
                    const approve = plan ? plan.querySelector('.mk-ar-approve') : null;
                    gsap.set(bubbles, { opacity: 0, y: 12 });
                    gsap.set(cuotas, { opacity: 0, y: 8 });
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 2.6, delay: 0.5 });
                    tl.set(bubbles, { opacity: 0, y: 12 })
                      .set(cuotas, { opacity: 0, y: 8 });
                    bubbles.forEach((b, i) => tl.to(b, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, i === 0 ? '>' : '+=0.85'));
                    tl.to(cuotas, { opacity: 1, y: 0, duration: 0.45, stagger: 0.14, ease: 'power2.out' }, '+=0.3');
                    if (approve) tl.fromTo(approve, { boxShadow: '0 0 0 0 rgba(52,211,153,0)' }, { boxShadow: '0 0 0 5px rgba(52,211,153,0.2)', duration: 0.6, yoyo: true, repeat: 3, ease: 'sine.inOut' }, '+=0.2');
                    tl.to([...bubbles, ...cuotas], { opacity: 0, duration: 0.5 }, '+=2.2');
                }

                // Multi-divisa Animation (count-up de la tasa + pop del lock + flash del total MXN)
                const fxHero = document.getElementById('fxHero');
                if (fxHero) {
                    const rate = document.getElementById('fxRate');
                    const lock = document.getElementById('fxLock');
                    const mxn = document.getElementById('fxMxn');
                    gsap.set(lock, { opacity: 0, scale: 0.6 });
                    ScrollTrigger.create({
                        trigger: fxHero, start: 'top 78%', once: true,
                        onEnter: () => {
                            const obj = { v: 17.9 };
                            gsap.timeline({ delay: 0.5 })
                                .to(obj, { v: 18.50, duration: 1, ease: 'power2.out', onUpdate: () => { if (rate) rate.textContent = '$' + obj.v.toFixed(2) + ' MXN'; } })
                                .to(lock, { opacity: 1, scale: 1, duration: 0.45, ease: 'back.out(1.6)' }, '-=0.25')
                                .fromTo(mxn, { backgroundColor: 'rgba(16,185,129,0.18)' }, { backgroundColor: 'rgba(255,255,255,0.03)', duration: 1.1, ease: 'power2.out' }, '-=0.1');
                        },
                    });
                }

                // Facturación internacional Animation (pill "Tasa blindada" + flash del total fiscal)
                const intlHero = document.getElementById('intlHero');
                if (intlHero) {
                    const fiscal = document.getElementById('intlFiscal');
                    const pill = document.getElementById('intlPill');
                    gsap.set(pill, { opacity: 0, scale: 0.6, y: -6 });
                    ScrollTrigger.create({
                        trigger: intlHero, start: 'top 78%', once: true,
                        onEnter: () => {
                            gsap.timeline({ delay: 0.5 })
                                .to(pill, { opacity: 1, scale: 1, y: 0, duration: 0.5, ease: 'back.out(1.6)' })
                                .fromTo(fiscal, { backgroundColor: 'rgba(16,185,129,0.2)' }, { backgroundColor: 'rgba(255,255,255,0.03)', duration: 1.1, ease: 'power2.out' }, '-=0.1');
                        },
                    });
                }
            }

            // ───────────────────────── BLOCK MOCKUPS GSAP ─────────────────────────
            // Editor M0 (Discount Row & Cursor)
            const bEditor0 = document.querySelector('.bm-editor-m0');
            if (bEditor0) {
                const cursor = bEditor0.querySelector('.bm-fake-cursor');
                const row = bEditor0.querySelector('.bm-row-target');
                const chip = bEditor0.querySelector('.mk-chip');
                const price = bEditor0.querySelector('.price-val');
                const obj = { val: 191.48 };

                ScrollTrigger.create({
                    trigger: bEditor0, start: 'top 85%',
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 2 });
                        tl.set(cursor, { x: 120, y: 150, opacity: 0 })
                          .set(chip, { opacity: 0, scale: 0.5 })
                          .to(cursor, { opacity: 1, duration: 0.4 })
                          .to(cursor, { x: 190, y: 40, duration: 1, ease: 'power3.inOut' })
                          .to(cursor, { scale: 0.85, duration: 0.1, yoyo: true, repeat: 1 })
                          .to(row, { backgroundColor: 'rgba(16,185,129,0.15)', duration: 0.3 })
                          .to(chip, { opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(1.5)' })
                          .to(row, { backgroundColor: 'rgba(255,255,255,0.02)', duration: 0.3 })
                          .to(obj, { val: 168.50, duration: 0.8, onUpdate: () => price.textContent = `$${obj.val.toFixed(2)}` }, '-=0.3')
                          .to(cursor, { opacity: 0, y: '+=30', duration: 0.5 });
                    }
                });
            }

            // Editor M1 (Margin Bar)
            const bEditor1 = document.querySelector('.bm-editor-m1');
            if (bEditor1) {
                const fill = bEditor1.querySelector('.bm-margin-bar-fill');
                gsap.to(fill, {
                    width: '85%', ease: 'none',
                    scrollTrigger: { trigger: bEditor1, start: 'top 95%', end: 'top 40%', scrub: 1 }
                });
            }

            // Editor M2 (Staggered Taxes)
            const bEditor2 = document.querySelector('.bm-editor-m2');
            if (bEditor2) {
                const rows = bEditor2.querySelectorAll('.bm-stag-row');
                const stamp = bEditor2.querySelector('.bm-stamp-hide');
                ScrollTrigger.create({
                    trigger: bEditor2, start: 'top 85%', once: true,
                    onEnter: () => {
                        gsap.fromTo(rows, { opacity: 0, x: -10 }, { opacity: 1, x: 0, stagger: 0.15, duration: 0.6, ease: 'power2.out', delay: 0.3 });
                        gsap.fromTo(stamp, { opacity: 0, scale: 0 }, { opacity: 1, scale: 1, duration: 0.5, ease: 'back.out(1.5)', delay: 1 });
                    }
                });
            }

            // Public M0 (Chat)
            const bPub0 = document.querySelector('.bm-public-m0');
            if (bPub0) {
                const typing = bPub0.querySelector('.bm-msg-typing');
                const outMsg = bPub0.querySelector('.bm-msg-out');
                ScrollTrigger.create({
                    trigger: bPub0, start: 'top 85%',
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 3 });
                        tl.set(outMsg, { display: 'none', opacity: 0, y: 10 })
                          .set(typing, { display: 'block', opacity: 0 })
                          .to(typing, { opacity: 1, duration: 0.3, delay: 0.5 })
                          .to(typing, { opacity: 0, duration: 0.3 }, '+=1.5')
                          .set(typing, { display: 'none' })
                          .set(outMsg, { display: 'block' })
                          .to(outMsg, { opacity: 1, y: 0, duration: 0.4, ease: 'back.out(1.2)' });
                    }
                });
            }

            // Public M1 (Branding Colors Scrub)
            const bPub1 = document.querySelector('.bm-public-m1');
            if (bPub1) {
                const card = bPub1.querySelector('.bm-brand-card');
                const logoPill = bPub1.querySelector('.bm-logo-pill');
                
                const tl = gsap.timeline({
                    scrollTrigger: { trigger: bPub1, start: 'top 95%', end: 'top 30%', scrub: 1 }
                });
                tl.to(card, { borderColor: '#10b981', boxShadow: '0 0 30px rgba(16,185,129,0.2)', ease: 'none' }, 0)
                  .to(logoPill, { background: '#10b981', ease: 'none' }, 0);
            }

            // Public M2 (Push Notif)
            const bPub2 = document.querySelector('.bm-public-m2');
            if (bPub2) {
                const push = bPub2.querySelector('.bm-push-notif');
                ScrollTrigger.create({
                    trigger: bPub2, start: 'top 85%',
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 3 });
                        tl.set(push, { opacity: 0, y: -20, scale: 0.95 })
                          .to(push, { opacity: 1, y: 0, scale: 1, duration: 0.5, ease: 'back.out(1.5)' })
                          .to(push, { x: -3, duration: 0.05, yoyo: true, repeat: 3 }, '+=0.2') // vibrate
                          .to(push, { opacity: 0, y: -10, duration: 0.4 }, '+=2.5');
                    }
                });
            }

            // Seguimiento M0 (Timeline Fill)
            const bTrack0 = document.querySelector('.bm-track-m0');
            if (bTrack0) {
                const fill = bTrack0.querySelector('.bm-tl-fill');
                const node = bTrack0.querySelector('.bm-node-pending');
                ScrollTrigger.create({
                    trigger: bTrack0, start: 'top 85%', once: true,
                    onEnter: () => {
                        gsap.to(fill, { height: '80%', duration: 2, ease: 'power2.inOut', delay: 0.5 });
                        gsap.to(node, { opacity: 1, duration: 0.5, delay: 2.2 });
                    }
                });
            }

            // Seguimiento M1 (Kanban — auto-drag en loop, motion graphic)
            const bTrack1 = document.querySelector('.bm-track-m1');
            if (bTrack1) {
                const card = bTrack1.querySelector('.bm-kanban-drag');
                const drop = bTrack1.querySelector('.bm-kanban-drop');
                ScrollTrigger.create({
                    trigger: bTrack1, start: 'top 80%', once: true,
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 1.8 });
                        tl.set(card, { x: 0, y: 0, scale: 1, boxShadow: '0 2px 4px rgba(0,0,0,0.12)' })
                          .set(drop, { opacity: 0 })
                          .to(card, { scale: 1.04, boxShadow: '0 18px 36px rgba(0,0,0,0.45)', duration: 0.35, ease: 'power2.out' }, '+=0.5')
                          .to(drop, { opacity: 1, duration: 0.3 }, '<')
                          .to(card, { x: 120, y: 70, duration: 0.9, ease: 'power2.inOut' }, '+=0.15')
                          .to(card, { scale: 1, boxShadow: '0 2px 4px rgba(0,0,0,0.12)', duration: 0.3, ease: 'power2.out' })
                          .to(drop, { opacity: 0, duration: 0.3 }, '<');
                    }
                });
            }

            // Seguimiento M2 (Search)
            const bTrack2 = document.querySelector('.bm-track-m2');
            if (bTrack2) {
                const type = bTrack2.querySelector('.bm-search-type');
                const res1 = bTrack2.querySelector('.bm-s-res-1');
                const res2 = bTrack2.querySelector('.bm-s-res-2');
                ScrollTrigger.create({
                    trigger: bTrack2, start: 'top 85%',
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 2 });
                        const text = 'varilla';
                        let curr = '';
                        tl.set([res1, res2], { opacity: 0, y: 10 });
                        
                        text.split('').forEach(char => {
                            tl.add(() => { curr += char; type.textContent = curr + '_'; }, '+=0.1');
                        });
                        tl.add(() => type.textContent = curr, '+=0.2')
                          .to([res1, res2], { opacity: 1, y: 0, duration: 0.4, stagger: 0.1 }, '+=0.2')
                          .to(type, { opacity: 0, duration: 0.1 }, '+=1.5')
                          .add(() => type.textContent = '_')
                          .to(type, { opacity: 1, duration: 0.1 });
                    }
                });
            }

            // CFDI M0 (XML Matrix Scramble)
            const bCfdi0 = document.querySelector('.bm-cfdi-m0');
            if (bCfdi0) {
                const matrix = bCfdi0.querySelector('.bm-matrix-text');
                const orig = matrix.innerHTML;
                const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*';
                ScrollTrigger.create({
                    trigger: bCfdi0, start: 'top 85%', once: true,
                    onEnter: () => {
                        let iters = 0;
                        const interval = setInterval(() => {
                            matrix.innerHTML = orig.split('').map(c => {
                                if (c === '<' || c === '>' || c === ' ' || c === '\\n') return c;
                                return Math.random() > 0.5 ? chars[Math.floor(Math.random() * chars.length)] : c;
                            }).join('');
                            iters++;
                            if (iters > 15) { clearInterval(interval); matrix.innerHTML = orig; gsap.to(matrix, { opacity: 0.2, duration: 1 }); }
                        }, 50);
                    }
                });
            }

            // CFDI M1 (Terminal SCRUB)
            const bCfdi1 = document.querySelector('.bm-cfdi-m1');
            if (bCfdi1) {
                const lines = bCfdi1.querySelectorAll('.bm-term-line');
                const stamp = bCfdi1.querySelector('.bm-cert-stamp');
                
                const tl = gsap.timeline({
                    scrollTrigger: { trigger: bCfdi1, start: 'top 95%', end: 'top 40%', scrub: 1 }
                });
                
                gsap.set(stamp, { opacity: 0, scale: 0 });
                lines.forEach((l, i) => {
                    tl.to(l, { opacity: 1, duration: 0.1 }, i * 0.1);
                });
                tl.to(stamp, { opacity: 1, scale: 1, duration: 0.5, ease: 'back.out(1.5)' });
            }

            // CFDI M2 (Laser Barcode)
            const bCfdi2 = document.querySelector('.bm-cfdi-m2');
            if (bCfdi2) {
                const laser = bCfdi2.querySelector('.bm-laser');
                ScrollTrigger.create({
                    trigger: bCfdi2, start: 'top 85%',
                    onEnter: () => {
                        gsap.to(laser, { opacity: 1, duration: 0.2, repeat: -1, repeatDelay: 2, yoyo: true });
                        gsap.to(laser, { top: '100%', duration: 1, repeat: -1, repeatDelay: 1.2, ease: 'none' });
                    }
                });
            }

            // Credit M0 (Progress Bar SCRUB)
            const bCred0 = document.querySelector('.bm-credit-m0');
            if (bCred0) {
                const fill = bCred0.querySelector('.bm-credit-fill');
                const val = bCred0.querySelector('.bm-credit-val');
                const req = bCred0.querySelector('.bm-req-appr');
                const obj = { v: 0 };
                
                const tl = gsap.timeline({
                    scrollTrigger: { trigger: bCred0, start: 'top 95%', end: 'top 30%', scrub: 1 }
                });
                
                gsap.set(req, { opacity: 0, scale: 0 });
                tl.to(fill, { width: '85%', duration: 2, ease: 'none' }, 0)
                  .to(obj, { v: 425, duration: 2, ease: 'none', onUpdate: () => val.textContent = Math.round(obj.v).toString() }, 0)
                  .to(fill, { backgroundColor: '#f59e0b', duration: 0.5 }, 1.5)
                  .to(req, { opacity: 1, scale: 1, duration: 0.5, ease: 'back.out(1.5)' }, 1.8);
            }

            // Credit M1 (SPEI Payment)
            const bCred1 = document.querySelector('.bm-credit-m1');
            if (bCred1) {
                const status = bCred1.querySelector('.bm-spei-status');
                const toast = bCred1.querySelector('.bm-spei-toast');
                ScrollTrigger.create({
                    trigger: bCred1, start: 'top 85%',
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 3 });
                        tl.set(toast, { opacity: 0, y: 10 })
                          .to(status, { opacity: 0.4, duration: 0.4, yoyo: true, repeat: 3 })
                          .to(toast, { opacity: 1, y: 0, duration: 0.5, ease: 'back.out(1.5)' })
                          .to(status, { color: '#34d399', onStart: () => status.textContent = 'Pagado' }, '<')
                          .to(toast, { opacity: 0, duration: 0.4 }, '+=2')
                          .set(status, { clearProps: 'all', textContent: 'Pendiente' });
                    }
                });
            }

            // Credit M2 (Bar Chart SCRUB)
            const bCred2 = document.querySelector('.bm-credit-m2');
            if (bCred2) {
                const cols = bCred2.querySelectorAll('.bm-chart-col-fill');
                const heights = ['40%', '70%', '50%', '90%', '60%'];
                
                const tl = gsap.timeline({
                    scrollTrigger: { trigger: bCred2, start: 'top 95%', end: 'top 30%', scrub: 1 }
                });
                
                cols.forEach((c, i) => {
                    tl.to(c, { height: heights[i], duration: 1, ease: 'none' }, i * 0.1);
                });
            }

            // Cobranza IA M0 (la negociación cierra: respuesta + "Plan aceptado")
            const bAr0 = document.querySelector('.bm-ar-m0');
            if (bAr0) {
                const reply = bAr0.querySelector('.bm-ar-reply-hide');
                const badge = bAr0.querySelector('.bm-ar-badge-hide');
                ScrollTrigger.create({
                    trigger: bAr0, start: 'top 85%',
                    onEnter: () => {
                        const tl = gsap.timeline({ repeat: -1, repeatDelay: 3 });
                        tl.set(reply, { opacity: 0, y: 10 })
                          .set(badge, { opacity: 0, scale: 0.6 })
                          .to(reply, { opacity: 1, y: 0, duration: 0.5, ease: 'back.out(1.2)' }, '+=1')
                          .to(badge, { opacity: 1, scale: 1, duration: 0.45, ease: 'back.out(1.5)' }, '+=0.3')
                          .to(badge, { opacity: 0, duration: 0.4 }, '+=2');
                    }
                });
            }

            // Cobranza IA M1 (flujo de caja proyectado — barras suben al entrar)
            const bAr1 = document.querySelector('.bm-ar-m1');
            if (bAr1) {
                const cols = bAr1.querySelectorAll('.bm-chart-col-fill');
                const heights = ['45%', '65%', '80%', '95%', '70%'];
                const tl = gsap.timeline({ scrollTrigger: { trigger: bAr1, start: 'top 90%', once: true } });
                cols.forEach((c, i) => tl.to(c, { height: heights[i], duration: 0.6, ease: 'power2.out' }, i * 0.12));
            }

            // Cobranza IA M2 (supervisión — filas + cambio de estado en vivo)
            const bAr2 = document.querySelector('.bm-ar-m2');
            if (bAr2) {
                const rows = bAr2.querySelectorAll('.bm-ar-row');
                const status = bAr2.querySelector('.bm-ar-status');
                ScrollTrigger.create({
                    trigger: bAr2, start: 'top 85%', once: true,
                    onEnter: () => {
                        gsap.fromTo(rows, { opacity: 0, x: -10 }, { opacity: 1, x: 0, stagger: 0.14, duration: 0.5, ease: 'power2.out' });
                        if (status) {
                            gsap.timeline({ repeat: -1, repeatDelay: 3, delay: 1.6 })
                                .to(status, { color: '#34d399', duration: 0.4, onStart: () => { status.textContent = 'Pagado'; } })
                                .to(status, { color: '#fbbf24', duration: 0.4, onStart: () => { status.textContent = 'Negociando'; } }, '+=2.2');
                        }
                    }
                });
            }

            // Multi-divisa M0 (dos monedas — filas entran)
            const bFx0 = document.querySelector('.bm-fx-m0');
            if (bFx0) {
                const rows = bFx0.querySelectorAll('.bm-row');
                ScrollTrigger.create({ trigger: bFx0, start: 'top 88%', once: true,
                    onEnter: () => gsap.fromTo(rows, { opacity: 0, x: -10 }, { opacity: 1, x: 0, stagger: 0.15, duration: 0.5, ease: 'power2.out' }) });
            }

            // Multi-divisa M1 (tipo de cambio — terminal que se enciende)
            const bFx1 = document.querySelector('.bm-fx-m1');
            if (bFx1) {
                const lines = bFx1.querySelectorAll('.bm-term-line');
                gsap.set(lines, { opacity: 0 });
                ScrollTrigger.create({ trigger: bFx1, start: 'top 88%', once: true,
                    onEnter: () => gsap.to(lines, { opacity: 1, stagger: 0.25, duration: 0.15 }) });
            }

            // Multi-divisa M2 (cobertura — barra + tasa aplicada en loop)
            const bFx2 = document.querySelector('.bm-fx-m2');
            if (bFx2) {
                const fill = bFx2.querySelector('.bm-fx-buffer-fill');
                const applied = bFx2.querySelector('.bm-fx-applied');
                ScrollTrigger.create({ trigger: bFx2, start: 'top 85%', once: true,
                    onEnter: () => {
                        const obj = { v: 18.50 };
                        gsap.timeline({ repeat: -1, repeatDelay: 2 })
                            .set(fill, { width: '0%' })
                            .call(() => { if (applied) applied.textContent = '$18.50'; })
                            .to(fill, { width: '80%', duration: 1, ease: 'power2.out' })
                            .to(obj, { v: 18.87, duration: 0.8, ease: 'power2.out', onUpdate: () => { if (applied) applied.textContent = '$' + obj.v.toFixed(2); } }, '<')
                            .set(obj, { v: 18.50 })
                            .to({}, { duration: 1.6 });
                    } });
            }

            // Internacional M0 (cobertura — spot count-up + chip de buffer)
            const bIntl0 = document.querySelector('.bm-intl-m0');
            if (bIntl0) {
                const spot = bIntl0.querySelector('.bm-intl-spot');
                const chip = bIntl0.querySelector('.bm-intl-chip');
                gsap.set(chip, { opacity: 0, scale: 0.5 });
                ScrollTrigger.create({ trigger: bIntl0, start: 'top 85%', once: true,
                    onEnter: () => {
                        const obj = { v: 18.10 };
                        gsap.timeline()
                            .to(obj, { v: 18.42, duration: 0.8, ease: 'power2.out', onUpdate: () => { if (spot) spot.textContent = '$' + obj.v.toFixed(2); } })
                            .to(chip, { opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(1.6)' });
                    } });
            }

            // Internacional M1 (dos divisas — convertido USD→MXN en loop)
            const bIntl1 = document.querySelector('.bm-intl-m1');
            if (bIntl1) {
                const conv = bIntl1.querySelector('.bm-intl-conv');
                ScrollTrigger.create({ trigger: bIntl1, start: 'top 85%', once: true,
                    onEnter: () => {
                        const obj = { v: 12480 };
                        gsap.timeline({ repeat: -1, repeatDelay: 2.4 })
                            .set(obj, { v: 12480 })
                            .to(obj, { v: 230880, duration: 1.1, ease: 'power2.out', onUpdate: () => { if (conv) conv.textContent = '$' + Math.round(obj.v).toLocaleString('es-MX') + '.00'; } })
                            .to({}, { duration: 1.8 });
                    } });
            }

            // Internacional M2 (CFDI real — status "Timbrado" hace pop)
            const bIntl2 = document.querySelector('.bm-intl-m2');
            if (bIntl2) {
                const status = bIntl2.querySelector('.bm-intl-status');
                gsap.set(status, { scale: 0.7, opacity: 0.5 });
                ScrollTrigger.create({ trigger: bIntl2, start: 'top 85%', once: true,
                    onEnter: () => gsap.to(status, { scale: 1, opacity: 1, duration: 0.5, ease: 'back.out(1.6)', delay: 0.4 }) });
            }
        }
    });
</script>
