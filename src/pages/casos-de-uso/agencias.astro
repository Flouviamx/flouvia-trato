---

export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import MagneticNodes from '../../components/MagneticNodes.jsx';
import GreenRampShader from '../../components/soluciones/GreenRampShader.jsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para Agencias y Consultoras | Propuestas y Retainers";
const metaDesc = "Envía propuestas hermosas, obtén firmas vinculantes y automatiza el cobro de tus igualas (retainers).";

const magneticNodes = [
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://ogilvy.com&size=128", alt: "Ogilvy", top: "10%", left: "30%", width: 100, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://accenture.com&size=128", alt: "Accenture", top: "25%", left: "65%", width: 140, zIndex: 3 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://ideo.com&size=128", alt: "IDEO", top: "50%", left: "15%", width: 120, zIndex: 1 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://pentagram.com&size=128", alt: "Pentagram", top: "75%", left: "45%", width: 90, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://flouvia.com&size=128", alt: "Flouvia", top: "60%", left: "80%", width: 110, zIndex: 1 }
];

---


<Layout title={metaTitle} description={metaDesc}>
    <Nav />
    
    <main class="use-case-main">
        <!-- HERO & TRUST WRAPPER -->
        <div class="uc-hero-trust-group">
            <div class="uc-hero-bg">
                <GreenRampShader client:only="react" />
            </div>

            <!-- HERO SECTION -->
            <header class="uc-hero">
                        <div class="uc-container uc-hero-inner">
                <div class="uc-hero-content">
                    <h1 class="uc-title reveal">Propuestas magnéticas que cierran tratos</h1>
                    <p class="uc-sub reveal">
                        Deja de perder horas armando PDFs en Word. Envía propuestas interactivas en minutos, obtén firmas electrónicas al instante y automatiza el cobro de tus igualas.
                    </p>
                    <div class="uc-actions reveal">
                        <a href="/registro" class="btn-luxe">
                            <span>Empezar ahora</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost">
                            <span>Contactar a ventas</span>
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Agencias líderes usan Cord para profesionalizar su proceso de ventas</p>
            <div class="uc-logos">
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://ogilvy.com&size=64" alt="Ogilvy" width="24" height="24" loading="lazy" />
                    <span>Ogilvy</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://accenture.com&size=64" alt="Accenture" width="24" height="24" loading="lazy" />
                    <span>Accenture</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://ideo.com&size=64" alt="IDEO" width="24" height="24" loading="lazy" />
                    <span>IDEO</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://pentagram.com&size=64" alt="Pentagram" width="24" height="24" loading="lazy" />
                    <span>Pentagram</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://flouvia.com&size=64" alt="Flouvia" width="24" height="24" loading="lazy" />
                    <span>Flouvia</span>
                </div>
            </div>
        </section>
        </div>

        <!-- STRIPE-LIKE SPLIT SECTION -->
        <section class="uc-split-feature">
            <div class="uc-container">
                <div class="uc-split-grid">
                    
                    <div class="uc-split-text reveal">
                        <span class="uc-split-label">Automatización de Ingresos</span>
                        <h2 class="uc-split-title">Transforma proyectos en flujo de caja predecible</h2>
                        <p class="uc-split-desc">
                            Estabiliza los ingresos de tu agencia mediante igualas recurrentes. Genera propuestas vinculantes que habilitan el cobro mensual y la facturación automática sin intervención manual.
                        </p>
                        
                        <div class="uc-split-list">
                            <div class="uc-feature-item">
                                <div class="uc-feature-icon">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <path d="M4 6h16M4 12h16m-7 6h7" stroke="#0f172a" stroke-width="2" stroke-linecap="round"/>
                                    </svg>
                                </div>
                                <div class="uc-feature-content">
                                    <h3>Estructuración de servicios recurrentes</h3>
                                    <p>Diseña diferentes niveles de servicio para tus clientes corporativos. Ofrece opciones escalables y logra que aprueben la propuesta interactiva con total validez legal.</p>
                                </div>
                            </div>
                            
                            <div class="uc-feature-item">
                                <div class="uc-feature-icon">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#0f172a" stroke-width="2" stroke-linejoin="round"/>
                                    </svg>
                                </div>
                                <div class="uc-feature-content">
                                    <h3>Conciliación y CFDI automático</h3>
                                    <p>Al recibir la firma digital, el sistema agenda los cobros mensuales, procesa el pago y emite la factura (CFDI 4.0) automáticamente, eliminando la carga administrativa de tu equipo.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="uc-split-mockup reveal">
                        <div class="uc-rw-glow"></div>
                        <div class="uc-retainer-widget">
                            <div class="uc-rw-header">
                                <div class="uc-rw-brand">
                                    <div class="uc-rw-avatar">
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#0f172a" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                                    </div>
                                    <div>
                                        <div class="uc-rw-title">Acme Corporation</div>
                                        <div class="uc-rw-sub">Acuerdo Mensual: Growth Marketing</div>
                                    </div>
                                </div>
                                <div class="uc-rw-status">
                                    <span class="uc-status-dot"></span> Vigente
                                </div>
                            </div>
                            
                            <div class="uc-rw-body">
                                <div class="uc-rw-amount-block">
                                    <span class="uc-rw-currency">$</span>
                                    <span class="uc-rw-amount">38,000</span>
                                    <span class="uc-rw-period">/mes</span>
                                </div>
                                
                                <div class="uc-rw-timeline">
                                    <div class="uc-tl-item success">
                                        <div class="uc-tl-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
                                        <div class="uc-tl-content">
                                            <strong>Acuerdo firmado</strong>
                                            <span>Firma electrónica vinculante confirmada</span>
                                        </div>
                                    </div>
                                    <div class="uc-tl-item success">
                                        <div class="uc-tl-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg></div>
                                        <div class="uc-tl-content">
                                            <strong>Método de pago asegurado</strong>
                                            <span>Cobro recurrente habilitado</span>
                                        </div>
                                    </div>
                                    <div class="uc-tl-item active">
                                        <div class="uc-tl-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg></div>
                                        <div class="uc-tl-content">
                                            <strong>Facturación automatizada</strong>
                                            <span>CFDI 4.0 procesado exitosamente</span>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="uc-rw-footer">
                                    Próxima ejecución: <strong>01 de Julio, 2026</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </section>

                <!-- SECONDARY BENEFITS SECTION -->
        <section class="uc-benefits">
            <div class="uc-container">
                <div class="uc-benefits-intro reveal">
                    <span class="uc-split-label">Escala sin fricción operativa</span>
                    <h2 class="uc-split-title">Mantén a tu equipo enfocado en la creatividad</h2>
                    <p class="uc-split-desc">
                        Mientras tu equipo diseña, programa y lanza campañas, Cord se asegura de que el dinero entre a tiempo. Ofrece experiencias de pago sin fricción a tus clientes corporativos y automatiza la conciliación de cada iguala mensual.
                    </p>
                </div>

                <div class="uc-bento-cards">
                    <!-- Tarjeta 1 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Cobra anticipos al instante con links de pago</h3>
                            <p>No inicies un proyecto sin el anticipo. Genera un enlace de pago directamente desde tu propuesta, permitiendo que tu cliente pague por transferencia SPEI o tarjeta de crédito al momento de aceptar.</p>
                            <a href="/registro" class="uc-link-arrow">Descubre los enlaces de pago <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup">
                            <div class="uc-mockup-bg cord-bg-1"></div>
                            <div class="uc-mini-invoice" style="width:260px;">
                                <div class="uc-mi-logo" style="border-radius: 8px;">P</div>
                                <div class="uc-mi-title">Propuesta: Branding 2026</div>
                                <div class="uc-mi-sub">Anticipo (50%) - Acme Corp</div>
                                <div class="uc-mi-amount">$45,000.00 <span class="uc-mi-currency">MXN</span></div>
                                <div class="uc-mi-form">
                                    <div class="uc-mi-btn" style="background:#0a2540;">Pagar con Tarjeta</div>
                                    <div class="uc-mi-btn" style="background:#fff; color:#0a2540; border:1px solid #e2e8f0;">Transferencia SPEI</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tarjeta 2 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Cobranza de igualas con seguimiento en vivo</h3>
                            <p>Visualiza todas tus igualas activas, qué clientes ya vieron la propuesta y cuáles no han pagado. Cord envía recordatorios automáticos por correo y WhatsApp antes del vencimiento sin que tengas que intervenir.</p>
                            <a href="/registro" class="uc-link-arrow">Empieza a cobrar mejor <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup" style="background:#fff;">
                            <div class="uc-mini-portal" style="flex-direction: column;">
                                <div class="uc-mp-sidebar" style="width: 100%; border-right: none; border-bottom: 1px solid #e2e8f0; flex-direction: row; align-items: center; justify-content: space-between; padding: 12px 20px;">
                                    <div class="uc-mp-brand" style="margin:0;"><div class="uc-mp-dot"></div> Cord</div>
                                    <div class="uc-mp-nav" style="background: #0f172a; color: #fff; padding: 4px 10px; border-radius: 6px;">+ Nuevo Retainer</div>
                                </div>
                                <div class="uc-mp-main" style="padding: 16px 20px;">
                                    <div class="uc-mp-header" style="margin-bottom: 12px; font-size:1rem;">Igualas Activas — Jun 2026</div>
                                    <div class="uc-mp-card" style="margin-bottom:8px;">
                                        <div class="uc-mp-row">
                                            <div>
                                                <strong>Acme Corp - SEO Mensual</strong>
                                                <span>$30,000 MXN / mes</span>
                                            </div>
                                            <div class="uc-mp-tag">Cobrado hoy</div>
                                        </div>
                                    </div>
                                    <div class="uc-mp-card">
                                        <div class="uc-mp-row">
                                            <div>
                                                <strong>Stark Ind. - Social Media</strong>
                                                <span>$45,000 MXN / mes</span>
                                            </div>
                                            <div class="uc-mp-tag" style="background:#f1f5f9; color:#475569;">Próx: 01/Jul</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Micro Features Grid -->
                <div class="uc-micro-features reveal">
                    <h3 class="uc-mf-title">Herramientas que blindan el flujo de caja de tu agencia</h3>
                    <div class="uc-mf-grid">
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"></path><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"></path><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"></path></svg>
                            </div>
                            <h4>Seguimiento en tiempo real</h4>
                            <p>Cord te notifica en cuanto tu cliente abre la propuesta. Marca manualmente cada iguala como cobrada y el sistema actualiza el estado en el historial de la cotización.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                            </div>
                            <h4>Recordatorios inteligentes</h4>
                            <p>Si un cliente se retrasa, Cord le envía <a href="#" class="uc-link-inline">seguimientos por email</a> o WhatsApp de manera educada para que tú no tengas que hacerlo.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                            </div>
                            <h4>Cobros internacionales</h4>
                            <p><a href="#" class="uc-link-inline">Acepta dólares</a> y euros con tarjetas internacionales, perfecto para agencias con clientes en Estados Unidos o Europa.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                            </div>
                            <h4>Analítica de cartera</h4>
                            <p>Visualiza tu pipeline activo, el valor por cobrar, las igualas vencidas por cliente y el margen cedido en descuentos. Todo desde <a href="/app/analitica" class="uc-link-inline">el dashboard de Cord</a>.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    

        <!-- INTEGRATIONS SECTION -->
        <section class="uc-integrations">
            <div class="uc-container">
                <div class="uc-int-grid">
                    <div class="uc-int-text reveal">
                        <h2>Conecta Cord con tus herramientas vía webhooks y Slack</h2>
                        <p>
                            Cord emite eventos reales — <code>quote.approved</code>, <code>quote.paid</code>, <code>quote.invoiced</code> — que puedes escuchar desde Zapier o Make para disparar acciones en Asana, Notion o HubSpot. Las alertas en <a href="#">Slack</a> llegan de forma nativa: cada vez que un cliente aprueba o paga, tu equipo recibe la notificación al instante.
                        </p>
                    </div>
                    <div class="uc-int-visual reveal">
                        <MagneticNodes client:load nodes={magneticNodes} />
                    </div>
                </div>
            </div>
        </section>



    
                <!-- POWER SECTION -->
        <section class="uc-power">
            <div class="uc-container">
                <h2 class="uc-power-title reveal">Escala tu agencia con el motor financiero de Cord</h2>
                <div class="uc-power-grid">
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-toggle"></div></div>
                        <h3>Igualas mensuales sin perseguir pagos</h3>
                        <p>Envía la cotización de la iguala, tu cliente la aprueba con firma digital, el CFDI se timbra solo y Cord manda recordatorios automáticos si no ha pagado antes del vencimiento. Menos correos, más cobros.</p>
                    </div>
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-doc"></div></div>
                        <h3>Hitos y facturación por proyecto</h3>
                        <p>Cobra anticipos o pagos contra entrega fácilmente. Las <a href="#">facturas por hitos</a> de Cord permiten programar fechas de cobro asociadas a las etapas de tus proyectos creativos.</p>
                    </div>
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-sync"></div></div>
                        <h3>Cartera y cobranza con IA</h3>
                        <p>El módulo de cobranza de Cord muestra el aging de cada cliente, las igualas vencidas y el saldo por cobrar. El agente de IA puede negociar planes de pago con deudores de forma autónoma cuando lo activas.</p>
                    </div>
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-card"></div></div>
                        <h3>Portal de pagos para clientes</h3>
                        <p>Ofrece una experiencia verdaderamente premium. Tus clientes tendrán un <a href="#">portal de facturación</a> propio donde podrán descargar sus facturas, revisar estados de cuenta y pagar en línea.</p>
                    </div>
                </div>
            </div>
        </section>
    <Footer />

</Layout>

<style>
    /* VARIABLES Y UTILIDADES GLOBALES PARA USE CASES */
    .use-case-main {
        background: var(--color-bg);
        padding-top: 0;
        overflow-x: hidden;
        color: var(--color-text-muted);
    }


    .uc-container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 5%;
    }

    /* ── HERO SECTION ── */
    .uc-hero-trust-group {
        position: relative;
        overflow: hidden;
        background: #ffffff;
    }

    /* ── HERO SECTION ── */
    .uc-hero {
        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        padding: 8rem 0 4rem;
    }

    /* Shader background (R3F) — fondo absoluto del hero */
    .uc-hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }
    /* Fade suave hacia el blanco del contenido (legibilidad del texto) */
    .uc-hero-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.55) 38%, rgba(255,255,255,0) 72%);
        pointer-events: none;
        z-index: 2;
    }

    .uc-hero-inner {
        position: relative;
        z-index: 1;
        width: 100%;
    }

    .uc-hero-content {
        max-width: 640px;
    }

    .uc-title {
        font-size: clamp(2.2rem, 4vw, 3.8rem);
        font-weight: 800;
        color: var(--color-blue-deep);
        line-height: 1.1;
        letter-spacing: -0.04em;
        margin-bottom: 1.2rem;
        text-wrap: balance;
    }

    .uc-sub {
        font-size: 1.15rem;
        color: var(--color-text-muted);
        line-height: 1.6;
        margin-bottom: 2rem;
        max-width: 90%;
    }

    /* ── BUTTONS (estilo soluciones/startups) ── */
    .uc-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn-luxe {
        position: relative;
        display: inline-flex; align-items: center; justify-content: center;
        background: var(--color-blue-deep); color: #fff;
        padding: 18px 38px; border-radius: 100px;
        font-size: 0.95rem; font-weight: 600; text-decoration: none;
        overflow: hidden;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 8px 24px rgba(10, 25, 47, 0.2);
    }
    .btn-luxe span { position: relative; z-index: 2; }
    .btn-arrow {
        position: relative; z-index: 2; display: inline-block;
        width: 16px; height: 16px; margin-left: 6px;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .btn-luxe:hover .btn-arrow { transform: translateX(4px); }
    .btn-shimmer {
        position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.18), transparent);
        transform: skew(-20deg); transition: 0s; z-index: 1;
    }
    .btn-luxe:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(10, 25, 47, 0.3);
    }
    .btn-luxe:active {
        transform: translateY(-1px);
        box-shadow: 0 2px 4px rgba(10, 25, 47, 0.1);
