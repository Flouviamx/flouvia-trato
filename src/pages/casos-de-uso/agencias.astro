    .uc-pi-chart {
        display: flex;
        align-items: flex-end;
        gap: 4px;
        height: 24px;
    }
    .uc-pi-chart span {
        width: 6px;
        background: #0f172a;
        border-radius: 2px 2px 0 0;
    }
    .uc-pi-chart span:nth-child(1) { height: 12px; background: #cbd5e1; }
    .uc-pi-chart span:nth-child(2) { height: 18px; }
    .uc-pi-chart span:nth-child(3) { height: 24px; background: #020617; }
    
    /* 3. Sync / Refresh (using CSS borders) */
    .uc-pi-sync {
        width: 24px;
        height: 24px;
        border: 3px solid #0f172a;
        border-top-color: transparent;
        border-radius: 50%;
        position: relative;
    }
    .uc-pi-sync::after {
        content: '';
        position: absolute;
        top: -6px;
        right: -3px;
        border-left: 6px solid transparent;
        border-right: 6px solid transparent;
        border-top: 6px solid #0f172a;
        transform: rotate(-45deg);
    }
    
    /* 4. Invoice / Document */
    .uc-pi-doc {
        width: 20px;
        height: 26px;
        background: #fff;
        border: 2px solid #0f172a;
        border-radius: 4px;
        position: relative;
    }
    .uc-pi-doc::before {
        content: '';
        position: absolute;
        top: 4px; left: 3px; right: 8px;
        height: 2px; background: #0f172a;
    }
    .uc-pi-doc::after {
        content: '';
        position: absolute;
        top: 10px; left: 3px; right: 3px;
        height: 2px; background: #0f172a;
    }
    
    /* 5. Wallet / Card */
    .uc-pi-card {
        width: 26px;
        height: 18px;
        background: #0f172a;
        border-radius: 4px;
        position: relative;
    }
    .uc-pi-card::after {
        content: '';
        position: absolute;
        top: 4px; left: 0; right: 0;
        height: 4px;
        background: #475569;
    }
    
    /* 6. Code / Bracket */
    .uc-pi-code {
        color: #0f172a;
        font-family: monospace;
        font-size: 20px;
