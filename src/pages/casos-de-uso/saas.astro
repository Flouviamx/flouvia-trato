---

export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import MagneticNodes from '../../components/MagneticNodes.jsx';
import RampShader from '../../components/soluciones/RampShader.jsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para SaaS B2B | Contratos, Cobros y CFDI";
const metaDesc = "Cierra contratos B2B, cobra en línea y emite CFDI 4.0 en automático. La plataforma de ventas para empresas SaaS en México.";

const magneticNodes = [
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://stripe.com&size=128", alt: "Stripe", top: "10%", left: "30%", width: 100, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://notion.so&size=128", alt: "Notion", top: "25%", left: "65%", width: 140, zIndex: 3 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://vercel.com&size=128", alt: "Vercel", top: "50%", left: "15%", width: 120, zIndex: 1 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://slack.com&size=128", alt: "Slack", top: "75%", left: "45%", width: 90, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://aws.amazon.com&size=128", alt: "AWS", top: "60%", left: "80%", width: 110, zIndex: 1 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://github.com&size=128", alt: "GitHub", top: "-5%", left: "75%", width: 70, zIndex: 1 }
];

---


<Layout title={metaTitle} description={metaDesc}>
    <Nav />
    
    <main class="use-case-main">
        <!-- HERO (shader full-bleed, Light) -->
        <header class="uc-hero">
                        <div class="uc-container uc-hero-inner">
                <div class="uc-hero-content">
                    <h1 class="uc-title reveal">Contratos B2B y cobros para el software moderno</h1>
                    <p class="uc-sub reveal">
                        Envía propuestas interactivas, firma digitalmente los contratos y emite CFDI 4.0 al instante. Construido para empresas SaaS que venden a otras empresas en México.
                    </p>
                    <div class="uc-actions reveal">
                        <a href="/registro" class="btn-luxe">
                            <span>Empezar ahora</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost"><span>Contactar a ventas</span></a>
                    </div>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Empresas de SaaS innovadoras crecen con Cord</p>
            <div class="uc-logos">
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://linear.app&size=64" alt="Linear" width="24" height="24" loading="lazy" />
                    <span>Linear</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://vercel.com&size=64" alt="Vercel" width="24" height="24" loading="lazy" />
                    <span>Vercel</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://stripe.com&size=64" alt="Stripe" width="24" height="24" loading="lazy" />
                    <span>Stripe</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://notion.so&size=64" alt="Notion" width="24" height="24" loading="lazy" />
                    <span>Notion</span>
                </div>
            </div>
        </section>
        </div>

        <!-- STRIPE-LIKE SPLIT SECTION -->
        <section class="uc-split-feature">
            <div class="uc-container">
                <div class="uc-split-grid">
                    
                    <div class="uc-split-text reveal">
                        <span class="uc-split-label">Contratos y Cobros</span>
                        <h2 class="uc-split-title">Propuestas que cierran y facturas que salen solas</h2>
                        <p class="uc-split-desc">
                            Desde el primer contacto hasta el CFDI timbrado. Cord centraliza la cotización, la aprobación digital y la facturación en un solo flujo.
                        </p>
                        
                        <div class="uc-split-list">
                            <div class="uc-feature-item">
                                <div class="uc-feature-icon">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <defs>
                                            <linearGradient id="cord-blue-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#1e3a8a" />
                                                <stop offset="100%" stop-color="#0f172a" />
                                            </linearGradient>
                                        </defs>
                                        <polygon points="5 3 19 12 5 21 5 3" fill="url(#cord-blue-grad)" />
                                    </svg>
                                </div>
                                <div class="uc-feature-content">
                                    <h3>Planes y precios por nivel de cliente</h3>
                                    <p>Asigna niveles (Estándar, Agencia, Enterprise) con descuentos fijos por cliente. El cotizador aplica el precio correcto al instante, sin hojas de cálculo.</p>
                                </div>
                            </div>
                            
                            <div class="uc-feature-item">
                                <div class="uc-feature-icon">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <defs>
                                            <linearGradient id="cord-slate-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#334155" />
                                                <stop offset="100%" stop-color="#94a3b8" />
                                            </linearGradient>
                                        </defs>
                                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" fill="url(#cord-slate-grad)"/>
                                        <circle cx="7" cy="7" r="2" fill="#fff"/>
                                    </svg>
                                </div>
                                <div class="uc-feature-content">
                                    <h3>CFDI 4.0 al aprobar la propuesta</h3>
                                    <p>En cuanto tu cliente firma la cotización en línea, Cord timbra el CFDI con el SAT vía Facturapi y lo envía por correo. Sin captura manual, sin esperas.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="uc-split-mockup reveal">
                        <div class="uc-mockup-wrapper">
                            <div class="uc-mockup-header">
                                <div class="uc-mockup-logo">
                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="#0a2540"><rect x="2" y="2" width="20" height="20" rx="4"/></svg>
                                    Nexus SaaS
                                </div>
                                <div class="uc-mockup-nav">
                                    <span>Dashboard</span>
                                    <span class="active">Suscripciones</span>
                                    <span>Settings</span>
                                </div>
                            </div>
                            
                            <div class="uc-mockup-body" style="padding: 20px;">
                                <div class="uc-saas-checkout">
                                    <div class="uc-sc-header">
                                        <h4>Resumen de Contrato</h4>
                                        <div class="uc-sc-status">Pendiente</div>
                                    </div>
                                    <div class="uc-sc-plan">
                                        <div class="uc-sc-plan-info">
                                            <span class="uc-sc-tier">Plan Enterprise</span>
                                            <span class="uc-sc-seats">50 Asientos (Anual)</span>
                                        </div>
                                        <div class="uc-sc-price">$45,000<span>/año</span></div>
                                    </div>
                                    <div class="uc-sc-breakdown">
                                        <div class="uc-sc-row">
                                            <span>Licencias (50 x $1k)</span>
                                            <span>$50,000</span>
                                        </div>
                                        <div class="uc-sc-row uc-sc-discount">
                                            <span>Descuento (10%)</span>
                                            <span>-$5,000</span>
                                        </div>
                                        <div class="uc-sc-divider"></div>
                                        <div class="uc-sc-row uc-sc-total">
                                            <span>Total Neto</span>
                                            <span>$45,000</span>
                                        </div>
                                    </div>
                                    <div class="uc-sc-actions">
                                        <div class="uc-sc-btn">Firmar y Emitir CFDI</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </section>

                <!-- SECONDARY BENEFITS SECTION -->
        <section class="uc-benefits">
            <div class="uc-container">
                <div class="uc-benefits-intro reveal">
                    <span class="uc-split-label">Sin trabajo manual</span>
                    <h2 class="uc-split-title">Cobra rápido y mantén a tu equipo enfocado en el producto</h2>
                    <p class="uc-split-desc">
                        Tu equipo de ventas genera la propuesta en Cord, el cliente la aprueba en un clic y el CFDI sale solo. Sin perseguir firmas ni capturar datos fiscales manualmente.
                    </p>
                </div>

                <div class="uc-bento-cards">
                    <!-- Tarjeta 1 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Link de pago y CFDI en el mismo flujo</h3>
                            <p>Tu cliente recibe el link de la cotización, paga con tarjeta o SPEI, y Cord emite el CFDI 4.0 al instante. Sin recapturar datos, sin coordinar por correo.</p>
                            <a href="/registro" class="uc-link-arrow">Empieza ahora mismo <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup">
                            <div class="uc-mockup-bg cord-bg-1"></div>
                            <div class="uc-mini-invoice">
                                <div class="uc-mi-logo">N</div>
                                <div class="uc-mi-title">Factura de Nexus SaaS</div>
                                <div class="uc-mi-sub">Cobrado a Acme Corp</div>
                                <div class="uc-mi-amount">$9,900.00 <span class="uc-mi-currency">MXN</span></div>
                                <div class="uc-mi-form">
                                    <div class="uc-mi-input"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg> Tarjeta terminada en 4242</div>
                                    <div class="uc-mi-btn">Pagado exitosamente</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tarjeta 2 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Portal de cliente con tu marca en minutos</h3>
                            <p>Cada cotización tiene su propio link seguro donde tu cliente revisa el desglose, descarga el PDF y el XML, aprueba o rechaza con firma digital. Todo en los colores de tu empresa.</p>
                            <a href="/registro" class="uc-link-arrow">Empieza ahora mismo <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup" style="background:#fff;">
                            <div class="uc-mini-portal">
                                <div class="uc-mp-sidebar">
                                    <div class="uc-mp-brand"><div class="uc-mp-dot"></div> Nexus</div>
                                    <div class="uc-mp-nav">Planes</div>
                                    <div class="uc-mp-nav">Facturación</div>
                                </div>
                                <div class="uc-mp-main">
                                    <div class="uc-mp-header">Facturación</div>
                                    <div class="uc-mp-card">
                                        <div class="uc-mp-row">
                                            <div>
                                                <strong>Plan Pro (Anual)</strong>
                                                <span>Se renueva el 15/Nov/2026</span>
                                            </div>
                                            <div class="uc-mp-tag">Activo</div>
                                        </div>
                                        <div class="uc-mp-divider"></div>
                                        <div class="uc-mp-row">
                                            <span>•••• 4242 (Vence 12/28)</span>
                                            <span style="color:#0f172a; font-weight:600; cursor:pointer;">Actualizar</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Micro Features Grid -->
                <div class="uc-micro-features reveal">
                    <h3 class="uc-mf-title">Más velocidad en cada etapa del ciclo comercial</h3>
                    <div class="uc-mf-grid">
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                            </div>
                            <h4>Webhooks en cada evento</h4>
                            <p>Cord emite eventos reales — <code>quote.approved</code>, <code>quote.paid</code>, <code>quote.invoiced</code> — que puedes escuchar desde Zapier, Make o tu propio backend.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M16.2 7.8l-2 6.3-6.4 2.1 2-6.3z"></path></svg>
                            </div>
                            <h4>Cobranza automática</h4>
                            <p>Si un contrato vence y no se ha pagado, Cord envía recordatorios por correo y WhatsApp antes del vencimiento sin que tengas que intervenir.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                            </div>
                            <h4>Control de aprobaciones</h4>
                            <p>Define umbrales de descuento y margen mínimo. Si un vendedor se pasa, la propuesta se congela y espera aprobación del gerente antes de salir.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                            </div>
                            <h4>Correos al instante</h4>
                            <p>Tu cliente recibe el link de la propuesta por correo al enviar, y tú recibes una notificación en cuanto la abre, la aprueba o la rechaza.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    

        <!-- INTEGRATIONS SECTION -->
        <section class="uc-integrations">
            <div class="uc-container">
                <div class="uc-int-grid">
                    <div class="uc-int-text reveal">
                        <h2>Conecta Cord con tu stack vía webhooks y API</h2>
                        <p>
                            Cord emite eventos reales en cada etapa del ciclo de ventas — <code>quote.sent</code>, <code>quote.approved</code>, <code>quote.paid</code> — que puedes escuchar desde Zapier, Make, n8n o tu propio backend para sincronizar con Notion, Slack, tu CRM o cualquier herramienta de tu equipo.
                        </p>
                    </div>
                    <div class="uc-int-visual reveal">
                        <MagneticNodes client:load nodes={magneticNodes} />
                    </div>
                </div>
            </div>
        </section>



    
                <!-- POWER SECTION -->
        <section class="uc-power">
            <div class="uc-container">
                <h2 class="uc-power-title reveal">Cierra más contratos, cobra más rápido</h2>
                <div class="uc-power-grid">
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-toggle"></div></div>
                        <h3>Propuestas con precios por nivel de cliente</h3>
                        <p>Define niveles — Estándar, Plata, Oro, Distribuidor — y Cord aplica el descuento correspondiente automáticamente al elegir el cliente. Menos negociación improvisada, márgenes más controlados.</p>
                    </div>
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-sync"></div></div>
                        <h3>Portal de cliente con tu marca</h3>
                        <p>Cada propuesta genera un link seguro donde tu cliente revisa el desglose, aprueba con firma digital y descarga el PDF y el XML del CFDI — sin que tengas que mandar documentos por correo.</p>
                    </div>
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-doc"></div></div>
                        <h3>CFDI 4.0 sin salir de Cord</h3>
                        <p>Al aprobar la propuesta, Cord timbra el CFDI 4.0 vía PAC certificado. El XML y el PDF quedan vinculados a la cotización y disponibles para descarga desde el portal del cliente.</p>
                    </div>
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-chart"><span></span><span></span><span></span></div></div>
                        <h3>Seguimiento en vivo y cobranza</h3>
                        <p>Sabes en tiempo real cuándo tu cliente abrió la propuesta. Si no ha pagado, Cord envía recordatorios automáticos por correo y WhatsApp antes del vencimiento sin que tengas que intervenir.</p>
                    </div>
                </div>
            </div>
        </section>
    <Footer />

</Layout>

<style>
    /* VARIABLES Y UTILIDADES GLOBALES PARA USE CASES */
    .use-case-main {
        background: #fff;
        padding-top: 0;
        overflow-x: hidden;
        color: #425466; /* Texto Stripe */
    }

    .uc-container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 5%;
    }

    /* ── HERO SECTION (shader full-bleed) ── */
    .uc-hero {
        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        padding: 8rem 0 4rem;
        background: #ffffff;
        overflow: hidden;
        
    }

    /* Shader background (R3F) — fondo absoluto del hero */
    .uc-hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }
    /* Fade suave hacia el blanco del contenido (legibilidad del texto) */
    .uc-hero-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.55) 38%, rgba(255,255,255,0) 72%);
        pointer-events: none;
        z-index: 2;
    }

    .uc-hero-inner {
        position: relative;
        z-index: 1;
        width: 100%;
    }

    .uc-hero-content {
        max-width: 640px;
    }

    .uc-title {
        font-size: clamp(2.2rem, 4vw, 3.8rem);
        font-weight: 800;
        color: #0a2540;
        line-height: 1.1;
        letter-spacing: -0.04em;
        margin-bottom: 1.2rem;
        text-wrap: balance;
    }

    .uc-sub {
        font-size: 1.15rem;
        color: #425466;
        line-height: 1.6;
        margin-bottom: 2rem;
        max-width: 90%;
    }

    .uc-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    /* ── BUTTONS (estilo soluciones/startups) ── */
    .btn-luxe {
        position: relative;
        display: inline-flex; align-items: center; justify-content: center;
        background: #0a2540; color: #fff;
        padding: 18px 38px; border-radius: 100px;
        font-size: 0.95rem; font-weight: 600; text-decoration: none;
        overflow: hidden;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 8px 24px rgba(10, 37, 64, 0.2);
    }
    .btn-luxe span { position: relative; z-index: 2; }
    .btn-arrow {
        position: relative; z-index: 2; display: inline-block;
        width: 16px; height: 16px; margin-left: 6px;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .btn-luxe:hover .btn-arrow { transform: translateX(4px); }
    .btn-shimmer {
        position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.18), transparent);
        transform: skew(-20deg); transition: 0s; z-index: 1;
    }
    .btn-luxe:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(10, 37, 64, 0.3);
    }
    .btn-luxe:active {
        transform: translateY(-1px);
        box-shadow: 0 2px 4px rgba(10, 37, 64, 0.1);
    }
    .btn-luxe:hover .btn-shimmer {
        left: 150%;
        transition: left 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .btn-ghost {
        display: inline-flex; align-items: center; gap: 9px;
        color: #0a2540; text-decoration: none;
        font-size: 1rem; font-weight: 600;
        padding: 15px 26px; border-radius: 100px;
        border: 1px solid rgba(10, 37, 64, 0.15);
        background: rgba(10, 37, 64, 0.03);
        transition: background 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
    }
    .btn-ghost:hover {
        background: rgba(10, 37, 64, 0.08);
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.05);
    }

    /* ── TRUST LOGOS ── */
    .uc-trust {
        text-align: center;
        padding: 3rem 5%;
        background: #fff;
    }
    .uc-trust p {
        font-size: 0.9rem; font-weight: 600; color: #687385; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5rem;
    }
    .uc-logos {
        display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap; align-items: center;
    }
    .trust-logo-item {
        display: flex; align-items: center; gap: 8px;
        font-size: 1.25rem; font-weight: 700; color: #a1a9b3; letter-spacing: -0.5px;
        filter: grayscale(100%) opacity(0.8);
        transition: all 0.3s ease;
    }
    .trust-logo-item:hover {
