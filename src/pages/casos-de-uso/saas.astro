---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import RampShader from '../../components/soluciones/RampShader.jsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para SaaS B2B | Gestión de Suscripciones y Contratos";
const metaDesc = "Optimiza tus cobros recurrentes y contratos empresariales con Cord. La plataforma ideal para startups SaaS y negocios de software.";
---

<Layout title={metaTitle} description={metaDesc}>
    <Nav />
    
    <main class="use-case-main">
        <!-- HERO (shader full-bleed, Light) -->
        <header class="uc-hero">
            <div class="uc-hero-bg">
                <RampShader client:only="react" variant="blue" />
            </div>
            <div class="uc-container uc-hero-inner">
                <div class="uc-hero-content">
                    <h1 class="uc-title reveal">Gestión de suscripciones para el software moderno</h1>
                    <p class="uc-sub reveal">
                        Automatiza los pagos recurrentes, unifica tus contratos B2B y emite CFDI 4.0 en automático. Construido para empresas SaaS de alto crecimiento.
                    </p>
                    <div class="uc-actions reveal">
                        <a href="/registro" class="btn-luxe">
                            <span>Empezar ahora</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost"><span>Contactar a ventas</span></a>
                    </div>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Empresas de SaaS innovadoras crecen con Cord</p>
            <div class="uc-logos">
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://linear.app&size=64" alt="Linear" width="24" height="24" loading="lazy" />
                    <span>Linear</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://vercel.com&size=64" alt="Vercel" width="24" height="24" loading="lazy" />
                    <span>Vercel</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://stripe.com&size=64" alt="Stripe" width="24" height="24" loading="lazy" />
                    <span>Stripe</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://notion.so&size=64" alt="Notion" width="24" height="24" loading="lazy" />
                    <span>Notion</span>
                </div>
            </div>
        </section>

        <!-- STRIPE-LIKE SPLIT SECTION -->
        <section class="uc-split-feature">
            <div class="uc-container">
                <div class="uc-split-grid">
                    
                    <div class="uc-split-text reveal">
                        <span class="uc-split-label">Billing Engine</span>
                        <h2 class="uc-split-title">Suscripciones diseñadas para escalar</h2>
                        <p class="uc-split-desc">
                            Maneja facturación recurrente, prorrateos por asiento y asientos adicionales sin dolores de cabeza operativos en tu <a href="#">pasarela de pagos</a>.
                        </p>
                        
                        <div class="uc-split-list">
                            <div class="uc-feature-item">
                                <div class="uc-feature-icon">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <defs>
                                            <linearGradient id="cord-blue-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#1e3a8a" />
                                                <stop offset="100%" stop-color="#3b82f6" />
                                            </linearGradient>
                                        </defs>
                                        <polygon points="5 3 19 12 5 21 5 3" fill="url(#cord-blue-grad)" />
                                    </svg>
                                </div>
                                <div class="uc-feature-content">
                                    <h3>Modelos de precios complejos</h3>
                                    <p>Desde <a href="#">tarifas fijas</a> hasta <a href="#">facturación por uso</a> o por volumen, nuestro motor de pricing se adapta a la evolución de tu modelo B2B al instante.</p>
                                </div>
                            </div>
                            
                            <div class="uc-feature-item">
                                <div class="uc-feature-icon">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <defs>
                                            <linearGradient id="cord-slate-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#334155" />
                                                <stop offset="100%" stop-color="#94a3b8" />
                                            </linearGradient>
                                        </defs>
                                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" fill="url(#cord-slate-grad)"/>
                                        <circle cx="7" cy="7" r="2" fill="#fff"/>
                                    </svg>
                                </div>
                                <div class="uc-feature-content">
                                    <h3>Facturación automatizada (CFDI)</h3>
                                    <p>Emitir facturas válidas en México ya no requiere intervención humana. Tus clientes reciben sus <a href="#">comprobantes fiscales</a> automáticamente apenas se concreta el cargo mensual de su membresía.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="uc-split-mockup reveal">
                        <div class="uc-mockup-wrapper">
                            <div class="uc-mockup-header">
                                <div class="uc-mockup-logo">
                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="#0a2540"><rect x="2" y="2" width="20" height="20" rx="4"/></svg>
                                    Nexus SaaS
                                </div>
                                <div class="uc-mockup-nav">
                                    <span>Dashboard</span>
                                    <span class="active">Suscripciones</span>
                                    <span>Settings</span>
                                </div>
                            </div>
                            
                            <div class="uc-mockup-body">
                                <h4>Planes de Suscripción</h4>
                                <p>Elige el plan ideal para escalar tu equipo</p>
                                
                                <div class="uc-mockup-cards">
                                    <div class="uc-mc uc-mc-1">
                                        <div class="uc-mc-title">Hobby</div>
                                        <div class="uc-mc-icon">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r="2" fill="#fff"/></svg>
                                        </div>
                                        <div class="uc-mc-btn">Activar</div>
                                    </div>
                                    <div class="uc-mc uc-mc-2">
                                        <div class="uc-mc-badge">Scale</div>
                                        <div class="uc-mc-title">Pro</div>
                                        <div class="uc-mc-icon">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        </div>
                                        <div class="uc-mc-btn">Activar</div>
                                    </div>
                                    <div class="uc-mc uc-mc-3">
                                        <div class="uc-mc-title">Enterprise</div>
                                        <div class="uc-mc-icon">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r="2" fill="#fff"/></svg>
                                        </div>
                                        <div class="uc-mc-btn">Contactar</div>
                                    </div>
                                </div>
                                
                                <div class="uc-mockup-features">
                                    <ul>
                                        <li>1 proyecto activo</li>
                                        <li>10 miembros</li>
                                        <li>Soporte comunitario</li>
                                    </ul>
                                    <ul>
                                        <li>Proyectos ilimitados</li>
                                        <li>Hasta 50 miembros</li>
                                        <li>Integraciones API</li>
                                        <li>Soporte prioritario</li>
                                    </ul>
                                    <ul>
                                        <li>Entornos dedicados</li>
                                        <li>Miembros ilimitados</li>
                                        <li>Single Sign-On (SSO)</li>
                                        <li>Account manager</li>
                                        <li>SLA de 99.9%</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </section>

                <!-- SECONDARY BENEFITS SECTION -->
        <section class="uc-benefits">
            <div class="uc-container">
                <div class="uc-benefits-intro reveal">
                    <span class="uc-split-label">Reduce el trabajo de ingeniería</span>
                    <h2 class="uc-split-title">Ahorra tiempo y recursos dedicados a los cobros</h2>
                    <p class="uc-split-desc">
                        Atiende tus necesidades de cobranza sin comprometer la capacidad de tus ingenieros. Gracias a las interfaces de Cord, podrás ofrecer experiencias de cobro optimizadas mientras centras todos tus esfuerzos en desarrollar tu producto principal.
                    </p>
                </div>

                <div class="uc-bento-cards">
                    <!-- Tarjeta 1 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Recibe pagos más rápido con facturas prediseñadas</h3>
                            <p>Las facturas alojadas por Cord se cobran automáticamente y emiten el CFDI 4.0 al instante. Contamos con flujos optimizados para B2B que facilitan el cobro a clientes empresariales en todo México.</p>
                            <a href="/registro" class="uc-link-arrow">Empieza ahora mismo <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup">
                            <div class="uc-mockup-bg cord-bg-1"></div>
                            <div class="uc-mini-invoice">
                                <div class="uc-mi-logo">N</div>
                                <div class="uc-mi-title">Factura de Nexus SaaS</div>
                                <div class="uc-mi-sub">Cobrado a Acme Corp</div>
                                <div class="uc-mi-amount">$9,900.00 <span class="uc-mi-currency">MXN</span></div>
                                <div class="uc-mi-form">
                                    <div class="uc-mi-input"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg> Tarjeta terminada en 4242</div>
                                    <div class="uc-mi-btn">Pagado exitosamente</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tarjeta 2 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Lanza un portal de clientes en cuestión de minutos</h3>
                            <p>Deja que tus clientes modifiquen su suscripción, actualicen sus datos fiscales o descarguen sus XMLs por medio de un enlace seguro en el portal de clientes prediseñado de Cord. Todo con los colores de tu marca.</p>
                            <a href="/registro" class="uc-link-arrow">Empieza ahora mismo <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup" style="background:#fff;">
                            <div class="uc-mini-portal">
                                <div class="uc-mp-sidebar">
                                    <div class="uc-mp-brand"><div class="uc-mp-dot"></div> Nexus</div>
                                    <div class="uc-mp-nav">Planes</div>
                                    <div class="uc-mp-nav">Facturación</div>
                                </div>
                                <div class="uc-mp-main">
                                    <div class="uc-mp-header">Facturación</div>
                                    <div class="uc-mp-card">
                                        <div class="uc-mp-row">
                                            <div>
                                                <strong>Plan Pro (Anual)</strong>
                                                <span>Se renueva el 15/Nov/2026</span>
                                            </div>
                                            <div class="uc-mp-tag">Activo</div>
                                        </div>
                                        <div class="uc-mp-divider"></div>
                                        <div class="uc-mp-row">
                                            <span>•••• 4242 (Vence 12/28)</span>
                                            <span style="color:#3b82f6; font-weight:600; cursor:pointer;">Actualizar</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Micro Features Grid -->
                <div class="uc-micro-features reveal">
                    <h3 class="uc-mf-title">Agiliza tus operaciones con la automatización integrada</h3>
                    <div class="uc-mf-grid">
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                            </div>
                            <h4>Automatización con webhooks</h4>
                            <p><a href="#" class="uc-link-inline">Activa operaciones</a> automáticamente en función de eventos como actualizaciones de planes, pagos exitosos y cancelaciones.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M16.2 7.8l-2 6.3-6.4 2.1 2-6.3z"></path></svg>
                            </div>
                            <h4>Prorrateo de cobros</h4>
                            <p>Cord <a href="#" class="uc-link-inline">prorratea</a> de forma automática el cobro exacto cuando tus usuarios añaden asientos o hacen upgrades a mitad de mes.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                            </div>
                            <h4>Programa suscripciones</h4>
                            <p><a href="#" class="uc-link-inline">Configura reglas</a> para modificar fácilmente las suscripciones a lo largo del tiempo, como pruebas gratis que pasan a planes de pago.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                            </div>
                            <h4>Recordatorios automáticos</h4>
                            <p>Maximiza la retención de clientes mediante <a href="#" class="uc-link-inline">dunning y correos automáticos</a> por tarjetas vencidas o pagos rechazados.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>


        <!-- CTA SECTION -->
        <section class="uc-cta-section">
            <div class="uc-container">
                <div class="uc-cta-box reveal">
                    <h2>¿Listo para escalar tu SaaS?</h2>
                    <p>Únete a las empresas que ya automatizan su pipeline B2B con Cord.</p>
                    <a href="/registro" class="btn-luxe">Comenzar gratis</a>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    /* VARIABLES Y UTILIDADES GLOBALES PARA USE CASES */
    .use-case-main {
        background: #fff;
        padding-top: 0;
        overflow-x: hidden;
        color: #425466; /* Texto Stripe */
    }

    .uc-container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 5%;
    }

    /* ── HERO SECTION (shader full-bleed) ── */
    .uc-hero {
        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        padding: 8rem 0 4rem;
        background: #ffffff;
        overflow: hidden;
        border-bottom: 1px solid #e6ebf1;
    }

    /* Shader background (R3F) — fondo absoluto del hero */
    .uc-hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }
    /* Fade suave hacia el blanco del contenido (legibilidad del texto) */
    .uc-hero-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.55) 38%, rgba(255,255,255,0) 72%);
        pointer-events: none;
        z-index: 2;
    }

    .uc-hero-inner {
        position: relative;
        z-index: 1;
        width: 100%;
    }

    .uc-hero-content {
        max-width: 640px;
    }

    .uc-title {
        font-size: clamp(2.2rem, 4vw, 3.8rem);
        font-weight: 800;
        color: #0a2540;
        line-height: 1.1;
        letter-spacing: -0.04em;
        margin-bottom: 1.2rem;
        text-wrap: balance;
    }

    .uc-sub {
        font-size: 1.15rem;
        color: #425466;
        line-height: 1.6;
        margin-bottom: 2rem;
        max-width: 90%;
    }

    .uc-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    /* ── BUTTONS (estilo soluciones/startups) ── */
    .btn-luxe {
        position: relative;
        display: inline-flex; align-items: center; justify-content: center;
        background: #0a2540; color: #fff;
        padding: 18px 38px; border-radius: 100px;
        font-size: 0.95rem; font-weight: 600; text-decoration: none;
        overflow: hidden;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 8px 24px rgba(10, 37, 64, 0.2);
    }
    .btn-luxe span { position: relative; z-index: 2; }
    .btn-arrow {
        position: relative; z-index: 2; display: inline-block;
        width: 16px; height: 16px; margin-left: 6px;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .btn-luxe:hover .btn-arrow { transform: translateX(4px); }
    .btn-shimmer {
        position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.18), transparent);
        transform: skew(-20deg); transition: 0s; z-index: 1;
    }
    .btn-luxe:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(10, 37, 64, 0.3);
    }
    .btn-luxe:active {
        transform: translateY(-1px);
        box-shadow: 0 2px 4px rgba(10, 37, 64, 0.1);
    }
    .btn-luxe:hover .btn-shimmer {
        left: 150%;
        transition: left 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .btn-ghost {
        display: inline-flex; align-items: center; gap: 9px;
        color: #0a2540; text-decoration: none;
        font-size: 1rem; font-weight: 600;
        padding: 15px 26px; border-radius: 100px;
        border: 1px solid rgba(10, 37, 64, 0.15);
        background: rgba(10, 37, 64, 0.03);
        transition: background 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
    }
    .btn-ghost:hover {
        background: rgba(10, 37, 64, 0.08);
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.05);
    }

    /* ── TRUST LOGOS ── */
    .uc-trust {
        text-align: center;
        padding: 3rem 5%;
        background: #fff;
    }
    .uc-trust p {
        font-size: 0.9rem; font-weight: 600; color: #687385; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5rem;
    }
    .uc-logos {
        display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap; align-items: center;
    }
    .trust-logo-item {
        display: flex; align-items: center; gap: 8px;
        font-size: 1.25rem; font-weight: 700; color: #a1a9b3; letter-spacing: -0.5px;
        filter: grayscale(100%) opacity(0.8);
        transition: all 0.3s ease;
    }
    .trust-logo-item:hover {
        filter: grayscale(0%) opacity(1);
        color: #0a2540;
    }
    .trust-logo-item img {
        border-radius: 4px;
    }

    /* ── STRIPE-LIKE SPLIT FEATURE ── */
    .uc-split-feature {
        padding: 6rem 0;
        background: #ffffff;
        border-bottom: 1px solid #e6ebf1;
    }
    
    .uc-split-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 6rem;
        align-items: center;
    }

    .uc-split-text {
        max-width: 480px;
    }

    .uc-split-label {
        font-size: 1rem;
        font-weight: 700;
        color: #0a192f;
        margin-bottom: 1.2rem;
        display: block;
    }

    .uc-split-title {
        font-size: clamp(2.2rem, 3.5vw, 3rem);
        font-weight: 800;
        color: #0a2540;
        line-height: 1.15;
        letter-spacing: -0.03em;
        margin-bottom: 1.5rem;
        text-wrap: balance;
    }

    .uc-split-desc {
        font-size: 1.1rem;
        color: #425466;
        line-height: 1.6;
        margin-bottom: 3.5rem;
    }
    .uc-split-desc a {
        color: #0a2540;
        text-decoration: none;
        font-weight: 600;
        border-bottom: 1px solid rgba(10,37,64,0.2);
        padding-bottom: 2px;
        transition: border-color 0.2s;
    }
    .uc-split-desc a:hover {
        border-color: #0a2540;
    }

    .uc-feature-item {
        display: flex;
        gap: 1.25rem;
        margin-bottom: 3rem;
    }

    .uc-feature-icon {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
    }
    .uc-feature-icon svg {
        width: 100%;
        height: 100%;
    }

    .uc-feature-content h3 {
        font-size: 1.15rem;
        font-weight: 700;
        color: #0a2540;
        margin-bottom: 0.8rem;
        line-height: 1.35;
    }

    .uc-feature-content p {
        font-size: 1rem;
