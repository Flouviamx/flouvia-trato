---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import RampShader from '../../components/soluciones/RampShader.jsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para Software Factories | Presupuestos y Hitos";
const metaDesc = "Envía presupuestos de desarrollo a la medida, divide pagos por hitos y mantén a tu equipo sincronizado.";
---

<Layout title={metaTitle} description={metaDesc}>
    <Nav />
    
    <main class="use-case-main">
        <!-- HERO (shader full-bleed, Light) -->
        <header class="uc-hero">
            <div class="uc-hero-bg">
                <RampShader client:only="react" variant="purple" />
            </div>
            <div class="uc-container uc-hero-inner">
                <div class="uc-hero-content">
                    <h1 class="uc-title reveal">Presupuestos a la medida para desarrollo de software</h1>
                    <p class="uc-sub reveal">
                        El desarrollo de software requiere claridad. Envía presupuestos detallados, divide los pagos por hitos (Milestones) y notifica a tu equipo de ingeniería.
                    </p>
                    <div class="uc-actions reveal">
                        <a href="/registro" class="btn-luxe">
                            <span>Empezar ahora</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost"><span>Contactar a ventas</span></a>
                    </div>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Las mejores agencias de desarrollo usan Cord</p>
            <div class="uc-logos">
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://cursor.sh&size=64" alt="Cursor" width="24" height="24" loading="lazy" />
                    <span>Cursor</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://vercel.com&size=64" alt="Vercel" width="24" height="24" loading="lazy" />
                    <span>Vercel</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://gitlab.com&size=64" alt="GitLab" width="24" height="24" loading="lazy" />
                    <span>GitLab</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://linear.app&size=64" alt="Linear" width="24" height="24" loading="lazy" />
                    <span>Linear</span>
                </div>
            </div>
        </section>

        <!-- STRIPE-LIKE SPLIT SECTION -->
        <section class="uc-split-feature">
            <div class="uc-container">
                <div class="uc-split-grid">
                    
                    <div class="uc-split-text reveal">
                        <span class="uc-split-label">Hitos y Entregables</span>
                        <h2 class="uc-split-title">Presupuestos técnicos y pagos ágiles</h2>
                        <p class="uc-split-desc">
                            El desarrollo de software requiere claridad. Divide tus proyectos en entregables, redacta en <a href="#">Markdown</a> y sincroniza los cobros con tu pipeline de CI/CD.
                        </p>
                        
                        <div class="uc-split-list">
                            <div class="uc-feature-item">
                                <div class="uc-feature-icon">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <defs>
                                            <linearGradient id="cord-blue-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#1e3a8a" />
                                                <stop offset="100%" stop-color="#3b82f6" />
                                            </linearGradient>
                                        </defs>
                                        <polygon points="5 3 19 12 5 21 5 3" fill="url(#cord-blue-grad)" />
                                    </svg>
                                </div>
                                <div class="uc-feature-content">
                                    <h3>Hitos de Entrega (Milestones)</h3>
                                    <p>No cobres todo al principio ni todo al final. Cobra automáticamente al cumplir cada <a href="#">fase del proyecto</a> y notifica al cliente para liberar el siguiente bloque.</p>
                                </div>
                            </div>
                            
                            <div class="uc-feature-item">
                                <div class="uc-feature-icon">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <defs>
                                            <linearGradient id="cord-slate-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#334155" />
                                                <stop offset="100%" stop-color="#94a3b8" />
                                            </linearGradient>
                                        </defs>
                                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" fill="url(#cord-slate-grad)"/>
                                        <circle cx="7" cy="7" r="2" fill="#fff"/>
                                    </svg>
                                </div>
                                <div class="uc-feature-content">
                                    <h3>Soporte para Código</h3>
                                    <p>Tus propuestas son técnicas. Incluye especificaciones de API, <a href="#">diagramas de arquitectura</a> o snippets de código directamente en el editor.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="uc-split-mockup reveal">
                        <div class="uc-mockup-wrapper">
                            <div class="uc-mockup-header">
                                <div class="uc-mockup-logo">
                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="#0a2540"><rect x="2" y="2" width="20" height="20" rx="4"/></svg>
                                    Build &amp; Ship Inc.
                                </div>
                                <div class="uc-mockup-nav">
                                    <span>Propuesta</span>
                                    <span class="active">Milestones</span>
                                    <span>Settings</span>
                                </div>
                            </div>
                            
                            <div class="uc-mockup-body">
                                <h4>Desarrollo de MVP SaaS</h4>
                                <p>Cronograma de pagos y entregables del proyecto</p>
                                
                                <div class="uc-mockup-cards">
                                    <div class="uc-mc uc-mc-1">
                                        <div class="uc-mc-title">Fase 1: Setup</div>
                                        <div class="uc-mc-icon">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r="2" fill="#fff"/></svg>
                                        </div>
                                        <div class="uc-mc-btn" style="background:#e2e8f0; color:#64748b;">Pagado (15%)</div>
                                    </div>
                                    <div class="uc-mc uc-mc-2">
                                        <div class="uc-mc-badge">En Progreso</div>
                                        <div class="uc-mc-title">Fase 2: Core</div>
                                        <div class="uc-mc-icon">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        </div>
                                        <div class="uc-mc-btn">Aprobar (50%)</div>
                                    </div>
                                    <div class="uc-mc uc-mc-3">
                                        <div class="uc-mc-title">Fase 3: Launch</div>
                                        <div class="uc-mc-icon">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r="2" fill="#fff"/></svg>
                                        </div>
                                        <div class="uc-mc-btn">Pendiente (35%)</div>
                                    </div>
                                </div>
                                
                                <div class="uc-mockup-features">
                                    <ul>
                                        <li>Arquitectura DB</li>
                                        <li>Diseño UI/UX</li>
                                        <li>Configuración CI/CD</li>
                                    </ul>
                                    <ul>
                                        <li>Desarrollo Backend API</li>
                                        <li>Integración Stripe</li>
                                        <li>Testing Automatizado</li>
                                    </ul>
                                    <ul>
                                        <li>Despliegue a Producción</li>
                                        <li>QA final y bugfixes</li>
                                        <li>Traspaso de repositorio</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </section>

                <!-- SECONDARY BENEFITS SECTION -->
        <section class="uc-benefits">
            <div class="uc-container">
                <div class="uc-benefits-intro reveal">
                    <span class="uc-split-label">Sincroniza desarrollo y finanzas</span>
                    <h2 class="uc-split-title">Cobra por tus hitos técnicos a tiempo</h2>
                    <p class="uc-split-desc">
                        El desarrollo de software tiene su propio ritmo. Conecta tus repositorios y tableros de control con tu ciclo de facturación para que nunca se te olvide cobrar un entregable aprobado.
                    </p>
                </div>

                <div class="uc-bento-cards">
                    <!-- Tarjeta 1 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Liberación de pagos por milestones</h3>
                            <p>Asocia el cobro de una factura a la aprobación de un Pull Request o al cierre de un sprint. Cord envía automáticamente el link de cobro a tu cliente tan pronto como el hito se marca como completado.</p>
                            <a href="/registro" class="uc-link-arrow">Integra tus repositorios <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup">
                            <div class="uc-mockup-bg cord-bg-1"></div>
                            <div class="uc-mini-invoice" style="width:260px; padding:16px;">
                                <div style="display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #e2e8f0; padding-bottom:12px; margin-bottom:12px;">
                                    <div style="display:flex; align-items:center; gap:8px;">
                                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                                        <span style="font-size:0.85rem; font-weight:700; color:#0a2540;">Hito 2: Core Backend</span>
                                    </div>
                                    <span style="font-size:0.75rem; color:#64748b;">$18,000 MXN</span>
                                </div>
                                <div style="text-align:left; font-size:0.75rem; color:#475569; display:flex; flex-direction:column; gap:8px;">
                                    <div style="display:flex; align-items:center; gap:6px;"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> PR #42 merged (API Auth)</div>
                                    <div style="display:flex; align-items:center; gap:6px;"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> PR #45 merged (DB Schema)</div>
                                    <div style="display:flex; align-items:center; gap:6px;"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="#94a3b8" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg> Cliente aprueba Staging</div>
                                </div>
                                <div class="uc-mi-form" style="margin-top:16px;">
                                    <div class="uc-mi-btn" style="background:#e2e8f0; color:#64748b;">Factura Pendiente de Hito</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tarjeta 2 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Presupuestos técnicos modulares</h3>
                            <p>Crea cotizaciones detalladas que tus clientes entienden, con opciones adicionales y up-sells (como "Migración AWS" o "Soporte 24/7") que pueden activar o desactivar antes de firmar.</p>
                            <a href="/registro" class="uc-link-arrow">Genera propuestas técnicas <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup" style="background:#fff;">
                            <div class="uc-mini-portal" style="flex-direction: column;">
                                <div class="uc-mp-sidebar" style="width: 100%; border-right: none; border-bottom: 1px solid #e2e8f0; flex-direction: row; align-items: center; justify-content: space-between; padding: 12px 20px;">
                                    <div class="uc-mp-brand" style="margin:0;"><div class="uc-mp-dot"></div> Tech Proposal</div>
                                    <div class="uc-mp-nav" style="background: #3b82f6; color: #fff; padding: 4px 10px; border-radius: 6px;">Firmar y Pagar</div>
                                </div>
                                <div class="uc-mp-main" style="padding: 16px 20px;">
                                    <div class="uc-mp-header" style="margin-bottom: 12px; font-size:1rem;">Módulos Adicionales</div>
                                    <div class="uc-mp-card" style="margin-bottom:8px; display:flex; align-items:center; justify-content:space-between;">
                                        <div>
                                            <strong>Infraestructura AWS + CI/CD</strong>
                                            <span style="font-size:0.75rem; color:#64748b; display:block;">Setup inicial y pipelines</span>
                                        </div>
                                        <div style="display:flex; align-items:center; gap:10px;">
                                            <span style="font-weight:600; font-size:0.8rem; color:#0a2540;">+$2,500</span>
                                            <div style="width:36px; height:20px; background:#3b82f6; border-radius:12px; position:relative;">
                                                <div style="width:16px; height:16px; background:#fff; border-radius:50%; position:absolute; top:2px; right:2px;"></div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="uc-mp-card" style="display:flex; align-items:center; justify-content:space-between; opacity:0.6;">
                                        <div>
                                            <strong>Soporte Extendido (SLA 99%)</strong>
                                            <span style="font-size:0.75rem; color:#64748b; display:block;">Respuesta en &lt; 2hrs</span>
                                        </div>
                                        <div style="display:flex; align-items:center; gap:10px;">
                                            <span style="font-weight:600; font-size:0.8rem; color:#0a2540;">+$800/mes</span>
                                            <div style="width:36px; height:20px; background:#e2e8f0; border-radius:12px; position:relative;">
                                                <div style="width:16px; height:16px; background:#fff; border-radius:50%; position:absolute; top:2px; left:2px;"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Micro Features Grid -->
                <div class="uc-micro-features reveal">
                    <h3 class="uc-mf-title">Diseñado para el ecosistema de desarrollo</h3>
                    <div class="uc-mf-grid">
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                            </div>
                            <h4>Integración API First</h4>
                            <p>Utiliza nuestra <a href="#" class="uc-link-inline">API REST GraphQL</a> para integrar Cord profundamente en tus propias herramientas internas y dashboards.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                            </div>
                            <h4>Webhooks fiables</h4>
                            <p>Escucha eventos financieros con <a href="#" class="uc-link-inline">webhooks</a> 100% tipados y con reintentos automáticos configurables.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                            </div>
                            <h4>Cobros Internacionales</h4>
                            <p>Factura a clientes en el extranjero en su <a href="#" class="uc-link-inline">moneda local</a>, mientras tú recibes pesos mexicanos de forma segura.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                            </div>
                            <h4>Gestión de horas extras</h4>
                            <p>Añade fácilmente registros de <a href="#" class="uc-link-inline">horas por soporte</a> o consultoría como partidas a la siguiente factura del mes.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    
                <!-- POWER SECTION -->
        <section class="uc-power">
            <div class="uc-container">
                <h2 class="uc-power-title reveal">Optimiza la rentabilidad de tu factory con Cord</h2>
                <div class="uc-power-grid">
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-code">&lt;/&gt;</div></div>
                        <h3>Cobros vinculados a tu código</h3>
                        <p>Automatiza el inicio de cobros desde tus repositorios. Cuando apruebas un Pull Request crítico o cierras un sprint, Cord puede <a href="#">disparar la facturación</a> correspondiente sin que el Project Manager intervenga.</p>
                    </div>
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-doc"></div></div>
                        <h3>Cálculo de horas facturables</h3>
                        <p>Transforma el trabajo de tus desarrolladores en ingresos reales. Conecta tus herramientas de time-tracking para emitir facturas precisas basadas en modelos de tiempo y materiales (T&M).</p>
                    </div>
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-card"></div></div>
                        <h3>Dispersión a proveedores y freelancers</h3>
                        <p>Si tu factory trabaja con talento externo o staff augmentation, Cord facilita los pagos. Automatiza las <a href="#">transferencias masivas</a> a tus colaboradores una vez que el cliente haya liquidado el proyecto.</p>
                    </div>
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-chart"><span></span><span></span><span></span></div></div>
                        <h3>Reportes de margen por proyecto</h3>
                        <p>Entiende qué proyectos son realmente rentables para la agencia. Nuestra <a href="#">analítica financiera</a> cruza los costos operativos de tu equipo de desarrollo con los ingresos generados para darte el margen exacto.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- INTEGRATIONS SECTION -->
        <section class="uc-integrations">
            <div class="uc-container">
                <div class="uc-int-grid">
                    <div class="uc-int-text reveal">
                        <h2>Automatiza la cobranza desde tus repositorios</h2>
                        <p>
                            Elimina el trabajo manual de verificar entregables. Integra Cord con <a href="#">GitHub</a> o <a href="#">GitLab</a> para disparar facturas automáticamente al hacer merge de Pull Requests, o asocia pagos a hitos completados en <a href="#">Jira</a> y <a href="#">Linear</a>.
                        </p>
                    </div>
                    <div class="uc-int-visual reveal">
                        <div class="uc-bubble uc-b-1"><div class="uc-bubble-inner"><img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://github.com&size=128" alt="GitHub"/></div></div>
                        <div class="uc-bubble uc-b-2"><div class="uc-bubble-inner"><img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://jira.com&size=128" alt="Jira"/></div></div>
                        <div class="uc-bubble uc-b-3"><div class="uc-bubble-inner"><img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://linear.app&size=128" alt="Linear"/></div></div>
                        <div class="uc-bubble uc-b-4"><div class="uc-bubble-inner"><img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://gitlab.com&size=128" alt="GitLab"/></div></div>
                        <div class="uc-bubble uc-b-5"><div class="uc-bubble-inner"><img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://slack.com&size=128" alt="Slack"/></div></div>
                        <div class="uc-bubble uc-b-6"><div class="uc-bubble-inner"><img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://aws.amazon.com&size=128" alt="AWS"/></div></div>
                    </div>
                </div>
            </div>
        </section>
    <Footer />

</Layout>

<style>
    /* VARIABLES Y UTILIDADES GLOBALES PARA USE CASES */
    .use-case-main {
        background: #fff;
        padding-top: 0;
        overflow-x: hidden;
        color: #425466; /* Texto Stripe */
    }

    .uc-container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 5%;
    }

    /* ── HERO SECTION (shader full-bleed) ── */
    .uc-hero {
        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        padding: 8rem 0 4rem;
        background: #ffffff;
        overflow: hidden;
        
    }

    /* Shader background (R3F) — fondo absoluto del hero */
    .uc-hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }
    /* Fade suave hacia el blanco del contenido (legibilidad del texto) */
    .uc-hero-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.55) 38%, rgba(255,255,255,0) 72%);
        pointer-events: none;
        z-index: 2;
    }

    .uc-hero-inner {
        position: relative;
        z-index: 1;
        width: 100%;
    }

