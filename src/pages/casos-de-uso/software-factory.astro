        line-height: 1.2;
        letter-spacing: -0.02em;
        max-width: 600px;
    }
    .uc-power-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem 3rem;
    }
    .uc-power-item {
        display: flex;
        flex-direction: column;
    }
    
    /* CSS MOCKUPS FOR ICONS */
    .uc-power-icon {
        width: 54px;
        height: 54px;
        margin-bottom: 1.5rem;
        position: relative;
        border-radius: 12px;
        background: #f8fafc;
        box-shadow: 0 4px 12px rgba(10,37,64,0.06);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    
    /* 1. Toggle / Switch */
    .uc-pi-toggle {
        width: 28px;
        height: 16px;
        background: #0f172a;
        border-radius: 10px;
        position: relative;
    }
    .uc-pi-toggle::after {
        content: '';
        position: absolute;
        top: 2px;
        right: 2px;
        width: 12px;
        height: 12px;
        background: #fff;
        border-radius: 50%;
    }
    
    /* 2. Chart / Bars */
    .uc-pi-chart {
        display: flex;
        align-items: flex-end;
        gap: 4px;
        height: 24px;
    }
    .uc-pi-chart span {
        width: 6px;
        background: #0f172a;
        border-radius: 2px 2px 0 0;
    }
    .uc-pi-chart span:nth-child(1) { height: 12px; background: #cbd5e1; }
    .uc-pi-chart span:nth-child(2) { height: 18px; }
    .uc-pi-chart span:nth-child(3) { height: 24px; background: #020617; }
    
    /* 3. Sync / Refresh (using CSS borders) */
    .uc-pi-sync {
        width: 24px;
        height: 24px;
        border: 3px solid #0f172a;
        border-top-color: transparent;
        border-radius: 50%;
        position: relative;
    }
    .uc-pi-sync::after {
        content: '';
        position: absolute;
        top: -6px;
        right: -3px;
        border-left: 6px solid transparent;
        border-right: 6px solid transparent;
        border-top: 6px solid #0f172a;
        transform: rotate(-45deg);
    }
    
    /* 4. Invoice / Document */
    .uc-pi-doc {
        width: 20px;
        height: 26px;
        background: #fff;
        border: 2px solid #0f172a;
        border-radius: 4px;
        position: relative;
    }
    .uc-pi-doc::before {
        content: '';
        position: absolute;
        top: 4px; left: 3px; right: 8px;
        height: 2px; background: #0f172a;
    }
    .uc-pi-doc::after {
        content: '';
        position: absolute;
        top: 10px; left: 3px; right: 3px;
        height: 2px; background: #0f172a;
    }
    
    /* 5. Wallet / Card */
    .uc-pi-card {
        width: 26px;
        height: 18px;
        background: #0f172a;
        border-radius: 4px;
        position: relative;
    }
    .uc-pi-card::after {
        content: '';
        position: absolute;
        top: 4px; left: 0; right: 0;
        height: 4px;
        background: #475569;
    }
    
    /* 6. Code / Bracket */
    .uc-pi-code {
        color: #0f172a;
        font-family: monospace;
        font-size: 20px;
        font-weight: bold;
        letter-spacing: -2px;
    }

    .uc-power-item h3 {
        font-size: 1.15rem;
        font-weight: 700;
        color: #0a2540;
        margin-bottom: 1rem;
        border-left: 3px solid #0f172a;
        padding-left: 12px;
        line-height: 1.4;
    }
    .uc-power-item p {
        font-size: 1.05rem;
        color: #425466;
        line-height: 1.6;
    }
    .uc-power-item a {
        color: #0f172a;
        text-decoration: none;
        font-weight: 700;
        border-bottom: 1px solid rgba(15,23,42,0.2);
        padding-bottom: 1px;
        transition: border-color 0.2s;
    }
    .uc-power-item a:hover {
        border-color: #0f172a;
    }

    @media (max-width: 768px) {
        .uc-power-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        .uc-power-title {
            font-size: 2rem;
            margin-bottom: 2.5rem;
        }
    }

</style>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('DOMContentLoaded', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if(reduced) return;

        gsap.utils.toArray('.reveal').forEach((el: any) => {
            gsap.fromTo(el, { opacity: 0, y: 20 }, {
                opacity: 1, y: 0, duration: 0.8, ease: 'power2.out',
                scrollTrigger: { trigger: el, start: 'top 85%' }
            });
        });
    });
</script>
