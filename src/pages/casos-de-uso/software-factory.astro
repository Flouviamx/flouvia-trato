    .uc-b-3 { width: 120px; height: 120px; top: 50%; left: 15%; animation-delay: -4s; z-index: 1; }
    .uc-b-4 { width: 90px; height: 90px; top: 75%; left: 45%; animation-delay: -1s; z-index: 2; }
    .uc-b-5 { width: 110px; height: 110px; top: 60%; left: 80%; animation-delay: -3s; z-index: 1; }
    .uc-b-6 { width: 70px; height: 70px; top: -5%; left: 75%; animation-delay: -5s; z-index: 1; }

    @media (max-width: 900px) {
        .uc-int-grid {
