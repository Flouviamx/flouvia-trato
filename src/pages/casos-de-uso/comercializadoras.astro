    @keyframes floatBubble {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-12px); }
    }
    
    .uc-bubble {
        position: absolute;
        animation: floatBubble 6s ease-in-out infinite;
    }
    .uc-bubble-inner {
        width: 100%;
        height: 100%;
        background: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 15px 35px rgba(10,37,64,0.08), 0 5px 15px rgba(10,37,64,0.03);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s;
    }
    .uc-bubble:hover .uc-bubble-inner {
        transform: scale(1.1);
        box-shadow: 0 20px 45px rgba(10,37,64,0.12), 0 10px 20px rgba(10,37,64,0.05);
    }
    .uc-bubble-inner img {
        width: 45%;
        height: 45%;
        object-fit: contain;
    }
    .uc-bubble-inner span {
        font-weight: 800;
        font-size: 2.5rem;
        color: #0a2540;
    }

