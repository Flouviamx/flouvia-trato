---

export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import MagneticNodes from '../../components/MagneticNodes.jsx';
import RampShader from '../../components/soluciones/RampShader.jsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const t = useTranslations(lang);

const metaTitle = "Cord para Comercializadoras B2B | Cotizaciones y Pedidos";
const metaDesc = "Digitaliza las ventas de tu comercializadora. Cotiza volumen, maneja descuentos por tier y automatiza facturas de grandes pedidos.";

const magneticNodes = [
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://salesforce.com&size=128", alt: "Salesforce", top: "10%", left: "30%", width: 100, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://sap.com&size=128", alt: "SAP", top: "25%", left: "65%", width: 140, zIndex: 3 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://quickbooks.intuit.com&size=128", alt: "QuickBooks", top: "50%", left: "15%", width: 120, zIndex: 1 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://shopify.com&size=128", alt: "Shopify", top: "75%", left: "45%", width: 90, zIndex: 2 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://oracle.com&size=128", alt: "Oracle", top: "60%", left: "80%", width: 110, zIndex: 1 },
    { src: "https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://whatsapp.com&size=128", alt: "WhatsApp", top: "-5%", left: "75%", width: 70, zIndex: 1 }
];

---


<Layout title={metaTitle} description={metaDesc}>
    <Nav />
    
    <main class="use-case-main">
        <!-- HERO (shader full-bleed, Light) -->
        <header class="uc-hero">
                        <div class="uc-container uc-hero-inner">
                <div class="uc-hero-content">
                    <h1 class="uc-title reveal">Ventas B2B al por mayor sin fricción</h1>
                    <p class="uc-sub reveal">
                        Cotiza miles de productos, aplica descuentos por volumen y cierra tratos a crédito. Todo sincronizado directamente a facturación CFDI 4.0.
                    </p>
                    <div class="uc-actions reveal">
                        <a href="/registro" class="btn-luxe">
                            <span>Empezar ahora</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost"><span>Contactar a ventas</span></a>
                    </div>
                </div>
            </div>
        </header>

        <!-- LOGOS / TRUST -->
        <section class="uc-trust reveal">
            <p>Distribuidores modernos operan con Cord</p>
            <div class="uc-logos">
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://grainger.com&size=64" alt="Grainger" width="24" height="24" loading="lazy" />
                    <span>Grainger</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://uline.com&size=64" alt="Uline" width="24" height="24" loading="lazy" />
                    <span>Uline</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://fastenal.com&size=64" alt="Fastenal" width="24" height="24" loading="lazy" />
                    <span>Fastenal</span>
                </div>
                <div class="trust-logo-item">
                    <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://sysco.com&size=64" alt="Sysco" width="24" height="24" loading="lazy" />
                    <span>Sysco</span>
                </div>
            </div>
        </section>
        </div>

        <!-- STRIPE-LIKE SPLIT SECTION -->
        <section class="uc-split-feature">
            <div class="uc-container">
                <div class="uc-split-grid">
                    
                    <div class="uc-split-text reveal">
                        <span class="uc-split-label">Operaciones B2B</span>
                        <h2 class="uc-split-title">Cotizaciones y pedidos sin fricción</h2>
                        <p class="uc-split-desc">
                            Maneja un alto volumen de ventas empresariales. Desde la cotización rápida hasta la gestión de crédito y <a href="#">complementos de pago</a> automáticos.
                        </p>
                        
                        <div class="uc-split-list">
                            <div class="uc-feature-item">
                                <div class="uc-feature-icon">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <defs>
                                            <linearGradient id="cord-blue-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#1e3a8a" />
                                                <stop offset="100%" stop-color="#0f172a" />
                                            </linearGradient>
                                        </defs>
                                        <polygon points="5 3 19 12 5 21 5 3" fill="url(#cord-blue-grad)" />
                                    </svg>
                                </div>
                                <div class="uc-feature-content">
                                    <h3>Descuentos Dinámicos</h3>
                                    <p>Aplica <a href="#">descuentos por volumen</a>, márgenes personalizados y niveles de precios específicos por cliente. Todo se calcula al instante en tu cotizador.</p>
                                </div>
                            </div>
                            
                            <div class="uc-feature-item">
                                <div class="uc-feature-icon">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <defs>
                                            <linearGradient id="cord-slate-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#334155" />
                                                <stop offset="100%" stop-color="#94a3b8" />
                                            </linearGradient>
                                        </defs>
                                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" fill="url(#cord-slate-grad)"/>
                                        <circle cx="7" cy="7" r="2" fill="#fff"/>
                                    </svg>
                                </div>
                                <div class="uc-feature-content">
                                    <h3>Manejo de Crédito (Net 30/60)</h3>
                                    <p>Otorga términos de pago institucionales. Cord registra el límite de crédito por cliente, bloquea nuevos pedidos si hay saldo vencido y envía recordatorios automáticos antes del vencimiento Net 30/60.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="uc-split-mockup reveal">
                        <div class="uc-mockup-wrapper">
                            <div class="uc-mockup-header">
                                <div class="uc-mockup-logo">
                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="#0a2540"><rect x="2" y="2" width="20" height="20" rx="4"/></svg>
                                    Global Supply Co.
                                </div>
                                <div class="uc-mockup-nav">
                                    <span>Catálogo</span>
                                    <span class="active">Cotización</span>
                                    <span>Facturas</span>
                                </div>
                            </div>
                            
                            <div class="uc-mockup-body" style="padding: 24px;">
                                <div class="uc-com-po">
                                    <div class="uc-cpo-header">
                                        <div class="uc-cpo-title">
                                            <h4>Orden de Compra #PO-8924</h4>
                                            <span>Global Supply Co.</span>
                                        </div>
                                        <div class="uc-cpo-terms">Términos: Net 30</div>
                                    </div>
                                    <div class="uc-cpo-table">
                                        <div class="uc-cpo-th">
                                            <span>SKU</span>
                                            <span>Cant.</span>
                                            <span>Precio Unit.</span>
                                            <span>Total</span>
                                        </div>
                                        <div class="uc-cpo-tr">
                                            <span>SKU-892 (Industrial)</span>
                                            <span>500</span>
                                            <span>$115.20</span>
                                            <span>$57,600</span>
                                        </div>
                                        <div class="uc-cpo-tr">
                                            <span>SKU-104 (Filtros)</span>
                                            <span>200</span>
                                            <span>$45.00</span>
                                            <span>$9,000</span>
                                        </div>
                                    </div>
                                    <div class="uc-cpo-summary">
                                        <div class="uc-cpo-row">
                                            <span>Subtotal</span>
                                            <span>$66,600</span>
                                        </div>
                                        <div class="uc-cpo-row uc-cpo-tax">
                                            <span>IVA (16%)</span>
                                            <span>$10,656</span>
                                        </div>
                                        <div class="uc-cpo-divider"></div>
                                        <div class="uc-cpo-row uc-cpo-total">
                                            <span>Total a Pagar (MXN)</span>
                                            <span>$77,256</span>
                                        </div>
                                    </div>
                                    <div class="uc-cpo-actions">
                                        <div class="uc-cpo-btn">Autorizar PO y Generar CFDI</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </section>

                <!-- SECONDARY BENEFITS SECTION -->
        <section class="uc-benefits">
            <div class="uc-container">
                <div class="uc-benefits-intro reveal">
                    <span class="uc-split-label">Elimina la fricción en ventas B2B</span>
                    <h2 class="uc-split-title">Acelera tu ciclo comercial desde la orden hasta el pago</h2>
                    <p class="uc-split-desc">
                        Olvida los procesos manuales que retrasan el despacho de mercancía. Con Cord, tus agentes de ventas cierran pedidos más rápido, el crédito se gestiona automáticamente y la cobranza se concilia sin esfuerzo humano.
                    </p>
                </div>

                <div class="uc-bento-cards">
                    <!-- Tarjeta 1 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Límites de crédito por cliente con bloqueo automático</h3>
                            <p>Define el límite de crédito de cada distribuidor en Cord. Si un cliente intenta pasar un nuevo pedido con saldo vencido, el sistema lo marca y tu equipo recibe la alerta antes de aprobar.</p>
                            <a href="/registro" class="uc-link-arrow">Controla tu cartera de crédito <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup">
                            <div class="uc-mockup-bg cord-bg-1"></div>
                            <div class="uc-mini-invoice" style="width:260px;">
                                <div class="uc-mi-logo" style="border-radius: 8px;">D</div>
                                <div class="uc-mi-title">Distribuidora El Sol</div>
                                <div class="uc-mi-sub">Línea de Crédito (Net 30)</div>
                                <div style="text-align:left; margin-bottom:10px; font-size:0.8rem; color:#475569;">Crédito Utilizado: <strong style="color:#0a2540;">$85,000</strong></div>
                                <div style="width:100%; height:8px; background:#e2e8f0; border-radius:10px; margin-bottom:4px; overflow:hidden;">
                                    <div style="width:56%; height:100%; background:#0f172a;"></div>
                                </div>
                                <div style="text-align:right; font-size:0.75rem; color:#64748b; margin-bottom:20px;">Límite: $150,000 MXN</div>
                                <div class="uc-mi-form">
                                    <div class="uc-mi-btn" style="background:#0a2540;">Aprobar Nuevo Pedido</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tarjeta 2 -->
                    <div class="uc-bento-card reveal">
                        <div class="uc-bc-text">
                            <h3>Cobranza vencida con recordatorios automáticos</h3>
                            <p>Cord muestra el aging de tu cartera por cliente, los saldos vencidos y los días promedio de cobro. Cuando un cliente no ha pagado, manda recordatorios automáticos por correo y WhatsApp antes y después del vencimiento.</p>
                            <a href="/registro" class="uc-link-arrow">Mejora tu ciclo de cobro <span>&rarr;</span></a>
                        </div>
                        <div class="uc-bc-mockup" style="background:#fff;">
                            <div class="uc-mini-portal" style="flex-direction: column;">
                                <div class="uc-mp-sidebar" style="width: 100%; border-right: none; border-bottom: 1px solid #e2e8f0; flex-direction: row; align-items: center; justify-content: space-between; padding: 12px 20px;">
                                    <div class="uc-mp-brand" style="margin:0;"><div class="uc-mp-dot"></div> Cobranza vencida</div>
                                    <div class="uc-mp-nav" style="background: #f1f5f9; color: #475569; padding: 4px 10px; border-radius: 6px;">Hoy</div>
                                </div>
                                <div class="uc-mp-main" style="padding: 16px 20px;">
                                    <div class="uc-mp-card" style="margin-bottom:8px; border-left:4px solid #ef4444;">
                                        <div class="uc-mp-row">
                                            <div>
                                                <strong>Distribuidora El Sol — $45,200</strong>
                                                <span>Vence en 3 días · Net 30</span>
                                            </div>
                                            <div class="uc-mp-tag" style="background:#fef2f2; color:#dc2626;">Recordatorio enviado</div>
                                        </div>
                                    </div>
                                    <div class="uc-mp-card" style="border-left:4px solid #f59e0b;">
                                        <div class="uc-mp-row">
                                            <div>
                                                <strong>Grupo Norteño — $12,500</strong>
                                                <span>Vence mañana</span>
                                            </div>
                                            <div class="uc-mp-tag" style="background:#fffbeb; color:#92400e;">WhatsApp enviado</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Micro Features Grid -->
                <div class="uc-micro-features reveal">
                    <h3 class="uc-mf-title">Agilidad operativa para escalar tus ventas</h3>
                    <div class="uc-mf-grid">
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="14 2 18 6 7 17 3 17 3 13 14 2"></polygon><line x1="3" y1="22" x2="21" y2="22"></line></svg>
                            </div>
                            <h4>Descuentos por volumen</h4>
                            <p><a href="#" class="uc-link-inline">Aplica matrices de precios</a> automáticamente dependiendo de las cantidades solicitadas en el cotizador.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                            </div>
                            <h4>Webhooks para tu ERP</h4>
                            <p>Cord emite <code>quote.approved</code> y <code>quote.paid</code> para que tu ERP o sistema de inventario reaccione vía Zapier, Make o tu propio backend al cerrar un pedido.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5c-1.1 0-2 .9-2 2v2"></path><circle cx="8.5" cy="7" r="4"></circle><polyline points="17 11 19 13 23 9"></polyline></svg>
                            </div>
                            <h4>Roles de aprobación</h4>
                            <p>Establece <a href="#" class="uc-link-inline">flujos de validación</a> internos si un asesor otorga un descuento mayor al permitido.</p>
                        </div>
                        <div class="uc-mf-item">
                            <div class="uc-mf-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                            </div>
                            <h4>Notificaciones por WhatsApp</h4>
                            <p>Envía actualizaciones de estatus de pedido, facturas y <a href="#" class="uc-link-inline">recordatorios de cobro</a> directamente al WhatsApp del cliente.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    

        <!-- INTEGRATIONS SECTION -->
        <section class="uc-integrations">
            <div class="uc-container">
                <div class="uc-int-grid">
                    <div class="uc-int-text reveal">
                        <h2>Conecta Cord con tu ecosistema vía webhooks y API</h2>
                        <p>
                            Cord emite eventos reales en cada etapa del ciclo de venta — <code>quote.sent</code>, <code>quote.approved</code>, <code>quote.paid</code> — que puedes escuchar desde Zapier o Make para actualizar tu ERP, tu CRM o tu sistema de inventario sin escribir conectores complejos. La integración con Slack notifica a tu equipo al instante.
                        </p>
                    </div>
                    <div class="uc-int-visual reveal">
                        <MagneticNodes client:load nodes={magneticNodes} />
                    </div>
                </div>
            </div>
        </section>



    
                <!-- POWER SECTION -->
        <section class="uc-power">
            <div class="uc-container">
                <h2 class="uc-power-title reveal">Acelera el flujo de efectivo de tu comercializadora con Cord</h2>
                <div class="uc-power-grid">
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-chart"><span></span><span></span><span></span></div></div>
                        <h3>Líneas de crédito B2B bajo control</h3>
                        <p>Administra límites de crédito por cliente con precisión. Cord te permite definir plazos (Net 30, 60, 90) y bloquear automáticamente la autorización de nuevos pedidos si un cliente tiene facturas vencidas.</p>
                    </div>
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-sync"></div></div>
                        <h3>Gestión de promesas de pago</h3>
                        <p>Nuestro CRM de cobranza hace el seguimiento pesado por ti. Registra <a href="#">promesas de pago</a> y programa recordatorios automáticos multicanal (Email, SMS, WhatsApp) antes y después del vencimiento.</p>
                    </div>
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-toggle"></div></div>
                        <h3>Multi-divisa con tasa protegida</h3>
                        <p>Cotiza a clientes del extranjero en USD o EUR con tasa de cambio bloqueada (buffer configurable). Tu cliente ve el monto en su moneda; tú facturas y cobras en MXN con la tasa que fijaste al enviar la cotización.</p>
                    </div>
                    <div class="uc-power-item reveal">
                        <div class="uc-power-icon"><div class="uc-pi-doc"></div></div>
                        <h3>CFDI 4.0 al cerrar cada pedido</h3>
                        <p>Cuando tu cliente aprueba la cotización, Cord timbra el CFDI 4.0 vía PAC certificado. El XML y el PDF quedan vinculados al pedido y disponibles para descarga desde el portal del cliente sin intervención de tu equipo.</p>
                    </div>
                </div>
            </div>
        </section>
    <Footer />

</Layout>

<style>
    /* VARIABLES Y UTILIDADES GLOBALES PARA USE CASES */
    .use-case-main {
        background: #fff;
        padding-top: 0;
        overflow-x: hidden;
        color: #425466; /* Texto Stripe */
    }

    .uc-container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 5%;
    }

    /* ── HERO SECTION (shader full-bleed) ── */
    .uc-hero {
        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        padding: 8rem 0 4rem;
        background: #ffffff;
        overflow: hidden;
        
    }

    /* Shader background (R3F) — fondo absoluto del hero */
    .uc-hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }
    /* Fade suave hacia el blanco del contenido (legibilidad del texto) */
    .uc-hero-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.55) 38%, rgba(255,255,255,0) 72%);
        pointer-events: none;
        z-index: 2;
    }

    .uc-hero-inner {
        position: relative;
        z-index: 1;
        width: 100%;
    }

    .uc-hero-content {
        max-width: 640px;
    }

    .uc-title {
        font-size: clamp(2.2rem, 4vw, 3.8rem);
        font-weight: 800;
        color: #0a2540;
        line-height: 1.1;
        letter-spacing: -0.04em;
        margin-bottom: 1.2rem;
        text-wrap: balance;
    }

    .uc-sub {
        font-size: 1.15rem;
        color: #425466;
        line-height: 1.6;
        margin-bottom: 2rem;
        max-width: 90%;
    }

    .uc-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    /* ── BUTTONS (estilo soluciones/startups) ── */
    .btn-luxe {
        position: relative;
        display: inline-flex; align-items: center; justify-content: center;
        background: #0a2540; color: #fff;
        padding: 18px 38px; border-radius: 100px;
        font-size: 0.95rem; font-weight: 600; text-decoration: none;
        overflow: hidden;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 8px 24px rgba(10, 37, 64, 0.2);
    }
    .btn-luxe span { position: relative; z-index: 2; }
    .btn-arrow {
        position: relative; z-index: 2; display: inline-block;
        width: 16px; height: 16px; margin-left: 6px;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .btn-luxe:hover .btn-arrow { transform: translateX(4px); }
    .btn-shimmer {
        position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.18), transparent);
        transform: skew(-20deg); transition: 0s; z-index: 1;
    }
    .btn-luxe:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(10, 37, 64, 0.3);
    }
    .btn-luxe:active {
        transform: translateY(-1px);
        box-shadow: 0 2px 4px rgba(10, 37, 64, 0.1);
    }
    .btn-luxe:hover .btn-shimmer {
        left: 150%;
        transition: left 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .btn-ghost {
