        content: '';
        position: absolute;
        top: 4px; left: 3px; right: 8px;
        height: 2px; background: #0f172a;
    }
    .uc-pi-doc::after {
        content: '';
        position: absolute;
        top: 10px; left: 3px; right: 3px;
        height: 2px; background: #0f172a;
    }
    
    /* 5. Wallet / Card */
    .uc-pi-card {
        width: 26px;
