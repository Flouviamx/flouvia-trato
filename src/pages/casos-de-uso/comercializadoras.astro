    /* 1. Toggle / Switch */
    .uc-pi-toggle {
        width: 28px;
        height: 16px;
        background: #0f172a;
        border-radius: 10px;
        position: relative;
    }
    .uc-pi-toggle::after {
        content: '';
        position: absolute;
        top: 2px;
        right: 2px;
        width: 12px;
        height: 12px;
        background: #fff;
        border-radius: 50%;
    }
    
    /* 2. Chart / Bars */
    .uc-pi-chart {
        display: flex;
        align-items: flex-end;
        gap: 4px;
        height: 24px;
    }
    .uc-pi-chart span {
