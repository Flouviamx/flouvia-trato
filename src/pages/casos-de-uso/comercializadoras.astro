    /* ── INTEGRATIONS SECTION ── */
    .uc-integrations {
        padding: 6rem 0 8rem;
        background: transparent;
        overflow: hidden;
    }
    .uc-int-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }
    .uc-int-text {
        max-width: 480px;
    }
    .uc-int-text h2 {
        font-size: 2.1rem;
        font-weight: 800;
        color: #0a2540;
        margin-bottom: 1.5rem;
        line-height: 1.2;
        letter-spacing: -0.02em;
    }
    .uc-int-text p {
        font-size: 1.1rem;
        color: #425466;
        line-height: 1.6;
    }
    .uc-int-text a {
        color: #0f172a;
        text-decoration: none;
