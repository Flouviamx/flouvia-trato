---
import Layout from '../layouts/Layout.astro';
import { SignIn } from '@clerk/astro/components';
---

<Layout title="Iniciar sesión - Cord">
    <div class="auth-page">
        <div class="auth-left">
            <div class="auth-nav">
                <a href="/">
                    <img src="/imgs/logo-cord-navy.png" alt="Cord" class="logo-img" />
                </a>
            </div>
            <div class="auth-container">
                <SignIn routing="path" path="/sign-in" appearance={{
                    elements: {
                        rootBox: { width: '100%' },
                        cardBox: { width: '100%', boxShadow: 'none' },
                        card: { boxShadow: 'none', border: 'none', padding: '0', background: 'transparent' },
                        headerTitle: { fontSize: '1.7rem', color: '#0a192f', fontWeight: '700', letterSpacing: '-0.02em' },
                        headerSubtitle: { color: '#64748b', fontSize: '0.95rem' },
                        formFieldLabel: { color: '#0a192f', fontWeight: '600' },
                        formFieldInput: { borderRadius: '10px', borderColor: '#e2e8f0', padding: '0.65rem 1rem' },
                        formButtonPrimary: { backgroundColor: '#0a192f', borderRadius: '10px', padding: '0.65rem 1rem', fontSize: '0.95rem', fontWeight: '600', textTransform: 'none', '&:hover': { backgroundColor: '#112240' } },
                        footerActionLink: { color: '#0a192f', fontWeight: '600' },
                        identityPreview: { borderColor: '#e2e8f0', background: '#f8fafc' },
                        dividerLine: { background: '#e2e8f0' },
                        dividerText: { color: '#94a3b8' },
                        socialButtonsBlockButton: { borderColor: '#e2e8f0', '&:hover': { background: '#f8fafc' } },
                        socialButtonsBlockButtonText: { color: '#0a192f', fontWeight: '500' }
                    }
                }} />
            </div>
            <div class="auth-footer-text">
                &copy; 2026 Flouvia Cord. Hecho en México.
            </div>
        </div>
        <div class="auth-right">
            <div class="auth-right-content">
                <div class="quote-mark">"</div>
                <p class="quote-text">Desde que usamos Cord, redujimos el tiempo de cotización de 3 horas a solo 10 minutos. Nuestras ventas B2B nunca habían fluido tan rápido y nuestros clientes aman la experiencia.</p>
                <div class="quote-author">
                    <div class="author-avatar">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                    <div class="author-info">
                        <strong>Alejandro M.</strong>
                        <span>Director Comercial, Distribuidora XYZ</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    .auth-page {
        display: flex;
        min-height: 100vh;
        background: #ffffff;
        font-family: var(--font-sans, system-ui, sans-serif);
    }
    .auth-left {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 2.5rem;
        position: relative;
    }
    .auth-nav {
        margin-bottom: auto;
    }
    .logo-img {
        height: 24px;
        width: auto;
        transition: opacity 0.2s;
    }
    .logo-img:hover {
        opacity: 0.8;
    }
    .auth-container {
        margin: auto;
        width: 100%;
        max-width: 400px;
        animation: fadein 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .auth-footer-text {
        margin-top: auto;
        font-size: 0.8rem;
        color: #94a3b8;
    }
    .auth-right {
        flex: 1;
        background: #0a192f;
        background-image: radial-gradient(circle at 100% 100%, #152c54 0%, #0a192f 100%);
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 4rem;
        color: #fff;
        position: relative;
        overflow: hidden;
    }
    .auth-right::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: url('data:image/svg+xml;utf8,<svg width="20" height="20" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><circle cx="2" cy="2" r="1" fill="rgba(255,255,255,0.04)"/></svg>');
        background-size: 20px 20px;
        opacity: 0.5;
    }
    .auth-right-content {
        max-width: 480px;
        position: relative;
        z-index: 1;
        animation: fadeinup 0.7s cubic-bezier(0.16, 1, 0.3, 1) both 0.1s;
    }
    .quote-mark {
        font-size: 5rem;
        line-height: 1;
        color: rgba(255,255,255,0.1);
        font-family: Georgia, serif;
        margin-bottom: -2rem;
    }
    .quote-text {
        font-size: 1.4rem;
        line-height: 1.55;
        font-weight: 500;
        margin-bottom: 2rem;
        color: rgba(255,255,255,0.95);
    }
    .quote-author {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .author-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: rgba(255,255,255,0.1);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255,255,255,0.15);
    }
    .author-info {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
    }
    .author-info strong {
        font-size: 0.95rem;
        font-weight: 600;
    }
    .author-info span {
        font-size: 0.85rem;
        color: rgba(255,255,255,0.55);
    }
    
    @keyframes fadein {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    @keyframes fadeinup {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    @media (min-width: 1024px) {
        .auth-right {
            display: flex;
            flex: 1.1;
        }
    }
</style>
