---
// Login — Clerk SignIn montado sobre el layout borderless de la marca.
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { SignIn } from '@clerk/astro/components';

const clerkAppearance = {
    variables: {
        colorPrimary: '#0a192f',
        colorText: '#050505',
        colorTextSecondary: '#555556',
        borderRadius: '12px',
        fontFamily: "'Inter', system-ui, sans-serif",
    },
};
---

<Layout title="Entrar — Trato" noindex={true}>
    <main class="auth-page">
        <div class="auth-watermark editorial" aria-hidden="true">Acceso</div>

        <div class="auth-grid">
            <!-- Marca -->
            <div class="auth-brand">
                <a href="/"><img src="/imgs/logo-trato-navy.png" alt="Trato" class="auth-logo" /></a>
                <p class="auth-eyebrow">PLATAFORMA DE COTIZACIONES B2B</p>
                <h1 class="auth-title">Bienvenido<br />de vuelta.</h1>
                <p class="auth-sub">Tus cotizaciones, clientes y pipeline — en un solo lugar.</p>
                <div class="auth-badge">
                    <span class="auth-dot"></span>
                    <span>ACCESO SEGURO</span>
                </div>
            </div>

            <div class="auth-form">
                <SignIn appearance={clerkAppearance} />
                <p class="af-note">¿No tienes cuenta? <a href="/registro">Créala gratis</a></p>
            </div>
        </div>
    </main>
</Layout>

<!-- Clerk inyecta su DOM en runtime — sin scope de Astro, debe ser global -->
<style is:global>
    .auth-form .cl-rootBox { width: 100%; }
    .auth-form .cl-cardBox {
        width: 100%;
        border: 1px solid rgba(10, 25, 47, 0.07);
        border-radius: 18px;
        box-shadow: 0 24px 60px -24px rgba(10, 25, 47, 0.22);
    }
    .auth-form .cl-footer { background: #fcfcfd; }
</style>

<style>
    .auth-page {
        min-height: 100svh;
        background: var(--color-bg-soft);
        display: flex; align-items: center; justify-content: center;
        padding: 3rem 5%;
        position: relative; overflow: clip;
    }
    .auth-watermark {
        position: absolute; bottom: -7vw; right: -2vw;
        font-size: 26vw; line-height: 0.85; letter-spacing: -0.06em; font-weight: 800;
        color: rgba(0,0,0,0.025);
        pointer-events: none; user-select: none; white-space: nowrap;
    }
    .auth-grid {
        position: relative; z-index: 1;
        width: 100%; max-width: 880px;
        display: grid; grid-template-columns: 1.05fr 0.95fr;
        gap: 5rem; align-items: center;
    }

    .auth-logo { height: 26px; width: auto; margin-bottom: 2.2rem; }
    .auth-eyebrow { font-size: 0.62rem; font-weight: 800; letter-spacing: 3px; color: #888; margin: 0 0 1.2rem; }
    .auth-title { font-size: clamp(2.1rem, 4vw, 3rem); font-weight: 800; line-height: 1.05; letter-spacing: -1.5px; margin: 0 0 1rem; }
    .auth-sub { font-size: 1rem; color: var(--color-text-muted); margin: 0 0 1.8rem; }
    .auth-badge {
        display: inline-flex; align-items: center; gap: 8px;
        font-size: 0.6rem; font-weight: 800; letter-spacing: 1.2px; color: var(--color-text-muted);
        background: #fff; border: 1px solid var(--color-border);
        padding: 7px 13px; border-radius: 100px;
    }
    .auth-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-ok); animation: a-pulse 2.5s infinite; }
    @keyframes a-pulse {
        0% { box-shadow: 0 0 0 0 rgba(16,185,129,0.4); }
        70% { box-shadow: 0 0 0 6px rgba(16,185,129,0); }
        100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); }
    }

    .auth-form { display: flex; flex-direction: column; gap: 1.6rem; max-width: 380px; width: 100%; }
    .af-field { display: flex; flex-direction: column; gap: 0.5rem; }
    .af-field label { font-size: 0.62rem; font-weight: 800; letter-spacing: 1.8px; color: #99a2af; }
    .af-field input {
        font-family: var(--font-sans); font-size: 1rem; font-weight: 500;
        color: var(--color-text); background: none;
        border: none; border-bottom: 1px solid rgba(10,25,47,0.18);
        padding: 8px 2px; border-radius: 0;
        transition: border-color 0.3s var(--ease-ios);
    }
    .af-field input:focus { outline: none; border-bottom-color: var(--color-blue-deep); }
    .af-field input::placeholder { color: #b6bcc6; }

    .af-submit {
        display: flex; align-items: center; justify-content: center; gap: 10px;
        font-size: 0.95rem; font-weight: 600; text-decoration: none;
        background: var(--color-blue-deep); color: #fff;
        padding: 14px; border-radius: 12px;
        box-shadow: 0 14px 34px -12px rgba(10,25,47,0.55);
        transition: transform 0.5s var(--ease-spring), box-shadow 0.5s var(--ease-spring);
        margin-top: 0.4rem;
    }
    .af-submit svg { width: 15px; height: 15px; transition: transform 0.5s var(--ease-spring); }
    .af-submit:hover { transform: translateY(-3px); }
    .af-submit:hover svg { transform: translateX(4px); }

    .af-note { font-size: 0.82rem; color: var(--color-text-muted); margin: 0; text-align: center; }
    .af-note a { color: var(--color-blue-deep); font-weight: 600; text-decoration: none; }
    .af-note a:hover { text-decoration: underline; }

    @media (max-width: 760px) {
        .auth-grid { grid-template-columns: 1fr; gap: 3rem; }
        .auth-watermark { font-size: 42vw; }
    }
</style>
