---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import SupportSearch from '../../components/support/SupportSearch.astro';
import FeedbackWidget from '../../components/support/FeedbackWidget.astro';

export const prerender = true;

export async function getStaticPaths() {
  const supportEntries = await getCollection('support');
  return supportEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Filtrar headings para el TOC (H2 y H3)
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

// Build navigation (Sidebar & Pagination)
const allSupport = await getCollection('support');
const categoryEntries = allSupport
    .filter(a => a.data.category === entry.data.category)
    // Optional: Sort by an "order" field if present, otherwise by title
    .sort((a, b) => {
        if (a.data.order && b.data.order) return a.data.order - b.data.order;
        return a.data.title.localeCompare(b.data.title);
    });

const currentIndex = categoryEntries.findIndex(a => a.id === entry.id);
const prevEntry = currentIndex > 0 ? categoryEntries[currentIndex - 1] : null;
const nextEntry = currentIndex < categoryEntries.length - 1 ? categoryEntries[currentIndex + 1] : null;

// Get up to 3 related articles (excluding the current one)
const relatedArticles = categoryEntries.filter(a => a.id !== entry.id).slice(0, 3);

// Helper to format category for URLs
const slugifyCategory = (cat: string) => cat.toLowerCase().replace(/\s+/g, '-').replace(/&/g, 'y').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
const catSlug = slugifyCategory(entry.data.category);
---

<Layout
    title={`${entry.data.title} — Centro de Ayuda Cord`}
    description={entry.data.description}
>
    <Nav />
    <main class="article-layout">
        
        <div class="support-search-header">
            <SupportSearch />
        </div>

        <div class="article-container reveal">
            <!-- Left Sidebar -->
            <aside class="article-sidebar">
                <a href="/soporte" class="back-link">← Centro de Ayuda</a>
                <div class="sidebar-category">
                    <h3>{entry.data.category}</h3>
                    <nav class="sidebar-nav">
                        {categoryEntries.map(item => (
                            <a href={`/soporte/${item.id}`} class={`sidebar-link ${item.id === entry.id ? 'active' : ''}`}>
                                {item.data.title}
                            </a>
                        ))}
                    </nav>
                </div>
            </aside>

            <!-- Main Content Area -->
            <div class="article-main">
                <nav class="breadcrumbs">
                    <a href="/soporte">Soporte</a>
                    <span class="separator">/</span>
                    <a href={`/soporte/categoria/${catSlug}`}>{entry.data.category}</a>
                    <span class="separator">/</span>
                    <span class="current">{entry.data.title}</span>
                </nav>

                <article class="markdown-body" id="markdownContent">
                    <Content />
                </article>

                <FeedbackWidget />

                {relatedArticles.length > 0 && (
                    <div class="related-articles-section reveal">
                        <h4>Artículos relacionados</h4>
                        <div class="related-grid">
                            {relatedArticles.map((rel: any) => (
                                <a href={`/soporte/${rel.id}`} class="related-card">
                                    <span class="rc-title">{rel.data.title}</span>
                                    <span class="rc-desc">{rel.data.description}</span>
                                </a>
                            ))}
                        </div>
                    </div>
                )}

                <hr class="article-divider" />

                <!-- Next / Prev Pagination -->
                <nav class="article-pagination">
                    {prevEntry ? (
                        <a href={`/soporte/${prevEntry.id}`} class="pagination-link prev">
                            <span class="pag-label">← Anterior</span>
                            <span class="pag-title">{prevEntry.data.title}</span>
                        </a>
                    ) : <div></div>}

                    {nextEntry ? (
                        <a href={`/soporte/${nextEntry.id}`} class="pagination-link next">
                            <span class="pag-label">Siguiente →</span>
                            <span class="pag-title">{nextEntry.data.title}</span>
                        </a>
                    ) : <div></div>}
                </nav>
            </div>

            <!-- Right Sidebar: Table of Contents -->
            {tocHeadings.length > 0 && (
                <aside class="article-toc">
                    <div class="toc-sticky">
                        <h4>En este artículo</h4>
                        <nav id="tocNav">
                            {tocHeadings.map((h) => (
                                <a 
                                    href={`#${h.slug}`} 
                                    class={`toc-link depth-${h.depth}`}
                                    data-slug={h.slug}
                                >
                                    {h.text}
                                </a>
                            ))}
                        </nav>
                    </div>
                </aside>
            )}
        </div>
    </main>
    <Footer ctaTitle="¿Necesitas más ayuda?" ctaSub="Contacta a nuestro equipo especializado." />
    <PageAnims />
</Layout>

<style>
    .article-layout {
        padding: 140px 5% 80px;
        background-color: var(--color-bg);
        min-height: 80vh;
    }
    .support-search-header {
        max-width: 1200px;
        margin: 0 auto 3rem;
        padding: 0 20px;
    }
    .article-container {
        max-width: 1300px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 240px minmax(0, 1fr) 220px;
        gap: 60px;
        align-items: start;
    }
    
    /* Sidebar */
    .article-sidebar {
        position: sticky;
        top: 120px;
    }
    .back-link {
        display: inline-block;
        margin-bottom: 2.5rem;
        color: var(--color-text-muted);
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
        transition: color 0.2s;
    }
    .back-link:hover { color: var(--color-blue-deep); }
    
    .sidebar-category h3 {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-text-muted);
        margin-bottom: 1rem;
        font-weight: 700;
    }
    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .sidebar-link {
        color: var(--color-text);
        text-decoration: none;
        font-size: 0.95rem;
        padding: 8px 12px;
        border-radius: 8px;
        margin-left: -12px;
        transition: background 0.2s, color 0.2s;
        line-height: 1.4;
    }
    .sidebar-link:hover {
        background: rgba(10,25,47,0.04);
    }
    .sidebar-link.active {
        color: var(--color-blue-deep);
        font-weight: 600;
        background: rgba(10,25,47,0.06);
    }

    /* Main Content */
    .article-main {
        min-width: 0; /* Prevent flex overflow */
    }

    /* Breadcrumbs */
    .breadcrumbs {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 3rem;
        font-size: 0.9rem;
        color: var(--color-text-muted);
    }
    .breadcrumbs a {
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color 0.2s;
    }
    .breadcrumbs a:hover { color: var(--color-text); }
    .breadcrumbs .separator { opacity: 0.5; }
    .breadcrumbs .current {
        color: var(--color-text);
        font-weight: 500;
    }

    /* Related Articles */
    .related-articles-section {
        margin-top: 4rem;
        padding-top: 3rem;
        border-top: 1px solid var(--color-border);
    }
    .related-articles-section h4 {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--color-text);
        margin-bottom: 1.5rem;
    }
    .related-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
    }
    .related-card {
        display: flex;
        flex-direction: column;
        padding: 1.5rem;
        border: 1px solid var(--color-border);
        border-radius: 12px;
        text-decoration: none;
        transition: background 0.3s, border-color 0.3s;
    }
    .related-card:hover {
        background: var(--color-bg-soft);
        border-color: rgba(9, 105, 218, 0.3);
    }
    .rc-title {
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--color-text);
        margin-bottom: 8px;
        line-height: 1.3;
        transition: color 0.2s;
    }
    .related-card:hover .rc-title {
        color: var(--color-blue-deep);
    }
    .rc-desc {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Pagination */
    .article-divider {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 4rem 0 2rem;
    }
    .article-pagination {
        display: flex;
        justify-content: space-between;
        gap: 2rem;
    }
    .pagination-link {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        padding: 1.5rem;
        border: 1px solid var(--color-border);
        border-radius: 12px;
        flex: 1;
        transition: border-color 0.3s, box-shadow 0.3s;
    }
    .pagination-link:hover {
        border-color: rgba(10,25,47,0.15);
        box-shadow: 0 8px 20px rgba(10,25,47,0.04);
    }
    .pagination-link.next { text-align: right; }
    .pag-label {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
    }
    .pag-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--color-blue-deep);
    }

    @media (max-width: 1100px) {
        .article-container {
            grid-template-columns: 240px minmax(0, 1fr);
        }
        .article-toc {
            display: none;
        }
    }
    @media (max-width: 900px) {
        .article-container {
            grid-template-columns: 1fr;
            gap: 40px;
        }
        .article-sidebar {
            position: static;
            border-bottom: 1px solid var(--color-border);
            padding-bottom: 2rem;
        }
        .article-pagination {
            flex-direction: column;
        }
        .pagination-link.next { text-align: left; }
    }
    
    /* Table of Contents (Right Sidebar) */
    .article-toc {
        position: relative;
    }
    .toc-sticky {
        position: sticky;
        top: 120px;
        padding-left: 20px;
        border-left: 1px solid var(--color-border);
    }
    .toc-sticky h4 {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--color-text-muted);
        margin-bottom: 1rem;
        font-weight: 700;
    }
    #tocNav {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .toc-link {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        text-decoration: none;
        line-height: 1.4;
        transition: color 0.2s;
        border-left: 2px solid transparent;
        margin-left: -21px; /* Align with the border */
        padding-left: 19px;
    }
    .toc-link.depth-3 {
        padding-left: 30px;
        font-size: 0.85rem;
    }
    .toc-link:hover {
        color: var(--color-text);
    }
    .toc-link.active {
        color: var(--color-blue-deep);
        font-weight: 500;
        border-left-color: var(--color-blue-deep);
    }

    /* Estilos básicos para el contenido Markdown */
    .markdown-body {
        color: var(--color-text);
        line-height: 1.7;
    }
    .markdown-body :global(h1) {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 800;
        color: var(--color-blue-deep);
        margin-bottom: 1.5rem;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }
    .markdown-body :global(h2) {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--color-text);
        margin-top: 3rem;
        margin-bottom: 1rem;
        letter-spacing: -0.02em;
    }
    .markdown-body :global(p) {
        margin-bottom: 1.5rem;
        font-size: 1.05rem;
    }
    .markdown-body :global(ul), .markdown-body :global(ol) {
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
    }
    .markdown-body :global(li) {
        margin-bottom: 0.5rem;
        font-size: 1.05rem;
    }
    .markdown-body :global(strong) {
        font-weight: 600;
        color: var(--color-blue-deep);
    }
    .markdown-body :global(a) {
        color: var(--color-blue-deep);
        text-decoration: underline;
        text-underline-offset: 4px;
    }

    
    .markdown-body :global(pre) {
        background: #0d1117;
        color: #c9d1d9;
        padding: 1.5rem;
        border-radius: 12px;
        overflow-x: auto;
        margin: 2rem 0;
        font-size: 0.95rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }
    .markdown-body :global(code) {
        background: rgba(10,25,47,0.05);
        padding: 0.2em 0.4em;
        border-radius: 6px;
        font-size: 0.9em;
        font-family: monospace;
    }
    .markdown-body :global(pre code) {
        background: transparent;
        padding: 0;
    }
</style>

<script>
    // ScrollSpy Logic for TOC
    document.addEventListener('DOMContentLoaded', () => {
        const headings = document.querySelectorAll('#markdownContent h2, #markdownContent h3');
        const tocLinks = document.querySelectorAll('#tocNav .toc-link');
        
        if (headings.length === 0 || tocLinks.length === 0) return;

        // Intersection Observer options
        const observerOptions = {
            root: null,
            rootMargin: '0px 0px -60% 0px', // Trigger when heading is in the top 40% of the viewport
            threshold: 1.0
        };

        // Keeps track of the currently active heading ID
        let activeId = '';

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    activeId = entry.target.id;
                    updateActiveLink();
                }
            });
        }, observerOptions);

        headings.forEach(h => observer.observe(h));

        // Fallback for scrolling up: if no heading is intersecting, find the one just above the viewport
        window.addEventListener('scroll', () => {
            let current = '';
            headings.forEach(h => {
                const rect = h.getBoundingClientRect();
                if (rect.top <= 120) { // 120px offset for the fixed header
                    current = h.id;
                }
            });
            
            if (current && current !== activeId) {
                activeId = current;
                updateActiveLink();
            }
        }, { passive: true });

        function updateActiveLink() {
            tocLinks.forEach(link => {
                if (link.getAttribute('data-slug') === activeId) {
                    link.classList.add('active');
                } else {
                    link.classList.remove('active');
                }
            });
        }
    });
</script>
