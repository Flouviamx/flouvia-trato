---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';

export const prerender = true;

export async function getStaticPaths() {
    const blogEntries = await getCollection('blog');
    return blogEntries.map(entry => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Fallbacks para el post en caso de faltar datos opcionales
const authorName = entry.data.authorName || 'Equipo Cord';
const authorRole = entry.data.authorRole || 'Redacción';
const authorAvatar = entry.data.authorAvatar || 'https://images.unsplash.com/photo-1560250097-0b93528c311a?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&q=80';
---

<Layout
    title={`${entry.data.title} | Blog de Cord`}
    description={entry.data.excerpt}
>
    <Nav />
    
    <!-- Ruido analógico de lujo -->
    <div class="analog-noise" aria-hidden="true"></div>

    <!-- Barra de progreso -->
    <div id="reading-progress" class="reading-progress-bar"></div>

    <main class="blog-article-main">
        <!-- HEADER DEL ARTÍCULO -->
        <header class="article-hero">
            <div class="hero-container">
                <div class="article-meta reveal">
                    <span class="category-badge">{entry.data.category}</span>
                    <span class="technical-meta">{entry.data.date}</span>
                    <span class="dot">·</span>
                    <span class="technical-meta">{entry.data.readTime}</span>
                </div>
                
                <h1 class="article-title">
                    <span class="stagger-mask"><span class="stagger-line" style="animation-delay: 100ms">{entry.data.title}</span></span>
                </h1>
                
                <p class="article-excerpt reveal" style="transition-delay: 200ms">
                    {entry.data.excerpt}
                </p>

                <div class="article-author reveal" style="transition-delay: 300ms">
                    <img src={authorAvatar} alt={authorName} />
                    <div class="author-details">
                        <strong>{authorName}</strong>
                        <span class="technical-meta">{authorRole}</span>
                    </div>
                </div>
            </div>
        </header>

        <!-- LAYOUT DE 3 COLUMNAS -->
        <div class="article-layout">
            
            <!-- Izquierda: Share Pill -->
            <aside class="article-sidebar article-sidebar-left">
                <div class="share-pill sticky reveal" style="transition-delay: 500ms">
                    <button id="btn-copy-link" class="share-btn" aria-label="Copiar enlace" title="Copiar enlace">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                        <span class="tooltip">¡Copiado!</span>
                    </button>
                    <a href={`https://www.linkedin.com/sharing/share-offsite/?url=https://cord.flouvia.com/blog/${entry.id}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Compartir en LinkedIn" title="LinkedIn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                    </a>
                    <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(entry.data.title)}&url=https://cord.flouvia.com/blog/${entry.id}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Compartir en X" title="X (Twitter)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4l11.733 16h4.267l-11.733 -16z"></path><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path></svg>
                    </a>
                </div>
            </aside>

            <!-- Centro: CUERPO DEL ARTÍCULO (Markdown) -->
            <article class="article-body">
                <div class="prose-container" id="prose-content">
                    <Content />
                </div>
            </article>

            <!-- Derecha: Índice Flotante -->
            <aside class="article-sidebar article-sidebar-right">
                {headings.length > 0 && (
                    <div class="toc-container sticky reveal" style="transition-delay: 500ms">
                        <span class="toc-title">En este artículo</span>
                        <ul class="toc-list" id="toc-list">
                            {headings.map(h => (
                                <li class={`toc-depth-${h.depth}`}>
                                    <a href={`#${h.slug}`}>{h.text}</a>
                                </li>
                            ))}
                        </ul>
                    </div>
                )}
            </aside>
        </div>

        <!-- BENTO CTA FINAL (Estilo Stripe / Cord) -->
        <section class="article-footer-cta">
            <div class="bento-grid">
                
                <!-- Columna Grande: Suscripción -->
                <div class="bento-card span-2 hairline-border">
                    <h3>Suscríbete al Blog de Cord</h3>
                    <p>Estrategias financieras, análisis de mercado y novedades de producto directamente en tu bandeja de entrada.</p>
                    
                    <form class="subscribe-form" onsubmit="event.preventDefault()">
                        <input type="email" placeholder="tu@empresa.com" required />
                        <button type="submit" class="btn-primary">
                            Suscribirme <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </button>
                    </form>
                    <span class="privacy-note">Cord tratará tus datos según su <a href="/privacidad">Política de Privacidad</a>.</span>
                </div>

                <!-- Columna Pequeña 1: Careers -->
                <div class="bento-card hairline-border">
                    <div class="bento-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                    </div>
                    <h4>¿Te gusta lo que lees?</h4>
                    <p>Cord construye infraestructura financiera para acelerar las ventas B2B. Únete al equipo.</p>
                    <a href="/unirse" class="bento-link">Ver vacantes <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                </div>

                <!-- Columna Pequeña 2: Contact -->
                <div class="bento-card hairline-border">
                    <div class="bento-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    </div>
                    <h4>¿Dudas o comentarios?</h4>
                    <p>Nos encantaría escuchar tu opinión sobre este artículo o tu flujo de ventas.</p>
                    <a href="mailto:hello@cord.mx" class="bento-link">Contáctanos <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                </div>

            </div>
        </section>

    </main>

    <Footer 
        ctaTitle="Acelera tus ciclos de venta"
        ctaSub="Con Cord, tus prospectos aprueban y pagan cotizaciones en minutos, no en semanas."
    />
    <PageAnims />
</Layout>

<script is:inline>
    // UX Interactivity Script
    document.addEventListener('DOMContentLoaded', () => {
        // 1. Progress Bar
        const progressBar = document.getElementById('reading-progress');
        const prose = document.getElementById('prose-content');
        
        // 2. Scrollspy (TOC)
        const tocLinks = document.querySelectorAll('#toc-list a');
        const headings = Array.from(document.querySelectorAll('#prose-content h2, #prose-content h3'));
        
        // 3. Prose Micro-reveals
        const proseElements = document.querySelectorAll('#prose-content > *');
        proseElements.forEach((el, i) => {
            el.classList.add('micro-reveal');
            el.style.transitionDelay = `${(i % 5) * 50}ms`; // Stagger init
        });

        // 4. Copy Link
        const copyBtn = document.getElementById('btn-copy-link');
        if (copyBtn) {
            copyBtn.addEventListener('click', () => {
                navigator.clipboard.writeText(window.location.href);
                copyBtn.classList.add('copied');
                setTimeout(() => copyBtn.classList.remove('copied'), 2000);
            });
        }

        // --- Intersection Observers ---
        
        // Reveals
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    revealObserver.unobserve(entry.target);
                }
            });
        }, { rootMargin: '0px 0px -10% 0px' });
        
        proseElements.forEach(el => revealObserver.observe(el));

        // TOC Highlight
        let currentActive = null;
        const tocObserver = new IntersectionObserver((entries) => {
            // Find the intersecting heading nearest to top
            let activeId = currentActive;
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    activeId = entry.target.id;
                }
            });
            
            if (activeId !== currentActive) {
                tocLinks.forEach(link => {
                    link.classList.toggle('active', link.getAttribute('href') === `#${activeId}`);
                });
                currentActive = activeId;
            }
        }, { rootMargin: '0px 0px -80% 0px', threshold: 1.0 });

        headings.forEach(h => tocObserver.observe(h));

        // --- Scroll Event ---
        window.addEventListener('scroll', () => {
            if (!prose || !progressBar) return;
            const rect = prose.getBoundingClientRect();
            const windowHeight = window.innerHeight;
            
            // Calculate how much of prose is scrolled
            const totalScrollable = rect.height - windowHeight;
            let scrolled = -rect.top;
            
            if (scrolled < 0) scrolled = 0;
            if (scrolled > totalScrollable) scrolled = totalScrollable;
            
            let progress = 0;
            if (totalScrollable > 0) {
                progress = (scrolled / totalScrollable) * 100;
            } else if (rect.top <= 0) {
                progress = 100;
            }
            
            progressBar.style.transform = `scaleX(${progress / 100})`;
        }, { passive: true });
    });
</script>

<style>
    /* ==========================================================
       RUIDO ANALÓGICO & TIPOGRAFÍA TÉCNICA
       ========================================================== */
    .analog-noise {
        position: fixed; inset: 0; z-index: 1000; pointer-events: none;
        opacity: 0.035; 
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    }
    :global(html[data-theme="dark"]) .analog-noise { opacity: 0.05; }

    .technical-meta {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-variant-numeric: tabular-nums;
        font-size: 0.75rem; font-weight: 600;
        letter-spacing: 0.04em; color: #6b7280;
        text-transform: uppercase;
    }
    :global(html[data-theme="dark"]) .technical-meta { color: #9ca3af; }

    .stagger-mask { display: inline-block; overflow: hidden; vertical-align: top; }
    .stagger-line {
        display: inline-block; transform: translateY(110%);
        animation: slideUpReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes slideUpReveal { to { transform: translateY(0); } }

    /* ==========================================================
       BORDES HAIRLINE
       ========================================================== */
    .hairline-border {
        border: none !important;
        box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.08), 0 20px 40px -20px rgba(0,0,0,0.04);
    }
    :global(html[data-theme="dark"]) .hairline-border {
        box-shadow: inset 0 0 0 0.5px rgba(255,255,255,0.08), 0 20px 40px -20px rgba(0,0,0,0.5);
    }

    /* ==========================================================
       BASE Y LAYOUT
       ========================================================== */
    .blog-article-main {
        background: #fdfdfd; color: #111827;
        min-height: 100vh; font-family: 'Inter', sans-serif;
        padding-top: 100px;
    }
    :global(html[data-theme="dark"]) .blog-article-main { background: #050505; color: #f3f4f6; }

    /* ==========================================================
       HERO DEL ARTÍCULO
       ========================================================== */
    .article-hero {
        width: 100%; max-width: 800px; margin: 0 auto 3rem;
        padding: 4rem 5% 0; display: flex; flex-direction: column; align-items: flex-start;
        text-align: left;
    }

    .article-meta {
        display: flex; align-items: center; justify-content: flex-start; gap: 0.8rem;
        margin-bottom: 1.5rem;
    }
    .category-badge {
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--color-blue-deep); background: rgba(10,37,218,0.06);
        padding: 6px 14px; border-radius: 100px;
    }
    :global(html[data-theme="dark"]) .category-badge { color: #60a5fa; background: rgba(59,130,246,0.15); }
    .dot { color: #d1d5db; }

    .article-title {
        font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800; line-height: 1.1;
        letter-spacing: -0.04em; color: #111827; margin: 0 0 1.5rem;
        max-width: 100%;
    }
    :global(html[data-theme="dark"]) .article-title { color: #fff; }

    .article-excerpt {
        font-size: 1.15rem; color: #4b5563; line-height: 1.6;
        max-width: 100%; margin: 0 0 2.5rem;
    }
    :global(html[data-theme="dark"]) .article-excerpt { color: #d1d5db; }

    .article-author {
        display: flex; align-items: center; justify-content: flex-start; gap: 1rem;
        margin-bottom: 2rem;
    }
    .article-author img { width: 44px; height: 44px; border-radius: 50%; }
    .author-details { display: flex; flex-direction: column; align-items: flex-start; gap: 2px; }
    .author-details strong { font-size: 0.95rem; font-weight: 700; color: #111827; }
    :global(html[data-theme="dark"]) .author-details strong { color: #fff; }

    /* ==========================================================
       PROSE (MARKDOWN BODY)
       ========================================================== */
    .article-body { padding: 2rem 5% 6rem; }
    .prose-container {
        max-width: 680px; margin: 0 auto;
        font-size: 1.15rem; line-height: 1.8; color: #374151;
    }
    :global(html[data-theme="dark"]) .prose-container { color: #cbd5e1; }

    /* Estilos globales para el HTML generado por Markdown */
    .prose-container :global(h2) {
        font-size: 2rem; font-weight: 700; color: #111827; letter-spacing: -0.02em;
        margin: 3.5rem 0 1.5rem; line-height: 1.2;
    }
    :global(html[data-theme="dark"]) .prose-container :global(h2) { color: #fff; }

    .prose-container :global(h3) {
        font-size: 1.5rem; font-weight: 600; color: #111827;
        margin: 2.5rem 0 1rem; line-height: 1.3;
    }
    :global(html[data-theme="dark"]) .prose-container :global(h3) { color: #f3f4f6; }

    .prose-container :global(p) { margin-bottom: 1.5rem; }
    
    .prose-container :global(ul), .prose-container :global(ol) {
        margin-bottom: 2rem; padding-left: 1.5rem;
    }
    .prose-container :global(li) { margin-bottom: 0.5rem; }

    .prose-container :global(blockquote) {
        border-left: 4px solid var(--color-blue-deep);
        padding-left: 1.5rem; margin: 2.5rem 0;
        font-size: 1.35rem; font-style: italic; color: #111827;
        background: rgba(10,37,218,0.02); padding: 1.5rem;
        border-radius: 0 12px 12px 0;
    }
    :global(html[data-theme="dark"]) .prose-container :global(blockquote) {
        border-color: #60a5fa; color: #fff; background: rgba(59,130,246,0.05);
    }

    /* Micro-reveals in Prose */
    .prose-container :global(.micro-reveal) {
        opacity: 0; transform: translateY(15px);
        transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .prose-container :global(.micro-reveal.visible) {
        opacity: 1; transform: translateY(0);
    }

    /* ==========================================================
       UX IMPROVEMENTS (PROGRESS, TOC, SHARE)
       ========================================================== */
    .reading-progress-bar {
        position: fixed; top: 0; left: 0; width: 100%; height: 3px;
        background: var(--color-blue-deep); z-index: 9999;
        transform-origin: 0 50%; transform: scaleX(0);
        transition: transform 0.1s ease-out;
    }
    :global(html[data-theme="dark"]) .reading-progress-bar { background: #60a5fa; }

    .article-layout {
        display: grid; grid-template-columns: 1fr minmax(auto, 680px) 1fr;
        gap: 2rem; max-width: 1300px; margin: 0 auto; padding: 0 5%;
        align-items: start;
    }

    .article-body { padding: 0 0 6rem; }
    
    .sticky { position: sticky; top: 120px; }

    /* Share Pill */
    .article-sidebar-left { display: flex; justify-content: flex-end; padding-right: 2rem; }
    .share-pill {
        display: flex; flex-direction: column; gap: 0.8rem;
        background: rgba(255,255,255,0.8); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        padding: 0.8rem; border-radius: 100px;
        box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.08), 0 8px 16px -4px rgba(0,0,0,0.05);
    }
    :global(html[data-theme="dark"]) .share-pill {
        background: rgba(20,20,20,0.6); box-shadow: inset 0 0 0 0.5px rgba(255,255,255,0.08);
    }
    
    .share-btn {
        width: 40px; height: 40px; border-radius: 50%; border: none;
        display: flex; align-items: center; justify-content: center;
        background: transparent; color: #4b5563; cursor: pointer;
        transition: all 0.2s; text-decoration: none; position: relative;
    }
    :global(html[data-theme="dark"]) .share-btn { color: #9ca3af; }
    .share-btn:hover { background: rgba(0,0,0,0.05); color: #111827; }
    :global(html[data-theme="dark"]) .share-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .share-btn svg { width: 18px; height: 18px; }

    .share-btn .tooltip {
        position: absolute; left: calc(100% + 10px); top: 50%; transform: translateY(-50%) translateX(-5px);
        background: #111827; color: #fff; padding: 4px 10px; border-radius: 6px;
        font-size: 0.75rem; font-weight: 600; opacity: 0; pointer-events: none;
        transition: all 0.2s; white-space: nowrap;
    }
    :global(html[data-theme="dark"]) .share-btn .tooltip { background: #fff; color: #111827; }
    .share-btn.copied .tooltip { opacity: 1; transform: translateY(-50%) translateX(0); }

    /* TOC Scrollspy */
    .article-sidebar-right { padding-left: 2rem; }
    .toc-container {
        border-left: 1px solid rgba(0,0,0,0.08); padding-left: 1.5rem;
    }
    :global(html[data-theme="dark"]) .toc-container { border-left-color: rgba(255,255,255,0.1); }
    
    .toc-title {
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
        color: #9ca3af; display: block; margin-bottom: 1rem;
    }
    .toc-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.8rem; }
    .toc-list li a {
        font-size: 0.9rem; color: #6b7280; text-decoration: none; line-height: 1.4;
        display: block; transition: color 0.2s; font-weight: 500;
    }
    :global(html[data-theme="dark"]) .toc-list li a { color: #9ca3af; }
    .toc-list li a:hover { color: #111827; }
    :global(html[data-theme="dark"]) .toc-list li a:hover { color: #fff; }
    .toc-list li a.active { color: var(--color-blue-deep); font-weight: 600; }
    :global(html[data-theme="dark"]) .toc-list li a.active { color: #60a5fa; }
    
    .toc-depth-3 { padding-left: 1rem; font-size: 0.85rem; }

    @media (max-width: 1024px) {
        .article-layout { grid-template-columns: 1fr; gap: 0; }
        .article-sidebar-left, .article-sidebar-right { display: none; } /* Hide sticky sidebars on mobile */
    }

    /* ==========================================================
       BENTO CTA (SUBSCRIBE FOOTER)
       ========================================================== */
    .article-footer-cta {
        max-width: 1200px; margin: 0 auto 6rem; padding: 0 5%;
    }
    .bento-grid {
        display: grid; grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem; align-items: stretch;
    }

    .bento-card {
        background: #fff; border-radius: 20px; padding: 2.5rem;
        display: flex; flex-direction: column; justify-content: space-between;
        transition: transform 0.3s;
    }
    :global(html[data-theme="dark"]) .bento-card { background: rgba(255,255,255,0.02); }
    .bento-card:hover { transform: translateY(-2px); }

    .span-2 { grid-column: span 2; }

    .bento-card h3 {
        font-size: 1.6rem; font-weight: 700; color: #111827; letter-spacing: -0.02em;
        margin-bottom: 0.8rem;
    }
    :global(html[data-theme="dark"]) .bento-card h3 { color: #fff; }
    
    .bento-card h4 {
        font-size: 1.15rem; font-weight: 700; color: #111827;
        margin-bottom: 0.5rem;
    }
    :global(html[data-theme="dark"]) .bento-card h4 { color: #fff; }

    .bento-card p {
        font-size: 1rem; color: #4b5563; line-height: 1.5; margin-bottom: 2rem;
    }
    :global(html[data-theme="dark"]) .bento-card p { color: #9ca3af; }

    .bento-icon {
        width: 48px; height: 48px; border-radius: 12px;
        background: rgba(10,37,218,0.06); color: var(--color-blue-deep);
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 2rem;
    }
    :global(html[data-theme="dark"]) .bento-icon {
        background: rgba(59,130,246,0.15); color: #60a5fa;
    }
    .bento-icon svg { width: 24px; height: 24px; }

    /* Formulario de Suscripción */
    .subscribe-form {
        display: flex; gap: 0.8rem; margin-bottom: 1rem;
    }
    .subscribe-form input {
        flex: 1; padding: 0 1rem; border-radius: 100px;
        background: #f3f4f6; border: none;
        font-family: inherit; font-size: 1rem; color: #111827;
        box-shadow: inset 0 0 0 1px transparent; transition: box-shadow 0.2s;
    }
    :global(html[data-theme="dark"]) .subscribe-form input {
        background: #1f2937; color: #fff;
