---
// /src/pages/soporte.astro
// Página principal del Centro de Ayuda de Cord
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Footer from '../components/landing/Footer.astro';
import PageAnims from '../components/landing/PageAnims.astro';
import SupportHero from '../components/support/SupportHero.astro';
import SupportCards from '../components/support/SupportCards.astro';
---

<Layout
    title="Centro de Ayuda y Soporte — Cord"
    description="Encuentra respuestas rápidas, guías y artículos de soporte para dominar Cord. Estamos aquí para ayudarte."
>
    <Nav />
    <main>
        <SupportHero />
        <SupportCards />
    </main>
    <Footer 
        ctaTitle="¿Listo para acelerar tus ventas?"
        ctaSub="Únete a las empresas que ya cotizan como profesionales con Cord."
    />
    <PageAnims />
</Layout>
