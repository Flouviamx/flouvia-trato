---
// Página de solución (Startups).
// Diseño alineado al estilo Cord.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import SolucionBlockMockup from '../../components/soluciones/SolucionBlockMockup.astro';
import ProFeatures from '../../components/soluciones/ProFeatures.astro';
import MockupCotizacion from '../../components/soluciones/MockupCotizacion.astro';
import MockupPagos from '../../components/soluciones/MockupPagos.astro';
import MockupCFDI from '../../components/soluciones/MockupCFDI.astro';
import { SOLUCIONES } from '../../lib/solucion';
import { SOLUCIONES_EN } from '../../lib/solucion.en';
import { getLangFromUrl } from '../../i18n/utils';
import '../../styles/mockups.css';
import QuantizedWaveBg from '../../components/soluciones/QuantizedWaveBg.jsx';

const lang = getLangFromUrl(Astro.url);
const isEn = Astro.props.isEn || lang === 'en';
const baseSolucion = isEn ? SOLUCIONES_EN.find((s) => s.slug === 'startups') : SOLUCIONES.find((s) => s.slug === 'startups');
const solucion = baseSolucion!;
const otras = (isEn ? SOLUCIONES_EN : SOLUCIONES).filter((s) => s.slug !== solucion.slug);

const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: solucion.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};

// Array estático de logos (Stripe-style logo cloud)
const clientLogos = ['GAMA', 'ACEROS', 'VERTICE', 'ZARCO', 'FERREX', 'CEMENTOS'];
---

<Layout
    title={solucion.metaTitle ?? `${solucion.nav} — Cord`}
    description={solucion.metaDescription ?? solucion.sub}
>
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <Nav darkHero={solucion.slug === 'empresas'} />
    <main class="stripe-main">
        
        {solucion.slug === 'startups' ? (
            <header class="startup-hero">
                <div class="startup-hero-bg">
                    <QuantizedWaveBg client:only="react" />
                </div>
                
                <div class="startup-hero-content stripe-container">
                    <h1 class="startup-title reveal" set:html={solucion.titulo} />
                    
                    <p class="startup-sub">{solucion.sub}</p>
                    
                    <div class="startup-actions">
                        <a href={isEn ? '/en/registro' : '/registro'} class="btn-luxe">
                            <span>{isEn ? 'Start building' : 'Empezar ahora'}</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost">
                            <span>{isEn ? 'Book a demo' : 'Contactar a ventas'}</span>
                        </a>
                    </div>
                </div>
            </header>
        ) : (
            <header class="stripe-hero">
                <div class="stripe-hero-bg">
                    <div class="stripe-hero-aurora"></div>
                    <div class="stripe-hero-sweep"></div>
                </div>
                
                <div class="stripe-hero-content stripe-container">
                    <h1 class="stripe-title reveal" set:html={solucion.titulo} />
                    
                    <p class="stripe-sub">{solucion.sub}</p>
                    
                    <div class="stripe-actions">
                        <a href={isEn ? '/en/registro' : '/registro'} class="btn-luxe">
                            <span>{isEn ? 'Start now' : 'Empezar ahora'}</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost">
                            <span>{isEn ? 'Contact sales' : 'Contactar a ventas'}</span>
                        </a>
                    </div>
                </div>
            </header>
        )}

        <!-- ── STARTUP USE CASES ── -->
        {solucion.useCases && (
            <section class="startup-use-cases-section reveal">
                <div class="stripe-container">
                    <div class="startup-section-header">
                        <div class="startup-section-titles">
                            <h2 class="startup-section-title">{isEn ? 'Ideal for every business model' : 'Ideal para todo tipo de empresas'}</h2>
                            <p class="startup-section-sub">{isEn ? 'Thousands of successful companies automate their sales flow with Cord.' : 'Miles de empresas exitosas ya automatizan su proceso comercial con Cord.'}</p>
                        </div>
                        <div class="startup-carousel-controls">
                            <button id="startup-prev" class="carousel-btn" aria-label="Previous">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
                            </button>
                            <button id="startup-next" class="carousel-btn" aria-label="Next">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                            </button>
                        </div>
                    </div>
                </div> <!-- End stripe-container to allow full-bleed grid -->
                
                <div class="startup-use-cases-grid">
                        {solucion.useCases.map(uc => (
                            <div class="startup-use-case-card">
                                <div class="uc-content">
                                    <h3 class="uc-title">{uc.title}</h3>
                                    <p class="uc-desc">{uc.desc}</p>
                                    <a href={uc.link} class="uc-link">
                                        <span>{isEn ? 'Learn more' : 'Más información'}</span>
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                                    </a>
                                </div>
                                <div class="uc-logos">
                                    {uc.logos.map(l => (
                                        <div class="uc-logo-item">
                                            <img src={`https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://${l.domain}&size=128`} alt={l.name} class="uc-logo-img" loading="lazy" />
                                            <span class="uc-logo-name">{l.name}</span>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        ))}
                    </div>
            </section>
        )}

        <!-- ── STARTUP INTEGRATION TABS (Apple Style) ── -->
        {solucion.slug === 'startups' && (
            <section class="integration-tabs-section reveal">
                <div class="stripe-container">
                    <div class="integration-header">
                        <h2 class="integration-title">{isEn ? 'Integrate Cord your way' : 'Integra Cord a tu medida'}</h2>
                        <p class="integration-sub">{isEn ? 'Stripe offers a wide range of options to accept payments, from no-code and low-code options to powerful APIs.' : 'Cord ofrece una amplia gama de opciones para automatizar tus ventas, desde configuraciones visuales sin código hasta potentes API REST.'}</p>
                    </div>

                    <div class="stripe-tabs-container">
                        <div class="stripe-progress-track">
                            <div class="stripe-progress-fill" id="stripe-progress-fill"></div>
                        </div>
                        <div class="stripe-tabs-buttons" role="tablist">
                            <button class="stripe-tab active" role="tab" aria-selected="true" data-target="tab-nocode">
                                <span class="tab-label">Sin código</span>
                                <span class="tab-sub">Más rápido</span>
                            </button>
                            <button class="stripe-tab" role="tab" aria-selected="false" data-target="tab-lowcode">
                                <span class="tab-label">Bajo código</span>
                                <span class="tab-sub">Optimizado</span>
                            </button>
                            <button class="stripe-tab" role="tab" aria-selected="false" data-target="tab-api">
                                <span class="tab-label">API REST</span>
                                <span class="tab-sub">Control total</span>
                            </button>
                        </div>
                    </div>
                </div> <!-- Close stripe-container so track can bleed full width -->

                    <div class="integration-scroll-track" id="integration-scroll">
                        <!-- NO CODE -->
                        <div class="int-card" data-tab-group="tab-nocode">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Cotizador Visual</h3>
                                <p class="int-card-desc">Crea cotizaciones interactivas arrastrando y soltando elementos de tu catálogo en segundos.</p>
                                <a href="/producto/editor" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui imk-editor-bg">
                                    <!-- Top chrome -->
                                    <div class="imk-chrome-bar">
                                        <div class="imk-dots"><span class="imk-d imk-d-r"></span><span class="imk-d imk-d-y"></span><span class="imk-d imk-d-g"></span></div>
                                        <div class="imk-chrome-title">Nueva cotización — Innovatech SA</div>
                                        <div class="imk-chrome-send">Enviar</div>
                                    </div>
                                    <!-- Table header -->
                                    <div class="imk-tbl-head imk-tbl-head-5">
                                        <span>Producto</span><span class="imk-tc">Cant.</span><span class="imk-tr2">Lista</span><span class="imk-tr2">Negociado</span><span class="imk-tr2">Total</span>
                                    </div>
                                    <!-- Row 1 -->
                                    <div class="imk-tbl-row imk-tbl-row-5">
                                        <span class="imk-t1">Licencia Pro Anual</span>
                                        <span class="imk-tc imk-t2">5</span>
                                        <span class="imk-tr2 imk-t2 imk-strike">$24,000</span>
                                        <span class="imk-tr2 imk-t1">$21,600</span>
                                        <span class="imk-tr2 imk-t1">$108,000</span>
                                    </div>
                                    <!-- Row 2 active -->
                                    <div class="imk-tbl-row imk-tbl-row-5 imk-row-active">
                                        <span class="imk-t1">Soporte Premium <span class="imk-disc-badge">−10%</span></span>
                                        <span class="imk-tc imk-t2">3</span>
                                        <span class="imk-tr2 imk-t2 imk-strike">$2,500</span>
                                        <span class="imk-tr2 imk-t1 imk-neg-price">$2,250</span>
                                        <span class="imk-tr2 imk-t1">$6,750</span>
                                    </div>
                                    <!-- Row 3 -->
                                    <div class="imk-tbl-row imk-tbl-row-5">
                                        <span class="imk-t1">Implementación</span>
                                        <span class="imk-tc imk-t2">1</span>
                                        <span class="imk-tr2 imk-t2">$8,000</span>
                                        <span class="imk-tr2 imk-t1">$8,000</span>
                                        <span class="imk-tr2 imk-t1">$8,000</span>
                                    </div>
                                    <!-- Drag zone -->
                                    <div class="imk-drag-zone">
                                        <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                        Agregar producto del catálogo
                                    </div>
                                    <!-- Totals footer -->
                                    <div class="imk-tbl-foot imk-tbl-foot-breakdown">
                                        <div class="imk-foot-row"><span class="imk-foot-label">Subtotal</span><span class="imk-foot-sub">$122,750</span></div>
                                        <div class="imk-foot-row"><span class="imk-foot-label">IVA 16%</span><span class="imk-foot-sub">$19,640</span></div>
                                        <div class="imk-foot-row imk-foot-total-row"><span class="imk-foot-label imk-foot-label-bold">Total</span><span class="imk-foot-total">$142,390</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="int-card" data-tab-group="tab-nocode">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Ligas de Pago</h3>
                                <p class="int-card-desc">Genera links de cobro al instante y compártelos por WhatsApp sin escribir una línea de código.</p>
                                <a href="/producto/link-publico" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui imk-pay-bg">
                                    <div class="imk-pay-card">
                                        <!-- Header -->
                                        <div class="imk-pay-head">
                                            <div class="imk-pay-avatar">IN</div>
                                            <div class="imk-pay-company">
                                                <div class="imk-t1">Innovatech SA de CV</div>
                                                <div class="imk-t2">COT-0342 · 3 conceptos</div>
                                            </div>
                                            <div class="imk-badge-green">Vigente</div>
                                        </div>
                                        <!-- Items -->
                                        <div class="imk-pay-items">
                                            <div class="imk-pay-item">
                                                <span class="imk-t2 imk-pay-item-name">Licencia Pro Anual ×5</span>
                                                <span class="imk-t1 imk-pay-item-price">$108,000</span>
                                            </div>
                                            <div class="imk-pay-item">
                                                <span class="imk-t2 imk-pay-item-name">Soporte Premium ×3</span>
                                                <span class="imk-t1 imk-pay-item-price">$6,750</span>
                                            </div>
                                            <div class="imk-pay-item">
                                                <span class="imk-t2 imk-pay-item-name">Implementación ×1</span>
                                                <span class="imk-t1 imk-pay-item-price">$8,000</span>
                                            </div>
                                        </div>
                                        <!-- Divider + total -->
                                        <div class="imk-pay-divider"></div>
                                        <div class="imk-pay-amount">
                                            <div class="imk-pay-total">$142,390</div>
                                            <div class="imk-t2" style="text-align:center;margin-top:1px;">MXN · IVA incluido</div>
                                        </div>
                                        <!-- CTA -->
                                        <button class="imk-pay-btn">Aprobar cotización</button>
                                        <div class="imk-pay-reject">Rechazar</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- LOW CODE -->
                        <div class="int-card" data-tab-group="tab-lowcode">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Zapier & Make</h3>
                                <p class="int-card-desc">Conecta Cord con Zapier, Make o n8n usando webhooks para automatizar tu flujo de trabajo.</p>
                                <a href="/desarrolladores/api" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui imk-flow-bg">
                                    <!-- Step 1 -->
                                    <div class="imk-flow-step">
                                        <div class="imk-flow-node imk-flow-node-active">
                                            <div class="imk-flow-node-label">TRIGGER</div>
                                            <div class="imk-flow-node-brand">
                                                <div class="imk-flow-brand-icon imk-navy">C</div>
                                                <span class="imk-t1">Cord</span>
                                            </div>
                                            <div class="imk-flow-event imk-event-blue">quote.approved</div>
                                        </div>
                                        <div class="imk-flow-vline"></div>
                                    </div>
                                    <!-- Step 2 -->
                                    <div class="imk-flow-step">
                                        <div class="imk-flow-node">
                                            <div class="imk-flow-node-label">ROUTER</div>
                                            <div class="imk-flow-node-brand">
                                                <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://zapier.com&size=32" class="imk-flow-brand-img" alt="Zapier" />
                                                <span class="imk-t1">Zapier</span>
                                            </div>
                                            <div class="imk-flow-event imk-event-orange">Enrutar</div>
                                        </div>
                                        <div class="imk-flow-vline"></div>
                                    </div>
                                    <!-- Step 3: two parallel actions -->
                                    <div class="imk-flow-actions">
                                        <div class="imk-flow-action-node">
                                            <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://sheets.google.com&size=32" class="imk-flow-brand-img" alt="Sheets" />
                                            <span class="imk-t2" style="font-size:9px;">Sheets</span>
                                            <span class="imk-flow-action-label">+ Fila</span>
                                        </div>
                                        <div class="imk-flow-action-node">
                                            <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://slack.com&size=32" class="imk-flow-brand-img" alt="Slack" />
                                            <span class="imk-t2" style="font-size:9px;">Slack</span>
                                            <span class="imk-flow-action-label">Notificar</span>
                                        </div>
                                    </div>
                                    <!-- Also compatible with -->
                                    <div class="imk-flow-alts">
                                        <span class="imk-t2" style="font-size:9px;">También:</span>
                                        <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://make.com&size=32" class="imk-alt-img" alt="Make" />
                                        <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://n8n.io&size=32" class="imk-alt-img" alt="n8n" />
                                        <img src="https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://hubspot.com&size=32" class="imk-alt-img" alt="HubSpot" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="int-card" data-tab-group="tab-lowcode">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Webhooks</h3>
                                <p class="int-card-desc">Conecta Cord con tu ERP o CRM actual usando webhooks que disparan acciones en tiempo real.</p>
                                <a href="/desarrolladores/api" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui imk-wh-bg">
                                    <div class="imk-wh-card">
                                        <!-- Header with URL -->
                                        <div class="imk-wh-head">
                                            <div class="imk-wh-head-left">
                                                <div class="imk-live-dot">
                                                    <span class="imk-pulse-dot"></span>
                                                    <span class="imk-t2" style="font-size:9px;color:#10b981;">En vivo</span>
                                                </div>
                                                <code class="imk-wh-endpoint">POST mi-erp.com/hooks/cord</code>
                                            </div>
                                            <span class="imk-t1">Log de entregas</span>
                                        </div>
                                        <!-- Column headers -->
                                        <div class="imk-wh-cols">
                                            <span>Evento</span><span>Status</span><span class="imk-tr2">ms</span>
                                        </div>
                                        <!-- Events -->
                                        <div class="imk-wh-row">
                                            <div class="imk-wh-info">
                                                <span class="imk-wh-dot imk-wh-dot-green"></span>
                                                <span class="imk-wh-event">quote.paid</span>
                                            </div>
                                            <span class="imk-status-ok">200 OK</span>
                                            <span class="imk-wh-ms">124ms</span>
                                        </div>
                                        <div class="imk-wh-row">
                                            <div class="imk-wh-info">
                                                <span class="imk-wh-dot imk-wh-dot-green"></span>
                                                <span class="imk-wh-event">quote.approved</span>
                                            </div>
                                            <span class="imk-status-ok">200 OK</span>
                                            <span class="imk-wh-ms">98ms</span>
                                        </div>
                                        <div class="imk-wh-row" style="border-bottom:none;">
                                            <div class="imk-wh-info">
                                                <span class="imk-wh-dot imk-wh-dot-green"></span>
                                                <span class="imk-wh-event">quote.viewed</span>
                                            </div>
                                            <span class="imk-status-ok">200 OK</span>
                                            <span class="imk-wh-ms">87ms</span>
                                        </div>
                                        <!-- Footer action -->
                                        <div class="imk-wh-foot">
                                            <button class="imk-wh-btn">Reintentar</button>
                                            <button class="imk-wh-btn">Ver payload</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- API -->
                        <div class="int-card" data-tab-group="tab-api">
                            <div class="int-card-text">
                                <h3 class="int-card-title">API RESTful</h3>
                                <p class="int-card-desc">Crea cotizaciones, clientes y consulta tu cobranza desde tu propio software con nuestra API REST.</p>
                                <a href="/desarrolladores/api" class="int-link">Ver documentación <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui imk-term-bg">
                                    <!-- Dark terminal -->
                                    <div class="imk-term">
                                        <div class="imk-term-head">
                                            <div class="imk-dots"><span class="imk-d imk-d-r"></span><span class="imk-d imk-d-y"></span><span class="imk-d imk-d-g"></span></div>
                                            <span class="imk-term-title">Terminal — cord API v1</span>
                                        </div>
                                        <div class="imk-term-body">
                                            <div class="imk-term-line"><span class="imk-tc-gray">$ </span><span class="imk-tc-white">curl -s -X POST \</span></div>
                                            <div class="imk-term-line imk-term-indent"><span class="imk-tc-gray">https://</span><span class="imk-tc-white">cord.flouvia.com/api/v1/cotizaciones</span><span class="imk-tc-white"> \</span></div>
                                            <div class="imk-term-line imk-term-indent"><span class="imk-tc-gray">-H </span><span class="imk-tc-green">"Authorization: Bearer sk_live_***"</span><span class="imk-tc-white"> \</span></div>
                                            <div class="imk-term-line imk-term-indent"><span class="imk-tc-gray">-d </span><span class="imk-tc-yellow">'&#123;"cliente_id":"cl_9Xv"&#125;'</span></div>
                                            <div class="imk-term-blank"></div>
                                            <div class="imk-term-line"><span class="imk-tc-gray">HTTP/2 </span><span class="imk-tc-green">201 Created</span></div>
                                            <div class="imk-term-line"><span class="imk-tc-muted">&#123;</span></div>
