---
// Página de solución (Startups).
// Diseño alineado al estilo Cord.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import SolucionBlockMockup from '../../components/soluciones/SolucionBlockMockup.astro';
import ProFeatures from '../../components/soluciones/ProFeatures.astro';
import MockupCotizacion from '../../components/soluciones/MockupCotizacion.astro';
import MockupPagos from '../../components/soluciones/MockupPagos.astro';
import MockupCFDI from '../../components/soluciones/MockupCFDI.astro';
import { SOLUCIONES } from '../../lib/solucion';
import { SOLUCIONES_EN } from '../../lib/solucion.en';
import { getLangFromUrl } from '../../i18n/utils';
import '../../styles/mockups.css';

const lang = getLangFromUrl(Astro.url);
const isEn = Astro.props.isEn || lang === 'en';
const baseSolucion = isEn ? SOLUCIONES_EN.find((s) => s.slug === 'startups') : SOLUCIONES.find((s) => s.slug === 'startups');
const solucion = baseSolucion!;
const otras = (isEn ? SOLUCIONES_EN : SOLUCIONES).filter((s) => s.slug !== solucion.slug);

const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: solucion.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};

// Array estático de logos (Stripe-style logo cloud)
const clientLogos = ['GAMA', 'ACEROS', 'VERTICE', 'ZARCO', 'FERREX', 'CEMENTOS'];
---

<Layout
    title={solucion.metaTitle ?? `${solucion.nav} — Cord`}
    description={solucion.metaDescription ?? solucion.sub}
>
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <Nav darkHero={solucion.slug === 'empresas'} />
    <main class="stripe-main">
        
        {solucion.slug === 'startups' ? (
            <!-- ── HERO (Stripe Startups Style) ── -->
            <header class="startup-hero">
                <div class="startup-hero-bg">
                    <div class="startup-hero-blob-1"></div>
                    <div class="startup-hero-blob-2"></div>
                </div>
                
                <div class="startup-hero-content stripe-container">
                    <h1 class="startup-title reveal" set:html={solucion.titulo} />
                    
                    <p class="startup-sub">{solucion.sub}</p>
                    
                    <div class="startup-actions">
                        <a href={isEn ? '/en/registro' : '/registro'} class="btn-luxe">
                            <span>{isEn ? 'Start building' : 'Empezar ahora'}</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost">
                            <span>{isEn ? 'Book a demo' : 'Contactar a ventas'}</span>
                        </a>
                    </div>
                </div>
            </header>
        ) : (
            <!-- ── HERO (Stripe Enterprise) ── -->
            <header class="stripe-hero">
                <div class="stripe-hero-bg">
                    <div class="stripe-hero-aurora"></div>
                    <div class="stripe-hero-sweep"></div>
                </div>
                
                <div class="stripe-hero-content stripe-container">
                    <h1 class="stripe-title reveal" set:html={solucion.titulo} />
                    
                    <p class="stripe-sub">{solucion.sub}</p>
                    
                    <div class="stripe-actions">
                        <a href={isEn ? '/en/registro' : '/registro'} class="btn-luxe">
                            <span>{isEn ? 'Start now' : 'Empezar ahora'}</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost">
                            <span>{isEn ? 'Contact sales' : 'Contactar a ventas'}</span>
                        </a>
                    </div>
                </div>
            </header>
        )}

        <!-- ── STARTUP USE CASES ── -->
        {solucion.useCases && (
            <section class="startup-use-cases-section reveal">
                <div class="stripe-container">
                    <div class="startup-section-header">
                        <div class="startup-section-titles">
                            <h2 class="startup-section-title">{isEn ? 'Ideal for every business model' : 'Ideal para todo tipo de empresas'}</h2>
                            <p class="startup-section-sub">{isEn ? 'Thousands of successful companies automate their sales flow with Cord.' : 'Miles de empresas exitosas ya automatizan su proceso comercial con Cord.'}</p>
                        </div>
                        <div class="startup-carousel-controls">
                            <button id="startup-prev" class="carousel-btn" aria-label="Previous">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
                            </button>
                            <button id="startup-next" class="carousel-btn" aria-label="Next">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                            </button>
                        </div>
                    </div>
                </div> <!-- End stripe-container to allow full-bleed grid -->
                
                <div class="startup-use-cases-grid">
                        {solucion.useCases.map(uc => (
                            <div class="startup-use-case-card">
                                <div class="uc-content">
                                    <h3 class="uc-title">{uc.title}</h3>
                                    <p class="uc-desc">{uc.desc}</p>
                                    <a href={uc.link} class="uc-link">
                                        <span>{isEn ? 'Learn more' : 'Más información'}</span>
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                                    </a>
                                </div>
                                <div class="uc-logos">
                                    {uc.logos.map(l => (
                                        <div class="uc-logo-item">
                                            <img src={`https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://${l.domain}&size=128`} alt={l.name} class="uc-logo-img" loading="lazy" />
                                            <span class="uc-logo-name">{l.name}</span>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        ))}
                    </div>
            </section>
        )}

        <!-- ── STARTUP INTEGRATION TABS (Apple Style) ── -->
        {solucion.slug === 'startups' && (
            <section class="integration-tabs-section reveal">
                <div class="stripe-container">
                    <div class="integration-header">
                        <h2 class="integration-title">{isEn ? 'Integrate Cord your way' : 'Integra Cord a tu medida'}</h2>
                        <p class="integration-sub">{isEn ? 'Stripe offers a wide range of options to accept payments, from no-code and low-code options to powerful APIs.' : 'Cord ofrece una amplia gama de opciones para automatizar tus ventas, desde configuraciones visuales sin código hasta potentes API REST.'}</p>
                    </div>

                    <div class="stripe-tabs-container">
                        <div class="stripe-progress-track">
                            <div class="stripe-progress-fill" id="stripe-progress-fill"></div>
                        </div>
                        <div class="stripe-tabs-buttons" role="tablist">
                            <button class="stripe-tab active" role="tab" aria-selected="true" data-target="tab-nocode">
                                <span class="tab-label">Sin código</span>
                                <span class="tab-sub">Más rápido</span>
                            </button>
                            <button class="stripe-tab" role="tab" aria-selected="false" data-target="tab-lowcode">
                                <span class="tab-label">Bajo código</span>
                                <span class="tab-sub">Optimizado</span>
                            </button>
                            <button class="stripe-tab" role="tab" aria-selected="false" data-target="tab-api">
                                <span class="tab-label">API REST</span>
                                <span class="tab-sub">Control total</span>
                            </button>
                        </div>
                    </div>
                </div> <!-- Close stripe-container so track can bleed full width -->

                    <div class="integration-scroll-track" id="integration-scroll">
                        <!-- NO CODE -->
                        <div class="int-card" data-tab-group="tab-nocode">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Cotizador Visual</h3>
                                <p class="int-card-desc">Crea cotizaciones interactivas arrastrando y soltando elementos de tu catálogo en segundos.</p>
                                <a href="/producto/editor" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui">
                                    <div class="int-mini-card" style="width: 75%; padding: 14px;">
                                        <div style="font-size: 10px; font-weight: 600; color: #64748b; margin-bottom: 12px; text-transform: uppercase;">Catálogo</div>
                                        <div style="display: flex; gap: 10px; margin-bottom: 12px; align-items: center;">
                                            <div style="width: 28px; height: 28px; background: #e2e8f0; border-radius: 6px;"></div>
                                            <div style="flex: 1;">
                                                <div style="font-size: 12px; color: #0f172a; font-weight: 600; line-height: 1.2;">Licencia Anual</div>
                                                <div style="font-size: 11px; color: #64748b;">$990.00 / mes</div>
                                            </div>
                                        </div>
                                        <div style="border: 1px dashed #cbd5e1; border-radius: 8px; padding: 12px; text-align: center; color: #94a3b8; font-size: 11px; font-weight: 500; background: #f8fafc;">
                                            + Arrastrar producto
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="int-card" data-tab-group="tab-nocode">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Ligas de Pago</h3>
                                <p class="int-card-desc">Genera links de cobro al instante y compártelos por WhatsApp sin escribir una línea de código.</p>
                                <a href="/producto/link-publico" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui" style="flex-direction: row; gap: 16px; padding: 0 20px;">
                                    <div class="int-mini-card" style="flex: 1; padding: 12px; align-self: flex-start; margin-top: 20px;">
                                        <div style="background: #f1f5f9; padding: 10px; border-radius: 12px 12px 12px 0; font-size: 10px; color: #475569; margin-bottom: 8px; max-width: 90%;">
                                            Hola, necesito renovar.
                                        </div>
                                        <div style="background: #0ea5e9; padding: 10px; border-radius: 12px 12px 0 12px; font-size: 10px; color: #fff; margin-left: auto; max-width: 95%;">
                                            ¡Claro! Aquí tienes: <br/><strong>cord.mx/pay/123</strong>
                                        </div>
                                    </div>
                                    <div class="int-mini-card" style="width: 80px; padding: 12px; text-align: center; align-self: flex-end; margin-bottom: 20px;">
                                        <div style="font-size: 12px; font-weight: 700; color: #0f172a; margin-bottom: 8px;">$990</div>
                                        <div style="width: 50px; height: 50px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;">
                                            <div style="background: #0f172a; border-radius: 2px;"></div>
                                            <div style="background: #0f172a; border-radius: 2px;"></div>
                                            <div style="background: #0ea5e9; border-radius: 2px;"></div>
                                            <div style="background: transparent;"></div>
                                            <div style="background: #0f172a; border-radius: 2px;"></div>
                                            <div style="background: transparent;"></div>
                                            <div style="background: #0ea5e9; border-radius: 2px;"></div>
                                            <div style="background: transparent;"></div>
                                            <div style="background: #0f172a; border-radius: 2px;"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- LOW CODE -->
                        <div class="int-card" data-tab-group="tab-lowcode">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Zapier & Make</h3>
                                <p class="int-card-desc">Conecta Cord con Zapier, Make o n8n usando webhooks para automatizar tu flujo de trabajo.</p>
                                <a href="/desarrolladores/api" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui">
                                    <div style="display: flex; align-items: center; gap: 16px;">
                                        <div class="int-mini-card" style="width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; background: #0f172a; color: #fff;">
                                            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                                        </div>
                                        <svg width="40" height="20" style="color: #94a3b8;"><path d="M0 10h40" stroke="currentColor" stroke-width="3" stroke-dasharray="6 6" fill="none"/></svg>
                                        <div class="int-mini-card" style="width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; background: #ff4a00; color: #fff; font-weight: 900; font-size: 24px; border:none;">
                                            Z
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="int-card" data-tab-group="tab-lowcode">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Webhooks</h3>
                                <p class="int-card-desc">Conecta Cord con tu ERP o CRM actual usando webhooks que disparan acciones en tiempo real.</p>
                                <a href="/desarrolladores/api" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui">
                                    <div class="int-mini-card" style="width: 85%; padding: 0; overflow: hidden; background: #fff;">
                                        <div style="background: #f8fafc; padding: 12px; border-bottom: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
                                            <div style="font-size: 11px; font-weight: 600; color: #0f172a;">Eventos Recientes</div>
                                            <div style="width: 8px; height: 8px; border-radius: 50%; background: #10b981; box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2);"></div>
                                        </div>
                                        <div style="padding: 12px; display: flex; flex-direction: column; gap: 8px;">
                                            <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 8px; border-bottom: 1px solid #f1f5f9;">
                                                <div>
                                                    <div style="font-size: 10px; font-weight: 600; color: #0ea5e9;">quote.paid</div>
                                                    <div style="font-size: 9px; color: #94a3b8; font-family: monospace;">evt_Xy89Za</div>
                                                </div>
                                                <div style="font-size: 9px; font-weight: 600; color: #10b981; background: #d1fae5; padding: 2px 6px; border-radius: 4px;">200 OK</div>
                                            </div>
                                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                                <div>
                                                    <div style="font-size: 10px; font-weight: 600; color: #0ea5e9;">quote.approved</div>
                                                    <div style="font-size: 9px; color: #94a3b8; font-family: monospace;">evt_Bv32Wm</div>
                                                </div>
                                                <div style="font-size: 9px; font-weight: 600; color: #10b981; background: #d1fae5; padding: 2px 6px; border-radius: 4px;">200 OK</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- API -->
                        <div class="int-card" data-tab-group="tab-api">
                            <div class="int-card-text">
                                <h3 class="int-card-title">API RESTful</h3>
                                <p class="int-card-desc">Crea cotizaciones, clientes y consulta tu cobranza desde tu propio software con nuestra API REST.</p>
                                <a href="/desarrolladores/api" class="int-link">Ver documentación <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui">
                                    <div class="int-mini-card" style="width: 85%; padding: 16px; background: #fff;">
                                        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
                                            <div style="display: flex; align-items: center; gap: 8px;">
                                                <div style="width: 24px; height: 24px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; color: #0f172a;">API</div>
                                                <div style="font-size: 11px; font-weight: 600; color: #0f172a;">Rendimiento</div>
                                            </div>
                                            <div style="font-size: 10px; color: #64748b;">Últimos 30 min</div>
                                        </div>
                                        <div style="display: flex; gap: 16px; margin-bottom: 16px;">
                                            <div>
                                                <div style="font-size: 9px; color: #64748b; font-weight: 500; margin-bottom: 2px;">Éxito (200 OK)</div>
                                                <div style="font-size: 16px; font-weight: 700; color: #10b981;">99.99%</div>
                                            </div>
                                            <div>
                                                <div style="font-size: 9px; color: #64748b; font-weight: 500; margin-bottom: 2px;">Latencia (p95)</div>
                                                <div style="font-size: 16px; font-weight: 700; color: #0f172a;">42ms</div>
                                            </div>
                                        </div>
                                        <svg viewBox="0 0 100 20" style="width: 100%; height: 20px; overflow: visible;">
                                            <path d="M0,15 Q10,5 20,10 T40,12 T60,5 T80,10 T100,2" fill="none" stroke="#0ea5e9" stroke-width="2" />
                                        </svg>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="int-card" data-tab-group="tab-api">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Cord Elements</h3>
                                <p class="int-card-desc">Embebe el cotizador en tu web o app con Cord Elements: Web Component, React y Vue.</p>
                                <a href="/desarrolladores/elements" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui">
                                    <div class="int-mini-card" style="width: 80%; padding: 16px; background: #fff; display: flex; flex-direction: column; align-items: center; gap: 16px;">
                                        <div style="font-size: 11px; font-weight: 600; color: #0f172a;">Frameworks soportados</div>
                                        <div style="display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;">
                                            <div style="padding: 6px 10px; border-radius: 8px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 6px; background: #f8fafc;">
                                                <div style="width: 10px; height: 10px; border-radius: 3px; background: #F7DF1E;"></div>
                                                <div style="font-size: 10px; font-weight: 600; color: #0f172a;">JavaScript</div>
                                            </div>
                                            <div style="padding: 6px 10px; border-radius: 8px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 6px; background: #f8fafc;">
                                                <div style="width: 10px; height: 10px; border-radius: 3px; background: #61DAFB;"></div>
                                                <div style="font-size: 10px; font-weight: 600; color: #0f172a;">React</div>
                                            </div>
                                            <div style="padding: 6px 10px; border-radius: 8px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 6px; background: #f8fafc;">
                                                <div style="width: 10px; height: 10px; border-radius: 3px; background: #42B883;"></div>
                                                <div style="font-size: 10px; font-weight: 600; color: #0f172a;">Vue</div>
                                            </div>
                                        </div>
                                        <div style="font-size: 10px; font-weight: 600; color: #64748b; background: #f1f5f9; padding: 4px 12px; border-radius: 12px;">Instalación en 1 minuto</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
            </section>
        )}

        <!-- ── AIRY BENTO PILLARS ── -->
        {solucion.pillars && (
            <section class="stripe-pillars-section">
                <div class="stripe-container">
                    <div class="stripe-pillars-grid">
                        {solucion.pillars.map((p, i) => (
                            <div class="stripe-pillar-card reveal">
                                <div class="stripe-pillar-graphic">
                                    {i === 0 && (
                                        <div class="pillar-mock-light">
                                            <div class="stripe-light-card">
                                                <div class="slc-header">Propuesta P-1042</div>
                                                <div class="slc-body">
                                                    <div class="slc-row">
                                                        <span>Suscripción Anual</span>
                                                        <strong>$120,000.00</strong>
                                                    </div>
                                                    <button class="slc-btn">Aceptar y Pagar</button>
                                                </div>
                                            </div>
                                        </div>
                                    )}
                                    {i === 1 && (
                                        <div class="pillar-mock-light">
                                            <div class="stripe-light-card">
                                                <div class="slc-kpi">
                                                    <span class="slc-kpi-label">Ingresos Mensuales</span>
                                                    <strong class="slc-kpi-value">$450,000</strong>
                                                </div>
                                                <div class="slc-chart">
                                                    <div class="slc-bar" style="height: 40%"></div>
                                                    <div class="slc-bar" style="height: 60%"></div>
                                                    <div class="slc-bar" style="height: 50%"></div>
                                                    <div class="slc-bar" style="height: 80%"></div>
                                                    <div class="slc-bar" style="height: 100%"></div>
                                                </div>
                                            </div>
                                        </div>
                                    )}
                                    {i === 2 && (
                                        <div class="pillar-mock-light">
                                            <div class="stripe-light-card">
                                                <div class="slc-header" style="border: none; margin-bottom: 8px;">
                                                    <div class="slc-badge"><svg viewBox="0 0 12 12" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><polyline points="10 3 4.5 8.5 2 6"></polyline></svg> Timbrado SAT</div>
                                                </div>
                                                <div class="slc-xml">
                                                    &lt;cfdi:Comprobante&gt;<br/>
