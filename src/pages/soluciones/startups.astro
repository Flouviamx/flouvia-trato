    /* ── Aurora Card — white card, iridescent aurora over the FULL card ── */
    .aurora-card {
        position: relative; /* needed for absolute aurora-card-layer */
    }

    /* Aurora spans the full card (both content + mockup columns).
       Same palette as the empresas hero shader (teal esmeralda + indigo),
       reactive to the cursor via --ax/--ay (teal) and --bx/--by (indigo). */
    .aurora-card-layer {
        position: absolute;
        inset: -45%;
        background:
            radial-gradient(ellipse 70% 60% at var(--ax, 22%) var(--ay, 74%),
                rgba(0, 196, 138, 0.26) 0%, transparent 58%),
            radial-gradient(ellipse 62% 72% at var(--bx, 80%) var(--by, 22%),
                rgba(74, 46, 196, 0.20) 0%, transparent 56%),
            radial-gradient(ellipse 95% 55% at var(--cx, 50%) var(--cy, 48%),
                rgba(16, 185, 129, 0.13) 0%, transparent 60%),
            radial-gradient(ellipse 55% 45% at 18% 14%,
                rgba(37, 99, 235, 0.10) 0%, transparent 66%);
        animation: aurora-card-breathe 9s ease-in-out infinite alternate;
        pointer-events: none;
        z-index: 0;
        will-change: transform;
        transition: opacity 0.5s ease;
    }
    /* Stronger aurora on hover — mirrors the hero's mouse glow */
    .aurora-card:hover .aurora-card-layer { animation-duration: 6s; }

    @keyframes aurora-card-breathe {
        0%   { transform: scale(1)    rotate(0deg); }
        35%  { transform: scale(1.08) rotate(3deg); }
        70%  { transform: scale(0.95) rotate(-2.5deg); }
        100% { transform: scale(1.06) rotate(4deg); }
    }

    /* Both content and visual sit above the aurora layer */
    .aurora-card .stripe-fg-card-content,
    .aurora-card .stripe-fg-card-visual {
        position: relative;
        z-index: 2;
    }

    .stripe-fg-title {
        font-size: 1.75rem;
        font-weight: 600;
        color: var(--stripe-text);
        margin-bottom: 1rem;
        line-height: 1.2;
        letter-spacing: -0.02em;
    }

    .stripe-fg-desc {
        font-size: 1.05rem;
        color: var(--stripe-muted);
        line-height: 1.6;
        margin-bottom: 2rem;
    }

    .stripe-fg-tags {
