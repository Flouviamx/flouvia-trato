        flex-direction: column;
        gap: 0.75rem;
        align-items: flex-start;
    }

    .stripe-fg-tag {
        background: rgba(59, 130, 246, 0.08);
        color: var(--stripe-cyan);
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
