    }
    
    .stripe-fg-card-visual {
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        min-height: 400px;
        overflow: visible;
    }

    /* UI Mockup Base (Photorealistic) */
    .real-ui {
        width: 360px;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 40px 80px -20px rgba(50,50,93,0.15), 0 20px 40px -20px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,1);
        background: #fff;
        font-family: -apple-system, BlinkMacSystemFont, "Inter", sans-serif;
        color: #0f172a;
        overflow: hidden;
        transform: translateY(0);
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
        text-align: left;
    }
    .stripe-fg-card:hover .real-ui {
        transform: translateY(-8px);
    }

    /* ── PILOTO §MOCKUP_STANDARDS: screenshot que sangra y se recorta (estilo Stripe) ──
       El mockup NO es una tarjeta centrada: llena el espacio, sin borde visible, y se
       corta en el borde del card padre (overflow:hidden) como una imagen recortada. */
    .cmk0-wrap { position: absolute; inset: 0; }
    .cmk0 {
        position: absolute; top: 2.4rem; left: 2.4rem; width: 560px;
        background: #fff; text-align: left;
        border-radius: 14px 0 0 0;
        border-top: 1px solid rgba(10,25,47,0.06);
        border-left: 1px solid rgba(10,25,47,0.06);
        box-shadow: -24px 24px 60px -24px rgba(10,25,47,0.18);
        overflow: hidden;
        transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .stripe-fg-card:hover .cmk0 { transform: translateY(-6px); }
    .cmk0-nav { display: flex; align-items: center; justify-content: space-between; padding: 16px 22px; border-bottom: 1px solid #f1f5f9; }
    .cmk0-nav-title { font-size: 14px; font-weight: 700; color: #0a192f; letter-spacing: -0.01em; }
    .cmk0-seg { display: flex; gap: 2px; background: #f5f5f7; border-radius: 9px; padding: 3px; }
    .cmk0-seg span { font-size: 11px; font-weight: 600; color: #64748b; padding: 4px 11px; border-radius: 6px; }
    .cmk0-seg span.on { background: #fff; color: #0a192f; box-shadow: 0 1px 2px rgba(10,25,47,0.08); }
    .cmk0-th, .cmk0-tr { display: grid; grid-template-columns: 80px 1.5fr 96px 92px 52px; align-items: center; gap: 12px; padding: 0 22px; }
    .cmk0-th { height: 36px; border-bottom: 1px solid #eef1f4; }
    .cmk0-th span { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8; }
    .cmk0-r { text-align: right; }
    .cmk0-tr { height: 53px; border-bottom: 1px solid #f4f6f8; }
    .cmk0-folio2 { font-size: 12px; font-weight: 700; color: #475569; font-variant-numeric: tabular-nums; }
    .cmk0-cli { font-size: 13px; font-weight: 600; color: #0f172a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cmk0-amt { font-size: 13px; font-weight: 600; color: #0f172a; text-align: right; }
    .cmk0-date { font-size: 11px; color: #94a3b8; font-weight: 500; text-align: right; white-space: nowrap; }
    .cmk0-badge { font-size: 10.5px; font-weight: 700; padding: 3px 9px; border-radius: 999px; white-space: nowrap; justify-self: start; }
    .cmk0-b-green { background: rgba(16,185,129,0.12); color: #047857; }
    .cmk0-b-blue { background: rgba(37,99,235,0.10); color: #1d4ed8; }
    .cmk0-b-gray { background: rgba(10,25,47,0.06); color: #475569; }
    @media (max-width: 768px) { .cmk0 { top: 1.6rem; left: 1.6rem; } }

