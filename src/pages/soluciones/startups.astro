        border-color: rgba(10,25,47,0.08);
        background: rgba(255,255,255,0.6);
    }
    .stripe-cta-card .btn-ghost:hover {
        background: #fff;
        box-shadow: 0 6px 16px rgba(10,25,47,0.06);
    }

    /* ════════════════════════════════════════════════════════════════
       RESPONSIVE
    ════════════════════════════════════════════════════════════════ */
    @media (max-width: 992px) {
        .stripe-hero {
            padding: 140px 0 80px;
            min-height: 70vh;
        }
        
        .stripe-bento-grid {
            grid-template-columns: 1fr;
        }
        
        .stripe-bento-card.span-2 {
            grid-column: 1;
        }
        
        .span-2 .stripe-bento-inner {
            flex-direction: column-reverse;
            gap: 2rem;
        }
        
        .stripe-stats-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
    }
    
    @media (max-width: 768px) {
        .stripe-hero {
            padding: 120px 20px 60px;
        }
        
        .stripe-title {
            font-size: 2.5rem;
        }
        
        .stripe-actions {
            flex-direction: column;
            width: 100%;
        }
        
        .btn-luxe, .btn-ghost {
            width: 100%;
            justify-content: center;
        }
        
        .stripe-testimonial-card {
            padding: 2rem;
        }
        
        .stripe-testimonial-metrics {
            flex-direction: column;
            gap: 2rem;
        }
    }

    /* ════════════════════════════════════════════════════════════════
       NUEVAS SECCIONES STRIPE ENTERPRISE
    ════════════════════════════════════════════════════════════════ */
    
    .stripe-hero-eyebrow {
        color: var(--stripe-cyan);
        font-weight: 700;
        letter-spacing: 0.1em;
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
        background: rgba(59, 130, 246, 0.15);
        padding: 4px 12px;
        border-radius: 100px;
        border: 1px solid rgba(59, 130, 246, 0.3);
        display: inline-block;
    }

    .stripe-section-eyebrow {
        color: var(--stripe-cyan);
        font-weight: 700;
        letter-spacing: 0.1em;
        font-size: 0.85rem;
        margin-bottom: 1rem;
        display: block;
    }
    
    .stripe-eyebrow-light {
        color: #60a5fa; /* Light Blue */
    }

    .text-white { color: #fff !important; }
    .text-white-muted { color: rgba(255,255,255,0.7) !important; }

    /* ── INTEGRATIONS TICKER ── */
    .stripe-integrations-ticker {
        position: relative;
        z-index: 20;
        margin-top: -60px;
        margin-bottom: 4rem;
        background: rgba(255,255,255,0.8);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-top: 1px solid var(--stripe-border);
        border-bottom: 1px solid var(--stripe-border);
        padding: 24px 0;
        overflow: hidden;
    }
    
    .stripe-ticker-track {
        display: flex;
        width: max-content;
        animation: marquee 30s linear infinite;
    }
    
    .stripe-ticker-tape {
        display: flex;
        align-items: center;
        gap: 60px;
        padding-right: 60px;
    }
    
    .stripe-ticker-item {
        display: flex;
        align-items: center;
        gap: 12px;
        opacity: 0.6;
        transition: opacity 0.3s;
    }
    
    .stripe-ticker-item:hover {
        opacity: 1;
    }
    
    .stripe-ticker-icon {
        color: var(--stripe-accent);
        width: 24px; height: 24px;
    }
    
    .stripe-ticker-name {
        font-weight: 600;
        font-size: 1.1rem;
        letter-spacing: -0.02em;
        color: var(--stripe-text);
    }
    
    @keyframes marquee {
        to { transform: translateX(-50%); }
    }

    /* ── AIRY BENTO PILLARS ── */
    .stripe-pillars-section {
        padding: 4rem 0 6rem;
        background: var(--stripe-bg);
        position: relative;
        z-index: 10;
    }
    
    .stripe-pillars-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }
    
    .stripe-pillar-card {
        background: #fff;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 12px 32px rgba(0,0,0,0.03), 0 2px 8px rgba(0,0,0,0.02);
        display: flex;
        flex-direction: column;
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        border: 1px solid rgba(0,0,0,0.04);
    }
    
    .stripe-pillar-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 24px 48px rgba(0,0,0,0.06), 0 8px 16px rgba(0,0,0,0.03);
    }
    
    .stripe-pillar-graphic {
        background: #f6f9fc;
        height: 240px;
        position: relative;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        border-bottom: 1px solid rgba(0,0,0,0.04);
        overflow: hidden;
    }
    
    .pillar-mock-light {
        width: 100%; height: 100%;
        display: flex; align-items: flex-end; justify-content: center;
        position: relative; padding: 0 32px;
    }

    .stripe-light-card {
        background: #ffffff;
        width: 100%;
        border-radius: 12px 12px 0 0;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.04);
        border-bottom: none;
        padding: 24px;
        transform: translateY(16px);
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s;
        font-family: -apple-system, BlinkMacSystemFont, "Inter", sans-serif;
    }
    .stripe-pillar-card:hover .stripe-light-card {
        transform: translateY(0);
        box-shadow: 0 12px 30px rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.03);
    }

    /* Shared Mockup Elements */
    .slc-header { font-size: 11px; font-weight: 600; color: #475569; margin-bottom: 16px; border-bottom: 1px solid #f1f5f9; padding-bottom: 8px; display: flex; justify-content: space-between; align-items: center; }
    .slc-row { display: flex; justify-content: space-between; align-items: center; font-size: 13px; margin-bottom: 16px; }
    .slc-row span { color: #64748b; font-weight: 500; }
    .slc-row strong { color: #0f172a; font-weight: 700; font-size: 16px; }
    .slc-btn { background: #0ea5e9; color: #ffffff; border: none; width: 100%; padding: 12px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; transition: background 0.2s; }
    .stripe-pillar-card:hover .slc-btn { background: #0284c7; }
    
    .slc-kpi { display: flex; flex-direction: column; gap: 4px; margin-bottom: 24px; }
    .slc-kpi-label { font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; }
    .slc-kpi-value { font-size: 26px; font-weight: 700; color: #0f172a; letter-spacing: -0.5px; }
    .slc-chart { display: flex; align-items: flex-end; gap: 8px; height: 60px; }
    .slc-bar { flex: 1; background: linear-gradient(180deg, #6366f1 0%, #0ea5e9 100%); border-radius: 4px 4px 0 0; opacity: 0.8; transition: opacity 0.3s, transform 0.5s; transform-origin: bottom; transform: scaleY(0.85); }
    .stripe-pillar-card:hover .slc-bar { opacity: 1; transform: scaleY(1); }
    
    .slc-xml { font-family: 'SF Mono', Consolas, monospace; font-size: 11px; color: #475569; background: #f8fafc; padding: 12px; border-radius: 8px; line-height: 1.6; border: 1px solid #f1f5f9; }
    .slc-badge { display: inline-flex; align-items: center; gap: 4px; background: #ecfdf5; color: #059669; padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    
    .stripe-pillar-content {
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        flex: 1;
    }
    
    .stripe-pillar-title {
        font-size: 1.35rem;
        font-weight: 600;
        color: #0a192f;
        margin-bottom: 1rem;
        line-height: 1.3;
    }
    
    .stripe-pillar-desc {
        font-size: 1rem;
        color: #555556;
        line-height: 1.6;
        margin-bottom: 2rem;
        flex: 1;
    }
    
    .stripe-pillar-link {
        color: var(--stripe-cyan);
        font-weight: 600;
        font-size: 0.95rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        transition: color 0.2s;
        margin-top: auto;
    }
    
    .stripe-pillar-link svg {
        width: 16px;
        height: 16px;
        transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }
    
    .stripe-pillar-link:hover {
        color: var(--stripe-accent-light);
    }
    
    .stripe-pillar-card:hover .stripe-pillar-link svg {
        transform: translateY(2px);
    }

    /* ── SECURITY ── */
    .stripe-security-section {
        position: relative;
        padding: 8rem 0;
        margin: 4rem 0;
        overflow: hidden;
    }
    
    .stripe-security-bg {
        position: absolute;
        inset: 0;
        background: #0a192f;
        transform: skewY(-4deg);
        transform-origin: top left;
        z-index: 0;
    }
    
    .stripe-security-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 80% 20%, rgba(99, 102, 241, 0.2) 0%, transparent 60%);
    }
    
    .stripe-security-header {
        margin-bottom: 4rem;
        max-width: 600px;
    }
    
    .stripe-security-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }
    
    .stripe-security-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        padding: 2rem;
        backdrop-filter: blur(10px);
    }
    
    .stripe-sec-icon {
        color: var(--stripe-cyan);
        width: 32px; height: 32px;
        margin-bottom: 1.5rem;
    }
    
    .stripe-sec-title {
        color: #fff;
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
    }
    
    .stripe-sec-desc {
        color: rgba(255,255,255,0.7);
        font-size: 0.95rem;
        line-height: 1.5;
    }
    
    @media (max-width: 992px) {
        .stripe-pillars-grid { grid-template-columns: 1fr; gap: 1.5rem; }
        .stripe-security-grid { grid-template-columns: 1fr; }
        .stripe-fg-layout { grid-template-columns: 1fr; }
        .stripe-fg-card { grid-template-columns: 1fr; }
        .stripe-fg-sidebar { position: static; }
        .stripe-fg-card-visual { min-height: 300px; }
    }
    
    /* ==========================================================
       HERO (Startup - Vercel/Linear style)
       ========================================================== */
    .startup-hero {
        position: relative;
        padding: 0 0;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        background: #f6f9fc; /* Stripe light bg */
    }
    
    .startup-hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        background: #f6f9fc; /* fallback mientras carga el shader */
        overflow: hidden;
    }

    .startup-hero-content {
        position: relative;
        z-index: 10;
        text-align: left;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        max-width: 1140px;
        width: 100%;
        margin: 0 auto;
        padding-top: 2rem;
    }

    .startup-title {
        font-size: clamp(3rem, 5vw, 5.5rem);
        line-height: 1.05;
        font-weight: 800;
        letter-spacing: -0.04em;
        margin: 0 0 1.5rem;
        color: #0a2540;
        text-wrap: balance;
        max-width: 900px;
    }
    
    .startup-sub {
        font-size: clamp(1.1rem, 1.8vw, 1.3rem);
        line-height: 1.6;
        color: #425466;
        max-width: 650px;
        margin: 0 0 2.5rem 0;
        font-weight: 400;
    }

    .startup-actions {
        display: flex;
