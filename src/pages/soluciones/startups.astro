<script>
    // Reactive Parallax Effect for Startups Hero Blobs
    document.addEventListener('DOMContentLoaded', () => {
        const hero = document.querySelector('.startup-hero');
        if (!hero) return;
        
        hero.addEventListener('mousemove', (e) => {
            // Calculate mouse position relative to center of screen
            // Values range from roughly -20px to +20px
            const x = (e.clientX / window.innerWidth - 0.5) * 40; 
            const y = (e.clientY / window.innerHeight - 0.5) * 40;
            
            // Set CSS variables on the hero container
            hero.style.setProperty('--mouse-x', `${x}px`);
            hero.style.setProperty('--mouse-y', `${y}px`);
        });
        
        // Reset when mouse leaves the hero
        hero.addEventListener('mouseleave', () => {
            hero.style.setProperty('--mouse-x', `0px`);
            hero.style.setProperty('--mouse-y', `0px`);
        });
        
        // Carousel logic for Startups Use Cases
        const grid = document.querySelector('.startup-use-cases-grid');
        const prevBtn = document.getElementById('startup-prev');
        const nextBtn = document.getElementById('startup-next');

        if (grid && prevBtn && nextBtn) {
            const getScrollAmount = () => {
                const card = grid.querySelector('.startup-use-case-card');
                return card ? (card.clientWidth + 24) : 424; // 24 is gap
            };

            prevBtn.addEventListener('click', () => {
                grid.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
            });
            nextBtn.addEventListener('click', () => {
                grid.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
            });
        }
        
        // Integration ScrollSpy Carousel with Progress Bar
        const stripeTabs = document.querySelectorAll('.stripe-tab');
        const progressFill = document.getElementById('stripe-progress-fill');
        const intScrollTrack = document.getElementById('integration-scroll');
        const intCards = document.querySelectorAll('.int-card');

        if (stripeTabs.length > 0 && intScrollTrack && progressFill) {
            
            // Calculate and set progress based on scroll
            const updateProgress = () => {
                const maxScroll = intScrollTrack.scrollWidth - intScrollTrack.clientWidth;
                if (maxScroll <= 0) {
                    progressFill.style.width = '100%';
                    return;
                }
                const scrollLeft = intScrollTrack.scrollLeft;
                
                const numTabs = stripeTabs.length;
                const baseWidth = 100 / numTabs;
                const percentage = (scrollLeft / maxScroll);
                const width = baseWidth + (percentage * (100 - baseWidth));
                
                progressFill.style.width = `${width}%`;
            };

            intScrollTrack.addEventListener('scroll', () => {
                requestAnimationFrame(updateProgress);
            });
            updateProgress(); // init

            // Click to scroll
            stripeTabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    const targetId = tab.getAttribute('data-target');
                    const firstCard = intScrollTrack.querySelector(`[data-tab-group="${targetId}"]`);
                    if (firstCard) {
                        const paddingLeft = parseInt(window.getComputedStyle(intScrollTrack).paddingLeft) || 0;
                        intScrollTrack.scrollTo({
                            left: firstCard.offsetLeft - paddingLeft,
                            behavior: 'smooth'
                        });
                    }
                });
            });

            // Intersection Observer to highlight active text
            const observerOptions = {
                root: intScrollTrack,
                rootMargin: '0px',
                threshold: 0.6 // Trigger when 60% of card is visible
            };
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const groupId = entry.target.getAttribute('data-tab-group');
                        const correspondingTab = document.querySelector(`.stripe-tab[data-target="${groupId}"]`);
                        if (correspondingTab && !correspondingTab.classList.contains('active')) {
                            stripeTabs.forEach(t => t.classList.remove('active'));
                            correspondingTab.classList.add('active');
                        }
                    }
                });
            }, observerOptions);

            intCards.forEach(card => observer.observe(card));
        }
    });
</script>
