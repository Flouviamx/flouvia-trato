    .startup-use-case-card:hover {
        transform: scale(1.02);
        box-shadow: 0 16px 40px rgba(0,0,0,0.08);
    }
    .startup-hero-graphic {
        position: absolute;
        top: 0;
        bottom: 0;
        right: 0;
        width: 50%;
        z-index: 1;
        pointer-events: none;
    }
    .uc-content {
        padding: 3rem 2.5rem 2rem 2.5rem;

        flex: 1;
    }
    .uc-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1d1d1f;
        margin: 0 0 1rem;
        letter-spacing: -0.02em;
    }
    .uc-desc {
        font-size: 1.05rem;
        line-height: 1.6;
        color: #515154;
        margin: 0 0 2.5rem;
    }
    .uc-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
