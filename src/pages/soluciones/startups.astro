    /* ════════════════════════════════════════════════════════════════
       RESPONSIVE
    ════════════════════════════════════════════════════════════════ */
    @media (max-width: 992px) {
        .stripe-hero {
            padding: 140px 0 80px;
            min-height: 70vh;
        }
        
        .stripe-bento-grid {
            grid-template-columns: 1fr;
        }
        
        .stripe-bento-card.span-2 {
