    .cm-item:hover {
        color: var(--stripe-cyan);
    }
    
    .cm-tag {
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--stripe-cyan);
        background: rgba(59, 130, 246, 0.1);
        padding: 2px 8px;
        border-radius: 100px;
        text-transform: uppercase;
    }
    
