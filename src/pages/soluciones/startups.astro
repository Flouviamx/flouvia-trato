    /* ════════════════════════════════════════════════════════════════
       NUEVAS SECCIONES STRIPE ENTERPRISE
    ════════════════════════════════════════════════════════════════ */
    
    .stripe-hero-eyebrow {
        color: var(--stripe-cyan);
        font-weight: 700;
        letter-spacing: 0.1em;
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
        background: rgba(59, 130, 246, 0.15);
        padding: 4px 12px;
        border-radius: 100px;
        border: 1px solid rgba(59, 130, 246, 0.3);
        display: inline-block;
    }

    .stripe-section-eyebrow {
        color: var(--stripe-cyan);
        font-weight: 700;
        letter-spacing: 0.1em;
        font-size: 0.85rem;
        margin-bottom: 1rem;
