    /* Stripe Progress Bar Tabs */
    .stripe-tabs-container {
        margin-bottom: 3rem;
        position: relative;
    }
    .stripe-progress-track {
        width: 100%;
        height: 3px;
        background: #e6e6e6; /* light gray background */
        border-radius: 3px;
        overflow: hidden;
        position: relative;
        margin-bottom: 1.5rem;
    }
    .stripe-progress-fill {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        width: 33.33%; /* updated via JS */
