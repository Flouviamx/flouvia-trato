    /* ── btn-luxe (copiado exacto de Hero.astro) ── */
    .btn-luxe {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        color: #0a192f;
        padding: 18px 38px;
        border-radius: 100px;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 600;
        overflow: hidden;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    }
    .btn-luxe span { position: relative; z-index: 2; }
    .btn-luxe svg.btn-arrow {
        position: relative; z-index: 2; display: inline-block;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        width: 16px; height: 16px; margin-left: 6px;
    }
    .btn-luxe:hover svg.btn-arrow { transform: translate(4px); }
    .btn-shimmer {
        position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(10, 25, 47, 0.06), transparent);
        transform: skew(-20deg); transition: 0s; z-index: 1;
    }
    .btn-luxe:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(0,0,0,0.3);
    }
