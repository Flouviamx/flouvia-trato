    }
    .carousel-btn svg {
        width: 20px; height: 20px;
        opacity: 0.8;
    }
    
    @media (max-width: 768px) {
        .startup-section-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1.5rem;
        }
