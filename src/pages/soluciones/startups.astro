    /* ==========================================================
       STARTUP INTEGRATION TABS (Apple Style)
       ========================================================== */
    .integration-tabs-section {
        padding: 6rem 0;
        background: #f6f9fc;
    }
    .integration-header {
        text-align: left;
        margin-bottom: 3rem;
        max-width: 700px;
    }
    .integration-title {
        font-size: clamp(2.2rem, 4vw, 3.2rem);
        font-weight: 700;
        color: #1d1d1f;
        margin: 0 0 1rem;
        letter-spacing: -0.03em;
    }
    .integration-sub {
        font-size: 1.15rem;
