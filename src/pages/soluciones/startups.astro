    /* Stripe Progress Bar Tabs */
    .stripe-tabs-container {
        margin-bottom: 3rem;
        position: relative;
    }
    .stripe-progress-track {
        width: 100%;
        height: 3px;
        background: #e6e6e6; /* light gray background */
        border-radius: 3px;
        overflow: hidden;
        position: relative;
        margin-bottom: 1.5rem;
    }
    .stripe-progress-fill {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        width: 33.33%; /* updated via JS */
        border-radius: 3px;
        /* Premium light green to dark blue gradient */
        background: linear-gradient(90deg, #10b981 0%, #06b6d4 35%, #2563eb 70%, #020617 100%);
        transition: width 0.4s cubic-bezier(0.25, 1, 0.5, 1); /* snappy, premium easing */
    }
    .stripe-tabs-buttons {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
    }
    .stripe-tab {
        background: none;
        border: none;
        padding: 0;
        text-align: center;
        flex: 1;
        cursor: pointer;
        position: relative;
        color: #6b7280;
        transition: color 0.3s ease;
    }
    .stripe-tab.active {
        color: #111827; /* dark text for active */
    }
    .stripe-tab .tab-label {
        display: block;
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
        color: inherit;
    }
    .stripe-tab .tab-sub {
        display: block;
        font-size: 0.85rem;
        font-weight: 500;
        color: #9ca3af;
