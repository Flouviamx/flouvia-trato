    /* ==========================================================
       HERO (Startup - Vercel/Linear style)
       ========================================================== */
    .startup-hero {
        position: relative;
        padding: 0 0;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        background: #f6f9fc; /* Stripe light bg */
    }
    
    .startup-hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        background: #f6f9fc;
        overflow: hidden;
        /* Sutil patrón de puntos */
        background-image: radial-gradient(rgba(10, 37, 64, 0.05) 1px, transparent 1px);
        background-size: 24px 24px;
    }

    /* Manchas de color vibrante desenfocadas (Stripe style) - Tonos Azul y Verde */
    .startup-hero-blob-1 {
        position: absolute;
        top: -10%; right: 10%;
        width: 60vw; height: 60vw;
        background: radial-gradient(circle, rgba(14, 165, 233, 0.2) 0%, rgba(59, 130, 246, 0.15) 50%, transparent 70%); /* Sky Blue and Blue */
        border-radius: 50%;
        filter: blur(60px);
        animation: stripe-blob 15s infinite alternate ease-in-out;
        margin-left: calc(var(--mouse-x, 0px) * 2);
        margin-top: calc(var(--mouse-y, 0px) * 2);
        transition: margin 0.3s ease-out;
    }

    .startup-hero-blob-2 {
        position: absolute;
        bottom: -20%; left: 0%;
        width: 50vw; height: 50vw;
        background: radial-gradient(circle, rgba(16, 185, 129, 0.15) 0%, rgba(6, 182, 212, 0.12) 50%, transparent 70%); /* Emerald and Cyan */
        border-radius: 50%;
        filter: blur(60px);
        animation: stripe-blob-reverse 20s infinite alternate ease-in-out;
        margin-left: calc(var(--mouse-x, 0px) * -1.5);
        margin-top: calc(var(--mouse-y, 0px) * -1.5);
        transition: margin 0.3s ease-out;
    }

    @keyframes stripe-blob {
        0% { transform: translate(0, 0) scale(1); }
        100% { transform: translate(-5%, 10%) scale(1.1); }
    }
    @keyframes stripe-blob-reverse {
        0% { transform: translate(0, 0) scale(1); }
        100% { transform: translate(10%, -10%) scale(1.05); }
