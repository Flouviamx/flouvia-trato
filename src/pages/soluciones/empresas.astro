    /* Enterprise Mockup Shared Styles - PREMIUM REDESIGN */
    .ent-mock-panel {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 14px;
        border: 1px solid rgba(226, 232, 240, 0.8);
        box-shadow: 
            0 20px 40px -10px rgba(15, 23, 42, 0.08), 
            0 10px 20px -5px rgba(15, 23, 42, 0.04),
            inset 0 1px 0 rgba(255, 255, 255, 1);
        width: 270px;
        display: flex;
        flex-direction: column;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Inter", sans-serif;
        transform: translateY(12px) scale(0.98);
        transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
