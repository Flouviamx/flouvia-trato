    .stripe-testimonial-metrics {
        display: flex;
        gap: 3rem;
        border-top: 1px solid var(--stripe-border);
        padding-top: 2rem;
    }
    
    .stripe-testimonial-metrics b {
        display: block;
        font-size: 2rem;
        color: var(--stripe-text);
        margin-bottom: 0.25rem;
    }
    
    .stripe-testimonial-metrics span {
        font-size: 0.9rem;
        color: var(--stripe-muted);
    }

    /* ════════════════════════════════════════════════════════════════
       FAQ
    ════════════════════════════════════════════════════════════════ */
    .stripe-faq-section {
        padding: 6rem 0;
        position: relative;
        z-index: 10;
    }
    
    .stripe-faq-list {
        max-width: 800px;
        margin-top: 3rem;
    }
    
    .stripe-faq-item {
        border-bottom: 1px solid var(--stripe-border);
    }
    
    .stripe-faq-item summary {
        padding: 1.5rem 0;
        cursor: pointer;
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .stripe-faq-item summary::-webkit-details-marker {
        display: none;
    }
    
    .stripe-faq-item summary h3 {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0;
        color: var(--stripe-text);
    }
    
    .stripe-faq-item summary svg {
        width: 20px;
        height: 20px;
        color: var(--stripe-muted);
        transition: transform 0.2s ease;
    }
    
    .stripe-faq-item[open] summary svg {
        transform: rotate(180deg);
    }
    
    .stripe-faq-a {
        padding-bottom: 1.5rem;
        color: var(--stripe-muted);
        line-height: 1.6;
    }

    /* ════════════════════════════════════════════════════════════════
       CTA
    ════════════════════════════════════════════════════════════════ */
    .stripe-cta-section {
        padding: 6rem 0 10rem;
        position: relative;
        z-index: 10;
    }
    
    .stripe-cta-card {
        background: radial-gradient(circle at top, rgba(10, 25, 47, 0.1), transparent 50%), var(--stripe-card-bg);
        border: 1px solid var(--stripe-border);
        border-radius: 24px;
        padding: 5rem 2rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    
    .stripe-cta-card .stripe-p {
        max-width: 600px;
        margin-bottom: 3rem;
    }
    
    .stripe-cta-card .stripe-actions {
        justify-content: center;
    }

    /* Overrides para botones en fondo claro (CTA) */
    .stripe-cta-card .btn-luxe {
        background: #0a192f;
        color: #fff;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.15), 0 8px 24px rgba(10,25,47,0.18);
    }
    .stripe-cta-card .btn-luxe:hover {
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 12px 32px rgba(10,25,47,0.24);
    }
    .stripe-cta-card .btn-luxe .btn-shimmer {
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.18), transparent);
    }
    .stripe-cta-card .btn-ghost {
        color: #0a192f;
        border-color: rgba(10,25,47,0.08);
        background: rgba(255,255,255,0.6);
    }
    .stripe-cta-card .btn-ghost:hover {
        background: #fff;
        box-shadow: 0 6px 16px rgba(10,25,47,0.06);
    }

    /* ════════════════════════════════════════════════════════════════
       RESPONSIVE
    ════════════════════════════════════════════════════════════════ */
    @media (max-width: 992px) {
        .stripe-hero {
            padding: 140px 0 80px;
            min-height: 70vh;
        }
        
        .stripe-bento-grid {
            grid-template-columns: 1fr;
        }
        
        .stripe-bento-card.span-2 {
            grid-column: 1;
        }
        
        .span-2 .stripe-bento-inner {
            flex-direction: column-reverse;
            gap: 2rem;
        }
        
        .stripe-stats-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
    }
    
    @media (max-width: 768px) {
