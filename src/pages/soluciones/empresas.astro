        bottom: 0;
        background: radial-gradient(
            800px circle at var(--mouse-x, 0) var(--mouse-y, 0),
            rgba(10, 25, 47, 0.04),
            transparent 40%
        );
        z-index: 0;
        opacity: 0;
        transition: opacity 0.3s;
        pointer-events: none;
