       NUEVAS SECCIONES STRIPE ENTERPRISE
    ════════════════════════════════════════════════════════════════ */
    
    .stripe-hero-eyebrow {
        color: var(--stripe-cyan);
        font-weight: 700;
        letter-spacing: 0.1em;
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
