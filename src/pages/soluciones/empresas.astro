    .em-avatar { width: 34px; height: 34px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; box-shadow: 0 2px 5px rgba(0,0,0,0.05), inset 0 1px 0 rgba(255,255,255,0.2); }
    .avatar-admin { background: linear-gradient(135deg, #6366f1, #4338ca); color: white; }
    .avatar-finance { background: linear-gradient(135deg, #10b981, #047857); color: white; }
    
    .em-user-info { display: flex; flex-direction: column; flex: 1; gap: 2px; }
    .em-user-name { font-size: 12px; font-weight: 600; color: #0f172a; }
    .em-user-email { font-size: 9.5px; color: #64748b; font-weight: 500; }
    
    .em-role-select { font-size: 10.5px; font-weight: 600; color: #475569; display: flex; align-items: center; gap: 6px; background: #ffffff; padding: 6px 10px; border-radius: 6px; border: 1px solid #e2e8f0; cursor: pointer; box-shadow: 0 1px 2px rgba(15,23,42,0.02); transition: all 0.2s; }
    .em-role-select:hover { border-color: #cbd5e1; color: #0f172a; box-shadow: 0 2px 4px rgba(15,23,42,0.04); }
    .em-role-select svg { width: 12px; height: 12px; color: #94a3b8; transition: color 0.2s; }
    .em-role-select:hover svg { color: #475569; }


    .stripe-pillar-content {
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        flex: 1;
