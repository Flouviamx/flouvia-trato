---
// Página de solución (Empresas).
// Diseño alineado al estilo Cord.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import SolucionBlockMockup from '../../components/soluciones/SolucionBlockMockup.astro';
import ProFeatures from '../../components/soluciones/ProFeatures.astro';
import MockupCotizacion from '../../components/soluciones/MockupCotizacion.astro';
import MockupPagos from '../../components/soluciones/MockupPagos.astro';
import MockupCFDI from '../../components/soluciones/MockupCFDI.astro';
import { SOLUCIONES } from '../../lib/solucion';
import { SOLUCIONES_EN } from '../../lib/solucion.en';
import { getLangFromUrl } from '../../i18n/utils';
import '../../styles/mockups.css';
import DarkAuroraBg from '../../components/soluciones/DarkAuroraBg.jsx';

const lang = getLangFromUrl(Astro.url);
const isEn = Astro.props.isEn || lang === 'en';
const baseSolucion = isEn ? SOLUCIONES_EN.find((s) => s.slug === 'empresas') : SOLUCIONES.find((s) => s.slug === 'empresas');
const solucion = baseSolucion!;
const otras = (isEn ? SOLUCIONES_EN : SOLUCIONES).filter((s) => s.slug !== solucion.slug);

const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: solucion.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};

// Array estático de logos (Stripe-style logo cloud)
const clientLogos = ['GAMA', 'ACEROS', 'VERTICE', 'ZARCO', 'FERREX', 'CEMENTOS'];
---

<Layout
    title={solucion.metaTitle ?? `${solucion.nav} — Cord`}
    description={solucion.metaDescription ?? solucion.sub}
>
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <Nav darkHero={solucion.slug === 'empresas'} />
    <main class="stripe-main">
        
        {solucion.slug === 'startups' ? (
            <header class="startup-hero">
                <div class="startup-hero-bg">
                    <div class="startup-hero-blob-1"></div>
                    <div class="startup-hero-blob-2"></div>
                </div>
                
                <div class="startup-hero-content stripe-container">
                    <h1 class="startup-title reveal" set:html={solucion.titulo} />
                    
                    <p class="startup-sub">{solucion.sub}</p>
                    
                    <div class="startup-actions">
                        <a href={isEn ? '/en/registro' : '/registro'} class="btn-luxe">
                            <span>{isEn ? 'Start building' : 'Empezar ahora'}</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost">
                            <span>{isEn ? 'Book a demo' : 'Contactar a ventas'}</span>
                        </a>
                    </div>
                </div>
            </header>
        ) : (
            <header class="stripe-hero">
                <div class="stripe-hero-bg">
                    <DarkAuroraBg client:only="react" />
                </div>
                
                <div class="stripe-hero-content stripe-container">
                    <h1 class="stripe-title reveal" set:html={solucion.titulo} />
                    
                    <p class="stripe-sub">{solucion.sub}</p>
                    
                    <div class="stripe-actions">
                        <a href={isEn ? '/en/registro' : '/registro'} class="btn-luxe">
                            <span>{isEn ? 'Start now' : 'Empezar ahora'}</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost">
                            <span>{isEn ? 'Contact sales' : 'Contactar a ventas'}</span>
                        </a>
                    </div>
                </div>
            </header>
        )}

        <!-- ── STARTUP USE CASES ── -->
        {solucion.useCases && (
            <section class="startup-use-cases-section reveal">
                <div class="stripe-container">
                    <div class="startup-section-header">
                        <div class="startup-section-titles">
                            <h2 class="startup-section-title">{isEn ? 'Ideal for every business model' : 'Ideal para todo tipo de empresas'}</h2>
                            <p class="startup-section-sub">{isEn ? 'Thousands of successful companies automate their sales flow with Cord.' : 'Miles de empresas exitosas ya automatizan su proceso comercial con Cord.'}</p>
                        </div>
                        <div class="startup-carousel-controls">
                            <button id="startup-prev" class="carousel-btn" aria-label="Previous">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
                            </button>
                            <button id="startup-next" class="carousel-btn" aria-label="Next">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                            </button>
                        </div>
                    </div>
                </div> <!-- End stripe-container to allow full-bleed grid -->
                
                <div class="startup-use-cases-grid">
                        {solucion.useCases.map(uc => (
                            <div class="startup-use-case-card">
                                <div class="uc-content">
                                    <h3 class="uc-title">{uc.title}</h3>
                                    <p class="uc-desc">{uc.desc}</p>
                                    <a href={uc.link} class="uc-link">
                                        <span>{isEn ? 'Learn more' : 'Más información'}</span>
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                                    </a>
                                </div>
                                <div class="uc-logos">
                                    {uc.logos.map(l => (
                                        <div class="uc-logo-item">
                                            <img src={`https://t3.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=http://${l.domain}&size=128`} alt={l.name} class="uc-logo-img" loading="lazy" />
                                            <span class="uc-logo-name">{l.name}</span>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        ))}
                    </div>
            </section>
        )}

        <!-- ── STARTUP INTEGRATION TABS (Apple Style) ── -->
        {solucion.slug === 'startups' && (
            <section class="integration-tabs-section reveal">
                <div class="stripe-container">
                    <div class="integration-header">
                        <h2 class="integration-title">{isEn ? 'Integrate Cord your way' : 'Integra Cord a tu medida'}</h2>
                        <p class="integration-sub">{isEn ? 'Stripe offers a wide range of options to accept payments, from no-code and low-code options to powerful APIs.' : 'Cord ofrece una amplia gama de opciones para automatizar tus ventas, desde configuraciones visuales sin código hasta potentes API REST.'}</p>
                    </div>

                    <div class="stripe-tabs-container">
                        <div class="stripe-progress-track">
                            <div class="stripe-progress-fill" id="stripe-progress-fill"></div>
                        </div>
                        <div class="stripe-tabs-buttons" role="tablist">
                            <button class="stripe-tab active" role="tab" aria-selected="true" data-target="tab-nocode">
                                <span class="tab-label">Sin código</span>
                                <span class="tab-sub">Más rápido</span>
                            </button>
                            <button class="stripe-tab" role="tab" aria-selected="false" data-target="tab-lowcode">
                                <span class="tab-label">Bajo código</span>
                                <span class="tab-sub">Optimizado</span>
                            </button>
                            <button class="stripe-tab" role="tab" aria-selected="false" data-target="tab-api">
                                <span class="tab-label">API REST</span>
                                <span class="tab-sub">Control total</span>
                            </button>
                        </div>
                    </div>
                </div> <!-- Close stripe-container so track can bleed full width -->

                    <div class="integration-scroll-track" id="integration-scroll">
                        <!-- NO CODE -->
                        <div class="int-card" data-tab-group="tab-nocode">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Cotizador Visual</h3>
                                <p class="int-card-desc">Crea cotizaciones interactivas arrastrando y soltando elementos de tu catálogo en segundos.</p>
                                <a href="/producto/editor" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui mock-ui-blue">
                                    <div class="graphic-widget">
                                        <div class="graphic-widget-line short"></div>
                                        <div class="graphic-widget-line"></div>
                                        <div class="graphic-widget-line"></div>
                                        <div class="graphic-widget-btn"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="int-card" data-tab-group="tab-nocode">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Ligas de Pago</h3>
                                <p class="int-card-desc">Genera links de cobro al instante y compártelos por WhatsApp sin escribir una línea de código.</p>
                                <a href="/producto/link-publico" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui mock-ui-blue">
                                    <div class="graphic-widget" style="transform: perspective(800px) rotateY(15deg) rotateX(10deg);">
                                        <div class="graphic-widget-line"></div>
                                        <div class="graphic-widget-line short"></div>
                                        <div class="graphic-widget-line"></div>
                                        <div class="graphic-widget-btn" style="background: #27c93f;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- LOW CODE -->
                        <div class="int-card" data-tab-group="tab-lowcode">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Zapier & Make</h3>
                                <p class="int-card-desc">Conecta Cord con Zapier, Make o n8n usando webhooks para automatizar tu flujo de trabajo.</p>
                                <a href="/desarrolladores/api" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui mock-ui-purple">
                                    <div class="graphic-nodes">
                                        <div class="graphic-node"><div class="graphic-node-dot"></div></div>
                                        <div class="graphic-connection"></div>
                                        <div class="graphic-node"><div class="graphic-node-dot"></div></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="int-card" data-tab-group="tab-lowcode">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Webhooks</h3>
                                <p class="int-card-desc">Conecta Cord con tu ERP o CRM actual usando webhooks que disparan acciones en tiempo real.</p>
                                <a href="/desarrolladores/api" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui mock-ui-purple">
                                    <div class="graphic-nodes">
                                        <div class="graphic-node"><div class="graphic-node-dot"></div></div>
                                        <div class="graphic-connection"></div>
                                        <div class="graphic-node"><div class="graphic-node-dot"></div></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- API -->
                        <div class="int-card" data-tab-group="tab-api">
                            <div class="int-card-text">
                                <h3 class="int-card-title">API RESTful</h3>
                                <p class="int-card-desc">Crea cotizaciones, clientes y consulta tu cobranza desde tu propio software con nuestra API REST.</p>
                                <a href="/desarrolladores/api" class="int-link">Ver documentación <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui mock-ui-orange">
                                    <div class="graphic-code">
                                        <div class="graphic-code-line"></div>
                                        <div class="graphic-code-line"></div>
                                        <div class="graphic-code-line"></div>
                                        <div class="graphic-code-line"></div>
                                        <div class="graphic-code-line"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="int-card" data-tab-group="tab-api">
                            <div class="int-card-text">
                                <h3 class="int-card-title">Cord Elements</h3>
                                <p class="int-card-desc">Embebe el cotizador en tu web o app con Cord Elements: Web Component, React y Vue.</p>
                                <a href="/desarrolladores/elements" class="int-link">Más información <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                            </div>
                            <div class="int-card-graphic">
                                <div class="mock-ui mock-ui-orange">
                                    <div class="graphic-code">
                                        <div class="graphic-code-line" style="width: 40%; background: #0071e3;"></div>
                                        <div class="graphic-code-line" style="width: 50%; background: #27c93f;"></div>
                                        <div class="graphic-code-line" style="width: 30%; background: rgba(255,255,255,0.4);"></div>
                                        <div class="graphic-code-line" style="width: 60%; background: #ffbd2e;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
            </section>
        )}

        <!-- ── AIRY BENTO PILLARS ── -->
        {solucion.pillars && (
            <section class="stripe-pillars-section">
                <div class="stripe-container">
                    <div class="stripe-pillars-grid">
                        {solucion.pillars.map((p, i) => (
                            <div class="stripe-pillar-card reveal">
                                <div class="stripe-pillar-graphic">
                                    {i === 0 && (
                                        <div class="ent-mock-panel ent-mock-control">
                                            <div class="ent-mock-header">
                                                <span class="ent-mock-title">Reglas de Aprobación</span>
                                                <span class="ent-mock-badge badge-active">Activo</span>
                                            </div>
                                            <div class="ent-mock-body">
                                                <div class="ent-mock-row">
                                                    <div class="ent-mock-col">
                                                        <span class="em-label">Condición</span>
                                                        <span class="em-value">Descuento &gt; 15%</span>
                                                    </div>
                                                    <div class="ent-mock-col text-right">
                                                        <span class="em-label" style="display:block; margin-bottom:2px;">Acción</span>
                                                        <span class="em-badge badge-review">Revisión VP</span>
                                                    </div>
                                                </div>
                                                <div class="ent-mock-row">
                                                    <div class="ent-mock-col">
                                                        <span class="em-label">Condición</span>
                                                        <span class="em-value">Monto &gt; $50k</span>
                                                    </div>
                                                    <div class="ent-mock-col text-right">
                                                        <span class="em-label" style="display:block; margin-bottom:2px;">Acción</span>
                                                        <span class="em-badge badge-finance">Finanzas</span>
                                                    </div>
                                                </div>
                                                <div class="ent-mock-row em-disabled">
                                                    <div class="ent-mock-col">
                                                        <span class="em-label">Condición</span>
                                                        <span class="em-value">Estándar</span>
                                                    </div>
                                                    <div class="ent-mock-col text-right">
                                                        <span class="em-label" style="display:block; margin-bottom:2px;">Acción</span>
                                                        <span class="em-badge badge-auto">Auto-Aprobar</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    )}
                                    {i === 1 && (
                                        <div class="ent-mock-panel ent-mock-erp">
                                            <div class="ent-mock-header border-bottom">
                                                <span class="ent-mock-title">Sincronización ERP</span>
                                                <div class="em-status">
                                                    <span class="em-pulse"></span>
                                                    <span class="em-status-text">CONECTADO</span>
                                                </div>
                                            </div>
                                            <div class="ent-mock-body">
                                                <div class="em-sync-row">
                                                    <div class="em-icon sap-icon">SAP</div>
                                                    <div class="em-sync-info">
                                                        <span class="em-sync-title">Factura #INV-4920</span>
                                                        <span class="em-sync-time">Completado · hace 2s</span>
                                                    </div>
                                                    <div class="em-check">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                                    </div>
                                                </div>
                                                <div class="em-sync-row">
                                                    <div class="em-icon oracle-icon">O</div>
                                                    <div class="em-sync-info">
                                                        <span class="em-sync-title">Cliente: Grupo Modelo</span>
                                                        <span class="em-sync-time">Completado · hace 15s</span>
                                                    </div>
                                                    <div class="em-check">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    )}
                                    {i === 2 && (
                                        <div class="ent-mock-panel ent-mock-security">
                                            <div class="ent-mock-header">
                                                <span class="ent-mock-title">Control de Acceso (RBAC)</span>
                                                <button class="em-btn-add">Añadir</button>
                                            </div>
                                            <div class="ent-mock-body">
                                                <div class="em-user-row">
                                                    <div class="em-avatar avatar-admin">AG</div>
                                                    <div class="em-user-info">
                                                        <span class="em-user-name">Ana García</span>
                                                        <span class="em-user-email">ana@empresa.com</span>
                                                    </div>
                                                    <div class="em-role-select">Admin <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg></div>
                                                </div>
                                                <div class="em-user-row">
                                                    <div class="em-avatar avatar-finance">CR</div>
                                                    <div class="em-user-info">
                                                        <span class="em-user-name">Carlos Ruiz</span>
                                                        <span class="em-user-email">carlos@empresa.com</span>
                                                    </div>
                                                    <div class="em-role-select">Finanzas <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg></div>
                                                </div>
                                            </div>
                                        </div>
                                    )}
                                </div>
                                <div class="stripe-pillar-content">
                                    <h3 class="stripe-pillar-title">{p.titulo}</h3>
                                    <p class="stripe-pillar-desc">{p.desc}</p>
                                    <a href={p.href || '/producto/editor'} class="stripe-pillar-link">
                                        {p.link}
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="12" y1="5" x2="12" y2="19"></line>
                                            <polyline points="19 12 12 19 5 12"></polyline>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </section>
        )}

        <!-- ── FEATURE GRID (ASYMMETRIC) ── -->
        <section class="stripe-feature-grid-section">
            <div class="stripe-container">
                <div class="stripe-section-header reveal">
                    <span class="stripe-section-eyebrow">CAPACIDADES CORE</span>
                    <h2 class="stripe-h2">{isEn ? 'A complete ecosystem for your commercial process' : 'Un ecosistema completo para tu proceso comercial'}</h2>
                    <p class="stripe-p">{solucion.paraQuien}</p>
                </div>

                <div class="stripe-fg-layout">
                    <!-- Left Column: Main Features -->
                    <div class="stripe-fg-main">
                        {solucion.blocks.map((block, idx) => (
                            <div class="stripe-fg-card reveal">
                                <div class="stripe-fg-card-content">
                                    <h3 class="stripe-fg-title">{block.titulo}</h3>
                                    <p class="stripe-fg-desc">{block.copy}</p>
                                    <div class="stripe-fg-tags">
                                        {block.bullets.map((b, bulletIdx) => {
                                            const slugs = ['aprobaciones', 'finanzas', 'cfdi', 'editor', 'equipo'];
                                            const targetSlug = slugs[(idx + bulletIdx) % slugs.length];
                                            return (
                                                <a href={`/producto/${targetSlug}`} class="stripe-fg-tag">{b}</a>
                                            );
                                        })}
                                    </div>
                                </div>
                                <div class="stripe-fg-card-visual">
                                    {idx === 0 && (
                                        <div class="cmk-stage">
                                            <div class="cmk-shot">
                                                <div class="cmk-nav">
                                                    <span class="cmk-nav-title">Editor · COT-2207</span>
                                                    <span class="cmk-badge cmk-b-amber">Distribuidora · nivel Oro -12%</span>
                                                </div>
                                                <div class="cmk-th" style="grid-template-columns:1.7fr 92px 66px">
                                                    <span>Producto</span><span class="cmk-r">Negociado</span><span class="cmk-r">Margen</span>
                                                </div>
                                                <div class="cmk-tr" style="grid-template-columns:1.7fr 92px 66px">
                                                    <span class="cmk-t1">Cemento CPC 30R · 50kg</span>
                                                    <span class="cmk-amt editorial">$189.00</span>
                                                    <span class="cmk-badge cmk-b-green" style="justify-self:end">32%</span>
                                                </div>
                                                <div class="cmk-tr" style="grid-template-columns:1.7fr 92px 66px">
                                                    <span class="cmk-t1">Varilla corrugada 3/8"</span>
                                                    <span class="cmk-amt editorial">$168.50</span>
                                                    <span class="cmk-badge cmk-b-amber" style="justify-self:end">21%</span>
                                                </div>
                                                <div class="cmk-tr" style="grid-template-columns:1.7fr 92px 66px">
                                                    <span class="cmk-t1">Block estructural 15cm</span>
                                                    <span class="cmk-amt editorial">$24.90</span>
                                                    <span class="cmk-badge cmk-b-red" style="justify-self:end">14%</span>
                                                </div>
                                                <div class="cmk-body" style="padding-top:14px">
                                                    <div class="cmk-alert cmk-alert-amber">
