    /* ANIMATIONS */
    .mockup-cursor {
        position: absolute;
        z-index: 100;
        color: #0a2540;
        filter: drop-shadow(0 4px 4px rgba(0,0,0,0.2));
        width: 24px; height: 24px;
        pointer-events: none;
        animation: cursorAnim 10s infinite;
    }
    .mockup-cursor svg {
