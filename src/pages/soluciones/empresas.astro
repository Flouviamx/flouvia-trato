    .stripe-pillar-desc {
        font-size: 1rem;
        color: #555556;
        line-height: 1.6;
        margin-bottom: 2rem;
        flex: 1;
    }
    
    .stripe-pillar-link {
        color: var(--stripe-cyan);
        font-weight: 600;
        font-size: 0.95rem;
