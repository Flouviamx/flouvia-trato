    }
    .uc-logo-item {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .uc-logo-img {
        width: 20px;
        height: 20px;
        object-fit: contain;
        border-radius: 4px;
    }
    .uc-logo-name {
        font-weight: 700;
        font-size: 0.9rem;
        color: #0a2540;
        letter-spacing: -0.01em;
    }
    /* ==========================================================
       STARTUP INTEGRATION TABS (Apple Style)
       ========================================================== */
    .integration-tabs-section {
        padding: 6rem 0;
        background: #fbfbfd; /* Apple's subtle off-white */
    }
    .integration-header {
        text-align: left;
        margin-bottom: 3rem;
        max-width: 700px;
    }
    .integration-title {
        font-size: clamp(2.2rem, 4vw, 3.2rem);
        font-weight: 700;
        color: #1d1d1f;
        margin: 0 0 1rem;
        letter-spacing: -0.03em;
    }
    .integration-sub {
        font-size: 1.15rem;
        color: #515154;
        margin: 0;
        line-height: 1.5;
    }

    /* Stripe Progress Bar Tabs */
    .stripe-tabs-container {
        margin-bottom: 3rem;
        position: relative;
    }
    .stripe-progress-track {
        width: 100%;
        height: 3px;
        background: #e6e6e6; /* light gray background */
        border-radius: 3px;
        overflow: hidden;
        position: relative;
        margin-bottom: 1.5rem;
    }
    .stripe-progress-fill {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        width: 33.33%; /* updated via JS */
        /* Vibrant cyan to purple gradient */
        background: linear-gradient(90deg, #00C9FF 0%, #0071e3 50%, #8e43e7 100%);
        transition: width 0.1s ease-out; /* smooth follow */
    }
    .stripe-tabs-buttons {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
    }
    .stripe-tab {
        background: none;
        border: none;
        padding: 0;
        text-align: center;
        flex: 1;
        cursor: pointer;
        position: relative;
        color: #6b7280;
        transition: color 0.3s ease;
    }
    .stripe-tab.active {
        color: #111827; /* dark text for active */
    }
    .stripe-tab .tab-label {
        display: block;
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
        color: inherit;
    }
    .stripe-tab .tab-sub {
        display: block;
        font-size: 0.85rem;
        font-weight: 500;
        color: #9ca3af;
        transition: color 0.3s ease;
    }
    .stripe-tab.active .tab-sub {
        color: #6b7280;
    }

    /* Content Carousel */
    .integration-scroll-track {
        display: flex;
        gap: 24px;
        overflow-x: auto;
        padding-bottom: 3rem;
        padding-left: max(20px, calc(50vw - 550px));
        padding-right: max(20px, calc(50vw - 550px));
        scroll-padding-left: max(20px, calc(50vw - 550px));
        scroll-padding-right: max(20px, calc(50vw - 550px));
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -ms-overflow-style: none;
        scroll-behavior: smooth;
    }
    .integration-scroll-track::-webkit-scrollbar {
        display: none;
    }
    
    .int-card {
        flex: 0 0 440px;
        scroll-snap-align: start;
        background: #ffffff;
        border-radius: 32px;
        border: none;
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.06), inset 0 0 0 1px rgba(0,0,0,0.04);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @media (max-width: 600px) {
        .int-card {
            flex: 0 0 85vw;
        }
    }
    .int-card:hover {
        transform: scale(1.01) translateY(-4px);
        box-shadow: 0 30px 60px -15px rgba(0,0,0,0.1), inset 0 0 0 1px rgba(0,0,0,0.04);
    }
    .int-card-text {
        padding: 3rem 2.5rem 0 2.5rem;
    }

    .int-card-title {
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #1d1d1f;
        margin: 0 0 0.8rem;
    }
    .int-card-desc {
        font-size: 1.05rem;
        line-height: 1.5;
        color: #86868b;
        margin: 0 0 1.5rem;
    }
    .int-link {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        color: #0071e3;
        font-weight: 600;
        font-size: 1.05rem;
        text-decoration: none;
        transition: color 0.2s;
    }
    .int-link:hover { color: #005bb5; }
    .int-link svg { width: 18px; height: 18px; transition: transform 0.2s; }
    .int-link:hover svg { transform: translateX(4px); }

    .int-card-graphic {
        padding: 2.5rem;
        margin-top: auto;
        display: flex;
        justify-content: center;
    }
    .mock-ui {
        width: 100%;
        height: 220px;
        border-radius: 16px;
        background: #0a2540; /* Cord Navy */
        box-shadow: 0 10px 40px rgba(0,0,0,0.15), inset 0 0 0 1px rgba(255,255,255,0.1);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    /* Blue - No Code (UI Widgets) */
    .mock-ui-blue {
        background: radial-gradient(circle at 80% 20%, rgba(0,201,255,0.15) 0%, transparent 60%), radial-gradient(circle at 20% 80%, rgba(0,113,227,0.2) 0%, transparent 60%), #0a2540;
    }
    .graphic-widget {
        width: 150px;
        height: 110px;
        background: rgba(255,255,255,0.95);
        border-radius: 12px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.2);
        display: flex;
        flex-direction: column;
        padding: 16px;
        gap: 12px;
        transform: perspective(1000px) rotateY(-20deg) rotateX(15deg) translateZ(0);
        transform-style: preserve-3d;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .int-card:hover .graphic-widget {
        transform: perspective(1000px) rotateY(0deg) rotateX(0deg) scale(1.1) translateZ(30px) !important;
    }
    .graphic-widget-line { height: 8px; border-radius: 4px; background: #e2e8f0; transform: translateZ(10px); }
    .graphic-widget-line.short { width: 40%; background: #00C9FF; box-shadow: 0 0 10px rgba(0,201,255,0.4); }
    .graphic-widget-btn { margin-top: auto; height: 28px; border-radius: 6px; background: linear-gradient(135deg, #00C9FF, #0071e3); transform: translateZ(20px); box-shadow: 0 4px 12px rgba(0,113,227,0.3); }

    /* Purple -> Cyan/Blue - Low Code (Nodes/Webhooks) */
    .mock-ui-purple {
        background: radial-gradient(circle at 50% 50%, rgba(0,113,227,0.2) 0%, transparent 70%), #0a2540;
    }
    .graphic-nodes {
        display: flex;
        align-items: center;
        gap: 24px;
        transform: scale(0.9);
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .int-card:hover .graphic-nodes { transform: scale(1.1); }
    .graphic-node {
        width: 64px; height: 64px;
        border-radius: 20px;
        background: rgba(10,37,64,0.8);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.3), inset 0 0 0 1px rgba(0,201,255,0.3);
        display: flex; align-items: center; justify-content: center;
        position: relative;
    }
    .graphic-node-dot { width: 24px; height: 24px; border-radius: 50%; background: #00C9FF; box-shadow: 0 0 20px rgba(0,201,255,0.8); }
    .graphic-connection {
        width: 60px; height: 3px;
        background: repeating-linear-gradient(90deg, #00C9FF 0, #00C9FF 8px, transparent 8px, transparent 16px);
        animation: march 0.8s linear infinite;
        opacity: 0.8;
        filter: drop-shadow(0 0 8px rgba(0,201,255,0.6));
    }
    @keyframes march { to { background-position: 16px 0; } }

    /* Orange -> Dark Navy - API (Code Window) */
    .mock-ui-orange {
        background: #061626; /* Deeper navy for contrast */
        box-shadow: 0 10px 40px rgba(0,0,0,0.3), inset 0 0 0 1px rgba(255,255,255,0.05);
    }
    .graphic-code {
        width: 75%;
        display: flex;
        flex-direction: column;
        gap: 12px;
        transform: scale(0.95);
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        padding: 20px;
        background: rgba(255,255,255,0.02);
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.05);
    }
    .int-card:hover .graphic-code { transform: scale(1.08); background: rgba(255,255,255,0.04); }
    .graphic-code-line { height: 8px; border-radius: 4px; background: rgba(255,255,255,0.1); }
    .graphic-code-line:nth-child(1) { width: 35%; background: #00C9FF; box-shadow: 0 0 10px rgba(0,201,255,0.3); }
    .graphic-code-line:nth-child(2) { width: 65%; background: #27c93f; margin-left: 20px; }
    .graphic-code-line:nth-child(3) { width: 55%; background: #27c93f; margin-left: 20px; }
    .graphic-code-line:nth-child(4) { width: 45%; background: #ffbd2e; margin-left: 20px; }
    .graphic-code-line:nth-child(5) { width: 25%; background: rgba(255,255,255,0.3); }

    /* ── CORD APPS MARQUEE ── */
    .cord-apps-section {
        padding: 8rem 0;
        background: #ffffff;
        overflow: hidden;
    }
    .cord-apps-header {
        max-width: 650px;
        margin: 0 auto 5rem auto;
        text-align: center;
    }
    .cord-apps-title {
        font-size: clamp(2rem, 4vw, 3.2rem);
        font-weight: 700;
        color: #0a2540;
        margin-bottom: 1.5rem;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }
    .cord-apps-desc {
        font-size: 1.15rem;
        color: #425466;
        line-height: 1.6;
        margin-bottom: 2rem;
    }
    .cord-apps-link {
        color: #0071e3;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 1.05rem;
        transition: color 0.2s;
    }
    .cord-apps-link:hover { color: #005bb5; }
    .cord-apps-link svg { width: 16px; height: 16px; transition: transform 0.2s; }
    .cord-apps-link:hover svg { transform: translateX(4px); }

    .cord-apps-marquee {
        width: 100vw;
        position: relative;
        left: 50%;
        transform: translateX(-50%);
        overflow: hidden;
        padding: 2rem 0; /* Room for shadow */
    }
    .marquee-track {
        display: flex;
        gap: 32px;
        width: max-content;
        animation: marquee 35s linear infinite;
    }
    .marquee-track:hover {
        animation-play-state: paused;
    }
    @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(calc(-50% - 16px)); } /* 50% + half gap */
    }
    .app-icon {
        width: 160px;
        height: 160px;
        border-radius: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        /* Outer soft drop shadow + Double Inner Shadow for 3D Gummy Effect */
        box-shadow: 
            0 24px 48px -12px rgba(0,0,0,0.15),
            inset 0 8px 16px rgba(255,255,255,0.4),
            inset 0 -8px 16px rgba(0,0,0,0.15);
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), filter 0.4s;
        will-change: transform;
        user-select: none;
    }
    .app-icon:hover {
        transform: translateY(-8px) scale(1.02);
        filter: brightness(1.05);
    }
    .app-mask {
        width: 80px;
        height: 80px;
        background-color: currentColor;
        -webkit-mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        -webkit-mask-position: center;
        mask-size: contain;
        mask-repeat: no-repeat;
        mask-position: center;
        filter: drop-shadow(1px 1px 0px rgba(255,255,255,0.2)) drop-shadow(-1px -1px 0px rgba(0,0,0,0.15));
    }
    .app-icon.cord-cyan .app-mask { width: 100px; height: 100px; } /* xero logo is wide */

    /* Cord-curated Gradients */
    .app-icon.cord-navy { background: linear-gradient(135deg, #2a4365, #0a2540); color: rgba(0,0,0,0.4); }
    .app-icon.cord-blue { background: linear-gradient(135deg, #00C9FF, #0071e3); color: rgba(0,0,0,0.25); }
    .app-icon.cord-indigo { background: linear-gradient(135deg, #818cf8, #4f46e5); color: rgba(0,0,0,0.25); }
    .app-icon.cord-slate { background: linear-gradient(135deg, #64748b, #334155); color: rgba(0,0,0,0.3); }
    .app-icon.cord-green { background: linear-gradient(135deg, #34d399, #059669); color: rgba(0,0,0,0.25); }
    .app-icon.cord-cyan { background: linear-gradient(135deg, #67e8f9, #0891b2); color: rgba(0,0,0,0.25); }
    .app-icon.cord-dark { background: linear-gradient(135deg, #1e293b, #0f172a); color: rgba(0,0,0,0.4); }

    /* ── CORD DASHBOARD SECTION ── */
    .cord-dashboard-section {
        padding: 6rem 0 4rem 0;
        background: #f8fafc;
        position: relative;
        overflow: hidden;
    }
    .cord-dashboard-header {
        max-width: 680px;
        margin-bottom: 4rem;
    }
    .cord-dashboard-title {
        font-size: clamp(2.5rem, 4vw, 3.5rem);
        font-weight: 700;
