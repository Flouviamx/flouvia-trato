    /* ── SECURITY ── */
    .stripe-security-section {
        position: relative;
        padding: 8rem 0;
        margin: 4rem 0;
        overflow: hidden;
    }
    
    .stripe-security-bg {
        position: absolute;
        inset: 0;
        background: #0a192f;
        transform: skewY(-4deg);
        transform-origin: top left;
        z-index: 0;
    }
    
    .stripe-security-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 80% 20%, rgba(99, 102, 241, 0.2) 0%, transparent 60%);
    }
    
    .stripe-security-header {
        margin-bottom: 4rem;
        max-width: 600px;
    }
    
    .stripe-security-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }
    
    .stripe-security-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        padding: 2rem;
        backdrop-filter: blur(10px);
