    }
    .stripe-feature-grid-section {
        padding: 6rem 0;
        position: relative;
        z-index: 10;
    }
    
    .stripe-clients {
        padding: 4rem 0;
        position: relative;
        z-index: 10;
    }
    
    .stripe-clients-title {
        text-align: center;
        color: var(--stripe-muted);
        font-size: 0.95rem;
        font-weight: 500;
        margin-bottom: 2rem;
    }
    
    .stripe-logo-grid {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 2rem;
        opacity: 0.6;
    }
    
    .stripe-logo {
        font-family: var(--font-mono);
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--stripe-text);
