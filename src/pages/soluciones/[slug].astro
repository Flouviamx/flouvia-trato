    /* ════════ RESPONSIVE ════════ */
    @media (max-width: 860px) {
        .pp-hero { padding-top: 9.5rem; }
        .pp-audience { padding-top: 4rem; }
        .pp-result-grid { grid-template-columns: 1fr; gap: 2.2rem; }
        .pp-stats { grid-template-columns: 1fr; gap: 2.4rem; padding: 4rem 8%; }
        .pp-blocks { gap: 4.5rem; }
        .pp-block { grid-template-columns: 1fr; gap: 1.8rem; }
        .pp-block-flip .pp-block-text { order: 1; }
        .pp-block-flip .pp-block-visual { order: 2; }
        .pp-block-visual { min-height: 170px; }
        .pp-more-grid { grid-template-columns: 1fr; }
        .mk-rows-4 .mk-row { grid-template-columns: 1.5fr 0.8fr 0.9fr; }
        .mk-rows-4 .mk-row span:nth-child(4) { display: none; }
        .mk-rows-con .mk-row { grid-template-columns: 1.5fr 0.9fr 1fr; }
        .mk-rows-con .mk-row span:nth-child(3) { display: none; }
