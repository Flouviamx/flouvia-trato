---
// Página de solución (Empresas, Startups).
// Diseño alineado al estilo Cord.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import SolucionBlockMockup from '../../components/soluciones/SolucionBlockMockup.astro';
import ProFeatures from '../../components/soluciones/ProFeatures.astro';
import MockupCotizacion from '../../components/soluciones/MockupCotizacion.astro';
import MockupPagos from '../../components/soluciones/MockupPagos.astro';
import MockupCFDI from '../../components/soluciones/MockupCFDI.astro';
import { SOLUCIONES } from '../../lib/solucion';
import { SOLUCIONES_EN } from '../../lib/solucion.en';
import { getLangFromUrl } from '../../i18n/utils';

export function getStaticPaths() {
    return SOLUCIONES.map((s) => ({ params: { slug: s.slug }, props: { solucion: s } }));
}

const lang = getLangFromUrl(Astro.url);
const isEn = Astro.props.isEn || lang === 'en';
const currentSol = Astro.props.solucion || Astro.props.solucion;
const solucion = isEn && currentSol ? SOLUCIONES_EN.find((s) => s.slug === currentSol.slug) || currentSol : currentSol;
const otras = (isEn ? SOLUCIONES_EN : SOLUCIONES).filter((s) => s.slug !== solucion.slug);

const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: solucion.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};

// Array estático de logos (Stripe-style logo cloud)
const clientLogos = ['GAMA', 'ACEROS', 'VERTICE', 'ZARCO', 'FERREX', 'CEMENTOS'];
---

<Layout
    title={solucion.metaTitle ?? `${solucion.nav} — Cord`}
    description={solucion.metaDescription ?? solucion.sub}
>
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <Nav darkHero={solucion.slug === 'empresas'} />
    <main class="stripe-main">
        
        {solucion.slug === 'startups' ? (
            <!-- ── HERO (Stripe Startups Style) ── -->
            <header class="startup-hero">
                <div class="startup-hero-bg">
                    <div class="startup-hero-blob-1"></div>
                    <div class="startup-hero-blob-2"></div>
                </div>
                
                <div class="startup-hero-content stripe-container">
                    <div class="startup-badge">
                        <span class="badge-dot"></span>
                        <span>{isEn ? 'Built for speed' : 'Hecho para escalar'}</span>
                    </div>
                    <h1 class="startup-title reveal" set:html={solucion.titulo} />
                    
                    <p class="startup-sub">{solucion.sub}</p>
                    
                    <div class="startup-actions">
                        <a href={isEn ? '/en/registro' : '/registro'} class="btn-startup-primary">
                            <span>{isEn ? 'Start building' : 'Empezar ahora'}</span>
                        </a>
                        <a href="/contacto/ventas" class="btn-startup-secondary">
                            <span>{isEn ? 'Book a demo' : 'Contactar a ventas'}</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </a>
                    </div>
                </div>
            </header>
        ) : (
            <!-- ── HERO (Stripe Enterprise) ── -->
            <header class="stripe-hero">
                <div class="stripe-hero-bg">
                    <div class="stripe-hero-aurora"></div>
                    <div class="stripe-hero-sweep"></div>
                </div>
                
                <div class="stripe-hero-content stripe-container">
                    <h1 class="stripe-title reveal" set:html={solucion.titulo} />
                    
                    <p class="stripe-sub">{solucion.sub}</p>
                    
                    <div class="stripe-actions">
                        <a href={isEn ? '/en/registro' : '/registro'} class="btn-luxe">
                            <span>{isEn ? 'Start now' : 'Empezar ahora'}</span>
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            <div class="btn-shimmer"></div>
                        </a>
                        <a href="/contacto/ventas" class="btn-ghost">
                            <span>{isEn ? 'Contact sales' : 'Contactar a ventas'}</span>
                        </a>
                    </div>
                </div>
            </header>
        )}



        <!-- ── AIRY BENTO PILLARS ── -->
        {solucion.pillars && (
            <section class="stripe-pillars-section">
                <div class="stripe-container">
                    <div class="stripe-pillars-grid">
                        {solucion.pillars.map((p, i) => (
                            <div class="stripe-pillar-card reveal">
                                <div class="stripe-pillar-graphic">
                                    {i === 0 && (
                                        <svg class="abstract-svg abstract-pulse" viewBox="0 0 200 150">
                                            <defs>
                                                <radialGradient id="glow0" cx="50%" cy="50%" r="50%">
                                                    <stop offset="0%" stop-color="var(--stripe-cyan)" stop-opacity="0.3" />
                                                    <stop offset="100%" stop-color="var(--stripe-cyan)" stop-opacity="0" />
                                                </radialGradient>
                                                <linearGradient id="line0" x1="0%" y1="0%" x2="100%" y2="100%">
                                                    <stop offset="0%" stop-color="var(--stripe-cyan)" />
                                                    <stop offset="100%" stop-color="var(--stripe-accent)" />
                                                </linearGradient>
                                            </defs>
                                            <circle cx="100" cy="75" r="50" fill="url(#glow0)" />
                                            <circle cx="100" cy="75" r="30" fill="none" stroke="rgba(59, 130, 246, 0.2)" stroke-width="1" />
                                            <circle cx="100" cy="75" r="45" fill="none" stroke="rgba(59, 130, 246, 0.1)" stroke-width="1" />
                                            <circle cx="100" cy="75" r="8" fill="var(--stripe-cyan)" />
                                            <path d="M 20 120 C 60 120 80 50 100 50 C 120 50 140 90 180 90" fill="none" stroke="url(#line0)" stroke-width="2" stroke-dasharray="8 4" class="abstract-dash" />
                                        </svg>
                                    )}
                                    {i === 1 && (
                                        <svg class="abstract-svg abstract-float" viewBox="0 0 200 150">
                                            <defs>
                                                <radialGradient id="glow1" cx="50%" cy="50%" r="50%">
                                                    <stop offset="0%" stop-color="var(--stripe-accent)" stop-opacity="0.2" />
                                                    <stop offset="100%" stop-color="var(--stripe-accent)" stop-opacity="0" />
                                                </radialGradient>
                                                <linearGradient id="path1" x1="0" y1="0" x2="1" y2="0">
                                                    <stop offset="0%" stop-color="rgba(59, 130, 246, 0.1)" />
                                                    <stop offset="50%" stop-color="var(--stripe-cyan)" />
                                                    <stop offset="100%" stop-color="rgba(59, 130, 246, 0.1)" />
                                                </linearGradient>
                                            </defs>
                                            <circle cx="50" cy="75" r="40" fill="url(#glow1)" />
                                            <circle cx="150" cy="75" r="40" fill="url(#glow1)" />
                                            <path d="M 50 75 Q 100 20 150 75" fill="none" stroke="url(#path1)" stroke-width="1.5" />
                                            <path d="M 50 75 Q 100 130 150 75" fill="none" stroke="url(#path1)" stroke-width="1.5" stroke-dasharray="4 4" class="abstract-dash-reverse" />
                                            <circle cx="50" cy="75" r="12" fill="#fff" stroke="var(--stripe-cyan)" stroke-width="2" />
                                            <circle cx="50" cy="75" r="4" fill="var(--stripe-cyan)" />
                                            <circle cx="150" cy="75" r="12" fill="#fff" stroke="var(--stripe-accent)" stroke-width="2" />
                                            <circle cx="150" cy="75" r="4" fill="var(--stripe-accent)" />
                                            <circle cx="100" cy="47.5" r="3" fill="var(--stripe-cyan)" class="abstract-orbit" />
                                        </svg>
                                    )}
                                    {i === 2 && (
                                        <svg class="abstract-svg abstract-pulse-slow" viewBox="0 0 200 150">
                                            <defs>
                                                <linearGradient id="shieldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                    <stop offset="0%" stop-color="var(--stripe-cyan)" />
                                                    <stop offset="100%" stop-color="#10b981" />
                                                </linearGradient>
                                                <radialGradient id="glow2" cx="50%" cy="50%" r="50%">
                                                    <stop offset="0%" stop-color="#10b981" stop-opacity="0.15" />
                                                    <stop offset="100%" stop-color="#10b981" stop-opacity="0" />
                                                </radialGradient>
                                            </defs>
                                            <circle cx="100" cy="75" r="60" fill="url(#glow2)" />
                                            <polygon points="100,25 143,50 143,100 100,125 57,100 57,50" fill="none" stroke="rgba(16, 185, 129, 0.2)" stroke-width="1" />
                                            <polygon points="100,40 130,58 130,92 100,110 70,92 70,58" fill="none" stroke="rgba(16, 185, 129, 0.4)" stroke-width="1" />
                                            <path d="M 90 65 L 110 65 C 115 65 115 75 110 75 L 90 75 C 85 75 85 65 90 65 Z" fill="url(#shieldGrad)" />
                                            <path d="M 95 65 V 55 C 95 50 105 50 105 55 V 65" fill="none" stroke="url(#shieldGrad)" stroke-width="2" />
                                            <circle cx="100" cy="70" r="1.5" fill="#fff" />
                                        </svg>
                                    )}
                                </div>
                                <div class="stripe-pillar-content">
                                    <h3 class="stripe-pillar-title">{p.titulo}</h3>
                                    <p class="stripe-pillar-desc">{p.desc}</p>
                                    <a href="#" class="stripe-pillar-link">
                                        {p.link}
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="12" y1="5" x2="12" y2="19"></line>
                                            <polyline points="19 12 12 19 5 12"></polyline>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </section>
        )}

        <!-- ── FEATURE GRID (ASYMMETRIC) ── -->
        <section class="stripe-feature-grid-section">
            <div class="stripe-container">
                <div class="stripe-section-header reveal">
                    <span class="stripe-section-eyebrow">CAPACIDADES CORE</span>
                    <h2 class="stripe-h2">{isEn ? 'A complete ecosystem for your commercial process' : 'Un ecosistema completo para tu proceso comercial'}</h2>
                    <p class="stripe-p">{solucion.paraQuien}</p>
                </div>

                <div class="stripe-fg-layout">
                    <!-- Left Column: Main Features -->
                    <div class="stripe-fg-main">
                        {solucion.blocks.map((block, idx) => (
                            <div class="stripe-fg-card reveal">
                                <div class="stripe-fg-card-content">
                                    <h3 class="stripe-fg-title">{block.titulo}</h3>
                                    <p class="stripe-fg-desc">{block.copy}</p>
                                    <div class="stripe-fg-tags">
                                        {block.bullets.map((b, bulletIdx) => {
                                            const slugs = ['aprobaciones', 'finanzas', 'cfdi', 'editor', 'equipo'];
                                            const targetSlug = slugs[(idx + bulletIdx) % slugs.length];
                                            return (
                                                <a href={`/producto/${targetSlug}`} class="stripe-fg-tag">{b}</a>
                                            );
                                        })}
                                    </div>
                                </div>
                                <div class="stripe-fg-card-visual">
                                <div class="stripe-fg-card-visual">
                                    {idx === 0 && (
                                        <div class="pro-ui-card real-ui">
                                            <div class="rui-topbar">
                                                <div style="font-weight: 700; font-size: 13px; display: flex; align-items: center; gap: 8px;">
                                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4z"></path><path d="M3 5v14a2 2 0 0 0 2 2h16v-9H5a2 2 0 0 0-2 2z"></path></svg>
                                                    Reconocimiento de ingresos
                                                </div>
                                                <div class="rui-dropdown-header" style="margin-top: 0;"><span>Junio 2026</span><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg></div>
                                            </div>
                                            <div style="padding: 24px;">
                                                <div class="rui-header-flex">
                                                    <div>
                                                        <div class="rui-value">MXN 5,839,417.15</div>
                                                        <div class="rui-label text-green">+14.2% vs mes anterior</div>
                                                    </div>
                                                    <div class="rui-tabs-small">
                                                        <span class="active">Abierto</span>
                                                        <span>Cerrado</span>
                                                    </div>
                                                </div>
                                                
                                                <div class="rui-chart-container">
                                                    <div class="rui-chart-bar" style="height: 40%"></div>
                                                    <div class="rui-chart-bar" style="height: 60%"></div>
                                                    <div class="rui-chart-bar" style="height: 50%"></div>
                                                    <div class="rui-chart-bar" style="height: 80%"></div>
                                                    <div class="rui-chart-bar bar-active" style="height: 90%"></div>
                                                    <div class="rui-chart-bar" style="height: 70%"></div>
                                                    <div class="rui-chart-bar" style="height: 100%"></div>
                                                </div>
                                                <div class="rui-chart-labels">
                                                    <span>Ene</span><span>Feb</span><span>Mar</span><span>Abr</span><span>May</span><span>Jun</span><span>Jul</span>
                                                </div>

                                                <div class="rui-divider"></div>
                                                
                                                <div class="rui-dropdown-header">
                                                    <span>Resumen de Junio de 2026</span>
                                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                                                </div>
                                                <div class="rui-table-mini">
                                                    <div class="rt-row"><span class="rt-label">Ingresos reconocidos previamente</span><span class="rt-val">MXN 1,215,752.67</span></div>
                                                    <div class="rt-row"><span class="rt-label">Ingresos por servicios no facturados</span><span class="rt-val">MXN 4,244,870.34</span></div>
                                                    <div class="rt-row"><span class="rt-label">Menos reembolsos</span><span class="rt-val text-red">MXN 22.38</span></div>
                                                </div>
                                            </div>
                                        </div>
                                    )}
                                    {idx === 1 && (
                                        <div class="pro-ui-card real-ui" style="padding: 0;">
                                            <div class="rui-sidebar-layout">
                                                <div class="rui-sidebar">
                                                    <div class="rs-brand"><img src="/imgs/logo-cord-navy.png" width="18" alt="Cord" /></div>
                                                    <div class="rs-item active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><path d="M3 9h18M9 21V9"></path></svg></div>
                                                    <div class="rs-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg></div>
                                                    <div class="rs-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg></div>
                                                    <div class="rs-avatar rbac-grad-1 mt-auto mb-4">AG</div>
                                                </div>
                                                <div class="rui-main">
                                                    <div class="rui-topbar" style="border-bottom: 1px solid #e2e8f0; background: transparent;">
                                                        <span style="font-size: 13px; font-weight: 700; color: #0f172a;">Flujo de Datos ERP</span>
                                                        <span class="badge-blue">Sincronizando</span>
                                                    </div>
                                                    <div style="padding: 16px; background: #f8fafc;">
                                                        <div class="rui-pipeline-visual">
                                                            <div class="rp-node"><img src="/imgs/logo-cord-navy.png" width="20" alt="Cord"/></div>
                                                            <div class="rp-line"><div class="rp-dot"></div><div class="rp-dot delay-1"></div></div>
                                                            <div class="rp-node"><svg viewBox="0 0 24 24" fill="none" stroke="#0ea5e9" stroke-width="2" width="20"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg></div>
                                                        </div>
                                                    </div>
                                                    <div class="rui-terminal">
                                                        <div class="rui-term-header">
                                                            <div style="display: flex; gap: 8px; align-items: center; font-weight: 600;">
                                                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
                                                                <span>Terminal - Conexión Activa</span>
                                                            </div>
                                                        </div>
                                                        <div><span class="term-green">➜</span> <span class="term-blue">cord</span> sync --target=sap --watch</div>
                                                        <div style="margin-top: 4px;">[14:32:01] <span class="term-blue">INFO</span> Conectando con SAP NetWeaver...</div>
                                                        <div>[14:32:02] <span class="term-green">SUCCESS</span> Conexión establecida (3ms)</div>
                                                        <div>[14:32:03] <span class="term-blue">INFO</span> Sincronizando 45 nuevas facturas...</div>
                                                        <div>[14:32:04] <span class="term-purple">POST</span> /api/v1/erp/invoices (2.4kb)</div>
                                                        <div>[14:32:05] <span class="term-green">SUCCESS</span> Payload insertado correctamente.</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    )}
                                    {idx === 2 && (
                                        <div class="pro-ui-card real-ui">
                                            <div class="rui-topbar">
                                                <div style="font-weight: 700; font-size: 13px; display: flex; align-items: center; gap: 8px;">
                                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                                                    Seguridad y Accesos
                                                </div>
                                                <button class="rui-btn-save">Guardar</button>
                                            </div>
                                            <div style="padding: 16px;">
                                                <div class="rui-setting-group">
                                                    <div class="rui-setting-row">
                                                        <div class="rs-info">
                                                            <span class="rs-title">Autenticación de 2 Factores (2FA)</span>
                                                            <span class="rs-desc">Requerido para todos los admins.</span>
                                                        </div>
                                                        <div class="rui-toggle active"><div class="rt-knob"></div></div>
                                                    </div>
                                                    <div class="rui-setting-row">
                                                        <div class="rs-info">
                                                            <span class="rs-title">Cifrado End-to-End</span>
                                                            <span class="rs-desc">AES-256 GCM en tránsito y reposo.</span>
                                                        </div>
                                                        <div class="rui-toggle active"><div class="rt-knob"></div></div>
                                                    </div>
                                                </div>
                                                
                                                <div style="margin-top: 24px; margin-bottom: 8px; font-size: 10px; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.5px;">Políticas de Acceso (RBAC)</div>
                                                <div class="rui-rbac-list">
                                                    <div class="rbac-row">
                                                        <div style="display: flex; align-items: center; gap: 12px;">
                                                            <div class="rbac-avatar rbac-grad-1">AG</div>
                                                            <div class="rs-info">
                                                                <span class="rs-title">Ana García</span>
                                                                <span class="rs-desc">ana@empresa.com</span>
                                                            </div>
                                                        </div>
                                                        <span class="rbac-badge badge-admin">Admin</span>
                                                    </div>
                                                    <div class="rbac-row">
                                                        <div style="display: flex; align-items: center; gap: 12px;">
                                                            <div class="rbac-avatar rbac-grad-2">CR</div>
                                                            <div class="rs-info">
                                                                <span class="rs-title">Carlos Ruiz</span>
                                                                <span class="rs-desc">carlos@empresa.com</span>
                                                            </div>
                                                        </div>
                                                        <span class="rbac-badge badge-gray">
                                                            Finanzas
                                                            <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    )}
                                </div>
                                </div>
                            </div>
                        ))}
                    </div>

                    <!-- Right Column: Resources Sidebar -->
                    <div class="stripe-fg-sidebar">
                        <div class="stripe-resource-card reveal">
                            <div class="stripe-resource-visual stripe-bg-purple">
                                <svg width="100%" height="100%" viewBox="0 0 400 200" fill="none">
                                    <path d="M0,100 Q100,50 200,100 T400,100" stroke="rgba(255,255,255,0.2)" stroke-width="2" fill="none"/>
                                    <path d="M0,120 Q100,70 200,120 T400,120" stroke="rgba(255,255,255,0.2)" stroke-width="2" fill="none"/>
                                    <circle cx="300" cy="80" r="40" stroke="rgba(255,255,255,0.2)" stroke-width="2" fill="none"/>
                                    <circle cx="300" cy="80" r="20" stroke="rgba(255,255,255,0.2)" stroke-width="2" fill="none"/>
                                    <rect x="50" y="50" width="100" height="100" stroke="rgba(255,255,255,0.2)" stroke-width="2" fill="none"/>
                                </svg>
                            </div>
                            <div class="stripe-resource-content">
                                <span class="stripe-resource-eyebrow">Blog</span>
                                <h4 class="stripe-resource-title">Últimas tendencias B2B y estrategias de automatización</h4>
