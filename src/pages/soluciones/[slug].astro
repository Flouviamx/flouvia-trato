        height: 20px;
        color: var(--stripe-muted);
        transition: transform 0.2s ease;
    }
    
    .stripe-faq-item[open] summary svg {
        transform: rotate(180deg);
    }
    
    .stripe-faq-a {
        padding-bottom: 1.5rem;
        color: var(--stripe-muted);
        line-height: 1.6;
    }

    /* ════════════════════════════════════════════════════════════════
       CTA
    ════════════════════════════════════════════════════════════════ */
    .stripe-cta-section {
        padding: 6rem 0 10rem;
        position: relative;
        z-index: 10;
    }
    
    .stripe-cta-card {
        background: radial-gradient(circle at top, rgba(10, 25, 47, 0.1), transparent 50%), var(--stripe-card-bg);
        border: 1px solid var(--stripe-border);
        border-radius: 24px;
        padding: 5rem 2rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
