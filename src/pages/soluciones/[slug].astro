    .pp-faq-list { display: flex; flex-direction: column; }
    .pp-faq-item { border-bottom: 1px solid var(--color-border); }
    .pp-faq-q {
        display: flex; justify-content: space-between; align-items: center; gap: 1.5rem;
        width: 100%; padding: 1.5rem 0.2rem;
        cursor: pointer; background: none; border: none; text-align: left;
        font-family: var(--font-sans); font-size: 1.08rem; font-weight: 600;
        color: var(--color-text); transition: color 0.3s var(--ease-ios);
    }
    .pp-faq-q:hover, .pp-faq-item.open .pp-faq-q { color: var(--color-blue-deep); }
    .pp-faq-icon { position: relative; width: 16px; height: 16px; flex-shrink: 0; transition: transform 0.5s var(--ease-spring); }
    .pp-faq-icon::before, .pp-faq-icon::after {
        content: ''; position: absolute; top: 50%; left: 50%;
        background: var(--color-text-muted);
        transition: transform 0.4s var(--ease-spring);
    }
    .pp-faq-icon::before { width: 14px; height: 2px; transform: translate(-50%, -50%); }
    .pp-faq-icon::after { width: 2px; height: 14px; transform: translate(-50%, -50%); }
    .pp-faq-item.open .pp-faq-icon { transform: rotate(90deg); }
    .pp-faq-item.open .pp-faq-icon::after { transform: translate(-50%, -50%) scaleY(0); }
    .pp-faq-panel {
        display: grid; grid-template-rows: 0fr;
        transition: grid-template-rows 0.55s var(--ease-spring);
    }
    .pp-faq-panel > .pp-faq-a { overflow: hidden; min-height: 0; }
    .pp-faq-item.open .pp-faq-panel { grid-template-rows: 1fr; }
    .pp-faq-a {
        margin: 0; padding: 0 0.2rem;
        font-size: 1rem; line-height: 1.7; color: var(--color-text-muted); max-width: 92%;
        opacity: 0; transform: translateY(-6px);
        transition: opacity 0.45s var(--ease-ios) 0.08s, transform 0.5s var(--ease-spring) 0.08s, padding 0.45s var(--ease-spring);
    }
    .pp-faq-item.open .pp-faq-a { opacity: 1; transform: translateY(0); padding-bottom: 1.6rem; }
    @media (prefers-reduced-motion: reduce) {
        .pp-faq-panel, .pp-faq-a, .pp-faq-icon { transition: none; }
