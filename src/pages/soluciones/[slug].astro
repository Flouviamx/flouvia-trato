---
// Página de solución (Empresas, Startups).
// Diseño alineado al estilo Cord.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import SolucionBlockMockup from '../../components/soluciones/SolucionBlockMockup.astro';
import ProFeatures from '../../components/soluciones/ProFeatures.astro';
import MockupCotizacion from '../../components/soluciones/MockupCotizacion.astro';
import MockupPagos from '../../components/soluciones/MockupPagos.astro';
import MockupCFDI from '../../components/soluciones/MockupCFDI.astro';
import { SOLUCIONES } from '../../lib/solucion';
import { SOLUCIONES_EN } from '../../lib/solucion.en';
import { getLangFromUrl } from '../../i18n/utils';

export function getStaticPaths() {
    return SOLUCIONES.map((s) => ({ params: { slug: s.slug }, props: { solucion: s } }));
}

const lang = getLangFromUrl(Astro.url);
const isEn = Astro.props.isEn || lang === 'en';
const currentSol = Astro.props.solucion || Astro.props.solucion;
const solucion = isEn && currentSol ? SOLUCIONES_EN.find((s) => s.slug === currentSol.slug) || currentSol : currentSol;
const otras = (isEn ? SOLUCIONES_EN : SOLUCIONES).filter((s) => s.slug !== solucion.slug);

const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: solucion.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
};

// Array estático de logos (Stripe-style logo cloud)
const clientLogos = ['GAMA', 'ACEROS', 'VERTICE', 'ZARCO', 'FERREX', 'CEMENTOS'];
---

<Layout
    title={solucion.metaTitle ?? `${solucion.nav} — Cord`}
    description={solucion.metaDescription ?? solucion.sub}
>
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <Nav darkHero={solucion.slug === 'empresas'} />
    <main class="stripe-main">
        
        <!-- ── HERO (Stripe Enterprise) ── -->
        <header class="stripe-hero">
            <div class="stripe-hero-bg">
                <div class="stripe-hero-aurora"></div>
                <div class="stripe-hero-sweep"></div>
            </div>
            
            <div class="stripe-hero-content stripe-container">
                <h1 class="stripe-title reveal" set:html={solucion.titulo} />
                
                <p class="stripe-sub">{solucion.sub}</p>
                
                <div class="stripe-actions">
                    <a href={isEn ? '/en/registro' : '/registro'} class="btn-luxe">
                        <span>{isEn ? 'Start now' : 'Empezar ahora'}</span>
                        <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        <div class="btn-shimmer"></div>
                    </a>
                    <a href="/contacto/ventas" class="btn-ghost">
                        <span>{isEn ? 'Contact sales' : 'Contactar a ventas'}</span>
                    </a>
                </div>
            </div>
        </header>

        <!-- ── INTEGRATIONS MARQUEE (Stripe Style) ── -->
        {solucion.integrations && (
            <div class="stripe-integrations-ticker reveal">
                <div class="stripe-ticker-track">
                    {[1, 2].map(() => (
                        <div class="stripe-ticker-tape">
                            {solucion.integrations.map(int => (
                                <div class="stripe-ticker-item">
                                    <div class="stripe-ticker-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="4"/><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>
                                    </div>
                                    <span class="stripe-ticker-name">{int.name}</span>
                                </div>
                            ))}
                        </div>
                    ))}
                </div>
            </div>
        )}

        <!-- ── AIRY BENTO PILLARS ── -->
        {solucion.pillars && (
            <section class="stripe-pillars-section">
                <div class="stripe-container">
                    <div class="stripe-pillars-grid">
                        {solucion.pillars.map((p, i) => (
                            <div class="stripe-pillar-card reveal">
                                <div class="stripe-pillar-graphic">
                                    {i === 0 && (
                                        <svg class="abstract-svg abstract-pulse" viewBox="0 0 200 150">
                                            <defs>
                                                <radialGradient id="glow0" cx="50%" cy="50%" r="50%">
                                                    <stop offset="0%" stop-color="var(--stripe-cyan)" stop-opacity="0.3" />
                                                    <stop offset="100%" stop-color="var(--stripe-cyan)" stop-opacity="0" />
                                                </radialGradient>
                                                <linearGradient id="line0" x1="0%" y1="0%" x2="100%" y2="100%">
                                                    <stop offset="0%" stop-color="var(--stripe-cyan)" />
                                                    <stop offset="100%" stop-color="var(--stripe-accent)" />
                                                </linearGradient>
                                            </defs>
                                            <circle cx="100" cy="75" r="50" fill="url(#glow0)" />
                                            <circle cx="100" cy="75" r="30" fill="none" stroke="rgba(59, 130, 246, 0.2)" stroke-width="1" />
                                            <circle cx="100" cy="75" r="45" fill="none" stroke="rgba(59, 130, 246, 0.1)" stroke-width="1" />
                                            <circle cx="100" cy="75" r="8" fill="var(--stripe-cyan)" />
                                            <path d="M 20 120 C 60 120 80 50 100 50 C 120 50 140 90 180 90" fill="none" stroke="url(#line0)" stroke-width="2" stroke-dasharray="8 4" class="abstract-dash" />
                                        </svg>
                                    )}
                                    {i === 1 && (
                                        <svg class="abstract-svg abstract-float" viewBox="0 0 200 150">
                                            <defs>
                                                <radialGradient id="glow1" cx="50%" cy="50%" r="50%">
                                                    <stop offset="0%" stop-color="var(--stripe-accent)" stop-opacity="0.2" />
                                                    <stop offset="100%" stop-color="var(--stripe-accent)" stop-opacity="0" />
                                                </radialGradient>
                                                <linearGradient id="path1" x1="0" y1="0" x2="1" y2="0">
                                                    <stop offset="0%" stop-color="rgba(59, 130, 246, 0.1)" />
                                                    <stop offset="50%" stop-color="var(--stripe-cyan)" />
                                                    <stop offset="100%" stop-color="rgba(59, 130, 246, 0.1)" />
                                                </linearGradient>
                                            </defs>
                                            <circle cx="50" cy="75" r="40" fill="url(#glow1)" />
                                            <circle cx="150" cy="75" r="40" fill="url(#glow1)" />
                                            <path d="M 50 75 Q 100 20 150 75" fill="none" stroke="url(#path1)" stroke-width="1.5" />
                                            <path d="M 50 75 Q 100 130 150 75" fill="none" stroke="url(#path1)" stroke-width="1.5" stroke-dasharray="4 4" class="abstract-dash-reverse" />
                                            <circle cx="50" cy="75" r="12" fill="#fff" stroke="var(--stripe-cyan)" stroke-width="2" />
                                            <circle cx="50" cy="75" r="4" fill="var(--stripe-cyan)" />
                                            <circle cx="150" cy="75" r="12" fill="#fff" stroke="var(--stripe-accent)" stroke-width="2" />
                                            <circle cx="150" cy="75" r="4" fill="var(--stripe-accent)" />
                                            <circle cx="100" cy="47.5" r="3" fill="var(--stripe-cyan)" class="abstract-orbit" />
                                        </svg>
                                    )}
                                    {i === 2 && (
                                        <svg class="abstract-svg abstract-pulse-slow" viewBox="0 0 200 150">
                                            <defs>
                                                <linearGradient id="shieldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                    <stop offset="0%" stop-color="var(--stripe-cyan)" />
                                                    <stop offset="100%" stop-color="#10b981" />
                                                </linearGradient>
                                                <radialGradient id="glow2" cx="50%" cy="50%" r="50%">
                                                    <stop offset="0%" stop-color="#10b981" stop-opacity="0.15" />
                                                    <stop offset="100%" stop-color="#10b981" stop-opacity="0" />
                                                </radialGradient>
                                            </defs>
                                            <circle cx="100" cy="75" r="60" fill="url(#glow2)" />
                                            <polygon points="100,25 143,50 143,100 100,125 57,100 57,50" fill="none" stroke="rgba(16, 185, 129, 0.2)" stroke-width="1" />
                                            <polygon points="100,40 130,58 130,92 100,110 70,92 70,58" fill="none" stroke="rgba(16, 185, 129, 0.4)" stroke-width="1" />
                                            <path d="M 90 65 L 110 65 C 115 65 115 75 110 75 L 90 75 C 85 75 85 65 90 65 Z" fill="url(#shieldGrad)" />
                                            <path d="M 95 65 V 55 C 95 50 105 50 105 55 V 65" fill="none" stroke="url(#shieldGrad)" stroke-width="2" />
                                            <circle cx="100" cy="70" r="1.5" fill="#fff" />
                                        </svg>
                                    )}
                                </div>
                                <div class="stripe-pillar-content">
                                    <h3 class="stripe-pillar-title">{p.titulo}</h3>
                                    <p class="stripe-pillar-desc">{p.desc}</p>
                                    <a href="#" class="stripe-pillar-link">
                                        {p.link}
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="12" y1="5" x2="12" y2="19"></line>
                                            <polyline points="19 12 12 19 5 12"></polyline>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </section>
        )}

        <!-- ── FEATURE GRID (ASYMMETRIC) ── -->
        <section class="stripe-feature-grid-section">
            <div class="stripe-container">
                <div class="stripe-section-header reveal">
                    <span class="stripe-section-eyebrow">CAPACIDADES CORE</span>
                    <h2 class="stripe-h2">{isEn ? 'A complete ecosystem for your commercial process' : 'Un ecosistema completo para tu proceso comercial'}</h2>
                    <p class="stripe-p">{solucion.paraQuien}</p>
                </div>

                <div class="stripe-fg-layout">
                    <!-- Left Column: Main Features -->
                    <div class="stripe-fg-main">
                        {solucion.blocks.map((block, idx) => (
                            <div class="stripe-fg-card reveal">
                                <div class="stripe-fg-card-content">
                                    <h3 class="stripe-fg-title">{block.titulo}</h3>
                                    <p class="stripe-fg-desc">{block.copy}</p>
                                    <div class="stripe-fg-tags">
                                        {block.bullets.map((b, bulletIdx) => {
                                            const slugs = ['aprobaciones', 'finanzas', 'cfdi', 'editor', 'equipo'];
                                            const targetSlug = slugs[(idx + bulletIdx) % slugs.length];
                                            return (
                                                <a href={`/producto/${targetSlug}`} class="stripe-fg-tag">{b}</a>
                                            );
                                        })}
                                    </div>
                                </div>
                                <div class="stripe-fg-card-visual">
                                <div class="stripe-fg-card-visual">
                                    {idx === 0 && (
                                        <div class="pro-ui-card">
                                            <div class="ui-header">
                                                <div class="ui-title">Aprobación de Cotización</div>
                                                <div class="ui-badge ui-badge-warning">Pendiente</div>
                                            </div>
                                            <div class="ui-body">
                                                <div class="ui-amount">MXN 125,400.00</div>
                                                <div class="ui-subtitle">Cliente: Industrias Apex S.A.</div>
                                                
                                                <div class="ui-stats-row">
                                                    <div class="ui-stat">
                                                        <span>Margen</span>
                                                        <strong>42.5%</strong>
                                                    </div>
                                                    <div class="ui-stat">
                                                        <span>Descuento</span>
                                                        <strong>15%</strong>
                                                    </div>
                                                </div>

                                                <div class="ui-divider"></div>
                                                <div class="ui-list">
                                                    <div class="ui-list-item">
                                                        <div class="ui-item-info">
                                                            <span class="ui-item-title">Licencias Enterprise (x50)</span>
                                                            <span class="ui-item-desc">Suscripción anual</span>
                                                        </div>
                                                        <div class="ui-item-value">MXN 90,000.00</div>
                                                    </div>
                                                    <div class="ui-list-item">
                                                        <div class="ui-item-info">
                                                            <span class="ui-item-title">Implementación Core</span>
                                                            <span class="ui-item-desc">One-time fee</span>
                                                        </div>
                                                        <div class="ui-item-value">MXN 35,400.00</div>
                                                    </div>
                                                </div>

                                                <button class="ui-btn-primary">Aprobar cotización</button>
                                            </div>
                                        </div>
                                    )}
                                    {idx === 1 && (
                                        <div class="pro-ui-card">
                                            <div class="ui-header">
                                                <div class="ui-title">Sincronización en Tiempo Real</div>
                                                <div class="ui-badge ui-badge-success">En línea</div>
                                            </div>
                                            <div class="ui-body">
                                                <div class="ui-sync-flow">
                                                    <div class="ui-sync-node"><img src="/imgs/logo-cord-icon.png" width="24" alt="Cord" /> Cord</div>
                                                    <div class="ui-sync-line"><div class="ui-sync-dot"></div></div>
                                                    <div class="ui-sync-node"><svg viewBox="0 0 24 24" fill="none" stroke="#0ea5e9" stroke-width="2" width="24"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg> ERP Core</div>
                                                </div>

                                                <div class="ui-divider"></div>
                                                <div class="ui-list">
                                                    <div class="ui-list-item">
                                                        <div class="ui-item-icon success"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
                                                        <div class="ui-item-info">
                                                            <span class="ui-item-title">Factura FAC-8901</span>
                                                            <span class="ui-item-desc">Sincronizado hoy 14:32</span>
                                                        </div>
                                                        <div class="ui-item-value">MXN 45k</div>
                                                    </div>
                                                    <div class="ui-list-item">
                                                        <div class="ui-item-icon success"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
                                                        <div class="ui-item-info">
                                                            <span class="ui-item-title">Cliente CLI-092</span>
                                                            <span class="ui-item-desc">Sincronizado hoy 13:15</span>
                                                        </div>
                                                        <div class="ui-item-value">Success</div>
                                                    </div>
                                                    <div class="ui-list-item">
                                                        <div class="ui-item-icon sync"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.5 2v6h-6M2.13 15.57a9 9 0 0 0 16.14 1.34l3.23-3.23M2.5 22v-6h6M21.87 8.43a9 9 0 0 0-16.14-1.34L2.5 10.32"></path></svg></div>
                                                        <div class="ui-item-info">
                                                            <span class="ui-item-title">Pago PAG-441</span>
                                                            <span class="ui-item-desc">Procesando...</span>
                                                        </div>
                                                        <div class="ui-item-value" style="color:#94a3b8">Pending</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    )}
                                    {idx === 2 && (
                                        <div class="pro-ui-card">
                                            <div class="ui-header">
                                                <div class="ui-title">Control de Accesos (RBAC)</div>
                                                <div class="ui-badge ui-badge-gray">SOC 2 / ISO 27001</div>
                                            </div>
                                            <div class="ui-body">
                                                <div class="ui-security-overview">
                                                    <div class="ui-sec-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></div>
                                                    <div>
                                                        <div class="ui-sec-title">Cifrado E2E Activo</div>
                                                        <div class="ui-sec-desc">Todas las transacciones están firmadas criptográficamente.</div>
                                                    </div>
                                                </div>

                                                <div class="ui-divider"></div>
                                                <div class="ui-list">
                                                    <div class="ui-list-item">
                                                        <div class="ui-avatar">AG</div>
                                                        <div class="ui-item-info">
                                                            <span class="ui-item-title">Ana García</span>
                                                            <span class="ui-item-desc">ana@empresa.com</span>
                                                        </div>
                                                        <div class="ui-badge ui-badge-admin">Admin</div>
                                                    </div>
                                                    <div class="ui-list-item">
                                                        <div class="ui-avatar bg-blue">LM</div>
                                                        <div class="ui-item-info">
                                                            <span class="ui-item-title">Luis Mendoza</span>
                                                            <span class="ui-item-desc">luis@empresa.com</span>
                                                        </div>
                                                        <div class="ui-badge ui-badge-gray">Ventas</div>
                                                    </div>
                                                    <div class="ui-list-item">
                                                        <div class="ui-avatar bg-green">CR</div>
                                                        <div class="ui-item-info">
                                                            <span class="ui-item-title">Carlos Ruiz</span>
                                                            <span class="ui-item-desc">carlos@empresa.com</span>
                                                        </div>
                                                        <div class="ui-badge ui-badge-gray">Finanzas</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    )}
                                </div>
                                </div>
                            </div>
                        ))}
                    </div>

                    <!-- Right Column: Resources Sidebar -->
                    <div class="stripe-fg-sidebar">
                        <div class="stripe-resource-card reveal">
                            <div class="stripe-resource-visual stripe-bg-purple">
                                <svg width="100%" height="100%" viewBox="0 0 400 200" fill="none">
                                    <path d="M0,100 Q100,50 200,100 T400,100" stroke="rgba(255,255,255,0.2)" stroke-width="2" fill="none"/>
                                    <path d="M0,120 Q100,70 200,120 T400,120" stroke="rgba(255,255,255,0.2)" stroke-width="2" fill="none"/>
                                    <circle cx="300" cy="80" r="40" stroke="rgba(255,255,255,0.2)" stroke-width="2" fill="none"/>
                                    <circle cx="300" cy="80" r="20" stroke="rgba(255,255,255,0.2)" stroke-width="2" fill="none"/>
                                    <rect x="50" y="50" width="100" height="100" stroke="rgba(255,255,255,0.2)" stroke-width="2" fill="none"/>
                                </svg>
                            </div>
                            <div class="stripe-resource-content">
                                <span class="stripe-resource-eyebrow">Blog</span>
                                <h4 class="stripe-resource-title">Últimas tendencias B2B y estrategias de automatización</h4>
                                <a href="/blog" class="stripe-pillar-link">
                                    Explorar artículos
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M9 18l6-6-6-6"/>
                                    </svg>
                                </a>
                            </div>
                        </div>

                        <div class="stripe-resource-card reveal">
                            <div class="stripe-resource-visual stripe-bg-gray">
                                <img src="/imgs/logo-cord.png" alt="Cord" style="width:120px; opacity:0.8;" />
                            </div>
                            <div class="stripe-resource-content">
                                <span class="stripe-resource-eyebrow">Soporte</span>
                                <h4 class="stripe-resource-title">Centro de ayuda y guías detalladas paso a paso</h4>
                                <a href="/soporte" class="stripe-pillar-link">
                                    Buscar respuestas
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M9 18l6-6-6-6"/>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── SECURITY / TRUST CENTER ── -->
        {solucion.security && (
            <section class="stripe-security-section">
                <div class="stripe-security-bg"></div>
                <div class="stripe-container" style="position:relative; z-index:10;">
                    <div class="stripe-security-header reveal">
                        <span class="stripe-section-eyebrow stripe-eyebrow-light">{solucion.security.eyebrow}</span>
                        <h2 class="stripe-h2 text-white">{solucion.security.titulo}</h2>
                        <p class="stripe-p text-white-muted">{solucion.security.copy}</p>
                    </div>

                    <div class="stripe-security-grid">
                        {solucion.security.features.map(f => (
                            <div class="stripe-security-card reveal">
                                <div class="stripe-sec-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M8 11l3 3 5-5"/></svg>
                                </div>
                                <h4 class="stripe-sec-title">{f.title}</h4>
                                <p class="stripe-sec-desc">{f.desc}</p>
                            </div>
                        ))}
                    </div>
                </div>
            </section>
        )}

        <!-- ── STATS (Stripe Metric Cards) ── -->
        <section class="stripe-stats-section reveal">
            <div class="stripe-container">
                <div class="stripe-stats-grid">
                    {solucion.stats.map(st => (
                        <div class="stripe-stat-card">
                            <div class="stripe-stat-line"></div>
                            <div class="stripe-stat-val editorial">
                                {st.prefix}
                                {st.countup ? (
                                    <span class="count-up" data-val={st.countup} data-dec={st.decimals || 0}>{st.countup}</span>
                                ) : (
                                    st.valor
                                )}
                                {st.suffix}
                            </div>
                            <div class="stripe-stat-label">{st.label}</div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ── TESTIMONIAL ── -->
        {solucion.resultado && (
            <section class="stripe-testimonial-section reveal">
                <div class="stripe-container">
                    <div class="stripe-testimonial-card">
                        <div class="stripe-quote-mark">“</div>
                        <h2 class="stripe-testimonial-text">{solucion.resultado.nota}</h2>
                        <div class="stripe-testimonial-author">
                            <div class="stripe-author-avatar"></div>
                            <div class="stripe-author-info">
                                <b>{solucion.resultado.cliente}</b>
                                <span>{isEn ? 'Verified Customer' : 'Cliente Verificado'}</span>
                            </div>
                        </div>
                        <div class="stripe-testimonial-metrics">
                            {solucion.resultado.metricas.map(m => (
                                <div>
                                    <b class="editorial">{m.valor}</b>
                                    <span>{m.label}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </section>
        )}

        <!-- ── FAQ ── -->
        <section class="stripe-faq-section reveal">
            <div class="stripe-container">
                <h2 class="stripe-h2">{isEn ? 'Frequently asked questions' : 'Preguntas frecuentes'}</h2>
                <div class="stripe-faq-list">
