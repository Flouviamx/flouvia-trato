---
// Página para desarrolladores — una por tema (api, mcp). Mismo lenguaje visual y
// de animación que /producto/* (PageAnims, masked-title, reveal, editorial), pero
// con mockups de CÓDIGO/CHAT en vez de mockups de cotización. Copy en
// src/lib/desarrolladores.ts.
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import DevBlockMockup from '../../components/desarrolladores/DevBlockMockup.astro';
import { DEV_PAGES } from '../../lib/desarrolladores';
import { DEV_PAGES_EN } from '../../lib/desarrolladores.en';
import { getLangFromUrl } from '../../i18n/utils';

export function getStaticPaths() {
    return DEV_PAGES.map((p) => ({ params: { slug: p.slug }, props: { page: p } }));
}

const lang = getLangFromUrl(Astro.url);
const isEn = Astro.props.isEn || lang === 'en';
const currentPage = Astro.props.page || Astro.props.page;
const page = isEn && currentPage ? DEV_PAGES_EN.find((p) => p.slug === currentPage.slug) || currentPage : currentPage;
const otra = (isEn ? DEV_PAGES_EN : DEV_PAGES).find((p) => p.slug !== page.slug)!;
---

<Layout title={`${page.nav} — Cord`} description={page.sub}>
    <Nav />
    <main>
        <!-- ── HERO ── -->
        <section class="pp-hero">
            <div class="pp-hero-mesh" aria-hidden="true"></div>
            <div class="pp-hero-inner">
                <p class="pp-eyebrow reveal">{page.eyebrow}</p>
                <h1 class="pp-title masked-title" set:html={page.titulo} />
                <p class="pp-sub reveal">{page.sub}</p>
                <div class="pp-actions reveal">
                    <a href="/registro" class="pp-btn-primary">
                        <span>{isEn ? 'Start for free' : 'Empezar gratis'}</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                    <a href="/precios" class="pp-btn-ghost">Ver planes</a>
                </div>
                <p class="pp-plan reveal">{page.plan}</p>

                <!-- Mockup del hero -->
                <div class="pp-mockup-wrap reveal-mockup">
                    <div class="pp-glow" aria-hidden="true"></div>
                    <div class="pp-mockup">
                        {page.slug === 'api' && (
                            <div class="dv-api">
                                <div class="dv-api-bar">
                                    <span class="dv-dots"><i></i><i></i><i></i></span>
                                    <span class="dv-method">POST</span>
                                    <span class="dv-endpoint">/api/v1/cotizaciones</span>
                                    <span class="dv-api-stat" id="apiStat">{isEn ? 'sending...' : 'enviando…'}</span>
                                </div>
                                <div class="dv-api-body">
                                    <div class="dv-api-req"><code><span class="c-prompt">$</span> curl -X POST <span class="c-path">/api/v1/cotizaciones</span> \
  -H <span class="c-str">"Authorization: Bearer </span><span class="dv-keytok">sk_live_8f2a••••</span><span class="c-str">"</span> \
  -d <span class="c-str">'{`{`} "cliente_id": "c_8f2a", "items": [ … ] {`}`}'</span></code></div>
                                    <div class="dv-api-divider"><span class="dv-api-sending" id="apiSending">●&nbsp;&nbsp;{isEn ? 'sending' : 'enviando'}</span></div>
                                    <pre class="dv-api-res"><code><span class="dv-line">{`{`}</span>
<span class="dv-line">  <span class="c-key">"id"</span>: <span class="c-str">"q_19a…"</span>,</span>
<span class="dv-line">  <span class="c-key">"folio"</span>: <span class="c-str">"COT-0149"</span>,</span>
<span class="dv-line">  <span class="c-key">"cliente"</span>: <span class="c-str">"{isEn ? 'El Zarco Distribution' : 'Distribuidora El Zarco'}"</span>,</span>
<span class="dv-line">  <span class="c-key">"status"</span>: <span class="c-str">"sent"</span>,</span>
<span class="dv-line">  <span class="c-key">"total"</span>: <span class="c-num">196469.2</span></span>
<span class="dv-line">{`}`}</span></code></pre>
                                    <span class="dv-api-latency" id="apiLatency">142 ms · {isEn ? 'MX region' : 'región MX'}</span>
                                </div>
                            </div>
                        )}
                        {page.slug === 'mcp' && (
                            <div class="dv-mcp">
                                <div class="dv-mcp-row">
                                    <div class="dv-node dv-node-ai">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v4M12 17v4M3 12h4M17 12h4"/><circle cx="12" cy="12" r="3.2"/></svg>
                                        <span>{isEn ? 'Claude · AI' : 'Claude · IA'}</span>
                                    </div>
                                    <div class="dv-conn dv-conn-1">
                                        <span class="dv-dot" id="mcpD1"></span>
                                        <span class="dv-tool-chip" id="mcpChip1">{isEn ? 'overdue_invoices' : 'cartera_vencida'}</span>
                                    </div>
                                    <div class="dv-node dv-node-cord">
                                        <img src="/imgs/logo-cord-white.png" alt="Cord" />
                                    </div>
                                    <div class="dv-conn dv-conn-2">
                                        <span class="dv-dot dv-dot-r" id="mcpD2"></span>
                                        <i class="dv-check" id="mcpCheck">✓</i>
                                    </div>
                                    <div class="dv-node dv-node-ext">{isEn ? 'Your CRM / ERP' : 'Tu CRM / ERP'}</div>
                                </div>
                                <div class="dv-mcp-steps" id="mcpSteps">
                                    <div class="dv-mcp-step"><b>1</b> {isEn ? 'AI invokes one of your 7 tools' : 'La IA invoca una de tus 7 herramientas'}</div>
                                    <div class="dv-mcp-step"><b>2</b> {isEn ? 'Cord queries your CRM, with permission' : 'Cord consulta tu CRM, con permiso'}</div>
                                    <div class="dv-mcp-step"><b>3</b> {isEn ? 'Context returns to the conversation' : 'El contexto regresa a la conversación'}</div>
                                    <div class="dv-mcp-step"><b>4</b> {isEn ? 'AI builds the quote with that context' : 'La IA arma la cotización con ese contexto'}</div>
                                </div>
                            </div>
                        )}
                        {page.slug === 'elements' && (
                            <div class="dv-embed">
                                <div class="dv-embed-bar">
                                    <span class="dv-dots"><i></i><i></i><i></i></span>
                                    <span class="dv-embed-url">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
                                        portal.tucliente.com/cotizacion
                                    </span>
                                </div>
                                <div class="dv-embed-site">
                                    <div class="dv-embed-sitehead">
                                        <span class="dv-embed-logo">ACME Industrial</span>
                                        <span class="dv-embed-nav"><i></i><i></i><i></i></span>
                                    </div>
                                    <p class="dv-embed-h">{isEn ? 'Your quote is ready' : 'Tu cotización está lista'}</p>
                                    <div class="dv-embed-mount">
                                        <div class="dv-embed-skel" id="embedSkel"><span></span><span></span><span></span></div>
                                        <div class="dv-embed-card" id="embedCard">
                                            <div class="dv-embed-cardhead"><span class="dv-embed-brand">MV</span><b>{isEn ? 'Valle Materials' : 'Materiales del Valle'}</b><span class="dv-embed-badge" id="embedBadge">● {isEn ? 'Review' : 'Revisar'}</span></div>
                                            <div class="dv-embed-line"><span>{isEn ? 'Grey cement 50kg' : 'Cemento gris 50kg'} × 120</span><span class="editorial">$21,840.00</span></div>
                                            <div class="dv-embed-line"><span>{isEn ? 'Rebar 3/8"' : 'Varilla 3/8"'} × 340</span><span class="editorial">$57,290.00</span></div>
                                            <div class="dv-embed-total"><span>{isEn ? 'Total with tax' : 'Total con IVA'}</span><b class="editorial" id="embedTotal">$196,469.20</b></div>
                                            <div class="dv-embed-approve" id="embedApprove">{isEn ? 'Approve quote' : 'Aprobar cotización'}</div>
                                        </div>
                                        <div class="dv-embed-cursor" id="embedCursor">
                                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 2l12 11.2-5.8.5 3.3 7.3-2.25 1-3.2-7.4-4.4 4.7z"/></svg>
                                        </div>
                                    </div>
                                </div>
                                <div class="dv-embed-event" id="embedEvent"><i></i>cord:approved · COT-0148</div>
                            </div>
                        )}
                    </div>
                </div>
            </div>
        </section>

        <!-- ── STATS ── -->
        <section class="pp-stats">
            {page.stats.map((s) => (
                <div class="pp-stat reveal">
                    <span class="pp-stat-num editorial"
                        data-countup={s.countup !== undefined ? String(s.countup) : undefined}
                        data-decimals={s.decimals !== undefined ? String(s.decimals) : undefined}
                        data-prefix={s.prefix} data-suffix={s.suffix}
                    >{s.prefix ?? ''}{s.valor}{s.suffix ?? ''}</span>
                    <span class="pp-stat-label">{s.label}</span>
                </div>
            ))}
        </section>

        <!-- ── BLOQUES ── -->
        <section class="pp-blocks">
            {page.blocks.map((b, i) => (
                <article class:list={['pp-block', { 'pp-block-flip': i % 2 === 1 }]}>
                    <div class="pp-block-text">
                        <p class="pp-eyebrow reveal">{b.eyebrow}</p>
                        <h2 class="pp-h2 masked-title" set:html={b.titulo} />
                        <p class="pp-copy reveal">{b.copy}</p>
                        <ul class="pp-bullets">
                            {b.bullets.map((bl) => (
                                <li class="reveal">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    <span set:html={bl} />
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="pp-block-visual" style="align-items: center; justify-content: center; padding: 0;">
                        <DevBlockMockup slug={page.slug} index={i} />
                    </div>
                </article>
            ))}
        </section>

        <!-- ── CÓMO FUNCIONA (pasos) ── -->
        <section class="dv-steps">
            <div class="dv-steps-head">
                <p class="pp-eyebrow reveal">EN TRES PASOS</p>
                <h2 class="pp-h2 masked-title">Listo en minutos,<br/>no en semanas.</h2>
            </div>
            <div class="dv-steps-list">
                {page.steps.map((s, i) => (
                    <div class="dv-step reveal">
                        <span class="dv-step-n editorial">{i + 1}</span>
                        <div>
                            <b>{s.titulo}</b>
                            <span>{s.copy}</span>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- ── CROSS-LINK (estilo lista, no cards) ── -->
        <section class="dv-more">
            <a href={`/desarrolladores/${otra.slug}`} class="dv-more-row reveal">
                <div>
                    <span class="dv-more-eyebrow">{otra.eyebrow}</span>
                    <b>{otra.nav}</b>
                    <i>{otra.sub.split('.')[0]}.</i>
                </div>
                <span class="dv-more-arrow">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
            </a>
        </section>
    </main>

    <Footer ctaTitle={page.cta.titulo.replace(/\. /, '.<br />')} ctaSub={page.cta.sub} />
    <PageAnims />
</Layout>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    window.addEventListener('load', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // Stats count-in (en reduced-motion las revela PageAnims vía .reveal)
        const stats = document.querySelectorAll('.pp-stat');
        if (stats.length && !reduced) {
            gsap.fromTo(stats,
                { opacity: 0, y: 20 },
                { opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out', scrollTrigger: { trigger: '.pp-stats', start: 'top 85%', once: true } }
            );
        }

        // ── Entrada limpia de los BlockMockups: fade + rise (igual al index/producto) ──
        if (!reduced) {
            document.querySelectorAll('.pp-block-visual').forEach((block) => {
                const stage = block.querySelector('.dbm-stage');
                if (!stage) return;
                const internals = block.querySelectorAll('.dbm-card, .dbm-terminal, .dbm-el-card, .dbm-floating:not(.dbm-story-pill)');
                const glow = block.querySelector('.dbm-glow');
                gsap.set(internals, { y: 28, opacity: 0 });
                if (glow) gsap.set(glow, { opacity: 0, scale: 0.6 });
                ScrollTrigger.create({ trigger: block, start: 'top 85%', once: true,
                    onEnter: () => {
                        gsap.to(internals, { y: 0, opacity: 1, duration: 0.9, ease: 'power3.out', stagger: 0.08, clearProps: 'transform' });
                        if (glow) gsap.to(glow, { opacity: 1, scale: 1, duration: 1.6, ease: 'power3.out' });
                    } });
            });
        }

        // En reduced-motion, deja visibles los estados que arrancan ocultos por CSS.
        if (reduced) {
            ['embedCard', 'elMini'].forEach((id) => document.getElementById(id)?.style.setProperty('opacity', '1'));
            ['embedSkel', 'elSkel'].forEach((id) => document.getElementById(id)?.style.setProperty('opacity', '0'));
            ['apiSyncRow1', 'apiSyncRow2'].forEach((id) => document.getElementById(id)?.style.setProperty('opacity', '1'));
            document.querySelectorAll('#mcpClientLog > div').forEach((d) => { (d as HTMLElement).style.opacity = '1'; });
        }

        // HERO API — request → response: la respuesta JSON entra en streaming y el status salta a 200 OK.
        const apiHero = document.querySelector('.dv-api');
        if (apiHero && !reduced) {
            const stat = document.getElementById('apiStat');
            const sending = document.getElementById('apiSending');
            const latency = document.getElementById('apiLatency');
            const lines = apiHero.querySelectorAll('.dv-api-res .dv-line');
            ScrollTrigger.create({ trigger: apiHero, start: 'top 82%', once: true,
                onEnter: () => {
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 2 });
                    const isEn = document.documentElement.lang === 'en';
                    tl.call(() => { if (stat) { stat.textContent = isEn ? 'sending...' : 'enviando…'; stat.classList.remove('dv-api-ok'); } })
                      .set(lines, { opacity: 0 })
                      .set(sending, { opacity: 1 })
                      .set(latency, { opacity: 0, y: 4 })
                      .to(sending, { opacity: 0.3, duration: 0.4, yoyo: true, repeat: 2, ease: 'sine.inOut' })
                      .to(lines, { opacity: 1, duration: 0.3, stagger: 0.11, ease: 'power1.out' })
                      .to(sending, { opacity: 0, duration: 0.25 }, '<')
                      .call(() => { if (stat) { stat.textContent = '200 OK'; stat.classList.add('dv-api-ok'); } })
                      .fromTo(stat, { scale: 0.82 }, { scale: 1, duration: 0.4, ease: 'back.out(1.8)' })
                      .to(latency, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }, '<')
                      .to({}, { duration: 1.8 });
                } });
        }

        // HERO MCP — loop bidireccional: la IA invoca, Cord consulta el CRM y el contexto regresa (4 pasos).
        const mcpHero = document.querySelector('.dv-mcp');
        if (mcpHero && !reduced) {
            const d1 = document.getElementById('mcpD1');
            const d2 = document.getElementById('mcpD2');
            const chip = document.getElementById('mcpChip1');
            const check = document.getElementById('mcpCheck');
            const cord = mcpHero.querySelector('.dv-node-cord');
            const steps = mcpHero.querySelectorAll('.dv-mcp-step');
            const setStep = (k) => steps.forEach((s, i) => s.classList.toggle('dv-step-on', i === k));
            ScrollTrigger.create({ trigger: mcpHero, start: 'top 80%', once: true,
                onEnter: () => {
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 1.2 });
                    tl.set([d1, d2], { left: '0%', opacity: 0 })
                      .set([chip, check], { opacity: 0, scale: 0.6 })
                      .call(() => { setStep(0); if (cord) cord.classList.remove('dv-node-active'); })
                      .to(chip, { opacity: 1, scale: 1, duration: 0.3, ease: 'back.out(1.6)' })
                      .to(d1, { opacity: 1, duration: 0.2 }, '<')
                      .to(d1, { left: '100%', duration: 0.7, ease: 'power1.inOut' })
                      .to(d1, { opacity: 0, duration: 0.2 })
                      .call(() => { if (cord) cord.classList.add('dv-node-active'); setStep(1); })
                      .to(d2, { opacity: 1, duration: 0.2 }, '+=0.15')
                      .to(d2, { left: '100%', duration: 0.7, ease: 'power1.inOut' })
                      .to(d2, { opacity: 0, duration: 0.2 })
                      .call(() => setStep(2))
                      .to(check, { opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(1.6)' })
                      .call(() => { setStep(3); if (cord) cord.classList.remove('dv-node-active'); }, undefined, '+=0.4')
                      .to([chip, check], { opacity: 0, duration: 0.4 }, '+=1')
                      .call(() => setStep(-1));
                } });
        }

        // HERO ELEMENTS — el embed monta (skeleton → tarjeta), el cliente aprueba y dispara cord:approved.
        const embedHero = document.querySelector('.dv-embed');
        if (embedHero && !reduced) {
            const skel = document.getElementById('embedSkel');
            const card = document.getElementById('embedCard');
            const badge = document.getElementById('embedBadge');
            const total = document.getElementById('embedTotal');
            const approve = document.getElementById('embedApprove');
            const cursor = document.getElementById('embedCursor');
            const evt = document.getElementById('embedEvent');
            if (skel) gsap.to(skel.querySelectorAll('span'), { backgroundPosition: '-200% 0', duration: 1.2, ease: 'none', repeat: -1 });
            ScrollTrigger.create({ trigger: embedHero, start: 'top 78%', once: true,
                onEnter: () => {
                    const obj = { v: 0 };
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 1.4 });
                    tl.set(card, { opacity: 0, y: 10 })
                      .set(skel, { opacity: 1 })
                      .set(cursor, { opacity: 0, x: 14, y: 16 })
                      .set(evt, { opacity: 0, y: 6 })
                      .call(() => { if (badge) { badge.textContent = document.documentElement.lang === 'en' ? '● Review' : '● Revisar'; badge.style.color = ''; badge.style.background = ''; } obj.v = 0; })
                      .to({}, { duration: 1 })
                      .to(skel, { opacity: 0, duration: 0.4 })
                      .to(card, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '<0.12')
                      .to(obj, { v: 196469.2, duration: 0.9, ease: 'power2.out', onUpdate: () => { if (total) total.textContent = '$' + obj.v.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); } }, '<')
                      .to(cursor, { opacity: 1, duration: 0.3 }, '+=0.3')
                      .to(cursor, { x: -34, y: 0, duration: 0.6, ease: 'power2.inOut' })
                      .to(approve, { scale: 0.96, duration: 0.1, yoyo: true, repeat: 1 })
                      .call(() => { if (badge) { badge.textContent = document.documentElement.lang === 'en' ? '● Approved' : '● Aprobada'; badge.style.color = '#10b981'; badge.style.background = 'rgba(16,185,129,0.12)'; } })
                      .fromTo(approve, { boxShadow: '0 0 0 0 rgba(16,185,129,0.5)' }, { boxShadow: '0 0 0 10px rgba(16,185,129,0)', duration: 0.8 })
                      .to(cursor, { opacity: 0, duration: 0.3 }, '<')
                      .fromTo(evt, { opacity: 0, y: 6 }, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }, '-=0.2')
                      .to({}, { duration: 1.8 });
                } });
        }

        // ───────────────────────── BLOCK MOCKUPS (motion graphics en loop) ─────────────────────────

        // API 0 — sync ERP ↔ Cord: el catálogo viaja a la derecha, el estado regresa a la izquierda.
        const apiB0 = document.querySelector('.dbm-api-m0');
        if (apiB0 && !reduced) {
            const dr = document.getElementById('apiSyncR');
            const dl = document.getElementById('apiSyncL');
            const row1 = document.getElementById('apiSyncRow1');
            const row2 = document.getElementById('apiSyncRow2');
            ScrollTrigger.create({ trigger: apiB0, start: 'top 85%', once: true,
                onEnter: () => {
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 1.6 });
                    tl.set(dr, { left: '0%', opacity: 0 })
                      .set(dl, { left: '100%', opacity: 0 })
                      .set([row1, row2], { opacity: 0, x: -6 })
                      .to(dr, { opacity: 1, duration: 0.2 })
                      .to(dr, { left: '100%', duration: 0.7, ease: 'power1.inOut' })
                      .to(dr, { opacity: 0, duration: 0.2 })
                      .to(row1, { opacity: 1, x: 0, duration: 0.4, ease: 'power2.out' }, '-=0.2')
                      .to(dl, { opacity: 1, duration: 0.2 }, '+=0.3')
                      .to(dl, { left: '0%', duration: 0.7, ease: 'power1.inOut' })
                      .to(dl, { opacity: 0, duration: 0.2 })
                      .to(row2, { opacity: 1, x: 0, duration: 0.4, ease: 'power2.out' }, '-=0.2')
                      .to({}, { duration: 1.4 });
                } });
        }

        // API 1 — una llave revocable: 200 OK → "Revocada" → 401 (loop).
        const apiB1 = document.querySelector('.dbm-api-m1');
        if (apiB1 && !reduced) {
            const key = document.getElementById('apiKey');
            const status = document.getElementById('apiAuthStatus');
            const revoke = apiB1.querySelector('.dbm-api1-revoke');
            ScrollTrigger.create({ trigger: apiB1, start: 'top 85%', once: true,
                onEnter: () => {
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 1.4 });
                    tl.set(revoke, { opacity: 0, scale: 0.6 })
                      .call(() => { if (key) key.classList.remove('dbm-key-revoked'); if (status) { status.textContent = '200 OK'; status.classList.remove('dbm-status-fail'); } })
                      .to({}, { duration: 1.4 })
                      .to(revoke, { opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(1.6)' })
                      .call(() => { if (key) key.classList.add('dbm-key-revoked'); })
                      .to({}, { duration: 0.3 })
                      .call(() => { if (status) { status.textContent = '401'; status.classList.add('dbm-status-fail'); } })
                      .fromTo(status, { scale: 0.85 }, { scale: 1, duration: 0.3, ease: 'back.out(1.8)' })
                      .to({}, { duration: 1.6 })
                      .to(revoke, { opacity: 0, duration: 0.3 });
                } });
        }

        // API 2 — los endpoints en JSON: el cuerpo y el total cambian por pestaña (loop).
        const apiB2 = document.querySelector('.dbm-api-m2');
        if (apiB2 && !reduced) {
            const tabs = apiB2.querySelectorAll('.dbm-api-tabs span');
            const pre = document.getElementById('apiJson');
            const code = pre ? pre.querySelector('code') : null;
            const totalEl = apiB2.querySelector('.dbm-meta-total');
            const snaps = [
                { body: '{\n  <span class="dbm-key">"folio"</span>: <span class="dbm-str">"COT-0149"</span>,\n  <span class="dbm-key">"status"</span>: <span class="dbm-str">"sent"</span>,\n  <span class="dbm-key">"total"</span>: <span class="dbm-num dbm-hl-target">196469.2</span>\n}', total: 'total 412' },
                { body: '{\n  <span class="dbm-key">"empresa"</span>: <span class="dbm-str">"El Zarco"</span>,\n  <span class="dbm-key">"rfc"</span>: <span class="dbm-str">"DEZ981123QX1"</span>,\n  <span class="dbm-key">"credito"</span>: <span class="dbm-num dbm-hl-target">500000</span>\n}', total: 'total 318' },
                { body: '{\n  <span class="dbm-key">"sku"</span>: <span class="dbm-str">"CEM-50"</span>,\n  <span class="dbm-key">"nombre"</span>: <span class="dbm-str">"Cemento gris"</span>,\n  <span class="dbm-key">"precio"</span>: <span class="dbm-num dbm-hl-target">182</span>\n}', total: 'total 412' },
                { body: '{\n  <span class="dbm-key">"vencido"</span>: <span class="dbm-num dbm-hl-target">412300</span>,\n  <span class="dbm-key">"dso"</span>: <span class="dbm-num">47</span>,\n  <span class="dbm-key">"exposicion"</span>: <span class="dbm-str">"alta"</span>\n}', total: 'aging 4' },
            ];
            let i = 0;
            ScrollTrigger.create({ trigger: apiB2, start: 'top 85%', once: true,
                onEnter: () => {
                    gsap.timeline({ repeat: -1, repeatDelay: 1 }).call(() => {
                        tabs.forEach((t, k) => t.classList.toggle('dbm-seg-on', k === i));
                        if (code) code.innerHTML = snaps[i].body;
                        if (totalEl) totalEl.textContent = snaps[i].total;
                        const hl = pre ? pre.querySelector('.dbm-hl-target') : null;
                        if (hl) gsap.fromTo(hl, { color: '#fcd34d' }, { color: '#34d399', duration: 0.5, yoyo: true, repeat: 1 });
                        i = (i + 1) % snaps.length;
                    }).to({}, { duration: 1.3 });
                } });
        }

        // MCP 0 — las 7 herramientas entran escalonadas + el transporte (HTTP/SSE) alterna.
        const mcpB0 = document.querySelector('.dbm-mcp-m0');
        if (mcpB0 && !reduced) {
            const rows = mcpB0.querySelectorAll('.dbm-toolrow');
            const t0 = document.getElementById('mcpT0');
            const t1 = document.getElementById('mcpT1');
            gsap.set(rows, { opacity: 0, x: -8 });
            ScrollTrigger.create({ trigger: mcpB0, start: 'top 88%', once: true,
                onEnter: () => {
                    gsap.to(rows, { opacity: 1, x: 0, stagger: 0.09, duration: 0.45, ease: 'power2.out' });
                    let on = 0;
                    gsap.timeline({ repeat: -1, repeatDelay: 1.6, delay: 1.6 }).call(() => {
                        on = on ? 0 : 1;
                        if (t0) t0.classList.toggle('dbm-seg-on', on === 0);
                        if (t1) t1.classList.toggle('dbm-seg-on', on === 1);
                    }).to({}, { duration: 1.6 });
                } });
        }

        // MCP 1 — Cord consulta el CRM: el dot cruza y el log se enciende (loop).
        const mcpB1 = document.querySelector('.dbm-mcp-m1');
        if (mcpB1 && !reduced) {
            const dot = document.getElementById('mcpClientDot');
            const logs = document.querySelectorAll('#mcpClientLog > div');
            ScrollTrigger.create({ trigger: mcpB1, start: 'top 85%', once: true,
                onEnter: () => {
                    gsap.timeline({ repeat: -1, repeatDelay: 1.6 })
                        .set(dot, { left: '0%', opacity: 0 })
                        .set(logs, { opacity: 0, y: 6 })
                        .to(dot, { opacity: 1, duration: 0.2 })
                        .to(dot, { left: '100%', duration: 0.8, ease: 'power1.inOut' })
                        .to(dot, { opacity: 0, duration: 0.2 })
                        .to(logs, { opacity: 1, y: 0, stagger: 0.28, duration: 0.4, ease: 'power2.out' }, '-=0.5')
                        .to({}, { duration: 1.4 });
                } });
        }

        // MCP 2 — gobernanza: el permiso del CRM externo alterna sin acceso ↔ permitido (loop).
        const mcpB2 = document.querySelector('.dbm-mcp-m2');
        if (mcpB2 && !reduced) {
            const pill = document.getElementById('mcpGovPill');
            ScrollTrigger.create({ trigger: mcpB2, start: 'top 85%', once: true,
                onEnter: () => {
                    if (!pill) return;
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 2.2 });
                    tl.call(() => { pill.textContent = 'sin acceso'; pill.classList.remove('dbm-gov-on'); pill.classList.add('dbm-gov-off'); })
                      .to({}, { duration: 1.2 })
                      .to(pill, { scale: 0.85, duration: 0.15, ease: 'power2.in' })
                      .call(() => { pill.textContent = 'permitido'; pill.classList.remove('dbm-gov-off'); pill.classList.add('dbm-gov-on'); })
                      .to(pill, { scale: 1, duration: 0.4, ease: 'back.out(1.8)' })
                      .to({}, { duration: 1.6 });
                } });
        }

        // Elements 0 — skeleton shimmer → mini tarjeta (loop).
        const elB0 = document.querySelector('.dbm-el-m0');
        if (elB0 && !reduced) {
            const skel = document.getElementById('elSkel');
            const mini = document.getElementById('elMini');
            if (skel) gsap.to(skel, { backgroundPosition: '-200% 0', duration: 1.2, ease: 'none', repeat: -1 });
            ScrollTrigger.create({ trigger: elB0, start: 'top 85%', once: true,
                onEnter: () => {
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 1.6 });
                    tl.set(skel, { opacity: 1 }).set(mini, { opacity: 0 })
                      .to({}, { duration: 1.1 })
                      .to(skel, { opacity: 0, duration: 0.3 })
                      .to(mini, { opacity: 1, duration: 0.4, ease: 'power2.out' }, '<')
                      .to({}, { duration: 1.4 });
                } });
        }

        // Elements 1 — pestañas que rotan + crossfade del snippet (loop).
        const elB1 = document.querySelector('.dbm-el-m1');
        if (elB1 && !reduced) {
            const tabs = elB1.querySelectorAll('.dbm-el-tabs span');
            const code = document.getElementById('elCode');
            const snippets = [
                '<span class="dbm-tag-lt">&lt;script src=</span><span class="dbm-str">"…/embed.js"</span><span class="dbm-tag-lt">&gt;</span>',
                '<span class="dbm-tag-lt">import</span> { CordCotizador } <span class="dbm-tag-lt">from</span> <span class="dbm-str">\'@flouviahq/elements/react\'</span>',
                '<span class="dbm-tag-lt">&lt;cord-cotizador</span> token=<span class="dbm-str">"…"</span><span class="dbm-tag-lt">&gt;</span>',
            ];
            let i = 0;
            ScrollTrigger.create({ trigger: elB1, start: 'top 85%', once: true,
                onEnter: () => {
                    gsap.timeline({ repeat: -1, repeatDelay: 1.4 }).call(() => {
                        tabs.forEach((t, k) => t.classList.toggle('dbm-seg-on', k === i));
                        if (code) { code.style.opacity = '0'; setTimeout(() => { code.innerHTML = snippets[i]; code.style.opacity = '1'; }, 180); }
                        i = (i + 1) % snippets.length;
                    }).to({}, { duration: 1.4 });
                } });
        }

        // Elements 2 — el cursor "clickea" Aprobar → "Aprobada" + dispara cord:approved (loop).
        const elB2 = document.querySelector('.dbm-el-m2');
        if (elB2 && !reduced) {
            const cursor = document.getElementById('elCursor');
            const approve = document.getElementById('elApprove');
            const badge = document.getElementById('elBadge');
            const evt = elB2.querySelector('.dbm-el2-event');
            ScrollTrigger.create({ trigger: elB2, start: 'top 85%', once: true,
                onEnter: () => {
                    const tl = gsap.timeline({ repeat: -1, repeatDelay: 1.8 });
                    tl.set(cursor, { x: 14, y: 16, opacity: 0 })
                      .set(evt, { opacity: 0, scale: 0.6 })
                      .call(() => { if (badge) { badge.textContent = document.documentElement.lang === 'en' ? 'Review' : 'Revisar'; badge.style.color = ''; badge.style.background = ''; } })
                      .to(cursor, { opacity: 1, duration: 0.3 })
                      .to(cursor, { x: 0, y: 0, duration: 0.6, ease: 'power2.inOut' })
                      .to(approve, { scale: 0.95, duration: 0.1, yoyo: true, repeat: 1 })
                      .call(() => { if (badge) { badge.textContent = document.documentElement.lang === 'en' ? 'Approved' : 'Aprobada'; badge.style.color = '#10b981'; badge.style.background = 'rgba(16,185,129,0.12)'; } })
                      .fromTo(approve, { boxShadow: '0 0 0 0 rgba(16,185,129,0.5)' }, { boxShadow: '0 0 0 8px rgba(16,185,129,0)', duration: 0.7 })
                      .to(cursor, { opacity: 0, duration: 0.3 }, '<')
                      .to(evt, { opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(1.6)' }, '-=0.2')
                      .to({}, { duration: 1.6 });
                } });
        }
    });
</script>

