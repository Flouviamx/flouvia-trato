---
// Clientes — directorio con términos y límite de crédito. CRUD real (Neon).
import AppLayout from '../../layouts/AppLayout.astro';
import { getClientes, getCotizaciones, money } from '../../lib/queries';

const [CLIENTES, COTIZACIONES] = await Promise.all([getClientes(), getCotizaciones()]);
const countQuotes = (empresa: string) => COTIZACIONES.filter(q => q.cliente === empresa).length;

const TERM_VALUE: Record<string, string> = { 'Contado': 'contado', 'Net 30': 'net30', 'Net 60': 'net60' };
const NIVEL_LABEL: Record<string, string> = { estandar: 'Estándar', plata: 'Plata', oro: 'Oro', distribuidor: 'Distribuidor' };
---

<AppLayout title="Clientes — Trato" page="clientes" heading="Clientes">
    <div slot="topbar-actions" class="topbar-btns">
        <button class="btn-import" id="btnImport">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            Importar CSV
        </button>
        <button class="btn-new" id="btnNew">+ Nuevo cliente</button>
    </div>

    <section class="dir">
        <div class="section-head">
            <h2>Directorio</h2>
            <span class="dir-count">{CLIENTES.length} {CLIENTES.length === 1 ? 'cliente' : 'clientes'}</span>
        </div>
        <div class="t-head">
            <span>Cliente</span><span>Contacto</span><span>RFC</span><span>Términos</span><span class="t-right">Límite de crédito</span><span class="t-right">Cotizaciones</span>
        </div>
        {CLIENTES.map((c) => (
            <button
                class="t-row"
                data-id={c.id}
                data-empresa={c.empresa}
                data-contacto={c.contacto}
                data-email={c.email}
                data-rfc={c.rfc}
                data-terminos={TERM_VALUE[c.terminos] ?? 'contado'}
                data-limite={c.limite > 0 ? String(c.limite) : ''}
                data-nivel={c.nivel}
                data-descuento={c.descuentoPct > 0 ? String(c.descuentoPct) : ''}
            >
                <span class="t-client">
                    <span class="t-avatar">{c.inicial}</span>{c.empresa}
                    {c.nivel !== 'estandar' && (
                        <span class:list={['tier-badge', `tier-${c.nivel}`]}>{NIVEL_LABEL[c.nivel]}{c.descuentoPct > 0 ? ` −${c.descuentoPct}%` : ''}</span>
                    )}
                </span>
                <span class="t-contact">{c.contacto}<small>{c.email}</small></span>
                <span class="t-muted">{c.rfc}</span>
                <span class="t-term">{c.terminos}</span>
                <span class="editorial t-amount t-right">{c.limite > 0 ? money(c.limite, 0) : '—'}</span>
                <span class="t-muted t-right">{countQuotes(c.empresa)}</span>
            </button>
        ))}
        {CLIENTES.length === 0 && (
            <p class="t-empty">Aún no tienes clientes. Crea el primero con "+ Nuevo cliente".</p>
        )}
    </section>

    <!-- Modal alta / edición -->
    <dialog class="modal" id="clientModal">
        <form method="dialog" class="m-form" id="clientForm">
            <div class="m-head">
                <h2 id="mTitle">Nuevo cliente</h2>
                <button type="button" class="m-close" id="mClose" aria-label="Cerrar">✕</button>
            </div>

            <div class="m-field">
                <label for="fEmpresa">Empresa *</label>
                <input class="m-input" id="fEmpresa" name="empresa" required placeholder="Distribuidora El Zarco" />
            </div>
            <div class="m-row">
                <div class="m-field">
                    <label for="fContacto">Contacto</label>
                    <input class="m-input" id="fContacto" name="contacto" placeholder="Raúl Mendoza" />
                </div>
                <div class="m-field">
                    <label for="fEmail">Correo</label>
                    <input class="m-input" id="fEmail" name="email" type="email" placeholder="compras@elzarco.mx" />
                </div>
            </div>
            <div class="m-row">
                <div class="m-field">
                    <label for="fRfc">RFC</label>
                    <input class="m-input" id="fRfc" name="rfc" placeholder="DEZ981123QX1" maxlength="13" />
                </div>
                <div class="m-field">
                    <label for="fLimite">Límite de crédito (MXN)</label>
                    <input class="m-input" id="fLimite" name="limite" type="number" min="0" step="1000" placeholder="500000" />
                </div>
            </div>
            <div class="m-row">
                <div class="m-field">
                    <label for="fNivel">Nivel de precio</label>
                    <select class="m-input" id="fNivel">
                        <option value="estandar">Estándar (precio de lista)</option>
                        <option value="plata">Plata</option>
                        <option value="oro">Oro</option>
                        <option value="distribuidor">Distribuidor</option>
                    </select>
                </div>
                <div class="m-field">
                    <label for="fDescuento">Descuento automático (%)</label>
                    <input class="m-input" id="fDescuento" type="number" min="0" max="100" step="1" placeholder="0" />
                </div>
            </div>
            <span class="m-hint">El descuento del nivel se aplica solo a las líneas al cotizarle a este cliente.</span>
            <div class="m-field">
                <label>Términos de pago</label>
                <div class="m-chips" id="fTerminos">
                    <button type="button" class="chip active" data-v="contado">Contado</button>
                    <button type="button" class="chip" data-v="net30">Net 30</button>
                    <button type="button" class="chip" data-v="net60">Net 60</button>
                </div>
            </div>

            <p class="m-error" id="mError"></p>

            <div class="m-actions">
                <button type="button" class="m-delete" id="mDelete">Eliminar</button>
                <span class="m-spacer"></span>
                <button type="button" class="m-cancel" id="mCancel">Cancelar</button>
                <button type="submit" class="m-save" id="mSave">Guardar cliente</button>
            </div>
        </form>
    </dialog>

    <!-- Modal de importación CSV -->
    <dialog class="modal modal-lg" id="importModal">
        <div class="m-form">
            <div class="m-head">
                <h2>Importar clientes por CSV</h2>
                <button type="button" class="m-close" id="impClose" aria-label="Cerrar">✕</button>
            </div>

            <div class="imp-step" id="impStepFile">
                <label class="imp-drop" id="impDrop">
                    <input type="file" id="impFile" accept=".csv,text/csv" hidden />
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M12 18v-6"/><path d="m9 15 3-3 3 3"/></svg>
                    <b>Arrastra tu archivo CSV o haz clic para elegirlo</b>
                    <span>Columnas sugeridas: empresa, contacto, email, teléfono, RFC, términos, límite</span>
                </label>
                <button type="button" class="imp-tpl" id="impTpl">↓ Descargar plantilla de ejemplo</button>
            </div>

            <div class="imp-step" id="impStepMap" hidden>
                <p class="imp-lead">Empareja las columnas de tu archivo con los campos de Trato.</p>
                <label class="imp-check"><input type="checkbox" id="impHeader" checked /> La primera fila son encabezados</label>
                <div class="imp-maps" id="impMaps"></div>
            </div>

            <div class="imp-step" id="impStepPrev" hidden>
                <div class="imp-summary" id="impSummary"></div>
                <label class="imp-check"><input type="checkbox" id="impUpsert" checked /> Actualizar clientes existentes (mismo RFC o nombre)</label>
                <div class="imp-prev-wrap"><table class="imp-prev"><thead id="impPrevHead"></thead><tbody id="impPrevBody"></tbody></table></div>
            </div>

            <p class="m-error" id="impError"></p>

            <div class="m-actions">
                <button type="button" class="m-cancel" id="impBack" hidden>← Atrás</button>
                <span class="m-spacer"></span>
                <button type="button" class="m-cancel" id="impCancel">Cancelar</button>
                <button type="button" class="m-save" id="impNext" disabled>Continuar</button>
            </div>
        </div>
    </dialog>
</AppLayout>

<style>
    .btn-new {
        font-family: var(--font-sans);
        background: var(--color-blue-deep); color: #fff;
        font-size: 0.82rem; font-weight: 600; border: none; cursor: pointer;
        padding: 9px 16px; border-radius: 9px;
        box-shadow: 0 6px 18px -8px rgba(10,25,47,0.5);
        transition: transform 0.4s var(--ease-spring);
    }
    .btn-new:hover { transform: translateY(-2px); }
    .topbar-btns { display: flex; gap: 0.6rem; align-items: center; }
    .btn-import {
        font-family: var(--font-sans); display: inline-flex; align-items: center; gap: 7px;
        background: var(--color-bg-soft); color: var(--color-text);
        font-size: 0.82rem; font-weight: 600; border: 1px solid var(--color-border); cursor: pointer;
        padding: 8px 14px; border-radius: 9px; transition: border-color 0.25s, transform 0.4s var(--ease-spring);
    }
    .btn-import svg { width: 14px; height: 14px; }
    .btn-import:hover { transform: translateY(-2px); border-color: rgba(10,25,47,0.25); }

    /* ── Modal importación ── */
    .modal-lg { width: min(700px, calc(100vw - 2rem)); }
    .imp-step { display: flex; flex-direction: column; gap: 0.9rem; }
    .imp-lead { font-size: 0.84rem; color: var(--color-text-muted); margin: 0; }
    .imp-drop {
        display: flex; flex-direction: column; align-items: center; gap: 0.5rem; text-align: center;
        border: 1.5px dashed var(--color-border); border-radius: 14px; padding: 2.4rem 1.5rem; cursor: pointer;
        background: var(--color-bg-soft); transition: border-color 0.25s, background 0.25s;
    }
    .imp-drop.drag, .imp-drop:hover { border-color: var(--color-blue-deep); background: rgba(10,25,47,0.03); }
    .imp-drop svg { width: 32px; height: 32px; color: var(--color-blue-deep); }
    .imp-drop b { font-size: 0.9rem; font-weight: 700; color: var(--color-text); }
    .imp-drop span { font-size: 0.76rem; color: var(--color-text-muted); }
    .imp-tpl { align-self: center; background: none; border: none; cursor: pointer; font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600; color: var(--color-blue-deep); }
    .imp-tpl:hover { text-decoration: underline; }
    .imp-check { display: flex; align-items: center; gap: 8px; font-size: 0.82rem; color: var(--color-text); cursor: pointer; }
    .imp-maps { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
    .imp-map { display: flex; flex-direction: column; gap: 0.35rem; }
    .imp-map label { font-size: 0.62rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; color: #99a2af; }
    .imp-map label .req { color: var(--color-danger); }
    .imp-map select { font-family: var(--font-sans); font-size: 0.84rem; color: var(--color-text); background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 9px; padding: 9px 10px; }
    .imp-map select:focus { outline: none; border-color: var(--color-blue-deep); }
    .imp-summary { display: flex; gap: 1.4rem; flex-wrap: wrap; background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 11px; padding: 0.9rem 1.1rem; }
    .imp-summary .is-num { font-size: 1.3rem; font-weight: 700; color: var(--color-blue-deep); letter-spacing: -0.5px; }
    .imp-summary .is-num.warn { color: var(--color-warn); }
    .imp-summary div { display: flex; flex-direction: column; }
    .imp-summary small { font-size: 0.68rem; color: var(--color-text-muted); }
    .imp-prev-wrap { max-height: 230px; overflow: auto; border: 1px solid var(--color-border); border-radius: 11px; }
    .imp-prev { width: 100%; border-collapse: collapse; font-size: 0.76rem; }
    .imp-prev th { position: sticky; top: 0; background: var(--color-bg-soft); text-align: left; font-size: 0.6rem; font-weight: 800; letter-spacing: 0.6px; text-transform: uppercase; color: #99a2af; padding: 8px 10px; border-bottom: 1px solid var(--color-border); }
    .imp-prev td { padding: 7px 10px; border-bottom: 1px solid var(--color-border); color: var(--color-text); white-space: nowrap; }
    .imp-prev td.n { text-align: right; font-variant-numeric: tabular-nums; }
    .imp-prev tr.bad td { background: rgba(239,68,68,0.05); color: var(--color-text-muted); }

    /* ── Directorio (plano editorial, sin caja) ── */
    .dir { margin-bottom: 2.6rem; }
    .section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.2rem; padding-bottom: 0.7rem; border-bottom: 1px solid var(--color-border); }
    .section-head h2 { font-size: 0.7rem; font-weight: 800; letter-spacing: 1.6px; text-transform: uppercase; color: #99a2af; margin: 0; }
    .dir-count { font-size: 0.78rem; font-weight: 600; color: var(--color-text-muted); }

    .t-head, .t-row {
        display: grid;
        grid-template-columns: 1.6fr 1.4fr 1fr 0.7fr 1fr 0.8fr;
        gap: 1rem; align-items: center;
        padding: 0.85rem 0.7rem;
    }
    .t-head {
        font-size: 0.65rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
        color: var(--color-text-muted); border-bottom: 1px solid var(--color-border);
        padding-top: 0; padding-bottom: 0.7rem;
    }
    .t-head > span:first-child, .t-row > :first-child { padding-left: 0; }
    .t-head > span:last-child, .t-row > :last-child { padding-right: 0; }
    .t-row {
        width: 100%; text-align: left;
        font-family: var(--font-sans); background: none; border: none; cursor: pointer;
        border-bottom: 1px solid var(--color-border);
        border-radius: 8px;
        transition: background 0.2s var(--ease-ios);
    }
    .t-row:hover { background: var(--color-bg-soft); }
    .t-row:last-of-type { border-bottom: none; }

    .t-client { display: flex; align-items: center; gap: 10px; font-size: 0.86rem; font-weight: 600; color: var(--color-text); }
    .t-avatar {
        width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
        background: var(--color-blue-deep); color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.62rem; font-weight: 800;
    }
    .t-contact { display: flex; flex-direction: column; font-size: 0.82rem; font-weight: 500; color: var(--color-text); }
    .t-contact small { font-size: 0.7rem; color: var(--color-text-muted); }
    .t-muted { font-size: 0.78rem; color: var(--color-text-muted); }
    .t-term { font-size: 0.74rem; font-weight: 700; color: var(--color-blue-deep); }
    .tier-badge { font-size: 0.58rem; font-weight: 800; letter-spacing: 0.3px; padding: 2px 8px; border-radius: 100px; margin-left: 8px; vertical-align: 1px; white-space: nowrap; }
    .tier-oro { color: #92600a; background: rgba(245,158,11,0.18); }
    .tier-plata { color: #475569; background: rgba(100,116,139,0.15); }
    .tier-distribuidor { color: #1e3a5f; background: rgba(10,25,47,0.1); }
    .m-hint { font-size: 0.7rem; color: var(--color-text-muted); margin: -0.3rem 0 0; }
    .t-amount { font-size: 0.95rem; color: var(--color-blue-deep); }
    .t-right { text-align: right; }
    .t-empty { padding: 2rem 0; font-size: 0.85rem; color: var(--color-text-muted); margin: 0; }

    /* ── Modal ── */
    .modal {
        border: none; border-radius: 18px; padding: 0;
        width: min(520px, calc(100vw - 2rem));
        box-shadow: 0 40px 90px -30px rgba(10,25,47,0.45);
    }
    .modal::backdrop { background: rgba(10,25,47,0.38); backdrop-filter: blur(4px); }
    .m-form { display: flex; flex-direction: column; gap: 0.95rem; padding: 1.5rem 1.6rem 1.4rem; }
    .m-head { display: flex; align-items: center; justify-content: space-between; }
    .m-head h2 { font-size: 1.05rem; font-weight: 700; margin: 0; letter-spacing: -0.3px; }
    .m-close {
        background: var(--color-bg-soft); border: 1px solid var(--color-border);
        width: 30px; height: 30px; border-radius: 9px; cursor: pointer;
        font-size: 0.8rem; color: var(--color-text-muted);
    }
    .m-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.95rem; }
    .m-field { display: flex; flex-direction: column; gap: 0.4rem; }
    .m-field label { font-size: 0.62rem; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; color: #99a2af; }
    .m-input {
        font-family: var(--font-sans); font-size: 0.88rem; font-weight: 500;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px;
        padding: 10px 12px; transition: border-color 0.25s;
    }
    .m-input:focus { outline: none; border-color: var(--color-blue-deep); }

    .m-chips { display: flex; gap: 0.5rem; }
    .chip {
        font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600;
        color: var(--color-text-muted); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 100px;
        padding: 7px 16px; cursor: pointer;
        transition: all 0.25s var(--ease-ios);
    }
    .chip.active { background: var(--color-blue-deep); color: #fff; border-color: var(--color-blue-deep); }

    .m-error { font-size: 0.78rem; color: var(--color-danger); margin: 0; min-height: 1em; }

    .m-actions { display: flex; align-items: center; gap: 0.6rem; }
    .m-spacer { flex: 1; }
    .m-delete {
        font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600;
        color: var(--color-danger); background: none; border: none; cursor: pointer;
        padding: 9px 4px;
    }
    .m-delete[hidden] { display: none; }
    .m-cancel {
        font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px;
        padding: 9px 16px; cursor: pointer;
    }
    .m-save {
        font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600;
        background: var(--color-blue-deep); color: #fff;
        border: none; border-radius: 9px; padding: 9px 18px; cursor: pointer;
        box-shadow: 0 6px 18px -8px rgba(10,25,47,0.5);
    }
    .m-save:disabled { opacity: 0.6; cursor: wait; }

    @media (max-width: 880px) {
        .t-head { display: none; }
        .t-row { grid-template-columns: 1fr auto; gap: 0.3rem 1rem; }
        .t-muted, .t-contact { display: none; }
        .m-row { grid-template-columns: 1fr; }
    }
</style>

<script>
    // CRUD de clientes contra /api/clientes. Click en fila = editar.
    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('clientModal') as HTMLDialogElement;
        const form = document.getElementById('clientForm') as HTMLFormElement;
        const title = document.getElementById('mTitle')!;
        const errorEl = document.getElementById('mError')!;
        const btnDelete = document.getElementById('mDelete') as HTMLButtonElement;
        const btnSave = document.getElementById('mSave') as HTMLButtonElement;
        const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('#fTerminos .chip'));

        let editId: string | null = null;
        let terminos = 'contado';

        const input = (id: string) => document.getElementById(id) as HTMLInputElement;
        const setTerm = (v: string) => {
            terminos = v;
            chips.forEach(c => c.classList.toggle('active', c.dataset.v === v));
        };

        const open = (data?: DOMStringMap) => {
            errorEl.textContent = '';
            editId = data?.id ?? null;
            title.textContent = editId ? 'Editar cliente' : 'Nuevo cliente';
            btnDelete.hidden = !editId;
            input('fEmpresa').value = data?.empresa ?? '';
            input('fContacto').value = data?.contacto ?? '';
            input('fEmail').value = data?.email ?? '';
            input('fRfc').value = data?.rfc ?? '';
            input('fLimite').value = data?.limite ?? '';
            input('fNivel').value = data?.nivel ?? 'estandar';
            input('fDescuento').value = data?.descuento ?? '';
            setTerm(data?.terminos ?? 'contado');
            modal.showModal();
        };

        document.getElementById('btnNew')?.addEventListener('click', () => open());
        document.querySelectorAll<HTMLElement>('.t-row[data-id]').forEach(row =>
            row.addEventListener('click', () => open(row.dataset)));
        document.getElementById('mClose')?.addEventListener('click', () => modal.close());
        document.getElementById('mCancel')?.addEventListener('click', () => modal.close());
        chips.forEach(c => c.addEventListener('click', () => setTerm(c.dataset.v!)));

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            btnSave.disabled = true;
            errorEl.textContent = '';
            const payload = {
                id: editId ?? undefined,
                empresa: input('fEmpresa').value,
                contacto: input('fContacto').value,
                email: input('fEmail').value,
                rfc: input('fRfc').value,
                terminos,
                limite: input('fLimite').value,
                nivel: input('fNivel').value,
                descuento_pct: input('fDescuento').value,
            };
            try {
                const res = await fetch('/api/clientes', {
                    method: editId ? 'PATCH' : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo guardar');
                location.reload();
            } catch (err: any) {
                errorEl.textContent = err.message;
                btnSave.disabled = false;
            }
        });

        btnDelete.addEventListener('click', async () => {
            if (!editId || !confirm('¿Eliminar este cliente? Sus cotizaciones se conservan.')) return;
            const res = await fetch('/api/clientes', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: editId }),
            });
            if (res.ok) location.reload();
            else errorEl.textContent = (await res.json()).error || 'No se pudo eliminar';
        });
    });
</script>

<script>
    // Importador CSV de clientes: archivo → mapeo → preview → carga masiva.
    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('importModal') as HTMLDialogElement | null;
        if (!modal) return;
        const $ = (id: string) => document.getElementById(id)!;
        const fileInput = $('impFile') as HTMLInputElement;
        const drop = $('impDrop');
        const stepFile = $('impStepFile'), stepMap = $('impStepMap'), stepPrev = $('impStepPrev');
        const headerChk = $('impHeader') as HTMLInputElement;
        const upsertChk = $('impUpsert') as HTMLInputElement;
        const mapsEl = $('impMaps');
        const errorEl = $('impError');
        const btnNext = $('impNext') as HTMLButtonElement;
        const btnBack = $('impBack') as HTMLButtonElement;

        const FIELDS = [
            { key: 'empresa', label: 'Empresa', req: true, guess: ['empresa', 'cliente', 'razon', 'nombre', 'company'] },
            { key: 'contacto', label: 'Contacto', req: false, guess: ['contacto', 'contact', 'atencion'] },
            { key: 'email', label: 'Correo', req: false, guess: ['email', 'correo', 'mail'] },
            { key: 'telefono', label: 'Teléfono', req: false, guess: ['telefono', 'tel', 'phone', 'celular', 'movil', 'whats'] },
            { key: 'rfc', label: 'RFC', req: false, guess: ['rfc'] },
            { key: 'terminos', label: 'Términos de pago', req: false, guess: ['terminos', 'term', 'pago', 'condicion'] },
            { key: 'limite', label: 'Límite de crédito', req: false, guess: ['limite', 'credito', 'limit', 'credit'] },
        ];

        let grid: string[][] = [];
        let step: 'file' | 'map' | 'prev' = 'file';
        let prepared: any[] = [];

        const norm = (s: string) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').trim();
        const parseNum = (v: string) => Number(String(v ?? '').replace(/[^0-9.\-]/g, '')) || 0;
        const TERM_LABEL: Record<string, string> = { contado: 'Contado', net30: 'Net 30', net60: 'Net 60' };
        const normTerm = (v: string) => {
            const s = norm(v);
            if (s.includes('60')) return 'net60';
            if (s.includes('30')) return 'net30';
            if (s.includes('net') || s.includes('credito')) return 'net30';
            return 'contado';
        };
        const money = (n: number) => '$' + new Intl.NumberFormat('es-MX').format(n);
        const esc = (s: string) => String(s ?? '').replace(/</g, '&lt;');

        function parseCSV(text: string): string[][] {
            const first = text.split(/\r?\n/)[0] || '';
            const counts: Record<string, number> = {
                ',': (first.match(/,/g) || []).length,
                ';': (first.match(/;/g) || []).length,
                '\t': (first.match(/\t/g) || []).length,
            };
            const delim = Object.entries(counts).sort((a, b) => b[1] - a[1])[0][0] || ',';
            const rows: string[][] = []; let row: string[] = []; let field = ''; let q = false; let i = 0;
            while (i < text.length) {
                const c = text[i];
                if (q) {
                    if (c === '"') { if (text[i + 1] === '"') { field += '"'; i += 2; continue; } q = false; i++; continue; }
                    field += c; i++; continue;
                }
                if (c === '"') { q = true; i++; continue; }
                if (c === delim) { row.push(field); field = ''; i++; continue; }
                if (c === '\n') { row.push(field); rows.push(row); row = []; field = ''; i++; continue; }
                if (c === '\r') { i++; continue; }
                field += c; i++;
            }
            if (field.length || row.length) { row.push(field); rows.push(row); }
            return rows.filter(r => r.some(c => c.trim() !== ''));
        }

        const showStep = (s: 'file' | 'map' | 'prev') => {
            step = s;
            stepFile.hidden = s !== 'file';
            stepMap.hidden = s !== 'map';
            stepPrev.hidden = s !== 'prev';
            btnBack.hidden = s === 'file';
            errorEl.textContent = '';
            if (s === 'file') { btnNext.disabled = true; btnNext.textContent = 'Continuar'; }
            if (s === 'map') { btnNext.disabled = false; btnNext.textContent = 'Continuar'; }
        };
        const ncols = () => grid.reduce((m, r) => Math.max(m, r.length), 0);

        function buildMaps() {
            const useHeader = headerChk.checked;
            const headers = useHeader ? (grid[0] || []) : [];
            const n = ncols();
            mapsEl.innerHTML = FIELDS.map(f => {
                let guessed = -1;
                if (useHeader) guessed = headers.findIndex(h => f.guess.some(g => norm(h).includes(g)));
                const opts = ['<option value="-1">— ninguna —</option>'];
                for (let i = 0; i < n; i++) {
                    const label = useHeader && headers[i] ? headers[i] : `Columna ${i + 1}`;
                    opts.push(`<option value="${i}" ${i === guessed ? 'selected' : ''}>${esc(label)}</option>`);
                }
                return `<div class="imp-map"><label>${f.label}${f.req ? ' <span class="req">*</span>' : ''}</label><select data-field="${f.key}">${opts.join('')}</select></div>`;
            }).join('');
        }
        const readMap = () => {
            const m: Record<string, number> = {};
            mapsEl.querySelectorAll<HTMLSelectElement>('select[data-field]').forEach(s => { m[s.dataset.field!] = parseInt(s.value, 10); });
            return m;
        };

        function buildPreview() {
            const m = readMap();
            if ((m.empresa ?? -1) < 0) { errorEl.textContent = 'Elige qué columna tiene el nombre de la empresa.'; return false; }
            const dataRows = headerChk.checked ? grid.slice(1) : grid;
            prepared = dataRows.map(r => ({
                empresa: (r[m.empresa] ?? '').trim(),
                contacto: m.contacto >= 0 ? (r[m.contacto] ?? '').trim() : '',
                email: m.email >= 0 ? (r[m.email] ?? '').trim() : '',
                telefono: m.telefono >= 0 ? (r[m.telefono] ?? '').trim() : '',
                rfc: m.rfc >= 0 ? (r[m.rfc] ?? '').trim().toUpperCase() : '',
                terminos: m.terminos >= 0 ? normTerm(r[m.terminos] ?? '') : 'contado',
                limite: m.limite >= 0 ? (String(r[m.limite] ?? '').trim() === '' ? '' : parseNum(r[m.limite])) : '',
            }));
            const valid = prepared.filter(p => p.empresa);
            const skipped = prepared.length - valid.length;

            $('impSummary').innerHTML =
                `<div><span class="is-num">${valid.length}</span><small>clientes a importar</small></div>` +
                (skipped > 0 ? `<div><span class="is-num warn">${skipped}</span><small>filas omitidas (sin empresa)</small></div>` : '');

            $('impPrevHead').innerHTML = '<tr><th>Empresa</th><th>Contacto</th><th>Email</th><th>RFC</th><th>Términos</th><th class="n">Límite</th></tr>';
            $('impPrevBody').innerHTML = prepared.slice(0, 8).map(p => {
                const bad = !p.empresa;
                return `<tr class="${bad ? 'bad' : ''}"><td>${esc(p.empresa || '—')}</td><td>${esc(p.contacto || '—')}</td><td>${esc(p.email || '—')}</td><td>${esc(p.rfc || '—')}</td><td>${TERM_LABEL[p.terminos]}</td><td class="n">${p.limite === '' ? '—' : money(p.limite)}</td></tr>`;
            }).join('');

            btnNext.textContent = `Importar ${valid.length} cliente${valid.length === 1 ? '' : 's'}`;
            btnNext.disabled = valid.length === 0;
            return true;
        }

        async function doImport() {
            const valid = prepared.filter(p => p.empresa);
            if (!valid.length) return;
            btnNext.disabled = true; btnNext.textContent = 'Importando…';
            try {
                const res = await fetch('/api/clientes/import', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ rows: valid, upsert: upsertChk.checked }),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo importar');
                location.reload();
            } catch (err: any) {
                errorEl.textContent = err.message;
                btnNext.disabled = false; btnNext.textContent = `Importar ${valid.length} clientes`;
            }
        }

        const loadFile = (file: File) => {
            const reader = new FileReader();
            reader.onload = () => {
                grid = parseCSV(String(reader.result));
                if (!grid.length) { errorEl.textContent = 'El archivo está vacío o no se pudo leer.'; return; }
                buildMaps();
                showStep('map');
            };
            reader.readAsText(file, 'utf-8');
        };

        document.getElementById('btnImport')?.addEventListener('click', () => { showStep('file'); modal.showModal(); });
        $('impClose').addEventListener('click', () => modal.close());
        $('impCancel').addEventListener('click', () => modal.close());
        fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });
        headerChk.addEventListener('change', buildMaps);
        drop.addEventListener('dragover', (e) => { e.preventDefault(); drop.classList.add('drag'); });
        drop.addEventListener('dragleave', () => drop.classList.remove('drag'));
        drop.addEventListener('drop', (e) => {
            e.preventDefault(); drop.classList.remove('drag');
            const f = (e as DragEvent).dataTransfer?.files?.[0];
            if (f) loadFile(f);
        });
        btnNext.addEventListener('click', () => {
            if (step === 'map') { if (buildPreview()) showStep('prev'); }
            else if (step === 'prev') doImport();
        });
        btnBack.addEventListener('click', () => {
            if (step === 'prev') { showStep('map'); btnNext.textContent = 'Continuar'; }
            else if (step === 'map') showStep('file');
        });
        $('impTpl').addEventListener('click', () => {
            const csv = 'empresa,contacto,email,telefono,rfc,terminos,limite\nDistribuidora El Zarco,Raul Mendoza,compras@elzarco.mx,55 1234 5678,DEZ981123QX1,net30,500000\nConstructora GAMA,Lucia Ferreira,lucia@gama.com.mx,55 8765 4321,CGA050617HJ8,net60,850000\n';
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = 'plantilla-clientes-trato.csv';
            a.click();
            URL.revokeObjectURL(a.href);
        });
    });
</script>
