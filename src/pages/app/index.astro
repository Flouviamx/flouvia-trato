---
// Dashboard — pipeline, monto por cerrar, actividad reciente. Datos reales (Neon).
import AppLayout from '../../layouts/AppLayout.astro';
import { getDashboard, getTareas, getCFO, getAnalytics, STATUS_META, money } from '../../lib/queries';

const [dash, TAREAS, CFO, ANALYTICS] = await Promise.all([getDashboard(), getTareas(), getCFO(), getAnalytics()]);
const { quotes: COTIZACIONES, porCerrar, cerradoMes, tasaCierre, abiertas, feed: eventosFeed } = dash;
const recientes = COTIZACIONES.slice(0, 5);
const aprobadasN = COTIZACIONES.filter(q => q.status === 'approved').length;
const pagadasN = COTIZACIONES.filter(q => q.status === 'paid').length;
const seguimiento = COTIZACIONES.filter(q => q.status === 'viewed').length;

// ── Datos para los widgets nuevos (Salud / Flujo / Silenciadas / Mix) ──
const { dso, concentracion, totalEsperado: ingresoEsperado } = CFO.kpis;
const semanas = CFO.semanas;
const maxSemana = CFO.maxSemana;
const silenciadas = CFO.silenciadas.slice(0, 5);
const dsoTone = dso <= 30 ? 'ok' : dso <= 60 ? 'warn' : 'danger';
const concTone = concentracion >= 70 ? 'danger' : concentracion >= 40 ? 'warn' : 'ok';
const clientesTasa = [...ANALYTICS.clientes].filter(c => c.cotizaciones > 0).sort((a, b) => b.tasa - a.tasa).slice(0, 5);
const topProductos = ANALYTICS.productos.slice(0, 5);
const maxProd = Math.max(1, ...topProductos.map(p => p.importe));

const dotColor = (tipo: string) =>
    tipo === 'approved' || tipo === 'paid' ? '#10b981'
    : tipo === 'viewed' ? '#7c3aed'
    : tipo === 'sent' ? '#3b82f6'
    : tipo === 'rejected' ? '#ef4444'
    : '#cbd5e1';
---

<AppLayout title="Dashboard — Cord" page="dashboard" heading="Dashboard">
    <!-- KPIs -->
    <section class="kpis">
        <div class="kpi">
            <span class="kpi-label">POR CERRAR</span>
            <span class="editorial kpi-num" data-countup={porCerrar.toFixed(2)}>{money(porCerrar)}</span>
            <span class="kpi-sub">{abiertas} cotizaciones activas</span>
        </div>
        <div class="kpi">
            <span class="kpi-label">CERRADO ESTE MES</span>
            <span class="editorial kpi-num kpi-ok" data-countup={cerradoMes.toFixed(2)}>{money(cerradoMes)}</span>
            <span class="kpi-sub">{aprobadasN} aprobadas · {pagadasN} pagada{pagadasN === 1 ? '' : 's'}</span>
        </div>
        <div class="kpi">
            <span class="kpi-label">TASA DE CIERRE</span>
            <span class="editorial kpi-num">{tasaCierre}<span class="kpi-pct">%</span></span>
            <span class="kpi-sub">últimos 90 días</span>
        </div>
        <a class="kpi kpi-link" href="/app/cotizaciones">
            <span class="kpi-label">POR DAR SEGUIMIENTO</span>
            <span class:list={['editorial', 'kpi-num', { 'kpi-warn': seguimiento > 0 }]}>{seguimiento}</span>
            <span class="kpi-sub">{seguimiento === 1 ? 'cotización vista' : 'cotizaciones vistas'}, sin responder</span>
        </a>
    </section>

    <!-- Salud del pipeline (DSO · concentración · ingreso esperado) -->
    <section class="health">
        <div class="section-head">
            <h2>Salud del pipeline</h2>
            <a href="/app/cfo" class="see-all">Ver CFO →</a>
        </div>
        <div class="health-grid">
            <div class="health-cell">
                <span class="health-label">DÍAS PROMEDIO DE COBRO (DSO)</span>
                <span class:list={['editorial', 'health-num', `h-${dsoTone}`]}>{dso}<span class="health-unit">d</span></span>
                <span class="health-sub"><span class:list={['health-dot', `h-${dsoTone}`]}></span>{dsoTone === 'ok' ? 'Saludable' : dsoTone === 'warn' ? 'Vigilar' : 'Alto — acelerar cobro'}</span>
            </div>
            <div class="health-cell">
                <span class="health-label">CONCENTRACIÓN DE RIESGO</span>
                <span class:list={['editorial', 'health-num', `h-${concTone}`]}>{concentracion}<span class="health-unit">%</span></span>
                <span class="health-sub"><span class:list={['health-dot', `h-${concTone}`]}></span>{concentracion >= 70 ? 'Top cliente domina el pipeline' : concentracion >= 40 ? 'Moderada' : 'Bien diversificado'}</span>
            </div>
            <div class="health-cell">
                <span class="health-label">INGRESO ESPERADO (PONDERADO)</span>
                <span class="editorial health-num">{money(ingresoEsperado, 0)}</span>
                <span class="health-sub">de {money(CFO.kpis.totalPipeline, 0)} en pipeline abierto</span>
            </div>
        </div>
    </section>

    <!-- Pipeline -->
    <section class="pipeline">
        <div class="section-head">
            <h2>Pipeline</h2>
            <a href="/app/cotizaciones" class="see-all">Ver todas →</a>
        </div>
        <div class="pipe-row">
            {(['draft', 'sent', 'viewed', 'approved', 'paid'] as const).map((st) => {
                const qs = COTIZACIONES.filter(q => q.status === st);
                const total = qs.reduce((s, q) => s + (q.total ?? 0), 0);
                return (
                    <div class="pipe-col">
                        <div class="pipe-head" style={`color:${STATUS_META[st].color}`}>
                            <span class="pipe-dot" style={`background:${STATUS_META[st].color}`}></span>
                            {STATUS_META[st].label}
                            <span class="pipe-count">{qs.length}</span>
                        </div>
                        <span class="editorial pipe-total">{total > 0 ? money(total, 0) : '—'}</span>
                    </div>
                );
            })}
        </div>
    </section>

    <!-- Flujo esperado (5 semanas) + Necesitan seguimiento -->
    <div class="two-col two-col-flow">
        <section class="flow-card">
            <div class="section-head">
                <h2>Flujo esperado · 5 semanas</h2>
                <a href="/app/tesoreria/flujo" class="see-all">Tesorería →</a>
            </div>
            <div class="flow-bars">
                {semanas.map((s) => (
                    <div class="flow-col">
                        <span class="editorial flow-amount">{s.valorEsperado > 0 ? money(s.valorEsperado, 0) : '—'}</span>
                        <div class="flow-track">
                            <div class="flow-fill" style={`height:${Math.max(s.valorEsperado > 0 ? 6 : 0, Math.round((s.valorEsperado / maxSemana) * 100))}%`}></div>
                        </div>
                        <span class="flow-label">{s.label.replace('semana', 'sem')}</span>
                        <span class="flow-n">{s.n > 0 ? `${s.n} cot.` : ''}</span>
                    </div>
                ))}
            </div>
        </section>

        <section class="silence-card">
            <div class="section-head">
                <h2>Necesitan seguimiento</h2>
                {silenciadas.length > 0 && <span class="silence-count">{CFO.kpis.nSilenciadas}</span>}
            </div>
            {silenciadas.length > 0 ? (
                <div class="silence-list">
                    {silenciadas.map((s) => (
                        <a href={`/app/cotizaciones/${s.id}`} class="silence-row">
                            <div class="silence-info">
                                <span class="silence-folio">{s.folio}</span>
                                <span class="silence-client">{s.empresa}</span>
                            </div>
                            <span class="silence-days">{s.dias}d sin respuesta</span>
                            <span class="editorial silence-total">{money(s.total, 0)}</span>
                            <span class="silence-go">→</span>
                        </a>
                    ))}
                </div>
            ) : (
                <div class="silence-empty">
                    <span class="silence-empty-ico">✓</span>
                    <p>Sin cotizaciones silenciadas. Todo tu pipeline está activo.</p>
                </div>
            )}
        </section>
    </div>

    <div class="two-col">
        <!-- Cotizaciones recientes -->
        <section class="list-card">
            <div class="section-head">
                <h2>Recientes</h2>
                <a href="/app/cotizaciones" class="see-all">Ver todas →</a>
            </div>
            <div class="quote-list">
                {recientes.map((q) => (
                    <a href={`/app/cotizaciones/${q.id}`} class="quote-row">
                        <div class="qr-avatar">{q.clienteInicial}</div>
                        <div class="qr-info">
                            <span class="qr-folio">{q.folio}</span>
                            <span class="qr-client">{q.cliente}</span>
                        </div>
                        <span class="editorial qr-amount">{money(q.total ?? 0, 0)}</span>
                        <span class="status-pill" style={`color:${STATUS_META[q.status].color}; background:${STATUS_META[q.status].bg}`}>
                            {STATUS_META[q.status].label}
                        </span>
                    </a>
                ))}
            </div>
        </section>

        <!-- Actividad -->
        <section class="activity-card">
            <div class="section-head"><h2>Actividad</h2></div>
            <div class="feed">
                {eventosFeed.map((e) => (
                    <a href={`/app/cotizaciones/${e.id}`} class="feed-item">
                        <span class="feed-dot" style={`background:${dotColor(e.tipo)}`}></span>
                        <div class="feed-body">
                            <span class="feed-text">{e.detalle}</span>
                            <span class="feed-meta">{e.folio} · {e.cuando}</span>
                        </div>
                    </a>
                ))}
            </div>
        </section>
    </div>

    <!-- Mix: clientes por tasa de aprobación + productos por ingreso -->
    <div class="two-col two-col-even">
        <section class="rank-card">
            <div class="section-head"><h2>Clientes por tasa de aprobación</h2></div>
            {clientesTasa.length > 0 ? (
                <div class="rank-list">
                    {clientesTasa.map((c) => (
                        <div class="rank-row">
                            <span class="rank-name">{c.empresa}</span>
                            <div class="rank-track"><div class="rank-fill" style={`width:${c.tasa}%`}></div></div>
                            <span class="editorial rank-val">{c.tasa}%</span>
                        </div>
                    ))}
                </div>
            ) : <p class="rank-empty">Aún no hay historial suficiente.</p>}
        </section>

        <section class="rank-card">
            <div class="section-head"><h2>Productos por ingreso</h2></div>
            {topProductos.length > 0 ? (
                <div class="rank-list">
                    {topProductos.map((p) => (
                        <div class="rank-row">
                            <span class="rank-name">{p.nombre}</span>
                            <div class="rank-track"><div class="rank-fill rank-fill-ok" style={`width:${Math.max(4, Math.round((p.importe / maxProd) * 100))}%`}></div></div>
                            <span class="editorial rank-val">{money(p.importe, 0)}</span>
                        </div>
                    ))}
                </div>
            ) : <p class="rank-empty">Aún no hay productos cotizados.</p>}
        </section>
    </div>

    <!-- Tareas / recordatorios -->
    <section class="tasks-card">
        <div class="section-head"><h2>Tareas y recordatorios</h2></div>
        <form class="task-add" id="taskAdd">
            <input id="taskTitulo" class="task-input" placeholder="Ej. Llamar a GAMA para dar seguimiento…" autocomplete="off" required />
            <input id="taskDue" class="task-date" type="date" aria-label="Fecha límite" />
            <button class="task-btn" type="submit">Agregar</button>
        </form>
        <div class="task-list" id="taskList">
            {TAREAS.map((t) => (
                <div class="task-row" data-id={t.id}>
                    <button class="task-check" data-done aria-label="Marcar completada"></button>
                    <div class="task-body">
                        <span class="task-title">{t.titulo}</span>
                        {(t.folio || t.due) && <span class="task-meta">{[t.folio, t.due].filter(Boolean).join(' · ')}</span>}
                    </div>
                    {t.vencida && <span class="task-overdue">vencida</span>}
                    <button class="task-del" data-del aria-label="Eliminar">×</button>
                </div>
            ))}
            <p class="task-empty" id="taskEmpty" hidden={TAREAS.length > 0}>Sin pendientes. Agrega un recordatorio arriba.</p>
        </div>
    </section>
</AppLayout>

<style>
    .kpis {
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;
        margin-bottom: 2.6rem;
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
    }
    .kpi {
        padding: 1.5rem 1.7rem; display: flex; flex-direction: column; gap: 0.45rem;
        border-left: 1px solid var(--color-border);
    }
    .kpi:first-child { border-left: none; padding-left: 0; }
    .kpi-link { text-decoration: none; transition: background 0.3s var(--ease-ios); }
    .kpi-link:hover { background: var(--color-bg-soft); }
    .kpi-label { font-size: 0.6rem; font-weight: 800; letter-spacing: 1.6px; color: #99a2af; }
    .kpi-num { font-size: 2.1rem; color: var(--color-blue-deep); line-height: 1; font-variant-numeric: tabular-nums; }
    .kpi-ok { color: #059669; }
    .kpi-warn { color: var(--color-warn); }
    .kpi-pct { font-size: 1.3rem; }
    .kpi-sub { font-size: 0.78rem; color: var(--color-text-muted); }

    .pipeline { margin-bottom: 2.6rem; }
    .section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.2rem; padding-bottom: 0.7rem; border-bottom: 1px solid var(--color-border); }
    .section-head h2 { font-size: 0.7rem; font-weight: 800; letter-spacing: 1.6px; text-transform: uppercase; color: #99a2af; margin: 0; }
    .see-all { font-size: 0.78rem; font-weight: 600; color: var(--color-text-muted); text-decoration: none; transition: color 0.25s; }
    .see-all:hover { color: var(--color-blue-deep); }

    .pipe-row { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.8rem; }
    .pipe-col {
        padding: 0.2rem 0 0.2rem 1rem;
        border-left: 1px solid var(--color-border);
        display: flex; flex-direction: column; gap: 0.5rem;
    }
    .pipe-col:first-child { border-left: none; padding-left: 0; }
    .pipe-head { display: flex; align-items: center; gap: 7px; font-size: 0.72rem; font-weight: 700; }
    .pipe-dot { width: 7px; height: 7px; border-radius: 50%; }
    .pipe-count { margin-left: auto; font-size: 0.68rem; color: var(--color-text-muted); font-weight: 600; }
    .pipe-total { font-size: 1.15rem; color: var(--color-blue-deep); }

    .two-col { display: grid; grid-template-columns: 1.6fr 1fr; gap: 2.6rem; margin-bottom: 2.6rem; }

    .quote-list { display: flex; flex-direction: column; }
    .quote-row {
        display: grid; grid-template-columns: auto 1fr auto auto;
        align-items: center; gap: 1rem;
        padding: 0.8rem 0.6rem; margin: 0;
        border-radius: 10px; text-decoration: none;
        transition: background 0.25s var(--ease-ios);
    }
    .quote-row:hover { background: var(--color-bg-soft); }
    .quote-row + .quote-row { border-top: 1px solid var(--color-border); }
    .qr-avatar {
        width: 34px; height: 34px; border-radius: 9px;
        background: var(--color-blue-deep); color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.7rem; font-weight: 800;
    }
    .qr-info { display: flex; flex-direction: column; min-width: 0; }
    .qr-folio { font-size: 0.84rem; font-weight: 700; color: var(--color-text); }
    .qr-client { font-size: 0.75rem; color: var(--color-text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .qr-amount { font-size: 1.02rem; color: var(--color-blue-deep); }

    .feed { display: flex; flex-direction: column; gap: 0.15rem; }
    .feed-item {
        display: flex; gap: 11px; align-items: flex-start;
        padding: 0.55rem 0.6rem; margin: 0;
        border-radius: 9px; text-decoration: none;
        transition: background 0.25s var(--ease-ios);
    }
    .feed-item:hover { background: var(--color-bg-soft); }
    .feed-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 5px; flex-shrink: 0; }
    .feed-body { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
    .feed-text { font-size: 0.8rem; color: var(--color-text); font-weight: 500; }
    .feed-meta { font-size: 0.68rem; color: var(--color-text-muted); }

    /* ── Salud del pipeline ── */
    .health { margin-bottom: 2.6rem; }
    .health-grid {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 0;
        border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);
    }
    .health-cell { padding: 1.3rem 1.6rem; display: flex; flex-direction: column; gap: 0.4rem; border-left: 1px solid var(--color-border); }
    .health-cell:first-child { border-left: none; padding-left: 0; }
    .health-label { font-size: 0.6rem; font-weight: 800; letter-spacing: 1.4px; color: #99a2af; }
    .health-num { font-size: 1.9rem; color: var(--color-blue-deep); line-height: 1; font-variant-numeric: tabular-nums; }
    .health-num.h-ok { color: #059669; } .health-num.h-warn { color: #d97706; } .health-num.h-danger { color: var(--color-danger); }
    .health-unit { font-size: 1.1rem; margin-left: 1px; }
    .health-sub { display: flex; align-items: center; gap: 6px; font-size: 0.76rem; color: var(--color-text-muted); }
    .health-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; background: #cbd5e1; }
    .health-dot.h-ok { background: var(--color-ok); } .health-dot.h-warn { background: var(--color-warn); } .health-dot.h-danger { background: var(--color-danger); }

    /* ── Flujo esperado (mini bar chart) ── */
    .two-col-flow { grid-template-columns: 1.15fr 1fr; }
    .flow-bars { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.7rem; align-items: end; }
    .flow-col { display: flex; flex-direction: column; align-items: center; gap: 0.4rem; justify-content: flex-end; text-align: center; }
    .flow-amount { font-size: 0.74rem; color: var(--color-blue-deep); white-space: nowrap; }
    .flow-track { width: 60%; max-width: 34px; height: 130px; display: flex; align-items: flex-end; background: var(--color-bg-soft); border-radius: 7px; overflow: hidden; }
    .flow-fill { width: 100%; background: linear-gradient(180deg, #1d4ed8, #0a192f); border-radius: 7px 7px 0 0; min-height: 4px; transition: height 0.7s var(--ease-spring); }
    .flow-label { font-size: 0.64rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.3px; }
    .flow-n { font-size: 0.64rem; color: #aab2bd; min-height: 0.8em; }

    /* ── Necesitan seguimiento (silenciadas) ── */
    .silence-count { font-size: 0.62rem; font-weight: 800; color: #fff; background: var(--color-warn); border-radius: 100px; min-width: 20px; height: 20px; padding: 0 6px; display: inline-flex; align-items: center; justify-content: center; }
    .silence-list { display: flex; flex-direction: column; }
    .silence-row { display: grid; grid-template-columns: 1fr auto auto auto; align-items: center; gap: 0.8rem; padding: 0.7rem 0.5rem; border-radius: 10px; text-decoration: none; transition: background 0.25s var(--ease-ios); }
    .silence-row:hover { background: var(--color-bg-soft); }
    .silence-row + .silence-row { border-top: 1px solid var(--color-border); }
    .silence-info { display: flex; flex-direction: column; min-width: 0; }
    .silence-folio { font-size: 0.82rem; font-weight: 700; color: var(--color-text); }
    .silence-client { font-size: 0.74rem; color: var(--color-text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .silence-days { font-size: 0.66rem; font-weight: 700; color: #b45309; background: rgba(245,158,11,0.12); padding: 3px 8px; border-radius: 100px; white-space: nowrap; }
    .silence-total { font-size: 0.92rem; color: var(--color-blue-deep); }
    .silence-go { color: #c3c9d2; font-weight: 700; transition: transform 0.25s var(--ease-spring), color 0.25s; }
    .silence-row:hover .silence-go { transform: translateX(3px); color: var(--color-blue-deep); }
    .silence-empty { display: flex; align-items: center; gap: 12px; padding: 1.4rem 0.4rem; }
    .silence-empty-ico { width: 30px; height: 30px; flex-shrink: 0; border-radius: 50%; background: rgba(16,185,129,0.12); color: var(--color-ok); display: flex; align-items: center; justify-content: center; font-weight: 800; }
    .silence-empty p { margin: 0; font-size: 0.82rem; color: var(--color-text-muted); }

    /* ── Rankings (mix clientes/productos) ── */
    .two-col-even { grid-template-columns: 1fr 1fr; }
    .rank-list { display: flex; flex-direction: column; gap: 0.7rem; }
    .rank-row { display: grid; grid-template-columns: minmax(0, 1.1fr) 1.4fr auto; align-items: center; gap: 0.8rem; }
    .rank-name { font-size: 0.8rem; font-weight: 550; color: var(--color-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .rank-track { height: 8px; background: var(--color-bg-soft); border-radius: 100px; overflow: hidden; }
    .rank-fill { height: 100%; border-radius: 100px; background: linear-gradient(90deg, #1d4ed8, #0a192f); min-width: 4px; transition: width 0.7s var(--ease-spring); }
    .rank-fill-ok { background: linear-gradient(90deg, #10b981, #059669); }
    .rank-val { font-size: 0.82rem; color: var(--color-blue-deep); font-variant-numeric: tabular-nums; white-space: nowrap; }
    .rank-empty { font-size: 0.82rem; color: var(--color-text-muted); margin: 0.4rem 0; }

    @media (max-width: 1080px) {
        .health-grid { grid-template-columns: 1fr; }
        .health-cell { border-left: none; padding-left: 0; }
        .health-cell + .health-cell { border-top: 1px solid var(--color-border); }
        .two-col-flow, .two-col-even { grid-template-columns: 1fr; }
    }

    /* Tareas / recordatorios */
    .tasks-card { margin-top: 0; }
    .task-add { display: flex; gap: 0.6rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .task-input { flex: 1; min-width: 180px; font-family: var(--font-sans); font-size: 0.85rem; color: var(--color-text); background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 9px; padding: 9px 12px; }
    .task-input:focus, .task-date:focus { outline: none; border-color: var(--color-blue-deep); }
    .task-date { font-family: var(--font-sans); font-size: 0.82rem; color: var(--color-text); background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 9px; padding: 9px 10px; }
    .task-btn { font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600; color: #fff; background: var(--color-blue-deep); border: none; border-radius: 9px; padding: 9px 16px; cursor: pointer; transition: transform 0.3s var(--ease-spring); }
    .task-btn:hover { transform: translateY(-2px); }
    .task-list { display: flex; flex-direction: column; }
    .task-row { display: flex; align-items: center; gap: 11px; padding: 0.65rem 0; border-bottom: 1px solid var(--color-border); }
    .task-row:last-of-type { border-bottom: none; }
    .task-check { width: 19px; height: 19px; flex-shrink: 0; border: 1.8px solid var(--color-border); border-radius: 6px; background: var(--surface); cursor: pointer; transition: border-color 0.2s, background 0.2s; }
    .task-check:hover { border-color: var(--color-ok); background: rgba(16,185,129,0.08); }
    .task-body { display: flex; flex-direction: column; min-width: 0; flex: 1; }
    .task-title { font-size: 0.85rem; font-weight: 500; color: var(--color-text); }
    .task-meta { font-size: 0.7rem; color: var(--color-text-muted); }
    .task-overdue { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.4px; text-transform: uppercase; color: var(--color-danger); background: rgba(239,68,68,0.1); padding: 3px 8px; border-radius: 100px; flex-shrink: 0; }
    .task-del { background: none; border: none; cursor: pointer; color: #c3c9d2; font-size: 1.1rem; line-height: 1; padding: 2px 6px; border-radius: 6px; transition: color 0.2s, background 0.2s; }
    .task-del:hover { color: var(--color-danger); background: rgba(239,68,68,0.07); }
    .task-empty { font-size: 0.82rem; color: var(--color-text-muted); margin: 0.6rem 0; }

    @media (max-width: 1080px) {
        .kpis { grid-template-columns: repeat(2, 1fr); }
        .kpi:nth-child(odd) { border-left: none; padding-left: 0; }
        .kpi:nth-child(3), .kpi:nth-child(4) { border-top: 1px solid var(--color-border); }
        .pipe-row { grid-template-columns: repeat(3, 1fr); }
        .two-col { grid-template-columns: 1fr; gap: 2.2rem; }
    }
    @media (max-width: 680px) {
        .kpis { grid-template-columns: 1fr; }
        .kpi { border-left: none; padding-left: 0; border-top: 1px solid var(--color-border); }
        .kpi:first-child { border-top: none; }
        .pipe-row { grid-template-columns: repeat(2, 1fr); }
        .quote-row { grid-template-columns: auto 1fr auto; }
        .quote-row .status-pill { display: none; }
        /* Alta de tareas: apilar para que el campo de fecha se vea completo (no un hueco blanco) */
        .task-add { flex-direction: column; align-items: stretch; }
        .task-input, .task-date, .task-btn { width: 100%; min-width: 0; }
        .task-date { min-height: 44px; }
    }
</style>

<script>
    // Count-up ligero de los KPIs (vanilla, sin GSAP — la app no carga GSAP)
    document.addEventListener('DOMContentLoaded', () => {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const fmt = (n: number) => '$' + new Intl.NumberFormat('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
        document.querySelectorAll<HTMLElement>('[data-countup]').forEach((el) => {
            const target = parseFloat(el.dataset.countup || '0');
            const t0 = performance.now();
            const dur = 1100;
            const tick = (t: number) => {
                const p = Math.min((t - t0) / dur, 1);
                const eased = 1 - Math.pow(1 - p, 3);
                el.textContent = fmt(target * eased);
                if (p < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
        });
    });
</script>

<script>
    // ── Tareas / recordatorios ──
    document.getElementById('taskAdd')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const tEl = document.getElementById('taskTitulo') as HTMLInputElement;
        const dEl = document.getElementById('taskDue') as HTMLInputElement;
        const titulo = tEl.value.trim();
        if (!titulo) return;
        try {
            const res = await fetch('/api/tareas', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ titulo, due_date: dEl.value || null }) });
            if (!res.ok) throw new Error();
            location.reload();
        } catch { /* noop */ }
    });
    document.querySelectorAll<HTMLElement>('.task-row').forEach((row) => {
        const id = row.dataset.id;
        row.querySelector('[data-done]')?.addEventListener('click', async () => {
            await fetch('/api/tareas', { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, done: true }) }).catch(() => {});
            row.remove();
        });
        row.querySelector('[data-del]')?.addEventListener('click', async () => {
            await fetch('/api/tareas', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) }).catch(() => {});
            row.remove();
        });
    });
</script>
