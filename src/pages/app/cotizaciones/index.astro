---
// Lista de cotizaciones — tabla con filtros por estado (client-side sobre mock).
import AppLayout from '../../../layouts/AppLayout.astro';
import { COTIZACIONES, STATUS_META, money, quoteTotal } from '../../../lib/mock';

const FILTERS = [
    { key: 'all',      label: 'Todas' },
    { key: 'open',     label: 'Abiertas' },
    { key: 'approved', label: 'Aprobadas' },
    { key: 'paid',     label: 'Pagadas' },
    { key: 'closed',   label: 'Cerradas' },
];
const groupOf = (s: string) =>
    ['sent', 'viewed', 'draft'].includes(s) ? 'open'
    : s === 'approved' ? 'approved'
    : s === 'paid' || s === 'invoiced' ? 'paid'
    : 'closed';
---

<AppLayout title="Cotizaciones — Trato" page="cotizaciones" heading="Cotizaciones">
    <a slot="topbar-actions" href="/app/cotizaciones/nueva" class="btn-new">+ Nueva cotización</a>

    <div class="filters" id="filters">
        {FILTERS.map((f, i) => (
            <button class:list={['filter-pill', { active: i === 0 }]} data-filter={f.key}>{f.label}</button>
        ))}
    </div>

    <section class="card table-card">
        <div class="t-head">
            <span>Cotización</span><span>Cliente</span><span>Términos</span><span>Vigencia</span><span class="t-right">Total</span><span>Estado</span>
        </div>
        {COTIZACIONES.map((q) => (
            <a href={`/app/cotizaciones/${q.id}`} class="t-row" data-group={groupOf(q.status)}>
                <span class="t-folio">{q.folio}</span>
                <span class="t-client">
                    <span class="t-avatar">{q.clienteInicial}</span>
                    {q.cliente}
                </span>
                <span class="t-muted">{q.terminos}</span>
                <span class="t-muted">{q.vigencia}</span>
                <span class="editorial t-amount t-right">{money(quoteTotal(q), 0)}</span>
                <span class="status-pill" style={`color:${STATUS_META[q.status].color}; background:${STATUS_META[q.status].bg}`}>
                    {STATUS_META[q.status].label}
                </span>
            </a>
        ))}
        <div class="t-empty" id="tEmpty" hidden>
            <p>No hay cotizaciones en este filtro.</p>
        </div>
    </section>
</AppLayout>

<style>
    .btn-new {
        background: var(--color-blue-deep); color: #fff;
        font-size: 0.82rem; font-weight: 600; text-decoration: none;
        padding: 9px 16px; border-radius: 9px;
        box-shadow: 0 6px 18px -8px rgba(10,25,47,0.5);
        transition: transform 0.4s var(--ease-spring), box-shadow 0.4s var(--ease-spring);
        white-space: nowrap;
    }
    .btn-new:hover { transform: translateY(-2px); }

    .filters { display: flex; gap: 0.4rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .filter-pill {
        font-family: var(--font-sans);
        font-size: 0.78rem; font-weight: 600;
        color: var(--color-text-muted);
        background: #fff; border: 1px solid var(--color-border);
        padding: 7px 14px; border-radius: 100px; cursor: pointer;
        transition: all 0.25s var(--ease-ios);
    }
    .filter-pill:hover { color: var(--color-blue-deep); }
    .filter-pill.active { background: var(--color-blue-deep); color: #fff; border-color: var(--color-blue-deep); }

    .table-card { overflow: hidden; }
    .t-head, .t-row {
        display: grid;
        grid-template-columns: 95px 1.6fr 0.7fr 0.9fr 1fr 110px;
        gap: 1rem; align-items: center;
        padding: 0.8rem 1.3rem;
    }
    .t-head {
        font-size: 0.62rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase;
        color: #99a2af; border-bottom: 1px solid var(--color-border);
        background: var(--color-bg-soft);
    }
    .t-row {
        text-decoration: none;
        border-bottom: 1px solid var(--color-border);
        transition: background 0.2s var(--ease-ios);
    }
    .t-row:last-of-type { border-bottom: none; }
    .t-row:hover { background: var(--color-bg-soft); }
    .t-row.hidden { display: none; }

    .t-folio { font-size: 0.84rem; font-weight: 700; color: var(--color-text); }
    .t-client { display: flex; align-items: center; gap: 9px; font-size: 0.84rem; font-weight: 500; color: var(--color-text); min-width: 0; }
    .t-avatar {
        width: 26px; height: 26px; border-radius: 7px; flex-shrink: 0;
        background: var(--color-blue-deep); color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.58rem; font-weight: 800;
    }
    .t-muted { font-size: 0.8rem; color: var(--color-text-muted); }
    .t-amount { font-size: 1rem; color: var(--color-blue-deep); }
    .t-right { text-align: right; }

    .t-empty { padding: 2.5rem; text-align: center; }
    .t-empty p { font-size: 0.85rem; color: var(--color-text-muted); margin: 0; }

    @media (max-width: 880px) {
        .t-head { display: none; }
        .t-row { grid-template-columns: 1fr auto; gap: 0.3rem 1rem; padding: 0.9rem 1rem; }
        .t-folio { order: 1; }
        .t-amount { order: 2; }
        .t-client { order: 3; grid-column: 1; }
        .t-row .status-pill { order: 4; justify-self: end; }
        .t-muted { display: none; }
    }
</style>

<script>
    const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
    const rows = document.querySelectorAll<HTMLElement>('.t-row');
    const empty = document.getElementById('tEmpty');
    pills.forEach((pill) => {
        pill.addEventListener('click', () => {
            pills.forEach(p => p.classList.remove('active'));
            pill.classList.add('active');
            const f = pill.dataset.filter;
            let visible = 0;
            rows.forEach((r) => {
                const show = f === 'all' || r.dataset.group === f;
                r.classList.toggle('hidden', !show);
                if (show) visible++;
            });
            if (empty) empty.hidden = visible > 0;
        });
    });
</script>
