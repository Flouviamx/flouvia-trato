---
// Editor de cotizaciones — LA pantalla crítica. Interactivo, datos reales (Neon):
// agregas productos del catálogo, negocias precio por línea, el total se recalcula
// en vivo con IVA, y al enviar hace POST a /api/cotizaciones (inserta en Neon).
import AppLayout from '../../../layouts/AppLayout.astro';
import { getProductos, getClientes, getOrg } from '../../../lib/queries';

const [productos, CLIENTES, ORG] = await Promise.all([getProductos(), getClientes(), getOrg()]);
const catalogo = productos.filter(p => p.activo);

// Defaults reales desde Ajustes › Cotizaciones e impuestos.
const TERM_DEFAULT_LABEL = ({ contado: 'Contado', net30: 'Net 30', net60: 'Net 60' } as Record<string, string>)[ORG.terminosDefault] ?? 'Contado';
const VIGENCIAS = [...new Set([15, 30, 60, ORG.vigenciaDefaultDias])].sort((a, b) => a - b);
---

<AppLayout title="Nueva cotización" page="cotizaciones" heading="Nueva cotización" crumbs={[{ label: 'Cotizaciones', href: '/app/cotizaciones' }]}>
    <span slot="topbar-actions" class="draft-tag">Borrador</span>

    <div class="editor-grid">
        <!-- ── Columna principal ── -->
        <div class="ed-main">
            <!-- Armar con IA — la forma rápida (puerta de entrada) -->
            <section class="ed-block ai-block">
                <div class="ai-head">
                    <span class="ai-spark" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 4.6L18.5 9.5 13.9 11.4 12 16l-1.9-4.6L5.5 9.5l4.6-1.9L12 3z"/><path d="M19 14.5l.7 1.8 1.8.7-1.8.7-.7 1.8-.7-1.8-1.8-.7 1.8-.7.7-1.8z"/></svg>
                    </span>
                    <div>
                        <h2 class="ai-title">Arma la cotización con IA</h2>
                        <p class="ai-sub">La forma más rápida. Pega el pedido del cliente (WhatsApp, correo…) y la IA arma las líneas con tu catálogo.</p>
                    </div>
                </div>
                <textarea id="aiText" class="ed-textarea ai-textarea" rows="3" placeholder="Ej. Hola, necesito 200 sacos de cemento gris, 50 varillas de 3/8 y 2 m³ de arena. ¿Me pasas precio?"></textarea>
                <div class="ai-actions">
                    <button class="ai-btn" id="aiBtn"><span class="ai-btn-label">Armar cotización con IA</span></button>
                    <span class="ai-status" id="aiStatus"></span>
                </div>
            </section>

            <div class="ed-or"><span>o créala manualmente</span></div>

            <!-- Cliente -->
            <section class="ed-block">
                <div class="section-head step-head">
                    <span class="step-num">1</span>
                    <div class="step-text">
                        <h2>¿A quién le cotizas?</h2>
                        <p class="step-hint">Elige el cliente y cómo te paga. Si tiene un nivel con descuento, se aplica solo a los precios.</p>
                    </div>
                </div>
                <div class="client-row">
                    <select class="ed-select" id="clientSelect">
                        <option value="" disabled selected>— Selecciona un cliente —</option>
                        {CLIENTES.map((c) => (
                            <option value={c.id} data-desc={String(c.descuentoPct)} data-nivel={c.nivel}>{c.empresa} — {c.contacto}</option>
                        ))}
                    </select>
                    <div class="term-chips" id="termChips">
                        {['Contado', 'Net 30', 'Net 60'].map((t) => (
                            <button class:list={['chip', { active: t === TERM_DEFAULT_LABEL }]} data-term={t}>{t}</button>
                        ))}
                    </div>
                </div>
                <p class="desc-note" id="descNote" hidden></p>
            </section>

            <!-- Productos -->
            <section class="ed-block">
                <div class="section-head step-head">
                    <span class="step-num">2</span>
                    <div class="step-text">
                        <h2>¿Qué le vas a cotizar?</h2>
                        <p class="step-hint">Agrega productos de tu catálogo o una línea libre. Baja el precio en <b>Negociado</b> sin tocar tu lista.</p>
                    </div>
                </div>

                <div class="lines-head">
                    <span>Producto</span><span>Cant.</span><span>Lista</span><span>Negociado</span><span class="lh-right">Importe</span><span class="lh-margen">Margen <span class="lh-i" title="Tu ganancia sobre el precio negociado, ya descontando el costo. Verde = sano · rojo = por debajo de tu mínimo.">?</span></span><span></span>
                </div>
                <div id="lines"></div>

                <div class="lines-empty" id="linesEmpty">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v4H3z"/><path d="M3 7v14h18V7"/><path d="M9 12h6"/></svg>
                    <p><b>Aún no agregas productos</b><br/>Elige uno de tu catálogo abajo o agrega una línea libre.</p>
                </div>

                <div class="add-actions">
                    <select class="ed-select" id="productSelect">
                        <option value="" disabled selected>+ Producto del catálogo…</option>
                        {catalogo.map((p) => (
                            <option value={p.id}>{p.nombre} — ${p.precio.toFixed(2)} / {p.unidad}</option>
                        ))}
                    </select>
                    <button class="btn-free-line" id="btnFreeLine">+ Agregar línea libre</button>
                </div>
            </section>

            <!-- Notas -->
            <section class="ed-block">
                <div class="section-head"><h2>Notas para el cliente <span class="opt">(opcional)</span></h2></div>
                <textarea id="notasText" class="ed-textarea" rows="2" placeholder="Ej. Precio especial por volumen — entrega en obra incluida."></textarea>
            </section>
        </div>

        <!-- ── Sidebar resumen ── -->
        <aside class="ed-side">
            <section class="ed-summary">
                <div class="section-head"><h2>Revisa y envía</h2></div>
                <div class="sum-count" id="sumCount">Agrega productos para ver el total</div>
                <div class="sum-line"><span>Subtotal</span><span class="editorial" id="sumSubtotal">$0.00</span></div>
                <div class="sum-line sum-save" id="sumSaveLine" hidden><span>Le descontaste</span><span class="editorial" id="sumSave">$0.00</span></div>
                <div class="sum-line"><span>IVA {ORG.ivaPct}%</span><span class="editorial" id="sumIva">$0.00</span></div>
                <input type="hidden" id="cfgIva" value={ORG.ivaPct} />
                <div class="sum-divider"></div>
                <div class="sum-line sum-total"><span>Total</span><span class="editorial" id="sumTotal">$0.00</span></div>

                <div class="sum-field">
                    <label>Vigencia</label>
                    <select class="ed-select">
                        {VIGENCIAS.map((n) => <option selected={n === ORG.vigenciaDefaultDias}>{n} días</option>)}
                    </select>
                </div>

                <div class="sum-field">
                    <label>¿En qué moneda le cotizas?</label>
                    <select class="ed-select" id="fxBase">
                        <option value="MXN" selected>🇲🇽 Pesos mexicanos (MXN)</option>
                        <option value="USD">🇺🇸 Dólares (USD)</option>
                        <option value="EUR">🇪🇺 Euros (EUR)</option>
                    </select>
                </div>

                <div class="fx-cover" id="fxCover" hidden>
                    <p class="fx-explain">Le muestras precios en <b id="fxBaseLbl2">USD</b>, pero tu factura sale en pesos 🇲🇽. Congelamos el tipo de cambio de hoy para que un peso volátil no te coma el margen si tarda en pagarte.</p>

                    <div class="fx-stepper">
                        <div class="fx-step">
                            <span class="fx-step-lbl">Tipo de cambio hoy</span>
                            <span class="fx-step-val editorial" id="fxSpot">—</span>
                        </div>
                        <span class="fx-arrow" aria-hidden="true">→</span>
                        <div class="fx-step fx-step-on">
                            <span class="fx-step-lbl">Tu tasa protegida <span id="fxBufLbl">+2%</span></span>
                            <span class="fx-step-val editorial" id="fxApplied">—</span>
                        </div>
                    </div>

                    <label class="fx-cushion-lbl">¿Qué tan cauto quieres ser?</label>
                    <div class="fx-cushion" id="fxCushion">
                        <button type="button" class="fx-cush-chip" data-buf="1"><b>Poco</b><small>+1%</small></button>
                        <button type="button" class="fx-cush-chip active" data-buf="2"><b>Normal</b><small>+2%</small></button>
                        <button type="button" class="fx-cush-chip" data-buf="5"><b>Cauto</b><small>+5%</small></button>
                    </div>
                    <input type="hidden" id="fxBuffer" value="2" />

                    <p class="fx-client-sees" id="fxPreview">Tu cliente verá ≈ <b>US$—</b></p>
                    <div class="fx-lock-row"><span class="fx-lock-ic">🔒</span> Tasa congelada 30 días — tú decides el colchón</div>
                </div>

                <button class="btn-send" id="btnSend">
                    <span>Crear y enviar</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </button>
                <button class="btn-draft" id="btnDraft">Guardar borrador</button>
                <p class="sum-note">Al enviar se generará la V1 y se creará el link público.</p>
            </section>
        </aside>
    </div>

    <!-- Toast -->
    <div class="toast" id="toast" hidden>
        <span class="toast-dot"></span>
        <span id="toastMsg">Cotización enviada</span>
    </div>
</AppLayout>

<script is:inline define:vars={{ catalogo, aprobMargenMin: ORG.aprobMargenMin }}>
    const lines = [];
    const $lines = document.getElementById('lines');
    const $empty = document.getElementById('linesEmpty');
    const $select = document.getElementById('productSelect');
    const fmt = (n) => '$' + new Intl.NumberFormat('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    const fmtPct = (n) => Number.isFinite(n) ? Math.round(n) + '%' : '—';
    const margenPct = (costo, precio) => (costo > 0 && precio > 0) ? (precio - costo) / precio * 100 : null;

    // Catálogo map para acceso rápido por ID
    const catMap = Object.fromEntries(catalogo.map(p => [p.id, p]));

    // ── Descuento por nivel de cliente (price tiers) ──
    const $client = document.getElementById('clientSelect');
    const $descNote = document.getElementById('descNote');
    const currentDesc = () => { const o = $client && $client.options[$client.selectedIndex]; return o && !o.disabled ? (parseFloat(o.dataset.desc) || 0) : 0; };
    const applyDesc = (lista) => { const d = currentDesc(); return d > 0 ? Math.round(lista * (1 - d / 100) * 100) / 100 : null; };
    const reflectDesc = () => {
        const d = currentDesc();
        if ($descNote) { $descNote.textContent = d > 0 ? `Nivel del cliente: −${d}% aplicado automáticamente a los precios de lista.` : ''; $descNote.hidden = d <= 0; }
    };

    function recalc() {
        const ivaPct = (Number((document.getElementById('cfgIva') || {}).value) || 0) / 100;
        const subtotal = lines.reduce((s, l) => s + (l.negociado ?? l.lista) * l.cantidad, 0);
        document.getElementById('sumSubtotal').textContent = fmt(subtotal);
        document.getElementById('sumIva').textContent = fmt(subtotal * ivaPct);
        document.getElementById('sumTotal').textContent = fmt(subtotal * (1 + ivaPct));

        // Conteo de líneas/piezas + cuánto le descontaste al cliente (lista vs negociado)
        const nLines = lines.length;
        const pieces = lines.reduce((s, l) => s + l.cantidad, 0);
        const saved = lines.reduce((s, l) => {
            const neg = l.negociado ?? l.lista;
            return s + (l.lista > neg ? (l.lista - neg) * l.cantidad : 0);
        }, 0);
        const $cnt = document.getElementById('sumCount');
        if ($cnt) $cnt.textContent = nLines === 0
            ? 'Agrega productos para ver el total'
            : `${nLines} ${nLines === 1 ? 'línea' : 'líneas'} · ${pieces} ${pieces === 1 ? 'pieza' : 'piezas'}`;
        const $save = document.getElementById('sumSaveLine');
        const $saveV = document.getElementById('sumSave');
        if ($save && $saveV) { $save.hidden = saved <= 0; $saveV.textContent = '−' + fmt(saved); }

        // Si cotiza en divisa extranjera, el monto cambió → refrescar el FX
        const cov = document.getElementById('fxCover');
        if (cov && !cov.hidden) scheduleFx();
    }

    function margenBadge(costo, precio) {
        const m = margenPct(costo, precio);
        if (m === null) return '<span class="lr-margen lr-margen-na">—</span>';
        const low = aprobMargenMin > 0 && m < aprobMargenMin;
        return `<span class="lr-margen ${low ? 'lr-margen-low' : ''}" title="Margen bruto">${fmtPct(m)}</span>`;
    }

    function render() {
        $empty.hidden = lines.length > 0;
        $lines.innerHTML = '';
        lines.forEach((l, idx) => {
            const precioFinal = l.negociado ?? l.lista;
            const importe = precioFinal * l.cantidad;
            const row = document.createElement('div');
            row.className = 'line-row';
            
            // Si es línea libre, el nombre es editable.
            const nameHtml = l.id 
                ? `<span class="lr-name">${l.nombre}<small>${l.unidad}</small></span>`
                : `<input type="text" class="lr-input lr-desc-input" value="${l.nombre}" data-idx="${idx}" data-field="nombre" placeholder="Descripción de la línea..." />`;

            row.innerHTML = `
                ${nameHtml}
                <input type="number" min="1" value="${l.cantidad}" class="lr-input" data-idx="${idx}" data-field="cantidad" />
                <span class="lr-lista">${l.id ? fmt(l.lista) : '—'}</span>
                <input type="number" min="0" step="0.01" value="${precioFinal.toFixed(2)}" class="lr-input lr-nego ${l.negociado !== null && l.negociado < l.lista ? 'is-deal' : ''}" data-idx="${idx}" data-field="negociado" />
                <span class="editorial lr-importe">${fmt(importe)}</span>
                ${margenBadge(l.costo, precioFinal)}
                <button class="lr-del" data-del="${idx}" aria-label="Quitar">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            `;
            $lines.appendChild(row);
        });
        recalc();
    }

    $select.addEventListener('change', () => {
        const p = catMap[$select.value];
        if (!p) return;
        lines.push({ id: p.id, nombre: p.nombre, unidad: p.unidad, lista: p.precio, costo: p.costo || 0, negociado: applyDesc(p.precio), cantidad: 1 });
        $select.selectedIndex = 0;
        render();
    });

    document.getElementById('btnFreeLine')?.addEventListener('click', () => {
        lines.push({ id: null, nombre: '', unidad: 'pieza', lista: 0, costo: 0, negociado: 0, cantidad: 1 });
        render();
    });

    // Al cambiar de cliente, reaplica el descuento a las líneas del catálogo
    $client?.addEventListener('change', () => {
        const d = currentDesc();
        lines.forEach((l) => {
            if (l.id) { // Solo aplica a items del catálogo
                l.negociado = d > 0 ? Math.round(l.lista * (1 - d / 100) * 100) / 100 : null;
            }
        });
        reflectDesc();
        render();
    });

    $lines.addEventListener('input', (e) => {
        const t = e.target;
        if (!(t instanceof HTMLInputElement)) return;
        const idx = parseInt(t.dataset.idx, 10);
        
        if (t.dataset.field === 'nombre') {
            lines[idx].nombre = t.value;
            return; // No necesita recalcular
        }

        const val = parseFloat(t.value) || 0;
        if (t.dataset.field === 'cantidad') lines[idx].cantidad = Math.max(1, Math.round(val));
        if (t.dataset.field === 'negociado') {
            lines[idx].negociado = val;
            if (lines[idx].id) t.classList.toggle('is-deal', val < lines[idx].lista);
        }

        // recalcula visualmente la fila actual sin perder el foco
        const row = t.closest('.line-row');
        const l = lines[idx];
        const precioFinal = l.negociado ?? l.lista;
        row.querySelector('.lr-importe').textContent = fmt(precioFinal * l.cantidad);
        const badge = row.querySelector('.lr-margen');
        if (badge) badge.outerHTML = margenBadge(l.costo, precioFinal);
        
        recalc();
    });

    $lines.addEventListener('click', (e) => {
        const btn = e.target.closest('.lr-del');
        if (!btn) return;
        lines.splice(parseInt(btn.dataset.del, 10), 1);
        render();
    });

    // Chips de términos
    document.querySelectorAll('#termChips .chip').forEach((chip) => {
        chip.addEventListener('click', () => {
            document.querySelectorAll('#termChips .chip').forEach(c => c.classList.remove('active'));
            chip.classList.add('active');
        });
    });

    // ── Guardado real (POST /api/cotizaciones → Neon) ──
    const toast = document.getElementById('toast');
    const toastMsg = document.getElementById('toastMsg');
    const TERM_MAP = { 'Contado': 'contado', 'Net 30': 'net30', 'Net 60': 'net60' };
    const showToast = (msg, hide = 0) => {
        toastMsg.textContent = msg; toast.hidden = false;
        if (hide) setTimeout(() => { toast.hidden = true; }, hide);
    };

    function buildPayload(send) {
        const clientSel = document.getElementById('clientSelect');
        const activeChip = document.querySelector('#termChips .chip.active');
        const vigSel = document.querySelector('.sum-field .ed-select');
        const notas = document.getElementById('notasText');
        
        // Validación del cliente
        const cliente_id = clientSel && clientSel.value !== "" ? clientSel.value : null;

        // Multi-divisa: si la moneda elegida no es MXN, se factura en MXN con cobertura.
        const fxBaseSel = document.getElementById('fxBase');
        const fxBufferEl = document.getElementById('fxBuffer');
        const base_currency = fxBaseSel ? fxBaseSel.value : 'MXN';
        const fiscal_currency = base_currency === 'MXN' ? 'MXN' : 'MXN';
        const fx_buffer_pct = base_currency === 'MXN' ? 0 : (fxBufferEl ? parseFloat(fxBufferEl.value) || 0 : 0);

        return {
            send,
            cliente_id,
            terminos: TERM_MAP[activeChip ? activeChip.dataset.term : 'Contado'] || 'contado',
            vigencia_dias: vigSel ? parseInt(vigSel.value, 10) || 30 : 30,
            notas: notas ? notas.value.trim() : '',
            base_currency,
            fiscal_currency,
            fx_buffer_pct,
            items: lines.map(l => ({
                producto_id: l.id || null,
                descripcion: l.nombre || 'Línea libre',
                cantidad: l.cantidad,
                precio_unitario: l.lista,
                precio_negociado: l.negociado,
                costo_unitario: l.costo || 0,
            })),
        };
    }

    async function save(send, btn) {
        if (!lines.length) { showToast('Agrega al menos un producto', 2200); return; }
        const original = btn.innerHTML;
        btn.disabled = true; btn.style.opacity = '0.7';
        showToast(send ? 'Enviando…' : 'Guardando…');
        try {
            const res = await fetch('/api/cotizaciones', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(buildPayload(send)),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Error al guardar');
            if (data.needsApproval) showToast(`Aprobación solicitada — ${data.folio}. Espera el visto bueno de gerencia.`);
            else showToast(send ? `Enviada — ${data.folio} ✓` : `Borrador ${data.folio} guardado ✓`);
            setTimeout(() => { window.location.href = `/app/cotizaciones/${data.id}`; }, 1100);
        } catch (err) {
            btn.disabled = false; btn.style.opacity = '1'; btn.innerHTML = original;
            showToast(err.message || 'Error de red', 2600);
        }
    }

    document.getElementById('btnSend')?.addEventListener('click', (e) => save(true, e.currentTarget));
    document.getElementById('btnDraft')?.addEventListener('click', (e) => save(false, e.currentTarget));

    // ── Multi-divisa: tipo de cambio en lenguaje simple + colchón visual ──
    const $fxBase = document.getElementById('fxBase');
    const $fxBuffer = document.getElementById('fxBuffer');
    const $fxCover = document.getElementById('fxCover');
    const $fxPreview = document.getElementById('fxPreview');
    const $fxBaseLbl2 = document.getElementById('fxBaseLbl2');
    const $fxSpot = document.getElementById('fxSpot');
    const $fxApplied = document.getElementById('fxApplied');
    const $fxBufLbl = document.getElementById('fxBufLbl');
    const $fxCushion = document.getElementById('fxCushion');
    const nfFx = new Intl.NumberFormat('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const symFx = (c) => c === 'USD' ? 'US$' : c === 'EUR' ? '€' : '$';

    function parseTotal() {
        const t = (document.getElementById('sumTotal')?.textContent || '0').replace(/[^0-9.]/g, '');
        return parseFloat(t) || 0;
    }

    let fxTimer = null;
    async function refreshFx() {
        if (!$fxBase) return;
        const base = $fxBase.value;
        const isForeign = base !== 'MXN';
        if ($fxCover) $fxCover.hidden = !isForeign;
        if (!isForeign) return;
        if ($fxBaseLbl2) $fxBaseLbl2.textContent = base;
        const buffer = $fxBuffer ? parseFloat($fxBuffer.value) || 0 : 0;
        if ($fxBufLbl) $fxBufLbl.textContent = '+' + buffer + '%';
        const amount = parseTotal();
        try {
            const res = await fetch(`/api/fx/quote?base=${base}&fiscal=MXN&amount=${amount}&buffer=${buffer}`);
            const fx = await res.json();
            const spot = Number(fx.spotRate || 0);
            const applied = Number(fx.appliedRate || 0);
            // Tasas: hoy vs. protegida (con tu colchón)
            if ($fxSpot) $fxSpot.textContent = '$' + nfFx.format(spot);
            if ($fxApplied) $fxApplied.textContent = '$' + nfFx.format(applied);
            // Lo que el cliente verá en SU moneda = total en pesos ÷ tasa protegida
            const clientSees = applied > 0 ? amount / applied : 0;
            if ($fxPreview) {
                $fxPreview.innerHTML = amount > 0
                    ? `Tu cliente verá ≈ <b>${symFx(base)}${nfFx.format(clientSees)}</b> · tú facturas <b>$${nfFx.format(amount)} MXN</b>`
                    : `Agrega productos para ver el total en ${base}.`;
            }
        } catch {
            if ($fxPreview) $fxPreview.textContent = 'No se pudo obtener el tipo de cambio.';
        }
    }
    function scheduleFx() { clearTimeout(fxTimer); fxTimer = setTimeout(refreshFx, 250); }
    $fxBase?.addEventListener('change', refreshFx);
    // Colchón: chips de preset (Poco / Normal / Cauto)
    $fxCushion?.querySelectorAll('.fx-cush-chip').forEach((chip) => {
        chip.addEventListener('click', () => {
            $fxCushion.querySelectorAll('.fx-cush-chip').forEach(c => c.classList.remove('active'));
            chip.classList.add('active');
            if ($fxBuffer) $fxBuffer.value = chip.dataset.buf;
            refreshFx();
        });
    });

    // ── Armar con IA (POST /api/cotizaciones/ai-draft) ──
    const $aiBtn = document.getElementById('aiBtn');
    const $aiText = document.getElementById('aiText');
    const $aiStatus = document.getElementById('aiStatus');
    if ($aiBtn) {
        $aiBtn.addEventListener('click', async () => {
            const text = ($aiText.value || '').trim();
            if (!text) { $aiStatus.textContent = 'Escribe o pega el pedido primero.'; return; }
            const label = $aiBtn.querySelector('.ai-btn-label');
            const prev = label.textContent;
            $aiBtn.disabled = true; label.textContent = 'Armando…'; $aiStatus.textContent = '';
            try {
                const res = await fetch('/api/cotizaciones/ai-draft', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text }),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo armar');
                lines.length = 0;
                data.items.forEach((it) => lines.push({
                    id: it.id || null,
                    nombre: it.nombre || it.descripcion,
                    unidad: it.unidad || 'pieza',
                    lista: it.lista || 0,
                    costo: 0, 
                    negociado: it.negociado,
                    cantidad: it.cantidad || 1
                }));
                render();
                const n = data.items.length;
                $aiStatus.textContent = `✓ ${n} línea${n === 1 ? '' : 's'} armada${n === 1 ? '' : 's'}. Revisa cantidades y precios.`;
            } catch (err) {
                $aiStatus.textContent = err.message || 'Error de red';
            } finally {
                $aiBtn.disabled = false; label.textContent = prev;
            }
        });
    }

    // Inicializa la interfaz vacía.
    render();
    reflectDesc();
</script>

