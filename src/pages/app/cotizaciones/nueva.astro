---
// Editor de cotizaciones — LA pantalla crítica. Interactivo, datos reales (Neon):
// agregas productos del catálogo, negocias precio por línea, el total se recalcula
// en vivo con IVA, y al enviar hace POST a /api/cotizaciones (inserta en Neon).
import AppLayout from '../../../layouts/AppLayout.astro';
import { getProductos, getClientes } from '../../../lib/queries';

const [productos, CLIENTES] = await Promise.all([getProductos(), getClientes()]);
const catalogo = productos.filter(p => p.activo);
---

<AppLayout title="Nueva cotización — Trato" page="cotizaciones" heading="Nueva cotización">
    <span slot="topbar-actions" class="draft-tag">Borrador · COT-0149</span>

    <div class="editor-grid">
        <!-- ── Columna principal ── -->
        <div class="ed-main">
            <!-- Armar con IA -->
            <section class="ed-block ai-block">
                <div class="ai-head">
                    <span class="ai-spark">✦</span>
                    <div>
                        <h2 class="ai-title">Armar con IA</h2>
                        <p class="ai-sub">Pega el pedido del cliente (WhatsApp, correo…) y la IA arma las líneas con tu catálogo.</p>
                    </div>
                </div>
                <textarea id="aiText" class="ed-textarea" rows="3" placeholder="Ej. Hola, necesito 200 sacos de cemento gris, 50 varillas de 3/8 y 2 m³ de arena. ¿Me pasas precio?"></textarea>
                <div class="ai-actions">
                    <button class="ai-btn" id="aiBtn"><span class="ai-btn-label">Armar cotización con IA</span></button>
                    <span class="ai-status" id="aiStatus"></span>
                </div>
            </section>

            <!-- Cliente -->
            <section class="ed-block">
                <div class="section-head"><h2>Cliente</h2></div>
                <div class="client-row">
                    <select class="ed-select" id="clientSelect">
                        {CLIENTES.map((c, i) => (
                            <option value={c.id} selected={i === 0} data-desc={String(c.descuentoPct)} data-nivel={c.nivel}>{c.empresa} — {c.contacto}</option>
                        ))}
                    </select>
                    <div class="term-chips" id="termChips">
                        {['Contado', 'Net 30', 'Net 60'].map((t) => (
                            <button class:list={['chip', { active: t === 'Net 30' }]} data-term={t}>{t}</button>
                        ))}
                    </div>
                </div>
                <p class="desc-note" id="descNote" hidden></p>
            </section>

            <!-- Productos -->
            <section class="ed-block">
                <div class="section-head">
                    <h2>Productos</h2>
                    <div class="add-product">
                        <select class="ed-select" id="productSelect">
                            <option value="" disabled selected>Agregar producto del catálogo…</option>
                            {catalogo.map((p, i) => (
                                <option value={i}>{p.nombre} — ${p.precio.toFixed(2)} / {p.unidad}</option>
                            ))}
                        </select>
                    </div>
                </div>

                <div class="lines-head">
                    <span>Producto</span><span>Cant.</span><span>Lista</span><span>Negociado</span><span class="lh-right">Importe</span><span></span>
                </div>
                <div id="lines"></div>
                <p class="lines-empty" id="linesEmpty">Agrega productos del catálogo para empezar.</p>
            </section>

            <!-- Notas -->
            <section class="ed-block">
                <div class="section-head"><h2>Notas para el cliente <span class="opt">(opcional)</span></h2></div>
                <textarea id="notasText" class="ed-textarea" rows="2" placeholder="Ej. Precio especial por volumen — entrega en obra incluida."></textarea>
            </section>
        </div>

        <!-- ── Sidebar resumen ── -->
        <aside class="ed-side">
            <section class="ed-summary">
                <div class="section-head"><h2>Resumen</h2></div>
                <div class="sum-line"><span>Subtotal</span><span class="editorial" id="sumSubtotal">$0.00</span></div>
                <div class="sum-line"><span>IVA 16%</span><span class="editorial" id="sumIva">$0.00</span></div>
                <div class="sum-divider"></div>
                <div class="sum-line sum-total"><span>Total</span><span class="editorial" id="sumTotal">$0.00</span></div>

                <div class="sum-field">
                    <label>Vigencia</label>
                    <select class="ed-select">
                        <option>15 días</option>
                        <option selected>30 días</option>
                        <option>60 días</option>
                    </select>
                </div>

                <button class="btn-send" id="btnSend">
                    <span>Enviar cotización</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </button>
                <button class="btn-draft">Guardar borrador</button>
                <p class="sum-note">Al enviar se genera el link público y el PDF con tu marca.</p>
            </section>
        </aside>
    </div>

    <!-- Toast -->
    <div class="toast" id="toast" hidden>
        <span class="toast-dot"></span>
        <span id="toastMsg">Cotización enviada</span>
    </div>
</AppLayout>

<script is:inline define:vars={{ catalogo }}>
    const lines = [];
    const $lines = document.getElementById('lines');
    const $empty = document.getElementById('linesEmpty');
    const $select = document.getElementById('productSelect');
    const fmt = (n) => '$' + new Intl.NumberFormat('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);

    // ── Descuento por nivel de cliente (price tiers) ──
    const $client = document.getElementById('clientSelect');
    const $descNote = document.getElementById('descNote');
    const currentDesc = () => { const o = $client && $client.options[$client.selectedIndex]; return o ? (parseFloat(o.dataset.desc) || 0) : 0; };
    const applyDesc = (lista) => { const d = currentDesc(); return d > 0 ? Math.round(lista * (1 - d / 100) * 100) / 100 : null; };
    const reflectDesc = () => {
        const d = currentDesc();
        if ($descNote) { $descNote.textContent = d > 0 ? `Nivel del cliente: −${d}% aplicado automáticamente a las líneas.` : ''; $descNote.hidden = d <= 0; }
    };

    function recalc() {
        const subtotal = lines.reduce((s, l) => s + (l.negociado ?? l.lista) * l.cantidad, 0);
        document.getElementById('sumSubtotal').textContent = fmt(subtotal);
        document.getElementById('sumIva').textContent = fmt(subtotal * 0.16);
        document.getElementById('sumTotal').textContent = fmt(subtotal * 1.16);
    }

    function render() {
        $empty.hidden = lines.length > 0;
        $lines.innerHTML = '';
        lines.forEach((l, idx) => {
            const importe = (l.negociado ?? l.lista) * l.cantidad;
            const row = document.createElement('div');
            row.className = 'line-row';
            row.innerHTML = `
                <span class="lr-name">${l.nombre}<small>${l.unidad}</small></span>
                <input type="number" min="1" value="${l.cantidad}" class="lr-input" data-idx="${idx}" data-field="cantidad" />
                <span class="lr-lista">${fmt(l.lista)}</span>
                <input type="number" min="0" step="0.01" value="${(l.negociado ?? l.lista).toFixed(2)}" class="lr-input lr-nego ${l.negociado !== null && l.negociado < l.lista ? 'is-deal' : ''}" data-idx="${idx}" data-field="negociado" />
                <span class="editorial lr-importe">${fmt(importe)}</span>
                <button class="lr-del" data-del="${idx}" aria-label="Quitar">×</button>
            `;
            $lines.appendChild(row);
        });
        recalc();
    }

    $select.addEventListener('change', () => {
        const p = catalogo[parseInt($select.value, 10)];
        if (!p) return;
        lines.push({ id: p.id, nombre: p.nombre, unidad: p.unidad, lista: p.precio, negociado: applyDesc(p.precio), cantidad: 1 });
        $select.selectedIndex = 0;
        render();
    });

    // Al cambiar de cliente, reaplica el descuento de su nivel a todas las líneas.
    $client?.addEventListener('change', () => {
        const d = currentDesc();
        lines.forEach((l) => { l.negociado = d > 0 ? Math.round(l.lista * (1 - d / 100) * 100) / 100 : null; });
        reflectDesc();
        render();
    });

    $lines.addEventListener('input', (e) => {
        const t = e.target;
        if (!(t instanceof HTMLInputElement)) return;
        const idx = parseInt(t.dataset.idx, 10);
        const val = parseFloat(t.value) || 0;
        if (t.dataset.field === 'cantidad') lines[idx].cantidad = Math.max(1, Math.round(val));
        if (t.dataset.field === 'negociado') {
            lines[idx].negociado = val;
            t.classList.toggle('is-deal', val < lines[idx].lista);
        }
        // recalcula sin re-render (no perder el foco del input)
        const row = t.closest('.line-row');
        const l = lines[idx];
        row.querySelector('.lr-importe').textContent = fmt((l.negociado ?? l.lista) * l.cantidad);
        recalc();
    });

    $lines.addEventListener('click', (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement) || t.dataset.del === undefined) return;
        lines.splice(parseInt(t.dataset.del, 10), 1);
        render();
    });

    // Chips de términos
    document.querySelectorAll('#termChips .chip').forEach((chip) => {
        chip.addEventListener('click', () => {
            document.querySelectorAll('#termChips .chip').forEach(c => c.classList.remove('active'));
            chip.classList.add('active');
        });
    });

    // ── Guardado real (POST /api/cotizaciones → Neon) ──
    const toast = document.getElementById('toast');
    const toastMsg = document.getElementById('toastMsg');
    const TERM_MAP = { 'Contado': 'contado', 'Net 30': 'net30', 'Net 60': 'net60' };
    const showToast = (msg, hide = 0) => {
        toastMsg.textContent = msg; toast.hidden = false;
        if (hide) setTimeout(() => { toast.hidden = true; }, hide);
    };

    function buildPayload(send) {
        const clientSel = document.getElementById('clientSelect');
        const activeChip = document.querySelector('#termChips .chip.active');
        const vigSel = document.querySelector('.sum-field .ed-select');
        const notas = document.getElementById('notasText');
        return {
            send,
            cliente_id: clientSel ? clientSel.value : null,
            terminos: TERM_MAP[activeChip ? activeChip.dataset.term : 'Contado'] || 'contado',
            vigencia_dias: vigSel ? parseInt(vigSel.value, 10) || 30 : 30,
            notas: notas ? notas.value.trim() : '',
            items: lines.map(l => ({
                producto_id: l.id || null,
                descripcion: l.nombre,
                cantidad: l.cantidad,
                precio_unitario: l.lista,
                precio_negociado: l.negociado,
            })),
        };
    }

    async function save(send, btn) {
        if (!lines.length) { showToast('Agrega al menos un producto', 2200); return; }
        const original = btn.innerHTML;
        btn.disabled = true; btn.style.opacity = '0.7';
        showToast(send ? 'Enviando…' : 'Guardando…');
        try {
            const res = await fetch('/api/cotizaciones', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(buildPayload(send)),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Error al guardar');
            if (data.needsApproval) showToast(`Aprobación solicitada — ${data.folio}. Espera el visto bueno de gerencia.`);
            else showToast(send ? `Enviada — ${data.folio} ✓` : `Borrador ${data.folio} guardado ✓`);
            setTimeout(() => { window.location.href = `/app/cotizaciones/${data.id}`; }, 1100);
        } catch (err) {
            btn.disabled = false; btn.style.opacity = '1'; btn.innerHTML = original;
            showToast(err.message || 'Error de red', 2600);
        }
    }

    document.getElementById('btnSend').addEventListener('click', (e) => save(true, e.currentTarget));
    document.querySelector('.btn-draft').addEventListener('click', (e) => save(false, e.currentTarget));

    // ── Armar con IA (POST /api/cotizaciones/ai-draft) ──
    const $aiBtn = document.getElementById('aiBtn');
    const $aiText = document.getElementById('aiText');
    const $aiStatus = document.getElementById('aiStatus');
    if ($aiBtn) {
        $aiBtn.addEventListener('click', async () => {
            const text = ($aiText.value || '').trim();
            if (!text) { $aiStatus.textContent = 'Escribe o pega el pedido primero.'; return; }
            const label = $aiBtn.querySelector('.ai-btn-label');
            const prev = label.textContent;
            $aiBtn.disabled = true; label.textContent = 'Armando…'; $aiStatus.textContent = '';
            try {
                const res = await fetch('/api/cotizaciones/ai-draft', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text }),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo armar');
                lines.length = 0;
                data.items.forEach((it) => lines.push(it));
                render();
                const n = data.items.length;
                $aiStatus.textContent = `✓ ${n} línea${n === 1 ? '' : 's'} armada${n === 1 ? '' : 's'}. Revisa cantidades y precios.`;
            } catch (err) {
                $aiStatus.textContent = err.message || 'Error de red';
            } finally {
                $aiBtn.disabled = false; label.textContent = prev;
            }
        });
    }

    // arranca con una línea de ejemplo (precarga del primer producto del catálogo)
    if (catalogo.length) {
        const p0 = catalogo[0];
        lines.push({ id: p0.id, nombre: p0.nombre, unidad: p0.unidad, lista: p0.precio, negociado: Math.round(p0.precio * 0.92 * 100) / 100, cantidad: 120 });
    }
    render();
    reflectDesc();
</script>

<style is:global>
    /* Filas del editor — inyectadas por JS, por eso van en is:global */
    .line-row {
        display: grid;
        grid-template-columns: 1.7fr 70px 90px 110px 1fr 30px;
        gap: 0.8rem; align-items: center;
        padding: 0.65rem 0;
        border-bottom: 1px solid rgba(10,25,47,0.07);
    }
    .line-row:last-child { border-bottom: none; }
    .lr-name { font-size: 0.86rem; font-weight: 600; color: #0f1729; display: flex; flex-direction: column; }
    .lr-name small { font-size: 0.68rem; color: #99a2af; font-weight: 500; }
    .lr-lista { font-size: 0.8rem; color: #99a2af; text-decoration: line-through; }
    .lr-input {
        font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600;
        color: #0f1729; background: #fafbfc;
        border: 1px solid rgba(10,25,47,0.1); border-radius: 8px;
        padding: 8px 10px; width: 100%;
        transition: border-color 0.25s, box-shadow 0.25s;
    }
    .lr-input:focus { outline: none; border-color: #0a192f; box-shadow: 0 0 0 3px rgba(10,25,47,0.08); }
    .lr-nego.is-deal { color: #059669; border-color: rgba(16,185,129,0.4); background: rgba(16,185,129,0.04); }
    .lr-importe { font-size: 0.98rem; color: #0a192f; text-align: right; }
    .lr-del {
        background: none; border: none; cursor: pointer;
        color: #c3c9d2; font-size: 1.1rem; line-height: 1;
        border-radius: 6px; padding: 4px 7px;
        transition: color 0.2s, background 0.2s;
    }
    .lr-del:hover { color: #ef4444; background: rgba(239,68,68,0.07); }

    @media (max-width: 720px) {
        .line-row { grid-template-columns: 1fr 60px 90px auto; }
        .lr-lista, .lr-importe { display: none; }
    }
</style>

<style>
    .draft-tag { font-size: 0.72rem; font-weight: 700; color: var(--color-text-muted); background: #fff; border: 1px solid var(--color-border); padding: 6px 12px; border-radius: 100px; }

    /* Encabezados de sección — patrón plano editorial (idéntico al dashboard) */
    .section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 1.2rem; padding-bottom: 0.7rem; border-bottom: 1px solid var(--color-border); flex-wrap: wrap; }
    .section-head h2 { font-size: 0.7rem; font-weight: 800; letter-spacing: 1.6px; text-transform: uppercase; color: #99a2af; margin: 0; }

    /* Armar con IA — primera línea: separador editorial superior */
    .ai-block { border-top: 2px solid var(--color-blue-deep); padding-top: 1.4rem; }
    .ai-head { display: flex; gap: 12px; align-items: flex-start; margin-bottom: 0.9rem; }
    .ai-spark { font-size: 0.9rem; color: var(--color-blue-deep); background: rgba(10,25,47,0.06); width: 30px; height: 30px; border-radius: 9px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .ai-title { font-size: 0.92rem; font-weight: 700; margin: 0 0 2px; letter-spacing: -0.2px; }
    .ai-sub { font-size: 0.78rem; color: var(--color-text-muted); margin: 0; line-height: 1.45; }
    .ai-actions { display: flex; align-items: center; gap: 1rem; margin-top: 0.7rem; flex-wrap: wrap; }
    .ai-btn {
        font-family: var(--font-sans); font-size: 0.84rem; font-weight: 600; cursor: pointer;
        background: var(--color-blue-deep); color: #fff; border: none; border-radius: 10px; padding: 10px 18px;
        box-shadow: 0 8px 22px -10px rgba(10,25,47,0.5);
        transition: transform 0.4s var(--ease-spring), opacity 0.2s;
    }
    .ai-btn:hover { transform: translateY(-2px); }
    .ai-btn:disabled { opacity: 0.6; cursor: wait; }
    .ai-status { font-size: 0.78rem; color: var(--color-text-muted); font-weight: 500; }

    .editor-grid { display: grid; grid-template-columns: 1fr 320px; gap: 3rem; align-items: start; }
    .ed-main { display: flex; flex-direction: column; gap: 2.6rem; min-width: 0; }
    .ed-block { padding: 0; }
    .opt { font-size: 0.72rem; font-weight: 500; color: var(--color-text-muted); text-transform: none; letter-spacing: 0; }

    .client-row { display: flex; gap: 0.8rem; align-items: center; flex-wrap: wrap; }
    .ed-select {
        font-family: var(--font-sans); font-size: 0.85rem; font-weight: 500;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px;
        padding: 9px 12px; min-width: 220px; cursor: pointer;
        transition: border-color 0.25s;
    }
    .ed-select:focus { outline: none; border-color: var(--color-blue-deep); }

    .term-chips { display: flex; gap: 0.4rem; }
    .chip {
        font-family: var(--font-sans); font-size: 0.76rem; font-weight: 600;
        color: var(--color-text-muted); background: #fff;
        border: 1px solid var(--color-border); border-radius: 100px;
        padding: 7px 13px; cursor: pointer;
        transition: all 0.25s var(--ease-ios);
    }
    .chip.active { background: var(--color-blue-deep); color: #fff; border-color: var(--color-blue-deep); }
    .desc-note { font-size: 0.76rem; font-weight: 600; color: #059669; margin: 0.7rem 0 0; }
    .desc-note[hidden] { display: none; }

    .lines-head {
        display: grid; grid-template-columns: 1.7fr 70px 90px 110px 1fr 30px;
        gap: 0.8rem;
        font-size: 0.6rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase;
        color: #99a2af;
        padding: 0.6rem 0 0.5rem; border-bottom: 1px solid var(--color-border);
    }
    .lh-right { text-align: right; }
    .lines-empty { font-size: 0.82rem; color: var(--color-text-muted); padding: 1.4rem 0 0.6rem; margin: 0; }

    .ed-textarea {
        font-family: var(--font-sans); font-size: 0.86rem; width: 100%;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px;
        padding: 10px 12px; resize: vertical;
    }
    .ed-textarea:focus { outline: none; border-color: var(--color-blue-deep); }

    .ed-side { position: sticky; top: 76px; }
    .ed-summary { padding: 0; display: flex; flex-direction: column; gap: 0.7rem; }
    .ed-summary .section-head { margin-bottom: 0.4rem; }
    .sum-line { display: flex; justify-content: space-between; font-size: 0.84rem; color: var(--color-text-muted); }
    .sum-line .editorial { color: var(--color-blue-deep); font-size: 0.95rem; }
    .sum-divider { height: 1px; background: var(--color-border); margin: 0.2rem 0; }
    .sum-total { font-weight: 700; color: var(--color-text); }
    .sum-total .editorial { font-size: 1.6rem; }

    .sum-field { display: flex; flex-direction: column; gap: 0.4rem; margin-top: 0.4rem; }
    .sum-field label { font-size: 0.62rem; font-weight: 800; letter-spacing: 1.2px; color: #99a2af; }
    .sum-field .ed-select { min-width: 0; }

    .btn-send {
        display: flex; align-items: center; justify-content: center; gap: 9px;
        font-family: var(--font-sans); font-size: 0.9rem; font-weight: 600;
        background: var(--color-blue-deep); color: #fff;
        border: none; border-radius: 11px; padding: 13px; cursor: pointer;
        box-shadow: 0 10px 26px -10px rgba(10,25,47,0.55);
        transition: transform 0.4s var(--ease-spring), box-shadow 0.4s var(--ease-spring);
        margin-top: 0.5rem;
    }
    .btn-send svg { width: 15px; height: 15px; }
    .btn-send:hover { transform: translateY(-2px); box-shadow: 0 14px 32px -10px rgba(10,25,47,0.6); }
    .btn-draft {
        font-family: var(--font-sans); font-size: 0.84rem; font-weight: 600;
        color: var(--color-text-muted); background: none;
        border: 1px solid var(--color-border); border-radius: 11px;
        padding: 11px; cursor: pointer;
        transition: color 0.25s, border-color 0.25s;
    }
    .btn-draft:hover { color: var(--color-blue-deep); border-color: rgba(10,25,47,0.25); }
    .sum-note { font-size: 0.7rem; color: #99a2af; margin: 0.2rem 0 0; line-height: 1.5; }

    .toast {
        position: fixed; bottom: 1.6rem; left: 50%; transform: translateX(-50%);
        display: flex; align-items: center; gap: 10px;
        background: var(--color-blue-deep); color: #fff;
        font-size: 0.85rem; font-weight: 600;
        padding: 12px 20px; border-radius: 12px;
        box-shadow: 0 18px 44px -12px rgba(10,25,47,0.6);
        z-index: 200;
        animation: toast-in 0.4s var(--ease-spring);
    }
    @keyframes toast-in { from { opacity: 0; transform: translate(-50%, 12px); } to { opacity: 1; transform: translate(-50%, 0); } }
    .toast-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--color-ok); }

    /* En pantallas anchas, la columna de resumen se separa con un hairline (no es card) */
    @media (min-width: 981px) {
        .ed-side { border-left: 1px solid var(--color-border); padding-left: 2rem; }
        .editor-grid { gap: 1rem; }
    }
    @media (max-width: 980px) {
        .editor-grid { grid-template-columns: 1fr; gap: 2.6rem; }
        .ed-side { position: static; border-top: 1px solid var(--color-border); padding-top: 1.4rem; }
    }
    @media (max-width: 720px) {
        .lines-head { grid-template-columns: 1fr 60px 90px auto; }
        .lines-head span:nth-child(3), .lines-head span:nth-child(5) { display: none; }
    }
</style>
