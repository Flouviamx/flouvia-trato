---
// Vista imprimible de la cotización — "Guardar como PDF" del navegador.
// Personalizada por cuenta: color de marca, datos de contacto, mensaje y
// condiciones definidos en /app/ajustes (tabla orgs).
export const prerender = false;

import { getCotizacion, getOrg, money, lineTotal, quoteSubtotal, quoteIva, quoteTotal } from '../../../../lib/queries';

const { id } = Astro.params;
const [q, ORG] = await Promise.all([getCotizacion(id ?? ''), getOrg()]);
if (!q) return Astro.redirect('/app/cotizaciones');

const descuentoPct = (lista: number, nego: number) =>
    lista > 0 ? Math.round((1 - nego / lista) * 100) : 0;
const condiciones = ORG.pdfCondiciones ? ORG.pdfCondiciones.split('\n').filter(Boolean) : [];
const hoy = new Intl.DateTimeFormat('es-MX', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date());
---

<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{q.folio} — {ORG.nombre}</title>
</head>
<body>
    <!-- Toolbar (no se imprime) -->
    <div class="toolbar">
        <a href={`/app/cotizaciones/${q.id}`} class="tb-back">← Volver</a>
        <span class="tb-hint">Usa "Guardar como PDF" en el diálogo de impresión</span>
        <button class="tb-print" onclick="window.print()">Imprimir / Guardar PDF</button>
    </div>

    <main class="sheet">
        <!-- Encabezado con la marca de la org -->
        <header class="doc-head" style={`border-color: ${ORG.colorMarca}`}>
            <div class="dh-org">
                <span class="dh-mark" style={`background: ${ORG.colorMarca}`}>{ORG.inicial}</span>
                <div>
                    <h1>{ORG.nombre}</h1>
                    {ORG.razonSocial && <p>{ORG.razonSocial}</p>}
                    {ORG.rfc && <p>RFC {ORG.rfc}</p>}
                    {ORG.direccion && <p>{ORG.direccion}</p>}
                    {(ORG.email || ORG.telefono) && <p>{[ORG.email, ORG.telefono].filter(Boolean).join(' · ')}</p>}
                </div>
            </div>
            <div class="dh-doc">
                <span class="dh-label">COTIZACIÓN</span>
                <span class="dh-folio editorial" style={`color: ${ORG.colorMarca}`}>{q.folio}</span>
                <span class="dh-date">Emitida: {q.creada}</span>
                <span class="dh-date">Vigente hasta: {q.vigencia}</span>
            </div>
        </header>

        <!-- Cliente y términos -->
        <section class="doc-meta">
            <div>
                <span class="dm-label">PARA</span>
                <b>{q.cliente}</b>
            </div>
            <div>
                <span class="dm-label">TÉRMINOS</span>
                <b>{q.terminos}</b>
            </div>
            <div>
                <span class="dm-label">MONEDA</span>
                <b>MXN · IVA incluido en el total</b>
            </div>
        </section>

        <!-- Items -->
        <table class="doc-items">
            <thead>
                <tr style={`border-color: ${ORG.colorMarca}`}>
                    <th>Concepto</th>
                    <th class="num">Cantidad</th>
                    <th class="num">Precio unitario</th>
                    <th class="num">Importe</th>
                </tr>
            </thead>
            <tbody>
                {q.items.map((it) => (
                    <tr>
                        <td>
                            {it.descripcion}
                            <small>{it.unidad}</small>
                        </td>
                        <td class="num editorial">{it.cantidad.toLocaleString('es-MX')}</td>
                        <td class="num">
                            {ORG.pdfMostrarLista && it.precioNegociado !== null && (
                                <span class="strike">
                                    <s>{money(it.precioLista)}</s>
                                    <i>−{descuentoPct(it.precioLista, it.precioNegociado)}%</i>
                                </span>
                            )}
                            <span class="editorial">{money(it.precioNegociado ?? it.precioLista)}</span>
                        </td>
                        <td class="num editorial">{money(lineTotal(it))}</td>
                    </tr>
                ))}
            </tbody>
        </table>

        <!-- Totales -->
        <section class="doc-totals">
            <div><span>Subtotal</span><span class="editorial">{money(quoteSubtotal(q))}</span></div>
            <div><span>IVA {ORG.ivaPct}%</span><span class="editorial">{money(quoteIva(q))}</span></div>
            <div class="grand" style={`border-color: ${ORG.colorMarca}`}>
                <span>Total</span>
                <span class="editorial" style={`color: ${ORG.colorMarca}`}>{money(quoteTotal(q))}</span>
            </div>
        </section>

        {q.notas && (
            <section class="doc-notes">
                <span class="dm-label">NOTAS</span>
                <p>{q.notas}</p>
            </section>
        )}

        {condiciones.length > 0 && (
            <section class="doc-notes">
                <span class="dm-label">CONDICIONES COMERCIALES</span>
                <ul>
                    {condiciones.map((c) => <li>{c}</li>)}
                </ul>
            </section>
        )}

        <footer class="doc-foot">
            {ORG.pdfMensaje && <p class="df-msg">{ORG.pdfMensaje}</p>}
            <p class="df-meta">Documento generado el {hoy} · {ORG.nombre} vía Trato</p>
        </footer>
    </main>
</body>
</html>

<style>
    :root {
        --ink: #0f1729;
        --muted: #5b6472;
        --line: rgba(10,25,47,0.12);
    }
    * { box-sizing: border-box; }
    html, body {
        margin: 0; padding: 0;
        background: #eef0f3;
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
    }
    .editorial { font-weight: 600; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }

    .toolbar {
        display: flex; align-items: center; gap: 1rem;
        max-width: 820px; margin: 0 auto; padding: 1rem 1.2rem;
    }
    .tb-back { font-size: 0.82rem; font-weight: 600; color: var(--muted); text-decoration: none; }
    .tb-back:hover { color: var(--ink); }
    .tb-hint { flex: 1; font-size: 0.72rem; color: var(--muted); text-align: right; }
    .tb-print {
        font-family: inherit; font-size: 0.84rem; font-weight: 600;
        background: #0a192f; color: #fff; border: none; cursor: pointer;
        padding: 10px 18px; border-radius: 9px;
    }

    .sheet {
        max-width: 820px; margin: 0 auto 3rem;
        background: #fff; border-radius: 6px;
        box-shadow: 0 20px 50px -20px rgba(10,25,47,0.25);
        padding: 3rem 3.2rem;
    }

    .doc-head {
        display: flex; justify-content: space-between; gap: 2rem;
        padding-bottom: 1.6rem; margin-bottom: 1.6rem;
        border-bottom: 3px solid;
    }
    .dh-org { display: flex; gap: 14px; }
    .dh-mark {
        width: 46px; height: 46px; border-radius: 10px; flex-shrink: 0;
        color: #fff; display: flex; align-items: center; justify-content: center;
        font-size: 0.95rem; font-weight: 800;
    }
    .dh-org h1 { font-size: 1.2rem; font-weight: 800; margin: 0 0 2px; letter-spacing: -0.3px; }
    .dh-org p { font-size: 0.72rem; color: var(--muted); margin: 1px 0; }
    .dh-doc { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }
    .dh-label { font-size: 0.62rem; font-weight: 800; letter-spacing: 2px; color: var(--muted); }
    .dh-folio { font-size: 1.5rem; }
    .dh-date { font-size: 0.72rem; color: var(--muted); }

    .doc-meta {
        display: flex; gap: 3rem; flex-wrap: wrap;
        margin-bottom: 1.8rem;
    }
    .dm-label { display: block; font-size: 0.6rem; font-weight: 800; letter-spacing: 1.6px; color: var(--muted); margin-bottom: 3px; }
    .doc-meta b { font-size: 0.88rem; }

    .doc-items { width: 100%; border-collapse: collapse; margin-bottom: 1.4rem; }
    .doc-items th {
        text-align: left; font-size: 0.62rem; font-weight: 800; letter-spacing: 1.2px;
        text-transform: uppercase; color: var(--muted);
        padding: 0 10px 8px;
    }
    .doc-items thead tr { border-bottom: 2px solid; }
    .doc-items td {
        padding: 10px; font-size: 0.85rem;
        border-bottom: 1px solid var(--line);
        vertical-align: top;
    }
    .doc-items td small { display: block; font-size: 0.68rem; color: var(--muted); }
    .num { text-align: right; white-space: nowrap; }
    .strike { display: block; font-size: 0.7rem; color: #99a2af; }
    .strike i {
        font-style: normal; font-weight: 700; color: #059669;
        margin-left: 5px;
    }

    .doc-totals { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; margin-bottom: 2rem; }
    .doc-totals > div { display: flex; justify-content: space-between; gap: 4rem; min-width: 260px; font-size: 0.85rem; color: var(--muted); }
    .doc-totals .grand {
        border-top: 2px solid; padding-top: 9px; margin-top: 4px;
        font-weight: 700; color: var(--ink);
    }
    .doc-totals .grand .editorial { font-size: 1.35rem; }

    .doc-notes { margin-bottom: 1.6rem; }
    .doc-notes p, .doc-notes ul { font-size: 0.8rem; color: var(--ink); margin: 4px 0 0; line-height: 1.55; }
    .doc-notes ul { padding-left: 1.1rem; }
    .doc-notes li { margin-bottom: 2px; }

    .doc-foot { border-top: 1px solid var(--line); padding-top: 1.2rem; }
    .df-msg { font-size: 0.8rem; color: var(--ink); margin: 0 0 6px; }
    .df-meta { font-size: 0.66rem; color: var(--muted); margin: 0; }

    @media print {
        html, body { background: #fff; }
        .toolbar { display: none; }
        .sheet {
            max-width: none; margin: 0; padding: 0.4cm 0;
            box-shadow: none; border-radius: 0;
        }
        @page { margin: 1.4cm 1.6cm; }
    }
</style>
