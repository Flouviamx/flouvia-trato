        border: 1px solid var(--color-border); border-radius: 11px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.85), 0 1px 2px rgba(10,25,47,0.04);
        height: 42px; cursor: pointer; text-decoration: none;
        transition: transform 0.25s var(--ease-spring), box-shadow 0.25s var(--ease-spring), color 0.2s, border-color 0.2s;
    }
