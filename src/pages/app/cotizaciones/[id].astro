</style>

<script>
    // Acciones de la cotización contra PATCH/DELETE /api/cotizaciones/[id].
    document.addEventListener('DOMContentLoaded', () => {
        const panel = document.querySelector<HTMLElement>('.d-actions');
        if (!panel) return;
        const qid = panel.dataset.qid!;
        const token = panel.dataset.token!;
        const errorEl = document.getElementById('actError')!;

        // ── Presencia + conversación en vivo (polling cada 8s) ──
        // La presencia ("viendo ahora") se muestra solo en planes con la feature;
        // el aviso de mensajes nuevos aplica para todos (no recarga solo: ofrece botón).
        const lv = document.getElementById('liveViewing');
        const hasLiveView = panel.dataset.liveView === '1';
        const tlNew = document.getElementById('tlNew');
        let convBaseline: number | null = null;

        const poll = async () => {
            try {
                const r = await fetch(`/api/cotizaciones/${qid}/presence`);
                const d = await r.json();
                if (lv && hasLiveView) lv.hidden = !d.online;
                const count = Number(d.convCount) || 0;
                if (convBaseline === null) convBaseline = count;
                else if (tlNew && count > convBaseline) tlNew.hidden = false;
            } catch { /* ignora */ }
        };
        poll();
        setInterval(poll, 8000);
        tlNew?.addEventListener('click', () => location.reload());

        // ── Flujo de aprobación (gerencia) ──
        const apAction = async (action: string, btn: HTMLButtonElement) => {
            btn.disabled = true; errorEl.textContent = '';
            try {
                const res = await fetch(`/api/cotizaciones/${qid}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action }) });
                const d = await res.json();
                if (!res.ok) throw new Error(d.error || 'No se pudo procesar');
                location.reload();
            } catch (e: any) { errorEl.textContent = e.message; btn.disabled = false; }
        };
        document.getElementById('apApprove')?.addEventListener('click', (e) => apAction('approve_request', e.currentTarget as HTMLButtonElement));
        document.getElementById('apReject')?.addEventListener('click', (e) => { if (confirm('¿Rechazar esta solicitud de aprobación?')) apAction('reject_request', e.currentTarget as HTMLButtonElement); });

        const CONFIRM: Record<string, string> = {
            reject: '¿Marcar esta cotización como rechazada?',
            invoiced: 'El timbrado real ante el SAT llega con el plan Negocio. Por ahora la cotización se marcará como facturada. ¿Continuar?',
        };

        panel.querySelectorAll<HTMLButtonElement>('.act-do').forEach((btn) => {
            btn.addEventListener('click', async () => {
                const action = btn.dataset.action!;
                if (CONFIRM[action] && !confirm(CONFIRM[action])) return;
                btn.disabled = true;
                errorEl.textContent = '';
                try {
                    const res = await fetch(`/api/cotizaciones/${qid}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action }),
                    });
                    const data = await res.json();
                    if (!res.ok) throw new Error(data.error || 'No se pudo aplicar la acción');
                    location.reload();
                } catch (err: any) {
                    errorEl.textContent = err.message;
                    btn.disabled = false;
                }
            });
        });

        document.getElementById('btnWhats')?.addEventListener('click', () => {
            const folio = panel.dataset.folio || '';
            const cliente = panel.dataset.cliente || '';
            const total = panel.dataset.total || '';
            const link = `${location.origin}/q/${token}`;
            const msg = `¡Hola${cliente ? ' ' + cliente : ''}! Te comparto la cotización ${folio}${total ? ' por ' + total : ''}. Puedes revisarla y aprobarla aquí: ${link}`;
            window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
        });

        document.getElementById('btnCopy')?.addEventListener('click', async (e) => {
            const btn = e.currentTarget as HTMLButtonElement;
            await navigator.clipboard.writeText(`${location.origin}/q/${token}`);
            const prev = btn.textContent;
            btn.textContent = '✓ Link copiado';
            setTimeout(() => { btn.textContent = prev; }, 1800);
        });

        document.getElementById('btnReply')?.addEventListener('click', async (e) => {
            const btn = e.currentTarget as HTMLButtonElement;
            const ta = document.getElementById('replyMsg') as HTMLTextAreaElement;
            const mensaje = (ta?.value || '').trim();
            if (!mensaje) { errorEl.textContent = 'Escribe una respuesta.'; return; }
            btn.disabled = true; errorEl.textContent = '';
            try {
                const res = await fetch(`/api/cotizaciones/${qid}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'reply', mensaje }),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo enviar');
                location.reload();
            } catch (err: any) {
                errorEl.textContent = err.message;
                btn.disabled = false;
            }
        });

        document.getElementById('btnDuplicate')?.addEventListener('click', async (e) => {
            const btn = e.currentTarget as HTMLButtonElement;
            btn.disabled = true;
            errorEl.textContent = '';
            try {
                const res = await fetch(`/api/cotizaciones/${qid}/duplicate`, { method: 'POST' });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo duplicar');
                location.href = `/app/cotizaciones/${data.id}`;
            } catch (err: any) {
                errorEl.textContent = err.message;
                btn.disabled = false;
            }
        });

        document.getElementById('btnDelete')?.addEventListener('click', async () => {
            if (!confirm('¿Eliminar este borrador? Esta acción no se puede deshacer.')) return;
            const res = await fetch(`/api/cotizaciones/${qid}`, { method: 'DELETE' });
            if (res.ok) location.href = '/app/cotizaciones';
            else errorEl.textContent = (await res.json()).error || 'No se pudo eliminar';
        });
    });
</script>
