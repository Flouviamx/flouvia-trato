---
// Detalle de cotización — items, totales, timeline de eventos y acciones. Datos reales (Neon).
import AppLayout from '../../../layouts/AppLayout.astro';
import { getCotizacion, STATUS_META, money, lineTotal, quoteSubtotal, quoteIva, quoteTotal } from '../../../lib/queries';

const { id } = Astro.params;
const q = await getCotizacion(id ?? '');
if (!q) return Astro.redirect('/app/cotizaciones');

const meta = STATUS_META[q.status];
const dotColor = (tipo: string) =>
    tipo === 'approved' || tipo === 'paid' ? '#10b981'
    : tipo === 'viewed' ? '#7c3aed'
    : tipo === 'sent' ? '#3b82f6'
    : tipo === 'rejected' ? '#ef4444'
    : '#cbd5e1';
---

<AppLayout title={`${q.folio} — Trato`} page="cotizaciones" heading={q.folio}>
    <span slot="topbar-actions" class="status-pill tb-status" style={`color:${meta.color}; background:${meta.bg}`}>{meta.label}</span>

    <a href="/app/cotizaciones" class="back-link">← Cotizaciones</a>

    <div class="live-viewing" id="liveViewing" hidden>
        <span class="lv-dot"></span>
        <span>El cliente está viendo esta cotización <b>ahora mismo</b> — buen momento para llamarle.</span>
    </div>

    {q.aprobEstado === 'pendiente' && (
        <div class="approval-banner">
            <div class="ap-info">
                <span class="ap-title">⏳ Pendiente de aprobación</span>
                <span class="ap-motivo">{q.aprobMotivo}</span>
            </div>
            <div class="ap-actions">
                <button class="ap-approve" id="apApprove">Aprobar y enviar</button>
                <button class="ap-reject" id="apReject">Rechazar</button>
            </div>
        </div>
    )}
    {q.aprobEstado === 'rechazada' && (
        <div class="approval-banner ap-rejected">
            <span class="ap-title">Solicitud de aprobación rechazada por gerencia</span>
        </div>
    )}

    <div class="detail-grid">
        <div class="d-main">
            <!-- Encabezado -->
            <section class="d-head">
                <div class="dh-client">
                    <div class="dh-avatar">{q.clienteInicial}</div>
                    <div>
                        <h2 class="dh-name">{q.cliente}</h2>
                        <p class="dh-meta">{q.terminos} · Vigente hasta {q.vigencia} · Creada {q.creada}</p>
                    </div>
                </div>
                <div class="dh-total">
                    <span class="dh-total-label">TOTAL</span>
                    <span class="editorial dh-total-val">{money(quoteTotal(q))}</span>
                </div>
            </section>

            <!-- Items -->
            <section class="d-items">
                <div class="section-head"><h2>Detalle</h2></div>
                <div class="di-head"><span>Producto</span><span>Cant.</span><span>Precio</span><span class="di-right">Importe</span></div>
                {q.items.map((it) => (
                    <div class="di-row">
                        <span class="di-name">{it.descripcion}<small>{it.unidad}</small></span>
                        <span class="di-qty">{it.cantidad.toLocaleString('es-MX')}</span>
                        <span class="di-price">
                            {it.precioNegociado !== null && <s>{money(it.precioLista)}</s>}
                            <span class="editorial">{money(it.precioNegociado ?? it.precioLista)}</span>
                        </span>
                        <span class="editorial di-amount di-right">{money(lineTotal(it))}</span>
                    </div>
                ))}
                <div class="di-totals">
                    <div class="dt-line"><span>Subtotal</span><span class="editorial">{money(quoteSubtotal(q))}</span></div>
                    <div class="dt-line"><span>IVA 16%</span><span class="editorial">{money(quoteIva(q))}</span></div>
                    <div class="dt-line dt-grand"><span>Total</span><span class="editorial">{money(quoteTotal(q))}</span></div>
                </div>
            </section>

            {q.notas && (
                <section class="d-notes">
                    <div class="section-head"><h2>Notas</h2></div>
                    <p>{q.notas}</p>
                </section>
            )}
        </div>

        <!-- Sidebar: acciones + timeline -->
        <aside class="d-side">
            <section class="d-actions" data-qid={q.id} data-token={q.token} data-folio={q.folio} data-cliente={q.cliente} data-total={money(quoteTotal(q))}>
                <div class="section-head"><h2>Acciones</h2></div>
                {q.status === 'draft' && (
                    <button class="act-primary act-do" data-action="send">Enviar al cliente</button>
                )}
                <a href={`/q/${q.token}`} class:list={[q.status === 'draft' ? 'act-secondary act-link' : 'act-primary']} target="_blank">
                    <span>Ver link público</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
                <button class="act-whats" id="btnWhats">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.15-1.7-.85-2-.95-.26-.1-.46-.15-.65.15-.2.3-.74.94-.9 1.13-.17.2-.34.22-.63.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.04-.17-.3-.02-.46.13-.6.13-.14.3-.34.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.65-1.57-.9-2.15-.24-.56-.48-.48-.65-.49h-.56c-.2 0-.5.07-.77.37-.26.3-1 .98-1 2.4 0 1.4 1.03 2.76 1.17 2.96.14.2 2.02 3.08 4.9 4.32.68.3 1.22.47 1.64.6.69.22 1.31.19 1.8.12.55-.08 1.7-.7 1.94-1.36.24-.67.24-1.24.17-1.36-.07-.12-.26-.2-.56-.34zM12 2a10 10 0 0 0-8.6 15.06L2 22l5.06-1.33A10 10 0 1 0 12 2z"/></svg>
                    <span>Enviar por WhatsApp</span>
                </button>
                <button class="act-secondary" id="btnCopy">Copiar link</button>
                <a href={`/app/cotizaciones/${q.id}/imprimir`} target="_blank" class="act-secondary act-link">Descargar PDF</a>
                <button class="act-secondary" id="btnDuplicate">Duplicar cotización</button>

                {(q.status === 'sent' || q.status === 'viewed') && (
                    <>
                        <button class="act-ok act-do" data-action="approve">Marcar aprobada</button>
                        <button class="act-danger act-do" data-action="reject">Marcar rechazada</button>
                        <button class="act-secondary act-do" data-action="resend">Reenviar al cliente</button>
                    </>
                )}
                {q.status === 'approved' && (
                    <>
                        <button class="act-ok act-do" data-action="paid">Registrar pago</button>
                        <button class="act-cfdi act-do" data-action="invoiced">Timbrar CFDI 4.0</button>
                    </>
                )}
                {q.status === 'paid' && (
                    <button class="act-cfdi act-do" data-action="invoiced">Timbrar CFDI 4.0</button>
                )}
                {q.status === 'expired' && (
                    <button class="act-secondary act-do" data-action="resend">Reenviar al cliente</button>
                )}
                {q.status === 'draft' && (
                    <button class="act-delete" id="btnDelete">Eliminar borrador</button>
                )}
                <p class="act-error" id="actError"></p>
            </section>

            <section class="d-timeline">
                <div class="section-head"><h2>Actividad</h2></div>
                <div class="tl">
                    {q.eventos.map((e) => (
                        <div class="tl-item">
                            <span class="tl-dot" style={`background:${dotColor(e.tipo)}`}></span>
                            <div class="tl-body">
                                <span class="tl-text">{e.detalle}</span>
                                <span class="tl-time">{e.cuando}</span>
                            </div>
                        </div>
                    ))}
                </div>
                <div class="tl-reply">
                    <textarea id="replyMsg" rows="2" placeholder="Responder al cliente (aparece en su link)…"></textarea>
                    <button class="tl-reply-btn" id="btnReply">Enviar respuesta</button>
                </div>
            </section>
        </aside>
    </div>
</AppLayout>

<style>
    .tb-status { font-size: 0.74rem; }
    .back-link {
        display: inline-block; font-size: 0.78rem; font-weight: 600;
        color: var(--color-text-muted); text-decoration: none; margin-bottom: 0.9rem;
        transition: color 0.25s;
    }
    .back-link:hover { color: var(--color-blue-deep); }

    .live-viewing {
        display: flex; align-items: center; gap: 10px;
        background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.3);
        color: #047857; border-radius: 12px; padding: 10px 14px; margin-bottom: 0.9rem;
        font-size: 0.85rem; font-weight: 600;
        animation: lv-in 0.4s var(--ease-spring);
    }
    @keyframes lv-in { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: none; } }
    .live-viewing b { font-weight: 800; }
    .lv-dot { width: 9px; height: 9px; border-radius: 50%; background: #10b981; flex-shrink: 0; animation: lv-pulse 1.6s infinite; }
    @keyframes lv-pulse { 0% { box-shadow: 0 0 0 0 rgba(16,185,129,0.45); } 70% { box-shadow: 0 0 0 8px rgba(16,185,129,0); } 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); } }

    .approval-banner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.35); border-radius: 12px; padding: 12px 16px; margin-bottom: 0.9rem; }
    .approval-banner.ap-rejected { background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.3); }
    .ap-info { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .ap-title { font-size: 0.9rem; font-weight: 700; color: #92600a; }
    .ap-rejected .ap-title { color: var(--color-danger); }
    .ap-motivo { font-size: 0.78rem; color: var(--color-text-muted); }
    .ap-actions { display: flex; gap: 0.5rem; }
    .ap-approve { font-family: var(--font-sans); font-size: 0.82rem; font-weight: 700; cursor: pointer; color: #fff; background: var(--color-ok); border: none; border-radius: 9px; padding: 9px 16px; }
    .ap-reject { font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600; cursor: pointer; color: var(--color-danger); background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.25); border-radius: 9px; padding: 9px 14px; }
    .ap-approve:disabled, .ap-reject:disabled { opacity: 0.6; cursor: wait; }

    /* Encabezado de sección (eyebrow + hairline) — idéntico al dashboard */
    .section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.2rem; padding-bottom: 0.7rem; border-bottom: 1px solid var(--color-border); }
    .section-head h2 { font-size: 0.7rem; font-weight: 800; letter-spacing: 1.6px; text-transform: uppercase; color: #99a2af; margin: 0; }

    .detail-grid { display: grid; grid-template-columns: 1fr 300px; gap: 3rem; align-items: start; }
    .d-main { display: flex; flex-direction: column; min-width: 0; }

    .d-head { display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; flex-wrap: wrap; padding-bottom: 1.8rem; margin-bottom: 2.6rem; border-bottom: 1px solid var(--color-border); }
    .dh-client { display: flex; align-items: center; gap: 14px; }
    .dh-avatar {
        width: 46px; height: 46px; border-radius: 12px;
        background: var(--color-blue-deep); color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.9rem; font-weight: 800;
    }
    .dh-name { font-size: 1.15rem; font-weight: 700; margin: 0; letter-spacing: -0.3px; }
    .dh-meta { font-size: 0.78rem; color: var(--color-text-muted); margin: 3px 0 0; }
    .dh-total { display: flex; flex-direction: column; align-items: flex-end; }
    .dh-total-label { font-size: 0.58rem; font-weight: 800; letter-spacing: 1.6px; color: #99a2af; }
    .dh-total-val { font-size: 2rem; color: var(--color-blue-deep); line-height: 1.1; }

    .d-items { margin-bottom: 2.6rem; }
    .di-head, .di-row {
        display: grid; grid-template-columns: 1.8fr 80px 150px 1fr;
        gap: 1rem; align-items: center; padding: 0.8rem 0.6rem;
    }
    .di-head {
        padding-top: 0; padding-bottom: 0.55rem;
        font-size: 0.65rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
        color: var(--color-text-muted);
        border-bottom: 1px solid var(--color-border);
    }
    .di-row { border-bottom: 1px solid var(--color-border); transition: background 0.25s var(--ease-ios); }
    .di-row:hover { background: var(--color-bg-soft); }
    .di-name { font-size: 0.86rem; font-weight: 600; display: flex; flex-direction: column; }
    .di-name small { font-size: 0.68rem; color: #99a2af; font-weight: 500; }
    .di-qty { font-size: 0.84rem; color: var(--color-text-muted); }
    .di-price { display: flex; flex-direction: column; }
    .di-price s { font-size: 0.7rem; color: #b6bcc6; }
    .di-price .editorial { font-size: 0.92rem; color: var(--color-blue-deep); }
    .di-amount { font-size: 0.98rem; color: var(--color-blue-deep); }
    .di-right { text-align: right; }

    .di-totals { padding: 1.1rem 0.6rem 0; display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-end; }
    .dt-line { display: flex; justify-content: space-between; gap: 3rem; min-width: 230px; font-size: 0.82rem; color: var(--color-text-muted); }
    .dt-line .editorial { color: var(--color-blue-deep); font-size: 0.95rem; }
    .dt-grand { border-top: 1px solid var(--color-border); padding-top: 0.6rem; font-weight: 700; color: var(--color-text); }
    .dt-grand .editorial { font-size: 1.3rem; }

    .d-notes { margin-bottom: 2.6rem; }
    .d-notes p { font-size: 0.86rem; color: var(--color-text); margin: 0; line-height: 1.55; }

    .d-side { display: flex; flex-direction: column; gap: 2.6rem; position: sticky; top: 76px; }
    .d-actions { display: flex; flex-direction: column; gap: 0.5rem; }
    /* el .section-head ocupa el ancho completo de la columna de acciones */
    .d-actions .section-head, .d-timeline .section-head { margin-bottom: 1rem; }
    .act-primary {
        display: flex; align-items: center; justify-content: center; gap: 8px;
        font-size: 0.86rem; font-weight: 600; text-decoration: none;
        background: var(--color-blue-deep); color: #fff;
        padding: 11px; border-radius: 10px;
        box-shadow: 0 8px 22px -10px rgba(10,25,47,0.5);
        transition: transform 0.4s var(--ease-spring);
    }
    .act-primary svg { width: 14px; height: 14px; }
    .act-primary:hover { transform: translateY(-2px); }
    .act-secondary {
        font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 10px;
        padding: 10px; cursor: pointer;
        transition: background 0.25s, border-color 0.25s;
    }
    .act-secondary:hover { background: #fff; border-color: rgba(10,25,47,0.2); }
    .act-whats {
        display: flex; align-items: center; justify-content: center; gap: 8px;
        font-family: var(--font-sans); font-size: 0.84rem; font-weight: 600; cursor: pointer;
        color: #0b7a4b; background: rgba(37,211,102,0.1);
        border: 1px solid rgba(37,211,102,0.3); border-radius: 10px; padding: 10px;
        transition: background 0.25s, transform 0.4s var(--ease-spring);
    }
    .act-whats svg { width: 15px; height: 15px; }
    .act-whats:hover { background: rgba(37,211,102,0.16); transform: translateY(-1px); }
    .act-cfdi {
        font-family: var(--font-sans); font-size: 0.82rem; font-weight: 700;
        color: #059669; background: rgba(16,185,129,0.08);
        border: 1px solid rgba(16,185,129,0.25); border-radius: 10px;
        padding: 10px; cursor: pointer;
        transition: background 0.25s;
    }
    .act-cfdi:hover { background: rgba(16,185,129,0.14); }

    .act-primary.act-do {
        font-family: var(--font-sans); font-size: 0.86rem; border: none; cursor: pointer;
    }
    .act-link { display: flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none; text-align: center; }
    .act-link svg { width: 13px; height: 13px; }
    .act-ok {
        font-family: var(--font-sans); font-size: 0.82rem; font-weight: 700;
        color: #fff; background: var(--color-ok);
        border: none; border-radius: 10px; padding: 10px; cursor: pointer;
        box-shadow: 0 8px 22px -10px rgba(16,185,129,0.55);
        transition: transform 0.4s var(--ease-spring);
    }
    .act-ok:hover { transform: translateY(-2px); }
    .act-danger {
        font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600;
        color: var(--color-danger); background: rgba(239,68,68,0.07);
        border: 1px solid rgba(239,68,68,0.22); border-radius: 10px;
        padding: 10px; cursor: pointer;
        transition: background 0.25s;
    }
    .act-danger:hover { background: rgba(239,68,68,0.13); }
    .act-delete {
        font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600;
        color: var(--color-text-muted); background: none; border: none;
        padding: 6px; cursor: pointer; transition: color 0.25s;
    }
    .act-delete:hover { color: var(--color-danger); }
    .act-error { font-size: 0.74rem; color: var(--color-danger); margin: 0; min-height: 0; }
    button:disabled { opacity: 0.55; cursor: wait; }

    .d-timeline { display: flex; flex-direction: column; }
    .tl { display: flex; flex-direction: column; gap: 1rem; position: relative; }
    .tl::before { content: ''; position: absolute; left: 3.5px; top: 8px; bottom: 8px; width: 1px; background: var(--color-border); }
    .tl-item { display: flex; gap: 13px; position: relative; }
    .tl-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 4px; flex-shrink: 0; box-shadow: 0 0 0 3px #fff; z-index: 1; }
    .tl-body { display: flex; flex-direction: column; gap: 1px; }
    .tl-text { font-size: 0.8rem; font-weight: 500; color: var(--color-text); }
    .tl-time { font-size: 0.68rem; color: var(--color-text-muted); }

    .tl-reply { margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--color-border); display: flex; flex-direction: column; gap: 0.5rem; }
    .tl-reply textarea {
        font-family: var(--font-sans); font-size: 0.82rem; color: var(--color-text);
        background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 9px;
        padding: 9px 11px; resize: vertical;
    }
    .tl-reply textarea:focus { outline: none; border-color: var(--color-blue-deep); }
    .tl-reply-btn {
        font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600; cursor: pointer;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px; padding: 8px; transition: border-color 0.25s;
    }
    .tl-reply-btn:hover { border-color: rgba(10,25,47,0.25); }
    .tl-reply-btn:disabled { opacity: 0.55; cursor: wait; }

    @media (max-width: 980px) {
        .detail-grid { grid-template-columns: 1fr; }
        .d-side { position: static; }
    }
    @media (max-width: 680px) {
        .di-head { display: none; }
        .di-row { grid-template-columns: 1fr auto; }
        .di-qty, .di-price { display: none; }
    }
</style>

<script>
    // Acciones de la cotización contra PATCH/DELETE /api/cotizaciones/[id].
    document.addEventListener('DOMContentLoaded', () => {
        const panel = document.querySelector<HTMLElement>('.d-actions');
        if (!panel) return;
        const qid = panel.dataset.qid!;
        const token = panel.dataset.token!;
        const errorEl = document.getElementById('actError')!;

        // ── Presencia en vivo: "el cliente está viendo ahora" ──
        const lv = document.getElementById('liveViewing');
        if (lv) {
            const checkPresence = async () => {
                try {
                    const r = await fetch(`/api/cotizaciones/${qid}/presence`);
                    const d = await r.json();
                    lv.hidden = !d.online;
                } catch { /* ignora */ }
            };
            checkPresence();
            setInterval(checkPresence, 8000);
        }

        // ── Flujo de aprobación (gerencia) ──
        const apAction = async (action: string, btn: HTMLButtonElement) => {
            btn.disabled = true; errorEl.textContent = '';
            try {
                const res = await fetch(`/api/cotizaciones/${qid}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action }) });
                const d = await res.json();
                if (!res.ok) throw new Error(d.error || 'No se pudo procesar');
                location.reload();
            } catch (e: any) { errorEl.textContent = e.message; btn.disabled = false; }
        };
        document.getElementById('apApprove')?.addEventListener('click', (e) => apAction('approve_request', e.currentTarget as HTMLButtonElement));
        document.getElementById('apReject')?.addEventListener('click', (e) => { if (confirm('¿Rechazar esta solicitud de aprobación?')) apAction('reject_request', e.currentTarget as HTMLButtonElement); });

        const CONFIRM: Record<string, string> = {
            reject: '¿Marcar esta cotización como rechazada?',
            invoiced: 'El timbrado real ante el SAT llega con el plan Negocio. Por ahora la cotización se marcará como facturada. ¿Continuar?',
        };

        panel.querySelectorAll<HTMLButtonElement>('.act-do').forEach((btn) => {
            btn.addEventListener('click', async () => {
                const action = btn.dataset.action!;
                if (CONFIRM[action] && !confirm(CONFIRM[action])) return;
                btn.disabled = true;
                errorEl.textContent = '';
                try {
                    const res = await fetch(`/api/cotizaciones/${qid}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action }),
                    });
                    const data = await res.json();
                    if (!res.ok) throw new Error(data.error || 'No se pudo aplicar la acción');
                    location.reload();
                } catch (err: any) {
                    errorEl.textContent = err.message;
                    btn.disabled = false;
                }
            });
        });

        document.getElementById('btnWhats')?.addEventListener('click', () => {
            const folio = panel.dataset.folio || '';
            const cliente = panel.dataset.cliente || '';
            const total = panel.dataset.total || '';
            const link = `${location.origin}/q/${token}`;
            const msg = `¡Hola${cliente ? ' ' + cliente : ''}! Te comparto la cotización ${folio}${total ? ' por ' + total : ''}. Puedes revisarla y aprobarla aquí: ${link}`;
            window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
        });

        document.getElementById('btnCopy')?.addEventListener('click', async (e) => {
            const btn = e.currentTarget as HTMLButtonElement;
            await navigator.clipboard.writeText(`${location.origin}/q/${token}`);
            const prev = btn.textContent;
            btn.textContent = '✓ Link copiado';
            setTimeout(() => { btn.textContent = prev; }, 1800);
        });

        document.getElementById('btnReply')?.addEventListener('click', async (e) => {
            const btn = e.currentTarget as HTMLButtonElement;
            const ta = document.getElementById('replyMsg') as HTMLTextAreaElement;
            const mensaje = (ta?.value || '').trim();
            if (!mensaje) { errorEl.textContent = 'Escribe una respuesta.'; return; }
            btn.disabled = true; errorEl.textContent = '';
            try {
                const res = await fetch(`/api/cotizaciones/${qid}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'reply', mensaje }),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo enviar');
                location.reload();
            } catch (err: any) {
                errorEl.textContent = err.message;
                btn.disabled = false;
            }
        });

        document.getElementById('btnDuplicate')?.addEventListener('click', async (e) => {
            const btn = e.currentTarget as HTMLButtonElement;
            btn.disabled = true;
            errorEl.textContent = '';
            try {
                const res = await fetch(`/api/cotizaciones/${qid}/duplicate`, { method: 'POST' });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo duplicar');
                location.href = `/app/cotizaciones/${data.id}`;
            } catch (err: any) {
                errorEl.textContent = err.message;
                btn.disabled = false;
            }
        });

        document.getElementById('btnDelete')?.addEventListener('click', async () => {
            if (!confirm('¿Eliminar este borrador? Esta acción no se puede deshacer.')) return;
            const res = await fetch(`/api/cotizaciones/${qid}`, { method: 'DELETE' });
            if (res.ok) location.href = '/app/cotizaciones';
            else errorEl.textContent = (await res.json()).error || 'No se pudo eliminar';
        });
    });
</script>
