    .d-side { display: flex; flex-direction: column; gap: 2.6rem; position: sticky; top: 76px; }
    .d-actions { display: flex; flex-direction: column; gap: 0.5rem; }
    /* el .section-head ocupa el ancho completo de la columna de acciones */
    .d-actions .section-head, .d-timeline .section-head { margin-bottom: 1rem; }
    .act-primary {
