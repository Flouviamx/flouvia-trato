        font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600; cursor: pointer;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px; padding: 8px; transition: border-color 0.25s;
    }
    .tl-reply-btn:hover { border-color: rgba(10,25,47,0.25); }
    .tl-reply-btn:disabled { opacity: 0.55; cursor: wait; }

    @media (max-width: 980px) {
        .detail-grid { grid-template-columns: 1fr; }
        .d-side { position: static; }
