---
// Detalle de cotización — items, totales, timeline de eventos y acciones. Datos reales (Neon).
import AppLayout from '../../../layouts/AppLayout.astro';
import { getCotizacion, getDocumentosFiscales, getMyMembership, getOrg, STATUS_META, money, lineTotal, quoteSubtotal, quoteIva, quoteTotal } from '../../../lib/queries';
import { memberCan } from '../../../lib/permissions';

const { id } = Astro.params;
const [q, ME, ORG] = await Promise.all([getCotizacion(id ?? ''), getMyMembership(), getOrg()]);
if (!q) return Astro.redirect('/app/cotizaciones');
const docsFiscales = await getDocumentosFiscales(id ?? '');
const DOC_LABEL: Record<string, string> = { cfdi_40: 'CFDI 4.0', invoice: 'Factura comercial', dian_einvoice: 'Factura DIAN' };
const canCotizar = memberCan(ME, 'cotizar');
const canAprobar = memberCan(ME, 'aprobar');

const hasLiveView = ['pro', 'scale', 'developer'].includes(ORG.plan_raw);

// Stepper de estado (solo flujo positivo; rechazada/expirada lo omiten — basta el pill)
const STEPS = [
    { key: 'draft', label: 'Borrador' },
    { key: 'sent', label: 'Enviada' },
    { key: 'viewed', label: 'Vista' },
    { key: 'approved', label: 'Aprobada' },
    { key: q.status === 'invoiced' ? 'invoiced' : 'paid', label: q.status === 'invoiced' ? 'Facturada' : 'Pagada' },
];
const STEP_IDX: Record<string, number> = { draft: 0, sent: 1, viewed: 2, approved: 3, paid: 4, invoiced: 4 };
const showStepper = q.status in STEP_IDX;
const stepIdx = STEP_IDX[q.status] ?? 0;

const meta = STATUS_META[q.status];
const dotColor = (tipo: string) =>
    tipo === 'approved' || tipo === 'paid' ? '#10b981'
    : tipo === 'viewed' ? '#7c3aed'
    : tipo === 'sent' ? '#3b82f6'
    : tipo === 'rejected' ? '#ef4444'
    : '#cbd5e1';
---

<AppLayout title={`${q.folio} — Cord`} page="cotizaciones" heading={q.folio} crumbs={[{ label: 'Cotizaciones', href: '/app/cotizaciones' }]}>
    <span slot="topbar-actions" class="status-pill tb-status" style={`color:${meta.color}; background:${meta.bg}`}>{meta.label}</span>

    <a href="/app/cotizaciones" class="back-link">← Cotizaciones</a>

    {q.aprobEstado === 'pendiente' && (
        <div class="approval-banner">
            <div class="ap-info">
                <span class="ap-title">⏳ Pendiente de aprobación</span>
                <span class="ap-motivo">{q.aprobMotivo}</span>
            </div>
            <div class="ap-actions">
                <button class="ap-approve" id="apApprove">Aprobar y enviar</button>
                <button class="ap-reject" id="apReject">Rechazar</button>
            </div>
        </div>
    )}
    {q.aprobEstado === 'rechazada' && (
        <div class="approval-banner ap-rejected">
            <span class="ap-title">Solicitud de aprobación rechazada por gerencia</span>
        </div>
    )}

    {showStepper && (
        <div class="q-stepper">
            {STEPS.map((s, i) => (
                <div class:list={['qs-step', { done: i < stepIdx, current: i === stepIdx }]}>
                    <span class="qs-dot">{i < stepIdx ? '✓' : i + 1}</span>
                    <span class="qs-label">{s.label}</span>
                </div>
            ))}
        </div>
    )}

    <div class="detail-grid">
        <div class="d-main">
            <!-- Encabezado -->
            <section class="d-head">
                <div class="dh-client">
                    <div class="dh-avatar">{q.clienteInicial}</div>
                    <div>
                        <h2 class="dh-name">
                            {q.cliente} 
                            <span class="version-badge">V{q.version}</span>
                            {hasLiveView && (
                                <span class="lv-badge" id="liveViewing" hidden>
                                    <span class="lv-dot"></span> Viendo ahora
                                </span>
                            )}
                        </h2>
                        <p class="dh-meta">{q.terminos} · Vigente hasta {q.vigencia} · Creada {q.creada}</p>
                    </div>
                </div>
                <div class="dh-total">
                    <span class="dh-total-label">TOTAL</span>
                    <span class="editorial dh-total-val">{money(quoteTotal(q))}</span>
                </div>
            </section>

            <!-- Items -->
            <section class="d-items">
                <div class="section-head"><h2>Detalle</h2></div>
                <div class="di-head"><span>Producto</span><span>Cant.</span><span>Precio</span><span class="di-right">Importe</span></div>
                {q.items.map((it) => (
                    <div class="di-row">
                        <span class="di-name">{it.descripcion}<small>{it.unidad}</small></span>
                        <span class="di-qty">{it.cantidad.toLocaleString('es-MX')}</span>
                        <span class="di-price">
                            {it.precioNegociado !== null && <s>{money(it.precioLista)}</s>}
                            <span class="editorial">{money(it.precioNegociado ?? it.precioLista)}</span>
                        </span>
                        <span class="editorial di-amount di-right">{money(lineTotal(it))}</span>
                    </div>
                ))}
                <div class="di-totals">
                    <div class="dt-line"><span>Subtotal</span><span class="editorial">{money(quoteSubtotal(q))}</span></div>
                    <div class="dt-line"><span>IVA 16%</span><span class="editorial">{money(quoteIva(q))}</span></div>
                    <div class="dt-line dt-grand"><span>Total</span><span class="editorial">{money(quoteTotal(q))}</span></div>
                </div>
            </section>

            {q.notas && (
                <section class="d-notes">
                    <div class="section-head"><h2>Notas</h2></div>
                    <p>{q.notas}</p>
                </section>
            )}

            {q.versiones && q.versiones.length > 0 && (
                <section class="d-versions">
                    <details class="v-accordion">
                        <summary>Historial de versiones ({q.versiones.length})</summary>
                        <div class="v-list">
                            {q.versiones.map(v => (
                                <div class="v-item">
                                    <span class="v-badge">V{v.version}</span>
                                    <span class="v-date">{v.fecha}</span>
                                    <span class="editorial v-total">{money(v.total)}</span>
                                </div>
                            ))}
                        </div>
                    </details>
                </section>
            )}

            {docsFiscales.length > 0 && (
                <section class="d-fiscal">
                    <div class="section-head"><h2>Documentos fiscales</h2></div>
                    <div class="df-list">
                        {docsFiscales.map((d) => (
                            <div class="df-row" data-status={d.status}>
                                <span class="df-icon">{d.status === 'issued' ? '🧾' : '⚠️'}</span>
                                <div class="df-body">
                                    <div class="df-top">
                                        <span class="df-type">{DOC_LABEL[d.tipo] || d.tipo}</span>
                                        <span class="df-pais">{d.pais}</span>
                                        {d.simulado && <span class="df-sim">Simulado</span>}
                                        <span class:list={['df-state', d.status]}>
                                            {d.status === 'issued' ? 'Emitido' : d.status === 'error' ? 'Error' : 'Pendiente'}
                                        </span>
                                    </div>
                                    {d.fiscalId && <div class="df-uuid">UUID: <code>{d.fiscalId}</code></div>}
                                    <div class="df-meta">{d.creado}</div>
                                </div>
                                <div class="df-actions">
                                    {d.pdfUrl && <a href={d.pdfUrl} target="_blank" rel="noopener" class="df-link">PDF</a>}
                                    {d.xmlUrl && <a href={d.xmlUrl} target="_blank" rel="noopener" class="df-link">XML</a>}
                                </div>
                            </div>
                        ))}
                    </div>
                    {docsFiscales.some((d) => d.simulado) && (
                        <p class="df-note">Un timbre <b>simulado</b> significa que aún no hay PAC conectado (faltan <code>PAC_API_URL</code>/<code>PAC_API_KEY</code>). El registro queda para auditoría, pero no es un CFDI válido ante el SAT.</p>
                    )}
                </section>
            )}
        </div>

        <!-- Sidebar: acciones + timeline -->
        <aside class="d-side">
            <section class="d-actions" data-qid={q.id} data-token={q.token} data-folio={q.folio} data-cliente={q.cliente} data-total={money(quoteTotal(q))} data-live-view={hasLiveView ? '1' : ''}>
                <div class="section-head" style="margin-bottom: 0.5rem;"><h2>Acciones</h2></div>
                
                <!-- PRIMARY ACTIONS -->
                {q.status === 'draft' && canCotizar && (
                    <button class="act-primary act-do" data-action="send">Enviar al cliente</button>
                )}
                
                {(q.status === 'sent' || q.status === 'viewed') && canAprobar && (
                    <button class="act-ok act-do" data-action="approve">Marcar aprobada</button>
                )}
                {(q.status === 'sent' || q.status === 'viewed') && canAprobar && (
                    <button class="act-danger act-do" data-action="reject">Marcar rechazada</button>
                )}
                {(q.status === 'sent' || q.status === 'viewed' || q.status === 'expired') && canCotizar && (
                    <a href={`/app/cotizaciones/${q.id}/editar`} class="act-secondary act-link" style="text-align: center; text-decoration: none; display: block;">Modificar y reenviar (V{q.version + 1})</a>
                )}
                {q.status === 'approved' && canAprobar && (
                    <button class="act-ok act-do" data-action="paid">Registrar pago</button>
                )}
                {(q.status === 'approved' || q.status === 'paid') && canAprobar && (
                    <button class="act-cfdi act-do" data-action="invoiced">Timbrar CFDI 4.0</button>
                )}

                <!-- SECONDARY ACTIONS GRID -->
                {q.status !== 'draft' && (
                    <div class="act-grid">
                        <a href={`/q/${q.token}`} class="act-util" target="_blank" title="Ver link público">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                        </a>
                        <button class="act-util" id="btnCopy" title="Copiar link">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                        </button>
                        <a href={`/app/cotizaciones/${q.id}/imprimir`} target="_blank" class="act-util" title="Descargar PDF">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        </a>
                        <button class="act-util" id="btnWhats" title="Enviar por WhatsApp" style="color: #0b7a4b;">
                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.15-1.7-.85-2-.95-.26-.1-.46-.15-.65.15-.2.3-.74.94-.9 1.13-.17.2-.34.22-.63.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.04-.17-.3-.02-.46.13-.6.13-.14.3-.34.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.65-1.57-.9-2.15-.24-.56-.48-.48-.65-.49h-.56c-.2 0-.5.07-.77.37-.26.3-1 .98-1 2.4 0 1.4 1.03 2.76 1.17 2.96.14.2 2.02 3.08 4.9 4.32.68.3 1.22.47 1.64.6.69.22 1.31.19 1.8.12.55-.08 1.7-.7 1.94-1.36.24-.67.24-1.24.17-1.36-.07-.12-.26-.2-.56-.34zM12 2a10 10 0 0 0-8.6 15.06L2 22l5.06-1.33A10 10 0 1 0 12 2z"/></svg>
                        </button>
                    </div>
                )}
                {q.status === 'draft' && (
                    <div class="act-grid">
                        <a href={`/q/${q.token}`} class="act-util" target="_blank" title="Ver previsualización">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </a>
                    </div>
                )}

                <button class="act-secondary" id="btnDuplicate" style="width: 100%; margin-top: 0.5rem;">Duplicar cotización</button>

                {q.status === 'draft' && canCotizar && (
                    <button class="act-delete" id="btnDelete" style="width: 100%; margin-top: 0.5rem;">Eliminar borrador</button>
                )}
                <p class="act-error" id="actError"></p>
            </section>

            <section class="d-timeline">
                <div class="section-head"><h2>Actividad</h2></div>
                <button class="tl-new" id="tlNew" hidden>
                    <span class="tl-new-dot"></span> Hay mensajes nuevos · actualizar
                </button>
                <div class="tl">
                    {q.eventos.map((e) => (
                        <div class="tl-item">
                            <span class="tl-dot" style={`background:${dotColor(e.tipo)}`}></span>
                            <div class="tl-body">
                                <span class="tl-text">{e.detalle}</span>
                                <span class="tl-time">{e.cuando}</span>
                            </div>
                        </div>
                    ))}
                </div>
                <div class="tl-reply">
                    <textarea id="replyMsg" rows="2" placeholder="Responder al cliente (aparece en su link)…"></textarea>
                    <button class="tl-reply-btn" id="btnReply">Enviar respuesta</button>
                </div>
            </section>
        </aside>
    </div>
</AppLayout>

<style>
    .tb-status { font-size: 0.74rem; }
    .back-link { font-size: 0.82rem; font-weight: 500; color: var(--color-text-muted); text-decoration: none; display: inline-flex; margin-bottom: 1.5rem; transition: color 0.2s; }
    .back-link:hover { color: var(--color-blue-deep); }

    /* ── Stepper de estado ── */
    .q-stepper { display: flex; align-items: center; gap: 0; margin: 0 0 2.2rem; }
    .qs-step { display: flex; align-items: center; gap: 8px; flex: 1; min-width: 0; }
    .qs-step:not(:last-child)::after { content: ''; flex: 1; height: 2px; background: var(--color-border); margin: 0 10px; border-radius: 2px; transition: background 0.4s var(--ease-spring); }
    .qs-step.done:not(:last-child)::after { background: var(--color-ok); }
    .qs-dot { width: 24px; height: 24px; flex-shrink: 0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 800; background: var(--color-bg-soft); color: var(--color-text-muted); border: 1.5px solid var(--color-border); transition: all 0.3s var(--ease-spring); }
    .qs-step.done .qs-dot { background: var(--color-ok); color: #fff; border-color: var(--color-ok); }
    .qs-step.current .qs-dot { background: var(--color-blue-deep); color: #fff; border-color: var(--color-blue-deep); box-shadow: 0 0 0 4px rgba(10,25,47,0.08); }
    .qs-label { font-size: 0.74rem; font-weight: 600; color: var(--color-text-muted); white-space: nowrap; }
    .qs-step.done .qs-label, .qs-step.current .qs-label { color: var(--color-text); }
    @media (max-width: 680px) { .qs-label { display: none; } }
    
    .lv-badge {
        font-size: 0.65rem; font-weight: 700; color: #10b981; background: rgba(16,185,129,0.1);
        border: 1px solid rgba(16,185,129,0.3); border-radius: 20px;
        padding: 4px 10px; margin-left: 12px; display: inline-flex; align-items: center; gap: 6px;
        vertical-align: middle;
        animation: fadein 0.4s ease;
    }
    @keyframes fadein { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
    .lv-dot { width: 6px; height: 6px; background: #10b981; border-radius: 50%; box-shadow: 0 0 0 2px rgba(16,185,129,0.2); animation: pulse 1.8s infinite; }
    @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(16,185,129,0.5); } 70% { box-shadow: 0 0 0 6px rgba(16,185,129,0); } 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); } }

    .approval-banner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.35); border-radius: 12px; padding: 12px 16px; margin-bottom: 0.9rem; }
    .approval-banner.ap-rejected { background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.3); }
    .ap-info { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .ap-title { font-size: 0.9rem; font-weight: 700; color: #92600a; }
    .ap-rejected .ap-title { color: var(--color-danger); }
    .ap-motivo { font-size: 0.78rem; color: var(--color-text-muted); }
    .ap-actions { display: flex; gap: 0.5rem; }
    .ap-approve { font-family: var(--font-sans); font-size: 0.82rem; font-weight: 700; cursor: pointer; color: #fff; background: var(--color-ok); border: none; border-radius: 9px; padding: 9px 16px; }
    .ap-reject { font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600; cursor: pointer; color: var(--color-danger); background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.25); border-radius: 9px; padding: 9px 14px; }
    .ap-approve:disabled, .ap-reject:disabled { opacity: 0.6; cursor: wait; }

    /* Encabezado de sección (eyebrow + hairline) — idéntico al dashboard */
    .section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.2rem; padding-bottom: 0.7rem; border-bottom: 1px solid var(--color-border); }
    .section-head h2 { font-size: 0.7rem; font-weight: 800; letter-spacing: 1.6px; text-transform: uppercase; color: #99a2af; margin: 0; }

    .detail-grid { display: grid; grid-template-columns: 1fr 300px; gap: 3rem; align-items: start; }
    .d-main { display: flex; flex-direction: column; min-width: 0; }

    .d-head { display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; flex-wrap: wrap; padding-bottom: 1.8rem; margin-bottom: 2.6rem; border-bottom: 1px solid var(--color-border); }
    .dh-client { display: flex; align-items: center; gap: 14px; }
    .dh-avatar {
        width: 46px; height: 46px; border-radius: 12px;
        background: var(--color-blue-deep); color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.9rem; font-weight: 800;
    }
    .dh-name { font-size: 1.15rem; font-weight: 700; margin: 0; letter-spacing: -0.3px; }
    .dh-meta { font-size: 0.78rem; color: var(--color-text-muted); margin: 3px 0 0; }
    .dh-total { display: flex; flex-direction: column; align-items: flex-end; }
    .dh-total-label { font-size: 0.58rem; font-weight: 800; letter-spacing: 1.6px; color: #99a2af; }
    .dh-total-val { font-size: 2rem; color: var(--color-blue-deep); line-height: 1.1; }

    .d-items { margin-bottom: 2.6rem; }
    .di-head, .di-row {
        display: grid; grid-template-columns: 1.8fr 80px 150px 1fr;
        gap: 1rem; align-items: center; padding: 0.8rem 0.6rem;
    }
    .di-head {
        padding-top: 0; padding-bottom: 0.55rem;
        font-size: 0.65rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
        color: var(--color-text-muted);
        border-bottom: 1px solid var(--color-border);
    }
    .di-row { border-bottom: 1px solid var(--color-border); transition: background 0.25s var(--ease-ios); }
    .di-row:hover { background: var(--color-bg-soft); }
    .di-name { font-size: 0.86rem; font-weight: 600; display: flex; flex-direction: column; }
    .di-name small { font-size: 0.68rem; color: #99a2af; font-weight: 500; }
    .di-qty { font-size: 0.84rem; color: var(--color-text-muted); }
    .di-price { display: flex; flex-direction: column; }
    .di-price s { font-size: 0.7rem; color: #b6bcc6; }
    .di-price .editorial { font-size: 0.92rem; color: var(--color-blue-deep); }
    .di-amount { font-size: 0.98rem; color: var(--color-blue-deep); }
    .di-right { text-align: right; }

    .di-totals { padding: 1.1rem 0.6rem 0; display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-end; }
    .dt-line { display: flex; justify-content: space-between; gap: 3rem; min-width: 230px; font-size: 0.82rem; color: var(--color-text-muted); }
    .dt-line .editorial { color: var(--color-blue-deep); font-size: 0.95rem; }
    .dt-grand { border-top: 1px solid var(--color-border); padding-top: 0.6rem; font-weight: 700; color: var(--color-text); }
    .dt-grand .editorial { font-size: 1.3rem; }

    .d-notes { margin-bottom: 2.6rem; }
    .d-notes p { font-size: 0.86rem; color: var(--color-text); margin: 0; line-height: 1.55; }

    /* Historial de versiones */
    .d-fiscal { margin-bottom: 2.6rem; }
    .df-list { display: flex; flex-direction: column; }
    .df-row { display: flex; align-items: center; gap: 0.9rem; padding: 0.9rem 0.5rem; border-bottom: 1px solid var(--color-border); transition: background 0.25s var(--ease-ios); }
    .df-row:last-child { border-bottom: none; }
    .df-row:hover { background: var(--color-bg-soft); }
    .df-row[data-status="error"] { background: rgba(239,68,68,0.04); }
    .df-icon { font-size: 1.1rem; flex-shrink: 0; }
    .df-body { flex: 1; min-width: 0; }
    .df-top { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .df-type { font-size: 0.88rem; font-weight: 600; color: var(--color-text); }
    .df-pais { font-size: 0.66rem; font-weight: 700; padding: 1px 7px; border-radius: 100px; background: rgba(10,25,47,0.06); color: var(--color-text-muted); }
    .df-sim { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.5px; text-transform: uppercase; padding: 2px 7px; border-radius: 100px; color: #b45309; background: rgba(245,158,11,0.12); }
    .df-state { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.5px; text-transform: uppercase; padding: 2px 8px; border-radius: 100px; }
    .df-state.issued { color: var(--color-ok); background: rgba(16,185,129,0.12); }
    .df-state.error { color: var(--color-danger); background: rgba(239,68,68,0.12); }
    .df-state.pending { color: var(--color-text-muted); background: rgba(0,0,0,0.05); }
