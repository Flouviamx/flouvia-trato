    .act-delete { background: transparent; color: #ef4444; border: 1px solid transparent; padding: 10px; font-weight: 600; border-radius: 10px; cursor: pointer; transition: background 0.2s; }
    .act-delete:hover { background: #fee2e2; border-color: #fca5a5; }
