---
import AppLayout from '../../../../layouts/AppLayout.astro';
import { getMyMembership, money } from '../../../../lib/queries';
import { getCashFlowPrediction } from '../../../../lib/analytics/cashflow';

const ME = await getMyMembership();
const orgId = ME?.org_id;

let predictions = [];
let aiSummary = "Cargando proyecciones...";
let total90Days = 0;

if (orgId) {
  const data = await getCashFlowPrediction(orgId);
  predictions = data.predictions;
  aiSummary = data.aiSummary;
  
  total90Days = predictions.reduce((acc, p) => acc + p.expectedAmount, 0);
}
---

<AppLayout title="Proyección de Flujo de Caja" page="flujo-caja" heading="Flujo de Caja Predictivo">
  <section class="max-w-5xl mx-auto py-8">
    <div class="mb-8 flex justify-between items-end">
      <div>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Proyección a 90 Días</h2>
        <p class="text-gray-500">Estimación de ingresos basada en tu pipeline y el historial de pagos de tus clientes.</p>
      </div>
      <div class="text-right">
        <div class="text-sm text-gray-500 uppercase tracking-wide font-semibold">Total Esperado (90d)</div>
        <div class="text-3xl font-bold text-green-600 dark:text-green-400">{money(total90Days)}</div>
      </div>
    </div>

    <!-- AI Summary -->
    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-gray-800 dark:to-gray-800 p-6 rounded-xl border border-blue-100 dark:border-gray-700 mb-8 shadow-sm relative overflow-hidden">
      <div class="absolute top-0 right-0 p-4 opacity-10">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
      </div>
      <h3 class="text-sm font-bold uppercase tracking-wider text-blue-800 dark:text-blue-300 mb-2 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
        AI CFO Insight
      </h3>
      <p class="text-gray-800 dark:text-gray-200 text-lg leading-relaxed">{aiSummary}</p>
    </div>

    <!-- Data Visualization (Simple table for now, later a chart) -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50">
        <h3 class="font-semibold text-gray-800 dark:text-gray-200">Desglose de Proyecciones por Fecha</h3>
      </div>
      <div class="divide-y divide-gray-200 dark:divide-gray-700">
        {predictions.filter(p => p.expectedAmount > 0).length === 0 ? (
          <div class="p-8 text-center text-gray-500">
            No hay proyecciones de ingresos para los próximos 90 días. Crea o envía cotizaciones para ver el impacto aquí.
          </div>
        ) : (
          predictions.filter(p => p.expectedAmount > 0).map(p => (
            <div class="p-6 flex items-start justify-between hover:bg-gray-50 dark:hover:bg-gray-750 transition-colors">
              <div>
                <div class="font-medium text-gray-900 dark:text-white mb-1">
                  {new Date(p.date).toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
                </div>
                <div class="space-y-1 mt-3">
                  {p.contributingQuotes.map(q => (
                    <div class="text-sm flex items-center gap-2">
                      <span class="text-gray-500">{q.folio}</span>
                      <span class="font-medium text-gray-700 dark:text-gray-300">{q.empresa}</span>
                      <span class="text-gray-400">·</span>
                      <span class="text-gray-600 dark:text-gray-400">{money(q.amount)}</span>
                      <span class="text-xs bg-gray-100 dark:bg-gray-700 px-2 py-0.5 rounded text-gray-600 dark:text-gray-300">
                        {Math.round(q.probability * 100)}% prob.
                      </span>
                    </div>
                  ))}
                </div>
              </div>
              <div class="text-right">
                <div class="text-xl font-bold text-gray-900 dark:text-white">{money(p.expectedAmount)}</div>
                <div class="text-xs text-gray-500 mt-1">Escenario Esperado</div>
                
                <div class="mt-4 flex flex-col gap-1 items-end text-xs">
                  <div class="flex gap-2">
                    <span class="text-gray-400">Optimista:</span>
                    <span class="text-green-600 font-medium">{money(p.optimisticAmount)}</span>
                  </div>
                  <div class="flex gap-2">
                    <span class="text-gray-400">Conservador:</span>
                    <span class="text-yellow-600 font-medium">{money(p.conservativeAmount)}</span>
                  </div>
                </div>
              </div>
            </div>
          ))
        )}
      </div>
    </div>
  </section>
</AppLayout>
