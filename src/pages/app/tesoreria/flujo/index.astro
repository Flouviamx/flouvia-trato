---
import AppLayout from '../../../../layouts/AppLayout.astro';
import { money } from '../../../../lib/queries';
import { getActiveOrgId } from '../../../../lib/db';
import { getCashFlowPrediction } from '../../../../lib/analytics/cashflow';

const orgId = await getActiveOrgId();

let predictions: any[] = [];
let aiSummary = '';
let total90Days = 0;

if (orgId) {
  const data = await getCashFlowPrediction(orgId);
  predictions = data.predictions;
  aiSummary = data.aiSummary;
  total90Days = predictions.reduce((acc, p) => acc + p.expectedAmount, 0);
}

const conIngreso = predictions.filter((p) => p.expectedAmount > 0);
const fmtFecha = (d: any) => new Date(d).toLocaleDateString('es-MX', { weekday: 'long', day: 'numeric', month: 'long' });
---

<AppLayout title="Flujo de caja — Cord" page="flujo-caja" heading="Flujo de caja">
  <p slot="page-sub">Estimación de ingresos a 90 días, cruzando tu pipeline con el historial real de pago de cada cliente.</p>
  <div slot="page-tabs">
    <a href="/app/cobranza" class="ph-tab">Cobranza</a>
    <a href="/app/tesoreria/cobranza" class="ph-tab">Cobranza con IA</a>
    <a href="/app/tesoreria/flujo" class="ph-tab active">Flujo de caja</a>
  </div>

  <!-- KPI hero -->
  <div class="tf-kpis">
    <div class="card tf-kpi">
      <span class="tf-eyebrow">Total esperado · 90 días</span>
      <span class="editorial tf-big">{money(total90Days)}</span>
    </div>
    <div class="card tf-kpi">
      <span class="tf-eyebrow">Fechas con ingreso</span>
      <span class="editorial tf-big">{conIngreso.length}</span>
    </div>
  </div>

  <!-- AI CFO Insight -->
  {aiSummary && (
    <div class="tf-insight">
      <span class="tf-spark">✦</span>
      <div>
        <span class="tf-insight-label">AI CFO Insight</span>
        <p class="tf-insight-text">{aiSummary}</p>
      </div>
    </div>
  )}

  <!-- Desglose -->
  <div class="card tf-table">
    <div class="tf-thead">Proyección por fecha</div>
    {conIngreso.length === 0 ? (
      <div class="tf-empty">No hay proyecciones para los próximos 90 días. Crea o envía cotizaciones para ver el impacto aquí.</div>
    ) : (
      conIngreso.map((p) => (
        <div class="tf-row">
          <div class="tf-row-main">
            <div class="tf-date">{fmtFecha(p.date)}</div>
            <div class="tf-quotes">
              {p.contributingQuotes.map((q: any) => (
                <div class="tf-quote">
                  <span class="tf-folio">{q.folio}</span>
                  <span class="tf-empresa">{q.empresa}</span>
                  <span class="tf-sep">·</span>
                  <span class="editorial tf-monto">{money(q.amount)}</span>
                  <span class="tf-prob">{Math.round(q.probability * 100)}%</span>
                </div>
              ))}
            </div>
          </div>
          <div class="tf-row-right">
            <span class="editorial tf-expected">{money(p.expectedAmount)}</span>
            <span class="tf-expected-lbl">Escenario esperado</span>
            <div class="tf-scenarios">
              <span><b style="color:var(--color-ok)">{money(p.optimisticAmount)}</b> optimista</span>
              <span><b style="color:var(--color-warn)">{money(p.conservativeAmount)}</b> conservador</span>
            </div>
          </div>
        </div>
      ))
    )}
  </div>
</AppLayout>

<style>
  .tf-kpis { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 1.2rem; }
  .tf-kpi { padding: 1.2rem 1.4rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .tf-eyebrow { font-size: 0.62rem; font-weight: 800; letter-spacing: 1.4px; text-transform: uppercase; color: var(--color-text-muted); }
  .tf-big { font-size: 1.8rem; color: var(--color-text); }

  .tf-insight { display: flex; gap: 1rem; align-items: flex-start; padding: 1.2rem 1.4rem; border-radius: 16px; margin-bottom: 1.4rem;
    background: radial-gradient(ellipse at 0% 0%, rgba(10,25,47,0.05), transparent 70%), var(--color-bg-soft); border: 1px solid var(--color-border); }
  .tf-spark { font-size: 1.1rem; color: var(--color-blue-deep); flex-shrink: 0; }
  .tf-insight-label { font-size: 0.62rem; font-weight: 800; letter-spacing: 1.4px; text-transform: uppercase; color: var(--color-blue-deep); }
  .tf-insight-text { font-size: 0.98rem; line-height: 1.55; color: var(--color-text); margin: 0.3rem 0 0; }

  .tf-table { padding: 0; overflow: hidden; }
  .tf-thead { font-size: 0.82rem; font-weight: 700; color: var(--color-text); padding: 1rem 1.4rem; border-bottom: 1px solid var(--color-border); background: var(--color-bg-soft); }
  .tf-empty { padding: 2.5rem 1.4rem; text-align: center; color: var(--color-text-muted); font-size: 0.88rem; }
  .tf-row { display: flex; justify-content: space-between; gap: 1.5rem; padding: 1.2rem 1.4rem; border-bottom: 1px solid var(--color-border); }
  .tf-row:last-child { border-bottom: none; }
  .tf-row:hover { background: var(--color-bg-soft); }
  .tf-date { font-size: 0.92rem; font-weight: 600; color: var(--color-text); text-transform: capitalize; margin-bottom: 0.6rem; }
  .tf-quotes { display: flex; flex-direction: column; gap: 0.35rem; }
  .tf-quote { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; flex-wrap: wrap; }
  .tf-folio { font-family: ui-monospace, Menlo, monospace; font-size: 0.72rem; color: var(--color-text-muted); }
  .tf-empresa { font-weight: 600; color: var(--color-text); }
  .tf-sep { color: var(--color-text-muted); }
  .tf-monto { color: var(--color-text); }
  .tf-prob { font-size: 0.66rem; font-weight: 700; padding: 2px 7px; border-radius: 100px; background: rgba(10,25,47,0.06); color: var(--color-text-muted); }
  .tf-row-right { text-align: right; flex-shrink: 0; display: flex; flex-direction: column; gap: 2px; align-items: flex-end; }
  .tf-expected { font-size: 1.25rem; color: var(--color-text); }
  .tf-expected-lbl { font-size: 0.66rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.6px; }
  .tf-scenarios { display: flex; flex-direction: column; gap: 2px; margin-top: 0.5rem; font-size: 0.72rem; color: var(--color-text-muted); }

  @media (max-width: 720px) {
    .tf-kpis { grid-template-columns: 1fr; }
    .tf-row { flex-direction: column; gap: 0.8rem; }
    .tf-row-right { text-align: left; align-items: flex-start; }
  }
</style>
