---
import AppLayout from '../../../../layouts/AppLayout.astro';
import { getMyMembership } from '../../../../lib/queries';
import { sql } from '../../../../lib/db';

const ME = await getMyMembership();
const orgId = ME?.org_id;

let conversaciones = [];
if (orgId) {
  conversaciones = await sql`
    SELECT 
      c.id, c.cotizacion_id, c.autor_tipo, c.mensaje, c.created_at,
      cot.total, cl.empresa
    FROM cobranza_conversaciones c
    JOIN cotizaciones cot ON c.cotizacion_id = cot.id
    JOIN clientes cl ON cot.cliente_id = cl.id
    WHERE c.org_id = ${orgId}
    ORDER BY c.created_at DESC
    LIMIT 50
  `;
}
---

<AppLayout title="Agentes de Cobranza (AI AR)" page="ai-ar" heading="Supervisión de Agentes de Cobranza">
  <section class="max-w-4xl mx-auto py-8">
    <div class="mb-8 flex justify-between items-center">
      <div>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Bandeja de Negociaciones Activas</h2>
        <p class="text-gray-500">Supervisa las interacciones autónomas de tu agente de cobranza con los clientes.</p>
      </div>
      <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md font-medium text-sm">
        Forzar Ejecución del Agente
      </button>
    </div>

    {conversaciones.length === 0 ? (
      <div class="bg-white dark:bg-gray-800 rounded-lg p-8 text-center border border-gray-200 dark:border-gray-700">
        <p class="text-gray-500">No hay interacciones recientes del agente de cobranza.</p>
      </div>
    ) : (
      <div class="space-y-6">
        {conversaciones.map((conv) => (
          <div class={`bg-white dark:bg-gray-800 rounded-lg p-6 border ${conv.autor_tipo === 'agente_ia' ? 'border-blue-200 dark:border-blue-900' : 'border-green-200 dark:border-green-900'} shadow-sm`}>
            <div class="flex justify-between items-center mb-4 border-b border-gray-100 dark:border-gray-700 pb-2">
              <div class="flex items-center gap-2">
                <span class="font-semibold text-gray-900 dark:text-white">{conv.empresa}</span>
                <span class="text-gray-400 text-sm">•</span>
                <span class="text-gray-600 dark:text-gray-300 text-sm">Factura de ${parseFloat(conv.total).toFixed(2)}</span>
              </div>
              <div class="text-xs text-gray-400">
                {new Date(conv.created_at).toLocaleString()}
              </div>
            </div>
            
            <div class="mb-2">
              <span class={`inline-block px-2 py-1 text-xs rounded-full font-medium ${conv.autor_tipo === 'agente_ia' ? 'bg-blue-100 text-blue-800' : 'bg-green-100 text-green-800'}`}>
                {conv.autor_tipo === 'agente_ia' ? 'Agente de IA' : 'Cliente'}
              </span>
            </div>
            
            <p class="text-gray-700 dark:text-gray-200 whitespace-pre-wrap text-sm">{conv.mensaje}</p>
            
            {conv.autor_tipo === 'agente_ia' && (
              <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-700 flex justify-end">
                <button class="text-red-600 hover:text-red-700 text-sm font-medium">Tomar el control manual</button>
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </section>
</AppLayout>
