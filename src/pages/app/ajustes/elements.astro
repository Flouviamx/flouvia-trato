---
// Ajustes › Developers › Cotizador embebible (CORD Elements).
// Permite (1) copiar el snippet de instalación del <iframe> en sitios de terceros
// y (2) gestionar la allowlist de dominios (orgs.embed_domains) que alimenta el
// header CSP `frame-ancestors`. Estilo LISTA (regla de André, no tarjetas).
import SettingsShell from '../../../components/app/SettingsShell.astro';
import { getOrg } from '../../../lib/queries';
import { sql, getActiveOrgId } from '../../../lib/db';

const ORG = await getOrg();

// Token real de una cotización enviada → snippet copy-paste que YA funciona.
// Si no hay ninguna aún, mostramos un placeholder.
const orgId = await getActiveOrgId();
const [reciente] = await sql`
    select public_token from cotizaciones
    where org_id = ${orgId} and status <> 'draft'
    order by created_at desc limit 1`;
const sampleToken = (reciente?.public_token as string) || 'TOKEN_DE_TU_COTIZACION';

const base = Astro.url.origin;
const snippet = `<!-- Cotizador Cord -->
<script src="${base}/embed.js" async></script>
<div data-cord-cotizador data-token="${sampleToken}"></div>`;
const hasDomains = (ORG.embedDomains || '').trim().length > 0;
---

<SettingsShell title="Cotizador embebible — Ajustes" tab="elements" perm="ajustes" save={true}
    intro="Lleva tu cotizador a CUALQUIER sitio. Pega una línea de código en la web de tu cliente y la cotización aparece embebida, con tu marca y aprobación/pago en línea. Ideal para portales B2B que ya existen.">

    <div class="s-block">
        <h3>1 · Código de instalación</h3>
        <p class="el-p">Pega esto donde quieras que aparezca el cotizador. Se ajusta solo a la altura del contenido y hereda el fondo de la página anfitriona.</p>
        <div class="el-code">
            <pre><code id="elSnippet">{snippet}</code></pre>
            <button class="el-copy" id="elCopy" type="button">Copiar</button>
        </div>
        <a class="el-preview" href={`/embed/${sampleToken}`} target="_blank" rel="noopener">
            Ver el embed en una pestaña nueva ↗
        </a>
    </div>

    <div class="s-block">
        <h3>2 · Dominios autorizados</h3>
        <p class="el-p">
            Por seguridad (anti-clickjacking), indica en qué dominios se puede embeber tu
            cotizador. Uno por línea o separados por coma. Acepta comodines:
            <code>cliente.com</code>, <code>*.cliente.com</code>, <code>https://app.cliente.com</code>.
        </p>
        <textarea class="el-domains" data-field="embed_domains" rows="4"
            placeholder="cliente-a.com&#10;*.cliente-b.com">{ORG.embedDomains}</textarea>
        <p class:list={['el-status', hasDomains ? 'ok' : 'warn']}>
            {hasDomains
                ? '🔒 Solo los dominios de la lista pueden embeber tu cotizador.'
                : '⚠️ Lista vacía: cualquier sitio puede embeber tu cotizador (modo abierto, útil para pruebas). Agrega dominios antes de producción.'}
        </p>
    </div>

    <div class="s-block">
        <h3>3 · Reacciona a los eventos (opcional)</h3>
        <p class="el-p">El contenedor emite eventos cuando el cliente actúa, para que tu sitio reaccione (analítica, redirigir, etc.):</p>
        <div class="el-code">
            <pre><code>{`document.querySelector('[data-cord-cotizador]')
  .addEventListener('cord:approved', (e) => {
    console.log('Aprobada', e.detail.folio);
  });`}</code></pre>
        </div>
        <ul class="el-events">
            <li><code>cord:ready</code> — el cotizador cargó</li>
            <li><code>cord:approved</code> — el cliente aprobó <span>· detail: folio, token</span></li>
            <li><code>cord:rejected</code> — el cliente rechazó</li>
            <li><code>cord:message</code> — comentario o contraoferta</li>
            <li><code>cord:pay</code> — inició el pago en línea</li>
        </ul>
    </div>
</SettingsShell>

<style>
    .el-p { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.55; margin: 0 0 0.9rem; }
    .el-p code, .el-events code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.78rem; background: rgba(10,25,47,0.06); padding: 1px 5px; border-radius: 4px; }
    .el-code { position: relative; }
    .el-code pre { background: #0a192f; color: #e6edf3; border-radius: 12px; padding: 1.1rem 1.2rem; overflow-x: auto; margin: 0; }
    .el-code code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.8rem; line-height: 1.6; white-space: pre; }
    .el-copy {
        position: absolute; top: 10px; right: 10px;
        font-family: var(--font-sans); font-size: 0.72rem; font-weight: 600;
        color: #cdd9e5; background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.14); border-radius: 8px;
        padding: 5px 11px; cursor: pointer; transition: background 0.2s;
    }
    .el-copy:hover { background: rgba(255,255,255,0.16); }
    .el-copy.done { color: #6ee7b7; border-color: rgba(110,231,183,0.4); }
    .el-preview { display: inline-block; margin-top: 0.8rem; font-size: 0.82rem; font-weight: 600; color: var(--color-blue-deep); text-decoration: none; }
    .el-preview:hover { text-decoration: underline; }
    .el-domains {
        width: 100%; font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.82rem;
        color: var(--color-text); background: #fff;
        border: 1px solid var(--color-border); border-radius: 10px; padding: 11px 13px; resize: vertical;
    }
    .el-domains:focus { outline: none; border-color: var(--color-blue-deep); }
    .el-status { font-size: 0.8rem; line-height: 1.5; margin: 0.8rem 0 0; padding: 0.7rem 0.9rem; border-radius: 10px; }
    .el-status.ok { color: #047857; background: rgba(16,185,129,0.1); }
    .el-status.warn { color: #b45309; background: rgba(245,158,11,0.12); }
    .el-events { margin: 1rem 0 0; padding-left: 1.2rem; display: flex; flex-direction: column; gap: 0.5rem; }
    .el-events li { font-size: 0.83rem; color: var(--color-text); line-height: 1.5; }
    .el-events span { color: var(--color-text-muted); font-size: 0.76rem; }
</style>

<script>
    function initElements() {
        const btn = document.getElementById('elCopy');
        const code = document.getElementById('elSnippet');
        if (!btn || !code) return;
        btn.addEventListener('click', async () => {
            try {
                await navigator.clipboard.writeText(code.textContent || '');
                btn.textContent = '✓ Copiado'; btn.classList.add('done');
                setTimeout(() => { btn.textContent = 'Copiar'; btn.classList.remove('done'); }, 2000);
            } catch {}
        });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initElements);
    else initElements();
</script>
