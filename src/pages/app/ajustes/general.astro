---
// Ajustes › General — identidad del negocio, contacto, presencia y localización.
import SettingsShell from '../../../components/app/SettingsShell.astro';
import { getOrg } from '../../../lib/queries';
const ORG = await getOrg();

const MONEDAS = [
    { v: 'MXN', l: 'Peso mexicano (MXN)' },
    { v: 'USD', l: 'Dólar estadounidense (USD)' },
    { v: 'EUR', l: 'Euro (EUR)' },
];
const ZONAS = [
    { v: 'America/Mexico_City', l: 'Centro — Ciudad de México (GMT-6)' },
    { v: 'America/Tijuana',     l: 'Pacífico — Tijuana (GMT-8)' },
    { v: 'America/Cancun',      l: 'Sureste — Cancún (GMT-5)' },
    { v: 'America/Hermosillo',  l: 'Pacífico — Hermosillo (GMT-7)' },
];
---

<SettingsShell title="General — Ajustes" tab="general" perm="ajustes"
    intro="Lo esencial de tu negocio: cómo te llamas, cómo te contactan y en qué moneda operas. Estos datos viajan al link público y al PDF de cada cotización." save>

    <div class="s-block">
        <h3>Identidad del negocio</h3>
        <div class="s-body">
            <div class="s-row">
                <div class="s-field">
                    <label for="oNombre">Nombre del negocio</label>
                    <input class="s-input" id="oNombre" data-field="nombre" value={ORG.nombre} />
                </div>
                <div class="s-field">
                    <label for="oMoneda">Moneda base</label>
                    <select class="s-input" id="oMoneda" data-field="moneda">
                        {MONEDAS.map((m) => <option value={m.v} selected={ORG.moneda === m.v}>{m.l}</option>)}
                    </select>
                    <span class="s-hint">Moneda en la que cotizas. Cambiarla no convierte montos existentes.</span>
                </div>
            </div>
        </div>
    </div>

    <div class="s-block">
        <h3>Contacto</h3>
        <div class="s-body">
            <div class="s-row">
                <div class="s-field">
                    <label for="oEmail">Correo de contacto</label>
                    <input class="s-input" id="oEmail" data-field="email_contacto" type="email" value={ORG.email} placeholder="ventas@tunegocio.mx" />
                </div>
                <div class="s-field">
                    <label for="oTelefono">Teléfono</label>
                    <input class="s-input" id="oTelefono" data-field="telefono" value={ORG.telefono} placeholder="55 1234 5678" />
                </div>
            </div>
            <div class="s-field">
                <label for="oDireccion">Dirección</label>
                <input class="s-input" id="oDireccion" data-field="direccion" value={ORG.direccion} placeholder="Av. Industria 123, Tlalnepantla, Edo. Méx." />
            </div>
        </div>
    </div>

    <div class="s-block">
        <h3>Presencia en línea</h3>
        <div class="s-body">
            <div class="s-row">
                <div class="s-field">
                    <label for="oWeb">Sitio web</label>
                    <input class="s-input" id="oWeb" data-field="sitio_web" value={ORG.sitioWeb} placeholder="https://tunegocio.mx" />
                </div>
                <div class="s-field">
                    <label for="oWa">WhatsApp</label>
                    <input class="s-input" id="oWa" data-field="whatsapp" value={ORG.whatsapp} placeholder="5215512345678" />
                    <span class="s-hint">Con lada país (52). Se usa en el botón "Enviar por WhatsApp".</span>
                </div>
            </div>
        </div>
    </div>

    <div class="s-block">
        <h3>Localización</h3>
        <div class="s-body">
            <div class="s-row">
                <div class="s-field">
                    <label for="oZona">Zona horaria</label>
                    <select class="s-input" id="oZona" data-field="zona_horaria">
                        {ZONAS.map((z) => <option value={z.v} selected={ORG.zonaHoraria === z.v}>{z.l}</option>)}
                    </select>
                    <span class="s-hint">Para fechas de vencimiento y horarios de eventos.</span>
                </div>
                <div class="s-field">
                    <label for="oIdioma">Idioma</label>
                    <select class="s-input" id="oIdioma" data-field="idioma">
                        <option value="es-MX" selected={ORG.idioma === 'es-MX'}>Español (México)</option>
                        <option value="en-US" disabled>English (próximamente)</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
</SettingsShell>
