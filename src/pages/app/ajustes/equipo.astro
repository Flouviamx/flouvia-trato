---
// Ajustes › Equipo y roles — invita miembros y define permisos por sección.
// Gating: invitar requiere plan Negocio. El owner siempre puede gestionar.
import SettingsShell from '../../../components/app/SettingsShell.astro';
import { getOrg, getMembers, getMyMembership } from '../../../lib/queries';
import { PERMISOS, PRESETS, ROL_LABEL, memberCan, planTieneEquipo } from '../../../lib/permissions';

const [ORG, MEMBERS, ME] = await Promise.all([getOrg(), getMembers(), getMyMembership()]);
const canManage = memberCan(ME, 'equipo');
const teamEnabled = planTieneEquipo(ORG.plan_raw);

// Plan gate: no-owners sin plan de equipo → directo a precios.
// El owner sí puede quedarse a ver el upsell (para que upgradee).
if (!teamEnabled && !ME?.esOwner) {
    return Astro.redirect('/precios?feature=equipo');
}

const PRESETS_JSON = Object.fromEntries(Object.entries(PRESETS).map(([k, v]) => [k, v.permisos]));
---

<SettingsShell title="Equipo y roles — Ajustes" tab="equipo"
    intro="Invita a tu equipo y controla exactamente qué puede hacer cada quién, por sección.">

    {!teamEnabled && (
        <div class="upsell">
            <div class="upsell-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
            <div class="upsell-body">
                <b>El equipo multi-usuario es del plan Negocio</b>
                <span>Tu plan actual ({ORG.plan}) incluye 1 usuario. Sube a Negocio para invitar a tu equipo con permisos por sección.</span>
            </div>
            <a href="/app/ajustes/plan" class="upsell-btn">Ver planes</a>
        </div>
    )}

    {canManage && teamEnabled && (
        <div class="s-block">
            <h3>Invitar a alguien</h3>
            <div class="inv-form">
                <div class="inv-grid">
                    <div class="s-field"><label for="iNombre">Nombre (opcional)</label><input class="s-input" id="iNombre" placeholder="Laura Méndez" /></div>
                    <div class="s-field"><label for="iEmail">Correo (opcional)</label><input class="s-input" id="iEmail" type="email" placeholder="laura@tunegocio.mx" /></div>
                    <div class="s-field"><label for="iPreset">Rol inicial</label>
                        <select class="s-input" id="iPreset">
                            {Object.entries(PRESETS).map(([k, v]) => <option value={k} selected={k === 'vendedor'}>{v.label}</option>)}
                        </select>
                    </div>
                </div>
                <button class="inv-btn" id="invBtn">Crear invitación</button>
            </div>
            <div class="inv-link" id="invLink" hidden>
                <span class="inv-link-label" id="invLinkLabel">✓ Invitación lista — comparte este link:</span>
                <div class="inv-link-row" id="invLinkRow">
                    <input class="s-input" id="invLinkInput" readonly />
                    <button class="inv-copy" id="invCopy">Copiar</button>
                </div>
                <span class="s-hint" id="invHint">Quien lo abra e inicie sesión se unirá a tu organización con el rol elegido.</span>
            </div>
        </div>
    )}

    <div class="s-block">
        <h3>Miembros ({MEMBERS.length})</h3>
        <div class="mem-list">
            {MEMBERS.map((m) => (
                <div class="mem" data-id={m.id} data-rol={m.rol}>
                    <div class="mem-row">
                        <span class="mem-avatar">{m.inicial}</span>
                        <span class="mem-id">
                            <span class="mem-name">{m.nombre}{m.esYo && <span class="mem-you">Tú</span>}</span>
                            <span class="mem-sub">{m.email || (m.estado === 'invitado' ? 'Invitación pendiente' : '—')}</span>
                        </span>
                        <span class:list={['mem-rol', m.rol]}>{ROL_LABEL[m.rol] ?? 'Personalizado'}</span>
                        <span class:list={['mem-estado', { pend: m.estado === 'invitado' }]}>{m.estado === 'invitado' ? 'Pendiente' : 'Activo'}</span>
                        <span class="mem-actions">
                            {m.rol !== 'owner' && canManage && (
                                <>
                                    {m.estado === 'invitado' && m.token && (
                                        <button class="mem-link" data-token={m.token} title="Copiar link de invitación" aria-label="Copiar link">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
                                        </button>
                                    )}
                                    <button class="mem-edit-btn">Permisos</button>
                                    <button class="mem-del" title="Quitar">✕</button>
                                </>
                            )}
                            {m.rol === 'owner' && <span class="mem-owner-note">Acceso total</span>}
                        </span>
                    </div>

                    {m.rol !== 'owner' && canManage && (
                        <div class="mem-editor" hidden>
                            <div class="mem-presets">
                                <span class="mem-presets-lbl">Plantilla:</span>
                                {Object.entries(PRESETS).map(([k, v]) => <button class="mem-preset" data-preset={k}>{v.label}</button>)}
                            </div>
                            <div class="perm-grid">
                                {PERMISOS.map((p) => (
                                    <label class="perm">
                                        <input type="checkbox" data-perm={p.key} checked={!!m.permisos[p.key]} />
                                        <span class="perm-box" aria-hidden="true"></span>
                                        <span class="perm-text"><b>{p.label}</b><i>{p.desc}</i></span>
                                    </label>
                                ))}
                            </div>
                            <div class="mem-save-row">
                                <button class="mem-save">Guardar permisos</button>
                                <span class="mem-saved">✓ Guardado</span>
                            </div>
                        </div>
                    )}
                </div>
            ))}
        </div>
    </div>
</SettingsShell>

<script is:inline define:vars={{ PRESETS_JSON }}>
    document.addEventListener('DOMContentLoaded', () => {
        const origin = window.location.origin;

        // ── Invitar ──
        const invBtn = document.getElementById('invBtn');
        if (invBtn) invBtn.addEventListener('click', async () => {
            invBtn.disabled = true;
            try {
                const res = await fetch('/api/equipo', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        nombre: document.getElementById('iNombre').value,
                        email: document.getElementById('iEmail').value,
                        preset: document.getElementById('iPreset').value,
                    }),
                });
                const d = await res.json();
                if (!res.ok) throw new Error(d.error || 'No se pudo invitar');
                const box = document.getElementById('invLink');
                if (d.emailed) {
                    // Clerk envió la invitación por correo: no hay link que copiar.
                    document.getElementById('invLinkLabel').textContent = '✓ Invitación enviada por correo';
                    document.getElementById('invLinkRow').hidden = true;
                    document.getElementById('invHint').textContent = 'La persona recibirá un email para unirse a tu organización; aparecerá aquí en cuanto acepte. Podrás afinar sus permisos por sección entonces.';
                } else {
                    document.getElementById('invLinkRow').hidden = false;
                    document.getElementById('invLinkInput').value = d.link;
                }
                box.hidden = false;
                box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            } catch (e) { alert(e.message); } finally { invBtn.disabled = false; }
        });
        const invCopy = document.getElementById('invCopy');
        if (invCopy) invCopy.addEventListener('click', () => {
            const inp = document.getElementById('invLinkInput');
            navigator.clipboard.writeText(inp.value).then(() => { invCopy.textContent = '¡Copiado!'; setTimeout(() => invCopy.textContent = 'Copiar', 1600); });
        });

        // ── Copiar link de un invitado pendiente ──
        document.querySelectorAll('.mem-link').forEach((b) => b.addEventListener('click', () => {
            const link = origin + '/unirse/' + b.dataset.token;
            navigator.clipboard.writeText(link).then(() => { const o = b.style.color; b.style.color = '#10b981'; setTimeout(() => b.style.color = o, 1200); });
        }));

        // ── Editor de permisos por miembro ──
        document.querySelectorAll('.mem').forEach((mem) => {
            const editor = mem.querySelector('.mem-editor');
            const editBtn = mem.querySelector('.mem-edit-btn');
            if (editBtn && editor) editBtn.addEventListener('click', () => { editor.hidden = !editor.hidden; });

            // Presets → aplican a los checkboxes
            mem.querySelectorAll('.mem-preset').forEach((pb) => pb.addEventListener('click', () => {
                const perms = PRESETS_JSON[pb.dataset.preset] || {};
                mem.querySelectorAll('input[data-perm]').forEach((cb) => { cb.checked = !!perms[cb.dataset.perm]; });
                mem.dataset.rol = pb.dataset.preset;
            }));
            // Cambio manual → rol personalizado
            mem.querySelectorAll('input[data-perm]').forEach((cb) => cb.addEventListener('change', () => { mem.dataset.rol = 'miembro'; }));

            // Guardar
            const saveBtn = mem.querySelector('.mem-save');
            if (saveBtn) saveBtn.addEventListener('click', async () => {
                const permisos = {};
                mem.querySelectorAll('input[data-perm]').forEach((cb) => { permisos[cb.dataset.perm] = cb.checked; });
                saveBtn.disabled = true;
                try {
                    const res = await fetch('/api/equipo', {
                        method: 'PATCH', headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id: mem.dataset.id, permisos, rol: mem.dataset.rol }),
                    });
                    const d = await res.json();
                    if (!res.ok) throw new Error(d.error || 'No se pudo guardar');
                    const msg = mem.querySelector('.mem-saved');
                    msg.classList.add('show'); setTimeout(() => { msg.classList.remove('show'); location.reload(); }, 900);
                } catch (e) { alert(e.message); } finally { saveBtn.disabled = false; }
            });

            // Quitar
            const delBtn = mem.querySelector('.mem-del');
            if (delBtn) delBtn.addEventListener('click', async () => {
                if (!confirm('¿Quitar a este miembro de la organización?')) return;
                try {
                    const res = await fetch('/api/equipo', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: mem.dataset.id }) });
                    const d = await res.json();
                    if (!res.ok) throw new Error(d.error || 'No se pudo quitar');
                    location.reload();
                } catch (e) { alert(e.message); }
            });
        });
    });
</script>

<style>
    .upsell { display: flex; align-items: center; gap: 1rem; padding: 1.1rem 1.3rem; border: 1px solid rgba(245,158,11,0.35); background: rgba(245,158,11,0.07); border-radius: 12px; margin-bottom: 2rem; }
    .upsell-ico { width: 38px; height: 38px; border-radius: 10px; background: rgba(245,158,11,0.15); color: #b45309; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .upsell-ico svg { width: 19px; height: 19px; }
    .upsell-body { display: flex; flex-direction: column; gap: 2px; flex: 1; }
    .upsell-body b { font-size: 0.9rem; }
    .upsell-body span { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.4; }
    .upsell-btn { font-size: 0.82rem; font-weight: 600; color: #fff; background: var(--color-blue-deep); padding: 9px 16px; border-radius: 9px; text-decoration: none; white-space: nowrap; }

    .inv-form { display: flex; flex-direction: column; gap: 0.9rem; }
    .inv-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.9rem; }
    .inv-btn { align-self: flex-start; font-family: var(--font-sans); font-size: 0.85rem; font-weight: 600; color: #fff; background: var(--color-blue-deep); border: none; border-radius: 9px; padding: 10px 20px; cursor: pointer; transition: transform 0.3s var(--ease-spring); }
    .inv-btn:hover { transform: translateY(-2px); }
    .inv-btn:disabled { opacity: 0.6; }
    .inv-link { margin-top: 1.1rem; padding: 1rem 1.1rem; border: 1px solid rgba(16,185,129,0.35); background: rgba(16,185,129,0.06); border-radius: 11px; display: flex; flex-direction: column; gap: 0.6rem; }
    .inv-link-label { font-size: 0.82rem; font-weight: 600; color: #059669; }
    .inv-link-row { display: flex; gap: 0.5rem; }
    .inv-link-row .s-input { flex: 1; font-size: 0.78rem; }
    .inv-copy { font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600; background: var(--color-blue-deep); color: #fff; border: none; border-radius: 9px; padding: 0 16px; cursor: pointer; white-space: nowrap; }

    .mem-list { display: flex; flex-direction: column; }
    .mem { border-bottom: 1px solid var(--color-border); }
    .mem-row { display: grid; grid-template-columns: auto 1fr auto auto auto; align-items: center; gap: 0.9rem; padding: 1rem 0.4rem; }
    .mem-avatar { width: 36px; height: 36px; border-radius: 9px; background: var(--color-blue-deep); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 0.72rem; font-weight: 800; flex-shrink: 0; }
    .mem-id { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
    .mem-name { font-size: 0.9rem; font-weight: 600; display: flex; align-items: center; gap: 7px; }
    .mem-you { font-size: 0.58rem; font-weight: 800; letter-spacing: 0.5px; color: var(--color-blue-deep); background: var(--color-bg-soft); border: 1px solid var(--color-border); padding: 2px 6px; border-radius: 100px; }
    .mem-sub { font-size: 0.76rem; color: var(--color-text-muted); }
    .mem-rol { font-size: 0.66rem; font-weight: 700; color: var(--color-text-muted); background: var(--color-bg-soft); border: 1px solid var(--color-border); padding: 4px 10px; border-radius: 100px; white-space: nowrap; }
    .mem-rol.owner { color: var(--color-blue-deep); background: rgba(10,25,47,0.07); border-color: transparent; }
    .mem-estado { font-size: 0.66rem; font-weight: 700; color: #059669; white-space: nowrap; }
    .mem-estado.pend { color: #b45309; }
    .mem-actions { display: flex; align-items: center; gap: 0.4rem; }
    .mem-edit-btn, .mem-del, .mem-link { font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600; background: none; border: 1px solid var(--color-border); border-radius: 8px; padding: 6px 11px; cursor: pointer; color: var(--color-text-muted); transition: border-color 0.2s, color 0.2s; }
    .mem-link { padding: 6px 8px; display: inline-flex; }
    .mem-link svg { width: 15px; height: 15px; }
    .mem-edit-btn:hover, .mem-link:hover { color: var(--color-blue-deep); border-color: rgba(10,25,47,0.25); }
    .mem-del:hover { color: var(--color-danger); border-color: rgba(239,68,68,0.4); }
    .mem-owner-note { font-size: 0.72rem; color: #99a2af; }

    .mem-editor { padding: 0.4rem 0.4rem 1.4rem; }
    .mem-presets { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
    .mem-presets-lbl { font-size: 0.7rem; font-weight: 700; color: #99a2af; text-transform: uppercase; letter-spacing: 0.6px; }
    .mem-preset { font-family: var(--font-sans); font-size: 0.76rem; font-weight: 600; background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 100px; padding: 5px 13px; cursor: pointer; transition: border-color 0.2s; }
    .mem-preset:hover { border-color: var(--color-blue-deep); color: var(--color-blue-deep); }
    .perm-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem 1.4rem; margin-bottom: 1.1rem; }
    .perm { display: flex; align-items: flex-start; gap: 10px; cursor: pointer; }
    .perm input { position: absolute; opacity: 0; pointer-events: none; }
    .perm-box { width: 20px; height: 20px; border-radius: 6px; border: 1.5px solid var(--color-border); flex-shrink: 0; margin-top: 1px; position: relative; transition: background 0.2s, border-color 0.2s; }
    .perm input:checked + .perm-box { background: var(--color-blue-deep); border-color: var(--color-blue-deep); }
    .perm input:checked + .perm-box::after { content: ''; position: absolute; left: 6px; top: 2.5px; width: 5px; height: 9px; border: solid #fff; border-width: 0 2px 2px 0; transform: rotate(45deg); }
    .perm-text { display: flex; flex-direction: column; gap: 1px; }
    .perm-text b { font-size: 0.82rem; font-weight: 600; }
    .perm-text i { font-style: normal; font-size: 0.72rem; color: var(--color-text-muted); line-height: 1.35; }
    .mem-save-row { display: flex; align-items: center; gap: 1rem; }
    .mem-save { font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600; color: #fff; background: var(--color-blue-deep); border: none; border-radius: 9px; padding: 9px 18px; cursor: pointer; }
    .mem-save:disabled { opacity: 0.6; }
    .mem-saved { font-size: 0.78rem; font-weight: 600; color: var(--color-ok); opacity: 0; transition: opacity 0.2s; }
    .mem-saved.show { opacity: 1; }

    @media (max-width: 760px) {
        .inv-grid { grid-template-columns: 1fr; }
        .mem-row { grid-template-columns: auto 1fr auto; gap: 0.6rem; }
        .mem-rol, .mem-estado { grid-column: 2; justify-self: start; }
        .mem-actions { grid-column: 1 / -1; justify-content: flex-end; }
        .perm-grid { grid-template-columns: 1fr; }
    }
</style>
