---
// Ajustes › Developers › API y webhooks.
// API keys: REALES (tabla api_keys, hash sha-256). La clave en claro se muestra
// UNA vez al crearla. Webhooks: REALES (tabla webhooks, entrega firmada HMAC) con
// LOG DE ENTREGAS + replay + envío de prueba. Actividad del API en vivo. Probador
// de tools MCP. (Developers PRO, jun 2026.)
import SettingsShell from '../../../components/app/SettingsShell.astro';
import { getApiKeys, getOrg, getWebhooks, getApiActivity } from '../../../lib/queries';
import { planTieneApi } from '../../../lib/permissions';
import { WEBHOOK_EVENTS } from '../../../lib/webhooks';
import { MCP_TOOLS } from '../../../lib/mcp';
const ORG = await getOrg();
const tienePlan = planTieneApi(ORG.plan_raw);

const KEYS = await getApiKeys();
const WEBHOOKS = await getWebhooks();
const ACTIVITY = await getApiActivity();
const READ_TOOLS = MCP_TOOLS.filter((t) => t.scope === 'read');
---

<SettingsShell title="API y webhooks — Ajustes" tab="api" perm="ajustes"
    intro="Conecta Cord con tu propio sistema (ERP, CRM, scripts): lee y crea cotizaciones, clientes y productos por API. Genera una llave abajo y consulta los endpoints disponibles.">

    {!tienePlan && (
        <div class="dev-upsell">
            <div>
                <span class="dev-upsell-eyebrow">Plan Negocio</span>
                <p>Las llaves <b>en vivo</b> requieren el plan Negocio. Las llaves de <b>prueba</b> (sk_test_) son gratis — intégrate hoy y activa producción cuando subas de plan.</p>
            </div>
            <a href="/app/ajustes/plan" class="dev-upsell-cta">Ver planes</a>
        </div>
    )}

    <div class="s-block">
        <div class="dev-head">
            <h3>API keys</h3>
            <div class="dev-head-actions">
                <div class="dev-seg" role="tablist" aria-label="Modo de la llave">
                    <button class="dev-seg-btn active" data-mode="test">Prueba</button>
                    <button class={`dev-seg-btn ${tienePlan ? '' : 'locked'}`} data-mode="live">Vivo</button>
                </div>
                <button class="dev-new" id="kNew">+ Generar API key</button>
            </div>
        </div>

        <div class="key-list" id="keyList">
            {KEYS.length === 0 && (
                <p class="dev-empty" id="keyEmpty">Aún no tienes llaves. Genera una para empezar a llamar la API.</p>
            )}
            {KEYS.map((k) => (
                <div class:list={['key-row', { revoked: k.revocada }]} data-id={k.id}>
                    <span class="key-info">
                        <span class="key-name">{k.nombre}
                            <span class={`key-mode ${k.mode}`}>{k.mode === 'test' ? 'Prueba' : 'Vivo'}</span>
                            <span class={`key-scope ${k.scope}`}>{k.scope === 'write' ? 'Escritura' : 'Lectura'}</span>
                            {k.revocada && <span class="key-scope revoked">Revocada</span>}
                        </span>
                        <code class="key-mask">{k.masked}</code>
                        <span class="key-meta">Creada {k.creada}{k.ultimoUso ? ` · último uso ${k.ultimoUso}` : ' · sin uso aún'}</span>
                    </span>
                    {!k.revocada && <button class="key-revoke" data-revoke={k.id}>Revocar</button>}
                </div>
            ))}
        </div>
        <p class="dev-note">Las llaves dan acceso completo a tu cuenta por <code>org_id</code>. Trátalas como contraseñas: nunca las publiques en el front ni en repos.</p>
    </div>

    <div class="s-block">
        <h3>Endpoints disponibles</h3>
        <p class="dev-note" style="margin-top:0 0 1rem">Base: <code>https://cord.flouvia.com/api/v1</code> · autentícate con <code>Authorization: Bearer &lt;tu_key&gt;</code>.</p>
        <div class="ep-rows">
            <div class="ep-row"><span class="ep-m get">GET</span><code class="ep-path">/me</code><span class="ep-d">A qué negocio pertenece la llave</span></div>
            <div class="ep-row"><span class="ep-m get">GET</span><code class="ep-path">/cotizaciones</code><span class="ep-d">Lista (filtra con <code>?status=</code>, pagina con <code>?limit=&amp;offset=</code>)</span></div>
            <div class="ep-row"><span class="ep-m post">POST</span><code class="ep-path">/cotizaciones</code><span class="ep-d">Crea una cotización (requiere escritura)</span></div>
            <div class="ep-row"><span class="ep-m get">GET</span><code class="ep-path">/cotizaciones/:id</code><span class="ep-d">Detalle con líneas y timeline</span></div>
            <div class="ep-row"><span class="ep-m get">GET</span><code class="ep-path">/clientes</code><span class="ep-d">Directorio de clientes</span></div>
            <div class="ep-row"><span class="ep-m post">POST</span><code class="ep-path">/clientes</code><span class="ep-d">Alta de cliente (requiere escritura)</span></div>
            <div class="ep-row"><span class="ep-m get">GET</span><code class="ep-path">/productos</code><span class="ep-d">Catálogo</span></div>
            <div class="ep-row"><span class="ep-m post">POST</span><code class="ep-path">/productos</code><span class="ep-d">Alta de producto (requiere escritura)</span></div>
            <div class="ep-row"><span class="ep-m get">GET</span><code class="ep-path">/cobranza</code><span class="ep-d">Cartera, vencidos y aging</span></div>
        </div>
        <div class="ep-code">
            <span class="ep-code-label">Ejemplo</span>
            <pre><code>curl https://cord.flouvia.com/api/v1/cotizaciones \
  -H "Authorization: Bearer sk_live_xxxxxxxxxxxx"</code></pre>
        </div>
    </div>

    <!-- ── ACTIVIDAD DEL API (Developers PRO) ── -->
    <div class="s-block">
        <div class="dev-head">
            <h3>Actividad del API</h3>
            <button class="dev-refresh" id="actRefresh" title="Actualizar">Actualizar</button>
        </div>
        <div class="act-stats">
            <div class="act-stat"><span class="act-stat-n editorial" id="actTotal">{ACTIVITY.total24}</span><span class="act-stat-l">requests · 24 h</span></div>
            <div class="act-stat"><span class={`act-stat-n editorial ${ACTIVITY.errores24 > 0 ? 'bad' : ''}`} id="actErr">{ACTIVITY.errores24}</span><span class="act-stat-l">errores · 24 h</span></div>
            <div class="act-stat"><span class="act-stat-n editorial" id="actLat">{ACTIVITY.latProm}<em>ms</em></span><span class="act-stat-l">latencia promedio</span></div>
        </div>
        <div class="act-list" id="actList">
            {ACTIVITY.recent.length === 0 && <p class="dev-empty" id="actEmpty">Sin actividad todavía. Cuando llames la API con una llave, las requests aparecerán aquí.</p>}
            {ACTIVITY.recent.map((r) => (
                <div class="act-row">
                    <span class={`act-m ${r.metodo.toLowerCase()}`}>{r.metodo}</span>
                    <code class="act-path">{r.ruta}</code>
                    <span class={`act-status ${r.status >= 400 ? 'bad' : 'ok'}`}>{r.status}</span>
                    <span class="act-lat">{r.ms != null ? `${r.ms}ms` : '—'}</span>
                    <span class="act-when">{r.cuando}{r.mode === 'test' ? ' · test' : ''}</span>
                </div>
            ))}
        </div>
    </div>

    <!-- ── MCP ── -->
    <div class="s-block">
        <h3>MCP — conecta una IA a tus datos</h3>
        <p class="dev-note" style="margin-top:0">El servidor <b>MCP</b> deja que asistentes de IA (como Claude) consulten y creen información de tu negocio en lenguaje natural: <i>"¿qué facturas están vencidas?"</i>, <i>"arma una cotización para ACME de 50 sacos de cemento"</i>. Se autentica con la misma API key.</p>

        <div class="mcp-connect">
            <div class="mcp-tabs" role="tablist">
                <button class="mcp-tab active" data-client="claude">Claude Desktop</button>
                <button class="mcp-tab" data-client="cursor">Cursor</button>
                <button class="mcp-tab" data-client="url">URL directa</button>
            </div>
            <div class="ep-code mcp-code">
                <button class="mcp-copy" id="mcpCopy" type="button">Copiar</button>
                <pre><code id="mcpConfig"></code></pre>
            </div>
            <p class="dev-note" style="margin-top:0.7rem">Pega esto en la configuración de tu cliente MCP y reemplaza la llave por una real (de arriba). Reinicia el cliente para que tome la conexión.</p>
        </div>

        <span class="wh-events-label" style="margin-top:1.4rem">Herramientas disponibles ({MCP_TOOLS.length})</span>
        <div class="mcp-tools">
            {MCP_TOOLS.map((t) => (
                <div class="mcp-tool">
                    <div class="mcp-tool-head">
                        <code>{t.name}</code>
                        <span class={`mcp-scope ${t.scope}`}>{t.scope === 'write' ? 'escritura' : 'lectura'}</span>
                    </div>
                    <p>{t.description}</p>
                </div>
            ))}
        </div>

        <div class="mcp-try">
            <span class="wh-events-label">Probar una herramienta</span>
            <p class="dev-note" style="margin:0 0 0.8rem">Corre una tool de lectura con tus datos reales (usa tu sesión, sin llave). Así ves exactamente qué recibe la IA.</p>
            <div class="mcp-try-row">
                <select class="s-input mcp-select" id="mcpTool">
                    {READ_TOOLS.map((t) => <option value={t.name}>{t.name}</option>)}
                </select>
                <input class="s-input mcp-args" id="mcpArgs" placeholder='args JSON (opcional), ej. {"limit": 5}' />
                <button class="api-btn-solid" id="mcpRun" type="button">Ejecutar</button>
            </div>
            <pre class="mcp-out" id="mcpOut" hidden></pre>
        </div>
    </div>

    <!-- ── WEBHOOKS ── -->
    <div class="s-block">
        <div class="dev-head">
            <h3>Webhooks</h3>
            <button class="dev-new" id="whNew" disabled={!tienePlan}>+ Agregar endpoint</button>
        </div>
        <p class="dev-note" style="margin-top:0">Recibe un POST firmado (HMAC-sha256, header <code>X-Cord-Signature</code>) cuando algo pasa con una cotización. Verifica la firma con el secret del endpoint. Despliega un endpoint para ver su <b>log de entregas</b> y reintentar.</p>

        <div class="wh-list" id="whList">
            {WEBHOOKS.length === 0 && (
                <p class="dev-empty" id="whEmpty">Aún no tienes endpoints. Agrega uno para recibir eventos en tu sistema.</p>
            )}
            {WEBHOOKS.map((w) => (
                <div class:list={['wh-item', { off: !w.activo }]} data-id={w.id}>
                    <div class="wh-row">
                        <button class="wh-expand" data-expand={w.id} title="Ver entregas" aria-expanded="false">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                        </button>
                        <span class="wh-info">
                            <span class="wh-url">{w.url}</span>
                            <span class="wh-sub">
                                <code>{w.secretMasked}</code>
                                {w.eventos.length === 0 ? <i>· todos los eventos</i> : <i>· {w.eventos.length} evento{w.eventos.length > 1 ? 's' : ''}</i>}
                                {w.ultimaEntrega && (
                                    <i class:list={['wh-stat', { ok: w.lastStatus && w.lastStatus < 400, err: !w.lastStatus || w.lastStatus >= 400 }]}>
                                        · última {w.ultimaEntrega} {w.lastStatus ? `(${w.lastStatus})` : '(falló)'}
                                    </i>
                                )}
                            </span>
                        </span>
                        <button class="wh-test" data-test={w.id} title="Enviar evento de prueba">Probar</button>
                        <label class="s-toggle wh-toggle" title="Activar/pausar">
                            <input type="checkbox" data-toggle={w.id} checked={w.activo} />
                            <span class="s-toggle-track"><span class="s-toggle-thumb"></span></span>
                        </label>
                        <button class="key-revoke" data-del={w.id}>Eliminar</button>
                    </div>
                    <div class="wh-deliveries" data-deliveries={w.id} hidden>
                        <div class="wh-del-body" data-delbody={w.id}>
                            <span class="wh-del-loading">Cargando entregas…</span>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</SettingsShell>

<!-- Modal: crear API key (nombre + scope) -->
<dialog id="kCreate" class="kdlg">
    <div class="kdlg-inner">
        <h4 id="kCreateTitle">Nueva API key</h4>
        <div class="s-field" style="margin-bottom:1.1rem">
            <label for="kName">Nombre</label>
            <input class="s-input" id="kName" placeholder="Producción, Zapier, Mi ERP…" />
        </div>
        <div class="s-field">
            <label>Permisos</label>
            <div class="scope-opts">
                <label class="scope-opt">
                    <input type="radio" name="kScope" value="read" checked />
                    <span class="scope-body"><b>Solo lectura</b><i>Consultar cotizaciones, clientes, productos y cobranza.</i></span>
                </label>
                <label class="scope-opt">
                    <input type="radio" name="kScope" value="write" />
                    <span class="scope-body"><b>Lectura y escritura</b><i>Además puede crear cotizaciones, clientes y productos.</i></span>
                </label>
            </div>
        </div>
        <div class="wh-dlg-actions">
            <button type="button" class="api-btn-ghost" id="kCreateCancel">Cancelar</button>
            <button type="button" class="api-btn-solid" id="kCreateGo">Generar llave</button>
        </div>
    </div>
</dialog>

<!-- Modal: agregar webhook -->
<dialog id="whDialog" class="kdlg">
    <div class="kdlg-inner" id="whStepForm">
        <h4>Agregar endpoint</h4>
        <div class="s-field" style="margin-bottom:1.1rem">
            <label for="whUrl">URL de destino</label>
            <input class="s-input" id="whUrl" placeholder="https://tusistema.mx/webhooks/cord" />
        </div>
        <div class="wh-events">
            <span class="wh-events-label">Eventos (ninguno = todos)</span>
            <div class="wh-checks">
                {WEBHOOK_EVENTS.map((e) => (
                    <label class="wh-check">
                        <input type="checkbox" value={e.id} />
                        <span><code>{e.id}</code> {e.label}</span>
                    </label>
                ))}
            </div>
        </div>
        <div class="wh-dlg-actions">
            <button type="button" class="api-btn-ghost" id="whCancel">Cancelar</button>
            <button type="button" class="api-btn-solid" id="whCreate">Crear endpoint</button>
        </div>
    </div>
    <div class="kdlg-inner" id="whStepDone" hidden>
        <h4>Endpoint creado</h4>
        <p class="kdlg-warn">Guarda este <b>secret</b> para verificar la firma. Vuelve a verse enmascarado después.</p>
        <div class="kdlg-key">
            <code id="whSecret"></code>
            <button id="whCopy" class="kdlg-copy" type="button">Copiar</button>
        </div>
        <button class="kdlg-done" type="button" id="whDone">Listo</button>
    </div>
</dialog>

<!-- Modal: clave recién creada (se muestra UNA vez) -->
<dialog id="kDialog" class="kdlg">
    <div class="kdlg-inner">
        <h4 id="kdlgTitle">Tu nueva API key</h4>
        <p class="kdlg-warn">Cópiala ahora. Por seguridad <b>no podrás volver a verla</b> — sólo verás el prefijo.</p>
        <div class="kdlg-key">
            <code id="kdlgSecret">sk_live_…</code>
            <button id="kdlgCopy" class="kdlg-copy">Copiar</button>
        </div>
        <form method="dialog"><button class="kdlg-done">Listo, ya la guardé</button></form>
    </div>
</dialog>

<style>
    .dev-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; padding-bottom: 0.6rem; border-bottom: 1px solid var(--color-border); }
    .dev-head h3 { margin: 0; padding: 0; border: none; }
    .dev-new { font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600; color: #fff; background: var(--color-blue-deep); border: none; border-radius: 9px; padding: 8px 14px; cursor: pointer; transition: transform 0.3s var(--ease-spring); }
    .dev-new:hover:not(:disabled) { transform: translateY(-1px); }
    .dev-new:disabled { opacity: 0.4; cursor: not-allowed; }
    .dev-refresh { font-family: var(--font-sans); font-size: 0.76rem; font-weight: 600; color: var(--color-text-muted); background: none; border: 1px solid var(--color-border); border-radius: 8px; padding: 6px 12px; cursor: pointer; transition: border-color 0.25s, color 0.25s; }
    .dev-refresh:hover { border-color: var(--color-blue-deep); color: var(--color-blue-deep); }
    .dev-head-actions { display: flex; align-items: center; gap: 0.7rem; }
    .dev-seg { display: inline-flex; background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 9px; padding: 2px; }
    .dev-seg-btn { font-family: var(--font-sans); font-size: 0.76rem; font-weight: 600; color: var(--color-text-muted); background: none; border: none; border-radius: 7px; padding: 5px 12px; cursor: pointer; transition: background 0.2s, color 0.2s; }
    .dev-seg-btn.active { background: #fff; color: var(--color-blue-deep); box-shadow: 0 1px 3px rgba(10,25,47,0.12); }
    .dev-seg-btn.locked::after { content: ' 🔒'; font-size: 0.7em; }
    .key-mode { font-size: 0.56rem; font-weight: 800; letter-spacing: 0.6px; text-transform: uppercase; padding: 3px 7px; border-radius: 100px; }
    .key-mode.test { color: #b45309; background: rgba(245,158,11,0.14); }
    .key-mode.live { color: var(--color-ok); background: rgba(16,185,129,0.12); }
    .dev-empty { font-size: 0.84rem; color: var(--color-text-muted); margin: 0; padding: 0.6rem 0; }

    .dev-upsell { display: flex; align-items: center; gap: 1.2rem; justify-content: space-between; background: linear-gradient(135deg, #112240, #0a192f); border-radius: 16px; padding: 1.2rem 1.4rem; margin-bottom: 2rem; }
    .dev-upsell-eyebrow { display: block; font-size: 0.6rem; font-weight: 800; letter-spacing: 1.4px; text-transform: uppercase; color: #7fd1c1; margin-bottom: 0.4rem; }
    .dev-upsell p { font-size: 0.86rem; color: rgba(255,255,255,0.86); margin: 0; line-height: 1.5; }
    .dev-upsell b { color: #fff; }
    .dev-upsell-cta { flex-shrink: 0; font-size: 0.82rem; font-weight: 600; color: #0a192f; background: #fff; border-radius: 9px; padding: 9px 16px; text-decoration: none; white-space: nowrap; transition: transform 0.4s var(--ease-spring); }
    .dev-upsell-cta:hover { transform: translateY(-2px); }

    .key-list { display: flex; flex-direction: column; }
    .key-row { display: flex; align-items: center; gap: 1rem; padding: 1rem 0.3rem; border-bottom: 1px solid var(--color-border); }
    .key-row.revoked { opacity: 0.5; }
    .key-info { display: flex; flex-direction: column; gap: 4px; min-width: 0; flex: 1; }
    .key-name { font-size: 0.9rem; font-weight: 600; color: var(--color-text); display: flex; align-items: center; gap: 8px; }
    .key-scope { font-size: 0.56rem; font-weight: 800; letter-spacing: 0.6px; text-transform: uppercase; padding: 3px 7px; border-radius: 100px; }
    .key-scope.read { color: var(--color-blue-deep); background: rgba(10,25,47,0.08); }
    .key-scope.write { color: #b45309; background: rgba(245,158,11,0.12); }
    .key-scope.revoked { color: var(--color-danger); background: rgba(239,68,68,0.1); }
    .key-mask { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.78rem; color: var(--color-text-muted); letter-spacing: 0.5px; }
    .key-meta { font-size: 0.7rem; color: #99a2af; }
    .key-revoke { font-family: var(--font-sans); font-size: 0.76rem; font-weight: 600; color: var(--color-text-muted); background: none; border: 1px solid var(--color-border); border-radius: 8px; padding: 6px 12px; cursor: pointer; white-space: nowrap; transition: border-color 0.25s, color 0.25s; }
    .key-revoke:hover { border-color: var(--color-danger); color: var(--color-danger); }
    .dev-note { font-size: 0.78rem; color: var(--color-text-muted); line-height: 1.5; margin: 1.1rem 0 0; }
    .dev-note code, .wh-chip code, .dev-soon code, .ep-path, .ep-d code, .ep-code code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.74rem; background: rgba(10,25,47,0.06); padding: 1px 5px; border-radius: 4px; }

    .ep-rows { display: flex; flex-direction: column; margin-bottom: 1.2rem; }
    .ep-row { display: grid; grid-template-columns: 52px 180px 1fr; align-items: center; gap: 0.8rem; padding: 0.7rem 0.2rem; border-bottom: 1px solid var(--color-border); }
    .ep-m { font-size: 0.58rem; font-weight: 800; letter-spacing: 0.5px; text-align: center; padding: 3px 0; border-radius: 6px; }
    .ep-m.get { color: #1d4ed8; background: rgba(37,99,235,0.1); }
    .ep-m.post { color: #b45309; background: rgba(245,158,11,0.14); }
    .ep-path { background: none !important; padding: 0 !important; color: var(--color-text); font-weight: 600; }
    .ep-d { font-size: 0.78rem; color: var(--color-text-muted); line-height: 1.4; }
    .ep-d code { font-size: 0.7rem; }
    .ep-code { position: relative; background: #0a192f; border-radius: 12px; padding: 1rem 1.1rem; }
    .ep-code-label { display: block; font-size: 0.58rem; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; color: #7fd1c1; margin-bottom: 0.6rem; }
    .ep-code pre { margin: 0; overflow-x: auto; }
    .ep-code code { background: none !important; padding: 0 !important; color: #d7e3f4; font-size: 0.76rem; line-height: 1.6; white-space: pre; }

    @media (max-width: 600px) { .ep-row { grid-template-columns: 48px 1fr; } .ep-d { grid-column: 2; } }

    /* ── Actividad del API ── */
    .act-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; margin-bottom: 1.4rem; }
    .act-stat { background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 12px; padding: 0.9rem 1rem; display: flex; flex-direction: column; gap: 3px; }
    .act-stat-n { font-size: 1.5rem; color: var(--color-blue-deep); line-height: 1; }
    .act-stat-n.bad { color: var(--color-danger); }
    .act-stat-n em { font-style: normal; font-size: 0.8rem; color: var(--color-text-muted); margin-left: 2px; }
    .act-stat-l { font-size: 0.66rem; font-weight: 700; letter-spacing: 0.3px; text-transform: uppercase; color: #99a2af; }
    .act-list { display: flex; flex-direction: column; }
    .act-row { display: grid; grid-template-columns: 48px 1fr auto auto auto; align-items: center; gap: 0.7rem; padding: 0.6rem 0.2rem; border-bottom: 1px solid var(--color-border); font-size: 0.78rem; }
    .act-m { font-size: 0.56rem; font-weight: 800; text-align: center; padding: 3px 0; border-radius: 6px; }
    .act-m.get { color: #1d4ed8; background: rgba(37,99,235,0.1); }
    .act-m.post { color: #b45309; background: rgba(245,158,11,0.14); }
    .act-path { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.74rem; color: var(--color-text); background: none; padding: 0; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .act-status { font-family: ui-monospace, monospace; font-size: 0.72rem; font-weight: 700; }
    .act-status.ok { color: var(--color-ok); }
    .act-status.bad { color: var(--color-danger); }
    .act-lat { font-size: 0.7rem; color: var(--color-text-muted); font-variant-numeric: tabular-nums; }
    .act-when { font-size: 0.68rem; color: #99a2af; white-space: nowrap; }
    @media (max-width: 600px) { .act-row { grid-template-columns: 44px 1fr auto; } .act-lat, .act-when { display: none; } .act-stats { grid-template-columns: 1fr; } }

    /* ── MCP ── */
    .mcp-connect { margin-top: 1.2rem; }
    .mcp-tabs { display: flex; gap: 0.4rem; margin-bottom: 0.6rem; }
    .mcp-tab { font-family: var(--font-sans); font-size: 0.76rem; font-weight: 600; color: var(--color-text-muted); background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 8px; padding: 6px 12px; cursor: pointer; transition: all 0.2s; }
    .mcp-tab.active { background: var(--color-blue-deep); color: #fff; border-color: var(--color-blue-deep); }
    .mcp-code { position: relative; }
    .mcp-copy { position: absolute; top: 10px; right: 10px; font-family: var(--font-sans); font-size: 0.7rem; font-weight: 600; color: var(--color-blue-deep); background: #fff; border: none; border-radius: 6px; padding: 4px 10px; cursor: pointer; z-index: 1; }
    .mcp-tools { display: flex; flex-direction: column; gap: 0; margin-top: 0.7rem; }
    .mcp-tool { padding: 0.8rem 0.2rem; border-bottom: 1px solid var(--color-border); }
    .mcp-tool-head { display: flex; align-items: center; gap: 8px; margin-bottom: 3px; }
    .mcp-tool-head code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.78rem; font-weight: 600; color: var(--color-text); background: rgba(10,25,47,0.06); padding: 2px 7px; border-radius: 5px; }
    .mcp-scope { font-size: 0.54rem; font-weight: 800; letter-spacing: 0.6px; text-transform: uppercase; padding: 2px 6px; border-radius: 100px; }
    .mcp-scope.read { color: var(--color-blue-deep); background: rgba(10,25,47,0.08); }
    .mcp-scope.write { color: #b45309; background: rgba(245,158,11,0.12); }
    .mcp-tool p { font-size: 0.78rem; color: var(--color-text-muted); line-height: 1.5; margin: 0; }
    .mcp-try { margin-top: 1.6rem; padding-top: 1.4rem; border-top: 1px solid var(--color-border); }
    .mcp-try-row { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
    .mcp-select { flex: 0 0 auto; min-width: 190px; cursor: pointer; }
    .mcp-args { flex: 1; min-width: 180px; font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.78rem; }
    .mcp-out { margin: 1rem 0 0; background: #0a192f; color: #d7e3f4; border-radius: 12px; padding: 1rem 1.1rem; font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.74rem; line-height: 1.55; white-space: pre-wrap; word-break: break-word; max-height: 360px; overflow: auto; }
    .mcp-out.err { color: #fca5a5; }

    .wh-events-label { display: block; font-size: 0.62rem; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; color: #99a2af; margin-bottom: 0.5rem; }
    .dev-soon { display: flex; align-items: flex-start; gap: 9px; font-size: 0.8rem; color: var(--color-text-muted); background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 9px; padding: 12px 14px; line-height: 1.5; margin-top: 0.4rem; }

    /* Webhooks list */
    .wh-list { display: flex; flex-direction: column; margin-top: 0.6rem; }
    .wh-item { border-bottom: 1px solid var(--color-border); }
    .wh-item.off { opacity: 0.55; }
    .wh-row { display: grid; grid-template-columns: auto 1fr auto auto auto; align-items: center; gap: 0.8rem; padding: 1rem 0.3rem; }
    .wh-expand { background: none; border: none; cursor: pointer; color: #99a2af; padding: 2px; display: flex; align-items: center; transition: transform 0.25s var(--ease-spring), color 0.2s; }
    .wh-expand svg { width: 15px; height: 15px; }
    .wh-expand[aria-expanded="true"] { transform: rotate(90deg); color: var(--color-blue-deep); }
    .wh-info { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
    .wh-url { font-size: 0.88rem; font-weight: 600; color: var(--color-text); word-break: break-all; }
    .wh-sub { font-size: 0.72rem; color: #99a2af; display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
    .wh-sub code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.7rem; background: rgba(10,25,47,0.06); padding: 1px 5px; border-radius: 4px; }
    .wh-sub i { font-style: normal; }
    .wh-stat.ok { color: var(--color-ok); }
    .wh-stat.err { color: var(--color-danger); }
    .wh-test { font-family: var(--font-sans); font-size: 0.74rem; font-weight: 600; color: var(--color-blue-deep); background: none; border: 1px solid var(--color-border); border-radius: 8px; padding: 6px 11px; cursor: pointer; white-space: nowrap; transition: border-color 0.25s, background 0.2s; }
    .wh-test:hover { border-color: var(--color-blue-deep); background: rgba(10,25,47,0.04); }
    .wh-test:disabled { opacity: 0.5; cursor: wait; }
    .wh-toggle { margin: 0; }

    /* Log de entregas (expandible) */
    .wh-deliveries { padding: 0 0.3rem 1rem 2.4rem; }
    .wh-del-body { background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; }
    .wh-del-loading, .wh-del-empty { display: block; font-size: 0.78rem; color: var(--color-text-muted); padding: 0.9rem 1rem; }
    .del-row { display: grid; grid-template-columns: auto 1fr auto auto auto; align-items: center; gap: 0.7rem; padding: 0.6rem 0.9rem; border-bottom: 1px solid var(--color-border); font-size: 0.76rem; }
    .del-row:last-child { border-bottom: none; }
    .del-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .del-dot.ok { background: var(--color-ok); }
    .del-dot.err { background: var(--color-danger); }
    .del-ev { font-family: ui-monospace, monospace; font-size: 0.72rem; color: var(--color-text); }
    .del-ev .del-try { color: #99a2af; }
    .del-ev .del-test { font-style: normal; color: #b45309; font-size: 0.62rem; font-weight: 700; text-transform: uppercase; margin-left: 5px; }
    .del-status { font-family: ui-monospace, monospace; font-weight: 700; }
    .del-status.ok { color: var(--color-ok); }
    .del-status.err { color: var(--color-danger); }
    .del-meta { font-size: 0.68rem; color: #99a2af; white-space: nowrap; }
    .del-replay { font-family: var(--font-sans); font-size: 0.7rem; font-weight: 600; color: var(--color-text-muted); background: none; border: 1px solid var(--color-border); border-radius: 7px; padding: 4px 10px; cursor: pointer; transition: border-color 0.25s, color 0.25s; }
    .del-replay:hover { border-color: var(--color-blue-deep); color: var(--color-blue-deep); }
    .del-replay:disabled { opacity: 0.5; cursor: wait; }
    @media (max-width: 600px) { .wh-row { grid-template-columns: auto 1fr auto; } .wh-test { display: none; } .del-row { grid-template-columns: auto 1fr auto; } .del-meta { display: none; } }

    .wh-checks { display: flex; flex-direction: column; gap: 0.6rem; }
    .wh-check { display: flex; align-items: center; gap: 9px; cursor: pointer; font-size: 0.82rem; color: var(--color-text); }
    .wh-check input { width: 16px; height: 16px; accent-color: var(--color-blue-deep); }
    .wh-check code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.72rem; background: rgba(10,25,47,0.06); padding: 1px 5px; border-radius: 4px; }
    .wh-dlg-actions { display: flex; justify-content: flex-end; gap: 0.6rem; margin-top: 1.4rem; }
    .api-btn-ghost { font-family: var(--font-sans); font-size: 0.84rem; font-weight: 600; color: var(--color-text-muted); background: none; border: 1px solid var(--color-border); border-radius: 9px; padding: 9px 16px; cursor: pointer; }
    .api-btn-solid { font-family: var(--font-sans); font-size: 0.84rem; font-weight: 600; color: #fff; background: var(--color-blue-deep); border: none; border-radius: 9px; padding: 9px 18px; cursor: pointer; }
    .api-btn-solid:disabled { opacity: 0.6; cursor: wait; }

    /* Scope selector (modal de llave) */
    .scope-opts { display: flex; flex-direction: column; gap: 0.6rem; }
    .scope-opt { display: flex; align-items: flex-start; gap: 10px; cursor: pointer; border: 1px solid var(--color-border); border-radius: 11px; padding: 0.8rem 0.9rem; transition: border-color 0.2s, background 0.2s; }
    .scope-opt:has(input:checked) { border-color: var(--color-blue-deep); background: rgba(10,25,47,0.03); }
    .scope-opt input { margin-top: 2px; width: 16px; height: 16px; accent-color: var(--color-blue-deep); }
    .scope-body { display: flex; flex-direction: column; gap: 2px; }
    .scope-body b { font-size: 0.84rem; font-weight: 600; color: var(--color-text); }
    .scope-body i { font-style: normal; font-size: 0.74rem; color: var(--color-text-muted); line-height: 1.4; }

    /* Modal clave */
    .kdlg { border: none; border-radius: 16px; padding: 0; max-width: 460px; width: 92vw; box-shadow: 0 40px 90px -30px rgba(10,25,47,0.5); }
    .kdlg::backdrop { background: rgba(10,25,47,0.45); backdrop-filter: blur(3px); }
    .kdlg-inner { padding: 1.6rem; }
    .kdlg-inner h4 { font-size: 1.15rem; font-weight: 700; margin: 0 0 0.5rem; }
    .kdlg-warn { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.5; margin: 0 0 1rem; }
    .kdlg-warn b { color: var(--color-danger); }
    .kdlg-key { display: flex; align-items: center; gap: 0.5rem; background: var(--color-blue-deep); border-radius: 10px; padding: 12px 14px; margin-bottom: 1.2rem; }
    .kdlg-key code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.8rem; color: #fff; flex: 1; word-break: break-all; }
    .kdlg-copy { font-family: var(--font-sans); font-size: 0.74rem; font-weight: 600; color: var(--color-blue-deep); background: #fff; border: none; border-radius: 7px; padding: 6px 12px; cursor: pointer; white-space: nowrap; }
    .kdlg-done { font-family: var(--font-sans); font-size: 0.86rem; font-weight: 600; color: #fff; background: var(--color-blue-deep); border: none; border-radius: 10px; padding: 11px 22px; cursor: pointer; }
</style>

<script>
    function initApi() {
        const dialog = document.getElementById('kDialog') as HTMLDialogElement | null;
        const secretEl = document.getElementById('kdlgSecret');
        const newBtn = document.getElementById('kNew');
        const createDlg = document.getElementById('kCreate') as HTMLDialogElement | null;
        if (!dialog || !newBtn || !createDlg) return;

        // Segmented Vivo/Prueba → modo de la próxima llave (prueba por default).
        let mode = 'test';
        document.querySelectorAll('.dev-seg-btn').forEach((b) => b.addEventListener('click', () => {
            document.querySelectorAll('.dev-seg-btn').forEach((x) => x.classList.remove('active'));
            b.classList.add('active');
            mode = (b as HTMLElement).dataset.mode || 'test';
        }));

        const nameIn = document.getElementById('kName') as HTMLInputElement;
        const titleEl = document.getElementById('kCreateTitle')!;
        newBtn.addEventListener('click', () => {
            titleEl.textContent = mode === 'test' ? 'Nueva API key de prueba' : 'Nueva API key EN VIVO';
            nameIn.value = mode === 'test' ? 'Pruebas' : 'Producción';
            (createDlg.querySelector('input[name="kScope"][value="read"]') as HTMLInputElement).checked = true;
            createDlg.showModal(); nameIn.focus(); nameIn.select();
        });
        document.getElementById('kCreateCancel')?.addEventListener('click', () => createDlg.close());

        document.getElementById('kCreateGo')?.addEventListener('click', async () => {
            const nombre = nameIn.value.trim() || 'Sin nombre';
            const scope = (createDlg.querySelector('input[name="kScope"]:checked') as HTMLInputElement)?.value || 'read';
            const go = document.getElementById('kCreateGo') as HTMLButtonElement;
            go.disabled = true;
            try {
                const res = await fetch('/api/keys', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nombre, scope, mode }),
                });
                const d = await res.json();
                if (!res.ok) throw new Error(d.error || 'No se pudo crear');
                createDlg.close();
                if (secretEl) secretEl.textContent = d.secret;
                dialog.showModal();
                dialog.addEventListener('close', () => location.reload(), { once: true });
            } catch (err: any) {
                alert(err.message || 'No se pudo crear la llave');
            } finally { go.disabled = false; }
        });

        document.getElementById('kdlgCopy')?.addEventListener('click', async () => {
            const txt = secretEl?.textContent || '';
            try { await navigator.clipboard.writeText(txt); const b = document.getElementById('kdlgCopy')!; b.textContent = '✓ Copiada'; setTimeout(() => (b.textContent = 'Copiar'), 1800); } catch {}
        });

        document.querySelectorAll('[data-revoke]').forEach((btn) => {
            btn.addEventListener('click', async () => {
                const id = (btn as HTMLElement).dataset.revoke!;
                if (!confirm('¿Revocar esta API key? Dejará de funcionar de inmediato y no se puede deshacer.')) return;
                try {
                    const res = await fetch('/api/keys', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
                    if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'No se pudo revocar'); }
                    location.reload();
                } catch (err: any) { alert(err.message || 'No se pudo revocar'); }
            });
        });
    }

    // ── MCP: connect card (config por cliente) + probador de tools ──
    function initMcp() {
        const cfg = document.getElementById('mcpConfig');
        if (!cfg) return;
        const URL_BASE = 'https://cord.flouvia.com/api/mcp';
        const KEY = 'sk_live_xxxxxxxxxxxx';
        const CONFIGS: Record<string, string> = {
            claude: `{
  "mcpServers": {
    "cord": {
      "url": "${URL_BASE}",
      "headers": { "Authorization": "Bearer ${KEY}" }
    }
  }
}`,
            cursor: `{
  "mcpServers": {
    "cord": {
      "url": "${URL_BASE}",
      "headers": { "Authorization": "Bearer ${KEY}" }
    }
  }
}`,
            url: `URL:     ${URL_BASE}
Header:  Authorization: Bearer ${KEY}`,
        };
        const setCfg = (c: string) => { cfg.textContent = CONFIGS[c] || CONFIGS.url; };
        setCfg('claude');
        document.querySelectorAll('.mcp-tab').forEach((t) => t.addEventListener('click', () => {
            document.querySelectorAll('.mcp-tab').forEach((x) => x.classList.remove('active'));
            t.classList.add('active');
            setCfg((t as HTMLElement).dataset.client || 'claude');
        }));
        document.getElementById('mcpCopy')?.addEventListener('click', async () => {
            try { await navigator.clipboard.writeText(cfg.textContent || ''); const b = document.getElementById('mcpCopy')!; b.textContent = '✓'; setTimeout(() => (b.textContent = 'Copiar'), 1500); } catch {}
        });

        // Probador
        const runBtn = document.getElementById('mcpRun') as HTMLButtonElement | null;
        const out = document.getElementById('mcpOut');
        if (!runBtn || !out) return;
        runBtn.addEventListener('click', async () => {
            const tool = (document.getElementById('mcpTool') as HTMLSelectElement).value;
            const argsRaw = (document.getElementById('mcpArgs') as HTMLInputElement).value.trim();
            let args: any = {};
            if (argsRaw) { try { args = JSON.parse(argsRaw); } catch { out.hidden = false; out.className = 'mcp-out err'; out.textContent = 'El JSON de args no es válido.'; return; } }
            runBtn.disabled = true; out.hidden = false; out.className = 'mcp-out'; out.textContent = 'Ejecutando…';
            try {
                const res = await fetch('/api/mcp/playground', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ tool, args }) });
                const d = await res.json();
                if (!res.ok) { out.className = 'mcp-out err'; out.textContent = d.error || 'Falló'; }
                else out.textContent = JSON.stringify(d.result, null, 2);
            } catch (err: any) { out.className = 'mcp-out err'; out.textContent = err.message || 'Error de red'; }
            finally { runBtn.disabled = false; }
        });
    }

    // ── Actividad del API: refrescar sin recargar ──
    function initActivity() {
        const btn = document.getElementById('actRefresh');
        if (!btn) return;
        btn.addEventListener('click', async () => {
            (btn as HTMLButtonElement).disabled = true; btn.textContent = 'Actualizando…';
            try {
                const res = await fetch('/api/dev/activity');
                if (res.ok) {
                    const d = await res.json();
                    document.getElementById('actTotal')!.textContent = String(d.total24);
                    const errEl = document.getElementById('actErr')!;
                    errEl.textContent = String(d.errores24);
                    errEl.classList.toggle('bad', d.errores24 > 0);
                    document.getElementById('actLat')!.innerHTML = `${d.latProm}<em>ms</em>`;
                    renderActivity(d.recent);
                }
            } catch {}
            (btn as HTMLButtonElement).disabled = false; btn.textContent = 'Actualizar';
        });
    }
    function renderActivity(recent: any[]) {
        const list = document.getElementById('actList');
        if (!list) return;
        if (!recent.length) { list.innerHTML = '<p class="dev-empty">Sin actividad todavía. Cuando llames la API con una llave, las requests aparecerán aquí.</p>'; return; }
        const esc = (s: string) => String(s).replace(/[<>&]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;' }[c] || c));
        list.innerHTML = recent.map((r) => `
            <div class="act-row">
                <span class="act-m ${r.metodo.toLowerCase()}">${esc(r.metodo)}</span>
                <code class="act-path">${esc(r.ruta)}</code>
                <span class="act-status ${r.status >= 400 ? 'bad' : 'ok'}">${r.status}</span>
                <span class="act-lat">${r.ms != null ? r.ms + 'ms' : '—'}</span>
                <span class="act-when">${esc(r.cuando)}${r.mode === 'test' ? ' · test' : ''}</span>
            </div>`).join('');
    }

    // ── Webhooks: crear, toggle, eliminar, PROBAR, expandir log + replay ──
    function initWebhooks() {
        const dlg = document.getElementById('whDialog') as HTMLDialogElement | null;
        const newBtn = document.getElementById('whNew') as HTMLButtonElement | null;
        if (!dlg || !newBtn) return;
        const urlIn = document.getElementById('whUrl') as HTMLInputElement;
        const stepForm = document.getElementById('whStepForm')!;
        const stepDone = document.getElementById('whStepDone')!;
        const secretEl = document.getElementById('whSecret')!;
        const createBtn = document.getElementById('whCreate') as HTMLButtonElement;

        newBtn.addEventListener('click', () => {
            stepForm.hidden = false; stepDone.hidden = true;
            urlIn.value = '';
            dlg.querySelectorAll<HTMLInputElement>('.wh-check input').forEach((c) => (c.checked = false));
            createBtn.disabled = false;
            dlg.showModal(); urlIn.focus();
        });
        document.getElementById('whCancel')?.addEventListener('click', () => dlg.close());
        document.getElementById('whDone')?.addEventListener('click', () => { dlg.close(); location.reload(); });
        document.getElementById('whCopy')?.addEventListener('click', async () => {
            try { await navigator.clipboard.writeText(secretEl.textContent || ''); const b = document.getElementById('whCopy')!; b.textContent = '✓ Copiado'; setTimeout(() => (b.textContent = 'Copiar'), 1800); } catch {}
        });

        createBtn.addEventListener('click', async () => {
            const url = urlIn.value.trim();
            if (!url) { urlIn.focus(); return; }
            const eventos = Array.from(dlg.querySelectorAll<HTMLInputElement>('.wh-check input:checked')).map((c) => c.value);
            createBtn.disabled = true;
            try {
                const res = await fetch('/api/webhooks', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ url, eventos }),
                });
                const d = await res.json();
                if (!res.ok) throw new Error(d.error || 'No se pudo crear');
                secretEl.textContent = d.secret;
                stepForm.hidden = true; stepDone.hidden = false;
            } catch (err: any) { alert(err.message || 'No se pudo crear'); createBtn.disabled = false; }
        });

        document.querySelectorAll('[data-toggle]').forEach((el) => {
            el.addEventListener('change', async () => {
                const id = (el as HTMLElement).dataset.toggle!;
                const activo = (el as HTMLInputElement).checked;
                try {
                    const res = await fetch('/api/webhooks', { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, activo }) });
                    if (!res.ok) throw new Error();
                    (el.closest('.wh-item') as HTMLElement)?.classList.toggle('off', !activo);
                } catch { (el as HTMLInputElement).checked = !activo; alert('No se pudo actualizar'); }
            });
        });

        document.querySelectorAll('[data-del]').forEach((btn) => {
            btn.addEventListener('click', async () => {
                const id = (btn as HTMLElement).dataset.del!;
                if (!confirm('¿Eliminar este endpoint? Dejará de recibir eventos.')) return;
                try {
                    const res = await fetch('/api/webhooks', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
                    if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'No se pudo eliminar'); }
                    (btn.closest('.wh-item') as HTMLElement)?.remove();
                } catch (err: any) { alert(err.message || 'No se pudo eliminar'); }
            });
        });

        // Enviar evento de prueba
        document.querySelectorAll('[data-test]').forEach((btn) => {
            btn.addEventListener('click', async () => {
                const id = (btn as HTMLElement).dataset.test!;
                const b = btn as HTMLButtonElement;
                b.disabled = true; const orig = b.textContent; b.textContent = '…';
                try {
                    const res = await fetch('/api/webhooks', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'test', id }) });
                    const d = await res.json();
                    b.textContent = d.ok ? '✓ Enviado' : `✗ ${d.status || 'falló'}`;
                    // refrescar el log si está abierto
                    const open = document.querySelector(`[data-expand="${id}"][aria-expanded="true"]`);
                    if (open) loadDeliveries(id);
                    setTimeout(() => (b.textContent = orig), 2400);
                } catch { b.textContent = '✗ error'; setTimeout(() => (b.textContent = orig), 2400); }
                finally { b.disabled = false; }
            });
        });

        // Expandir / colapsar log de entregas
        document.querySelectorAll('[data-expand]').forEach((btn) => {
            btn.addEventListener('click', () => {
                const id = (btn as HTMLElement).dataset.expand!;
                const panel = document.querySelector(`[data-deliveries="${id}"]`) as HTMLElement;
                const open = btn.getAttribute('aria-expanded') === 'true';
                btn.setAttribute('aria-expanded', String(!open));
                panel.hidden = open;
                if (!open) loadDeliveries(id);
            });
        });
    }

    async function loadDeliveries(webhookId: string) {
        const body = document.querySelector(`[data-delbody="${webhookId}"]`);
        if (!body) return;
        body.innerHTML = '<span class="wh-del-loading">Cargando entregas…</span>';
        try {
            const res = await fetch(`/api/webhooks?deliveries=${encodeURIComponent(webhookId)}`);
            const d = await res.json();
            const list: any[] = d.deliveries || [];
            if (!list.length) { body.innerHTML = '<span class="wh-del-empty">Sin entregas aún. Usa "Probar" o espera a que pase un evento real.</span>'; return; }
            body.innerHTML = list.map((x) => `
                <div class="del-row">
                    <span class="del-dot ${x.ok ? 'ok' : 'err'}"></span>
                    <span class="del-ev">${x.evento}${x.intento > 1 ? `<span class="del-try"> · intento ${x.intento}</span>` : ''}${x.prueba ? '<i class="del-test">prueba</i>' : ''}</span>
                    <span class="del-status ${x.ok ? 'ok' : 'err'}">${x.status || (x.error || 'falló')}</span>
                    <span class="del-meta">${x.ms != null ? x.ms + 'ms' : ''} · ${x.cuando}</span>
                    <button class="del-replay" data-replay="${x.id}">Reintentar</button>
                </div>`).join('');
            body.querySelectorAll('[data-replay]').forEach((rb) => {
                rb.addEventListener('click', async () => {
                    const deliveryId = (rb as HTMLElement).dataset.replay!;
                    const b = rb as HTMLButtonElement; b.disabled = true; b.textContent = '…';
                    try {
                        const r = await fetch('/api/webhooks', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'redeliver', deliveryId }) });
                        const dd = await r.json();
                        b.textContent = dd.ok ? '✓' : `✗ ${dd.status || ''}`;
                        setTimeout(() => loadDeliveries(webhookId), 800);
                    } catch { b.textContent = '✗'; b.disabled = false; }
                });
            });
        } catch { body.innerHTML = '<span class="wh-del-empty">No se pudo cargar el log.</span>'; }
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', () => { initApi(); initMcp(); initActivity(); initWebhooks(); });
    else { initApi(); initMcp(); initActivity(); initWebhooks(); }
</script>
