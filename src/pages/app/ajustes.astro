---
// Ajustes — marca, datos fiscales y plan. Datos mock (deshabilitado hasta tener DB).
import AppLayout from '../../layouts/AppLayout.astro';
import { ORG } from '../../lib/mock';
---

<AppLayout title="Ajustes — Trato" page="ajustes" heading="Ajustes">
    <div class="settings">
        <!-- Marca -->
        <section class="card s-block">
            <div class="s-head">
                <h2>Marca</h2>
                <p>Tu logo y colores aparecen en el link público y el PDF de cada cotización.</p>
            </div>
            <div class="s-body">
                <div class="s-field">
                    <label>Logo</label>
                    <div class="logo-drop">
                        <div class="logo-preview">{ORG.inicial}</div>
                        <span>Arrastra tu logo o <b>haz click para subir</b></span>
                    </div>
                </div>
                <div class="s-row">
                    <div class="s-field">
                        <label>Nombre del negocio</label>
                        <input class="s-input" value={ORG.nombre} />
                    </div>
                    <div class="s-field">
                        <label>Color de marca</label>
                        <div class="color-row">
                            <span class="color-swatch"></span>
                            <input class="s-input" value="#0a192f" />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Fiscales -->
        <section class="card s-block">
            <div class="s-head">
                <h2>Datos fiscales</h2>
                <p>Necesarios para timbrar CFDI 4.0 ante el SAT (plan Negocio).</p>
            </div>
            <div class="s-body">
                <div class="s-row">
                    <div class="s-field">
                        <label>RFC</label>
                        <input class="s-input" value={ORG.rfc} />
                    </div>
                    <div class="s-field">
                        <label>Razón social</label>
                        <input class="s-input" value="Materiales del Valle SA de CV" />
                    </div>
                </div>
                <div class="s-field">
                    <label>Certificado de Sello Digital (CSD)</label>
                    <div class="csd-state">
                        <span class="csd-dot"></span>
                        <span>Sin conectar — disponible al activar el plan Negocio</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Plan -->
        <section class="card s-block">
            <div class="s-head">
                <h2>Plan y facturación</h2>
                <p>Gestiona tu suscripción de Trato.</p>
            </div>
            <div class="s-body">
                <div class="plan-row">
                    <div>
                        <span class="plan-name">Plan {ORG.plan}</span>
                        <span class="plan-price"><span class="editorial">$590</span> MXN/mes</span>
                    </div>
                    <button class="plan-btn">Gestionar suscripción</button>
                </div>
            </div>
        </section>

        <button class="s-save">Guardar cambios</button>
        <p class="s-note">Los cambios se guardarán cuando la base de datos esté conectada (Neon).</p>
    </div>
</AppLayout>

<style>
    .settings { display: flex; flex-direction: column; gap: 1rem; max-width: 760px; }
    .s-block { padding: 1.4rem 1.5rem; }
    .s-head h2 { font-size: 0.95rem; font-weight: 700; margin: 0 0 0.2rem; }
    .s-head p { font-size: 0.78rem; color: var(--color-text-muted); margin: 0 0 1.2rem; }
    .s-body { display: flex; flex-direction: column; gap: 1rem; }
    .s-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .s-field { display: flex; flex-direction: column; gap: 0.45rem; }
    .s-field label { font-size: 0.62rem; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; color: #99a2af; }
    .s-input {
        font-family: var(--font-sans); font-size: 0.86rem; font-weight: 500;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px;
        padding: 10px 12px;
        transition: border-color 0.25s;
    }
    .s-input:focus { outline: none; border-color: var(--color-blue-deep); }

    .logo-drop {
        display: flex; align-items: center; gap: 14px;
        border: 1.5px dashed rgba(10,25,47,0.18); border-radius: 12px;
        padding: 1rem 1.2rem; cursor: pointer;
        font-size: 0.8rem; color: var(--color-text-muted);
        transition: border-color 0.25s, background 0.25s;
    }
    .logo-drop:hover { border-color: var(--color-blue-deep); background: var(--color-bg-soft); }
    .logo-drop b { color: var(--color-blue-deep); }
    .logo-preview {
        width: 44px; height: 44px; border-radius: 11px;
        background: var(--color-blue-deep); color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.85rem; font-weight: 800;
    }

    .color-row { display: flex; align-items: center; gap: 9px; }
    .color-swatch { width: 36px; height: 36px; border-radius: 9px; background: #0a192f; flex-shrink: 0; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.1); }

    .csd-state {
        display: flex; align-items: center; gap: 9px;
        font-size: 0.8rem; color: var(--color-text-muted);
        background: var(--color-bg-soft); border: 1px solid var(--color-border);
        border-radius: 9px; padding: 10px 12px;
    }
    .csd-dot { width: 8px; height: 8px; border-radius: 50%; background: #f59e0b; }

    .plan-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
    .plan-name { display: block; font-size: 0.92rem; font-weight: 700; }
    .plan-price { font-size: 0.8rem; color: var(--color-text-muted); }
    .plan-price .editorial { font-size: 1.05rem; color: var(--color-blue-deep); }
    .plan-btn {
        font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600;
        color: var(--color-text); background: var(--color-bg-soft);
        border: 1px solid var(--color-border); border-radius: 9px;
        padding: 9px 16px; cursor: pointer;
        transition: border-color 0.25s;
    }
    .plan-btn:hover { border-color: rgba(10,25,47,0.25); }

    .s-save {
        font-family: var(--font-sans); font-size: 0.88rem; font-weight: 600;
        background: var(--color-blue-deep); color: #fff;
        border: none; border-radius: 10px; padding: 12px; cursor: pointer;
        box-shadow: 0 8px 22px -10px rgba(10,25,47,0.5);
        transition: transform 0.4s var(--ease-spring);
        width: max-content; padding-inline: 26px;
    }
    .s-save:hover { transform: translateY(-2px); }
    .s-note { font-size: 0.72rem; color: #99a2af; margin: -0.3rem 0 0; }

    @media (max-width: 640px) { .s-row { grid-template-columns: 1fr; } }
</style>
