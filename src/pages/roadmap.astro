---
// /roadmap — Product detailed roadmap, inspired by Stripe's roadmap
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Footer from '../components/landing/Footer.astro';
import PageAnims from '../components/landing/PageAnims.astro';
---

<Layout
    title="Roadmap y Plataforma — Cord"
    description="Descubre todas las herramientas y funciones de Cord a detalle. Desde el editor de cotizaciones hasta facturación y cobranza con IA."
>
    <Nav />
    <main class="rd-main">
        <!-- ── HERO ── -->
        <header class="rd-hero">
            <div class="rd-hero-inner">
                <p class="pp-eyebrow reveal">PLATAFORMA CORD</p>
                <h1 class="rd-h1 masked-title">Todo lo que estamos<br/>construyendo.</h1>
                <p class="rd-lead reveal">
                    Cord es el sistema operativo para ventas B2B. Conoce a detalle cada módulo de nuestra plataforma, diseñado para que cierres más tratos y cobres más rápido, sin fricción.
                </p>
            </div>
        </header>

        <!-- ── CONTENIDO ROADMAP ── -->
        <div class="rd-layout">
            <!-- Sidebar Navigation -->
            <aside class="rd-sidebar reveal">
                <nav class="rd-nav">
                    <a href="#cotizaciones" class="rd-nav-link is-active">
                        <span class="rd-nav-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></span>
                        Cotizaciones
                    </a>
                    <a href="#cobranza" class="rd-nav-link">
                        <span class="rd-nav-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></span>
                        Finanzas y Cobranza
                    </a>
                    <a href="#fiscal" class="rd-nav-link">
                        <span class="rd-nav-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg></span>
                        Fiscal y Cumplimiento
                    </a>
                </nav>
            </aside>

            <!-- Secciones -->
            <div class="rd-content">
                
                <!-- 1. Cotizaciones -->
                <section id="cotizaciones" class="rd-section">
                    <h2 class="rd-h2 reveal">Cotizaciones y Ventas</h2>
                    <p class="rd-section-desc reveal">Arma propuestas comerciales que tu cliente no podrá rechazar. La experiencia de compra B2B moderna, desde el primer contacto hasta el cierre.</p>
                    
                    <div class="rd-grid">
                        <div class="rd-card reveal">
                            <div class="rd-card-status status-live">Disponible</div>
                            <h3>Editor de cotizaciones</h3>
                            <p>Precios negociados línea por línea. Arrastra productos, aplica descuentos por volumen y ajusta márgenes en tiempo real con cálculo de impuestos en vivo.</p>
                        </div>
                        <div class="rd-card reveal">
                            <div class="rd-card-status status-live">Disponible</div>
                            <h3>Link público interactivo</h3>
                            <p>Tu cliente aprueba en un clic desde su celular. Olvídate de los PDFs estáticos. Entrega una experiencia de marca profesional y digital.</p>
                        </div>
                        <div class="rd-card reveal">
                            <div class="rd-card-status status-live">Disponible</div>
                            <h3>Seguimiento en vivo</h3>
                            <p>Notificaciones push en el momento exacto en que tu cliente abre la cotización. Llama en el momento de mayor interés y cierra más tratos.</p>
                        </div>
                        <div class="rd-card rd-card-future reveal">
                            <div class="rd-card-status status-beta">En beta</div>
                            <h3>Cord Elements</h3>
                            <p>Embebe nuestro motor de cotizaciones directamente en el portal de tu empresa o sitio web B2B. Tus clientes cotizan solos.</p>
                        </div>
                    </div>
                </section>

                <hr class="rd-divider" />

                <!-- 2. Finanzas -->
                <section id="cobranza" class="rd-section">
                    <h2 class="rd-h2 reveal">Finanzas y Cobranza</h2>
                    <p class="rd-section-desc reveal">Controla los términos comerciales, líneas de crédito y persigue la cartera vencida en automático.</p>
                    
                    <div class="rd-grid">
                        <div class="rd-card reveal">
                            <div class="rd-card-status status-live">Disponible</div>
                            <h3>Clientes y crédito (Net 30/60)</h3>
                            <p>Asigna límites de crédito y términos de pago por cliente. Cord bloquea nuevas cotizaciones si el cliente excede su límite o tiene facturas vencidas.</p>
                        </div>
                        <div class="rd-card reveal">
                            <div class="rd-card-status status-live">Disponible</div>
                            <h3>Multi-divisa y FX</h3>
                            <p>Cotiza en dólares, cobra en pesos. Tipo de cambio actualizado en tiempo real según el Banco de México (Banxico). Protégete de la volatilidad.</p>
                        </div>
                        <div class="rd-card rd-card-future reveal">
                            <div class="rd-card-status status-next">Próximamente</div>
                            <h3>Cobranza con IA</h3>
                            <p>Un agente inteligente que envía recordatorios cordiales de pago por correo y WhatsApp a tu cartera vencida, usando un tono adaptado a la relación con cada cliente.</p>
                        </div>
                    </div>
                </section>

                <hr class="rd-divider" />

                <!-- 3. Fiscal -->
                <section id="fiscal" class="rd-section">
                    <h2 class="rd-h2 reveal">Fiscal y Cumplimiento</h2>
                    <p class="rd-section-desc reveal">Arquitectura robusta para cumplir con las autoridades fiscales sin tener que salir de la plataforma.</p>
                    
                    <div class="rd-grid">
                        <div class="rd-card reveal">
                            <div class="rd-card-status status-live">Disponible</div>
                            <h3>Timbrado CFDI 4.0 automático</h3>
                            <p>Directo al SAT. Cuando una cotización es aprobada, se convierte en pedido y se timbra la factura PUE o PPD con su respectivo complemento de pago. Sin recaptura.</p>
                        </div>
                        <div class="rd-card reveal">
                            <div class="rd-card-status status-live">Disponible</div>
                            <h3>Validación de RFC y Constancia</h3>
                            <p>Lectura automática de la Constancia de Situación Fiscal de tus clientes mediante OCR. Evita errores de timbrado por códigos postales o regímenes incorrectos.</p>
                        </div>
                        <div class="rd-card rd-card-future reveal">
                            <div class="rd-card-status status-beta">En beta</div>
                            <h3>Facturación internacional</h3>
                            <p>Emite facturas de comercio exterior con cumplimiento de regulaciones locales para ventas en Estados Unidos y Latinoamérica. Arquitectura fiscal global.</p>
                        </div>
                    </div>
                </section>

            </div>
        </div>

        <section class="rd-cta reveal">
            <h2>¿Listo para modernizar tus ventas B2B?</h2>
            <p>Empieza a usar Cord hoy. Sin tarjetas, sin compromisos.</p>
            <a href="/registro" class="rd-btn">Empezar gratis</a>
        </section>

    </main>
    <Footer />
    <PageAnims />
</Layout>

<style>
    /* Estilos base */
    .rd-main {
        background: var(--color-bg);
        min-height: 100vh;
        padding-top: 10rem;
    }

    .pp-eyebrow { font-size: 0.65rem; font-weight: 800; letter-spacing: 3px; text-transform: uppercase; color: #888; margin: 0 0 1.4rem; }
    
    /* Hero */
    .rd-hero {
        text-align: center;
        padding: 0 5% 4rem;
        max-width: 800px;
        margin: 0 auto;
    }
    .rd-h1 {
        font-size: clamp(2.6rem, 5.5vw, 4.2rem);
        font-weight: 800; line-height: 1.05; letter-spacing: -0.035em;
        color: var(--color-text); margin: 0 0 1.4rem;
    }
    .rd-lead {
        font-size: 1.15rem; line-height: 1.6; color: var(--color-text-muted);
    }

    /* Layout principal */
    .rd-layout {
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: 4rem;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 5% 5rem;
        align-items: start;
    }

    /* Sidebar */
    .rd-sidebar {
        position: sticky;
        top: 6rem;
    }
    .rd-nav {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }
    .rd-nav-link {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 0.8rem 1rem;
        border-radius: 12px;
        color: var(--color-text-muted);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    .rd-nav-link:hover {
        background: var(--color-bg-soft);
        color: var(--color-text);
    }
    .rd-nav-link.is-active {
        background: rgba(10, 37, 64, 0.05);
        color: var(--color-blue-deep);
    }
    .rd-nav-ico {
        display: flex;
        color: inherit;
    }
    .rd-nav-ico svg { width: 18px; height: 18px; }

    /* Content & Sections */
    .rd-section {
        padding-top: 1rem;
        margin-bottom: 2rem;
    }
    .rd-h2 {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin: 0 0 1rem;
        color: var(--color-text);
    }
    .rd-section-desc {
        font-size: 1.1rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin-bottom: 3rem;
        max-width: 700px;
    }

    /* Cards Grid */
    .rd-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
    }
    .rd-card {
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        padding: 2rem;
        transition: transform 0.4s var(--ease-spring), box-shadow 0.4s ease, border-color 0.4s ease;
        position: relative;
        overflow: hidden;
    }
    .rd-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 40px -15px rgba(0,0,0,0.05);
        border-color: rgba(10, 37, 64, 0.15);
    }
    .rd-card-future {
        background: var(--color-bg-soft);
        border-style: dashed;
    }
    .rd-card h3 {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 1.2rem 0 0.8rem;
        letter-spacing: -0.02em;
        color: var(--color-text);
    }
    .rd-card p {
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin: 0;
    }

    /* Status Badges */
    .rd-card-status {
        display: inline-flex;
        align-items: center;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 4px 10px;
        border-radius: 100px;
    }
    .status-live {
        background: rgba(16, 185, 129, 0.1);
        color: #059669;
    }
    .status-beta {
        background: rgba(245, 158, 11, 0.1);
        color: #d97706;
    }
    .status-next {
        background: rgba(99, 102, 241, 0.1);
        color: #4f46e5;
    }

    .rd-divider {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 4rem 0;
    }

    /* CTA Bottom */
    .rd-cta {
        text-align: center;
        padding: 6rem 5%;
        background: radial-gradient(ellipse at 50% 0%, rgba(10,37,64,0.03) 0%, transparent 70%);
        margin-top: 4rem;
        border-top: 1px solid var(--color-border);
    }
    .rd-cta h2 {
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin: 0 0 1rem;
    }
    .rd-cta p {
        font-size: 1.1rem;
        color: var(--color-text-muted);
        margin: 0 0 2rem;
    }
    .rd-btn {
        display: inline-flex;
        background: var(--color-blue-deep);
        color: #fff;
        text-decoration: none;
        font-weight: 600;
        padding: 14px 28px;
        border-radius: 12px;
        transition: transform 0.3s var(--ease-spring), box-shadow 0.3s;
    }
    .rd-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px -10px rgba(0,0,0,0.3);
    }

    /* Dark mode support */
    @media (prefers-color-scheme: dark) {
        .rd-nav-link.is-active {
            background: rgba(255,255,255,0.08);
            color: #fff;
        }
        .rd-card {
            background: rgba(255,255,255,0.02);
        }
        .rd-card:hover {
            box-shadow: 0 20px 40px -15px rgba(0,0,0,0.3);
            border-color: rgba(255,255,255,0.15);
        }
        .rd-card-future {
            background: rgba(0,0,0,0.2);
        }
        .status-live { background: rgba(16, 185, 129, 0.15); color: #34d399; }
        .status-beta { background: rgba(245, 158, 11, 0.15); color: #fbbf24; }
        .status-next { background: rgba(99, 102, 241, 0.15); color: #818cf8; }
    }

    /* Responsive */
    @media (max-width: 900px) {
        .rd-layout {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        .rd-sidebar {
            position: relative;
            top: 0;
            overflow-x: auto;
            padding-bottom: 1rem;
        }
        .rd-nav {
            flex-direction: row;
            width: max-content;
        }
    }
    @media (max-width: 600px) {
        .rd-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    // Intersection Observer for scroll spy on sidebar
    document.addEventListener('DOMContentLoaded', () => {
        const sections = document.querySelectorAll('.rd-section');
        const navLinks = document.querySelectorAll('.rd-nav-link');

        const observerOptions = {
            root: null,
            rootMargin: '-20% 0px -70% 0px',
            threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const id = entry.target.getAttribute('id');
                    navLinks.forEach(link => {
                        link.classList.remove('is-active');
                        if (link.getAttribute('href') === `#${id}`) {
                            link.classList.add('is-active');
                        }
                    });
                }
            });
        }, observerOptions);

        sections.forEach(section => {
            observer.observe(section);
        });

        // Smooth scroll for nav links
        navLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                const targetId = link.getAttribute('href');
                if (targetId) {
                    const targetEl = document.querySelector(targetId);
                    if (targetEl) {
                        const top = targetEl.getBoundingClientRect().top + window.scrollY - 100;
                        window.scrollTo({ top, behavior: 'smooth' });
                    }
                }
            });
        });
    });
</script>
