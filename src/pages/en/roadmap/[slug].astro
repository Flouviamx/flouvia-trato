---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/landing/Nav.astro';
import Footer from '../../../components/landing/Footer.astro';
import PageAnims from '../../../components/landing/PageAnims.astro';
import { roadmapData } from '../../../lib/roadmap-data';
import { marked } from 'marked';

export const prerender = true;

export function getStaticPaths() {
    return roadmapData.map(item => ({
        params: { slug: item.slug },
        props: { item }
    }));
}

const { item } = Astro.props;

const statusMap = {
    'live': 'Live',
    'beta': 'In beta',
    'next': 'Coming soon'
};

const areaMap = {
    'cotizaciones': 'Quotes & Sales',
    'finanzas': 'Finance & Credit',
    'fiscal': 'Tax & Compliance'
};

const htmlContent = marked.parse(item.content.en);
---

<Layout
    title={`${item.title.en} — Cord Roadmap`}
    description={item.shortDesc.en}
>
    <Nav />
    <main class="rd-doc-main">
        <!-- Main content Document style -->
        <article class="rd-doc-article">
            
            <!-- Header -->
            <header class="rd-doc-header reveal">
                <a href="/en/roadmap" class="rd-back-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                    Back to Roadmap
                </a>
                
                <h1 class="rd-doc-title">{item.title.en}</h1>
                <p class="rd-doc-lead">{item.shortDesc.en}</p>

                <div class="rd-doc-meta">
                    <div class="rd-meta-item">
                        <span class="rd-meta-label">Availability</span>
                        <div class={`rd-meta-value status-${item.status}`}>
                            {item.status === 'live' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>}
                            {item.status === 'beta' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>}
                            {item.status === 'next' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>}
                            {statusMap[item.status]}
                        </div>
                    </div>

                    <div class="rd-meta-item">
                        <span class="rd-meta-label">Module</span>
                        <div class="rd-meta-value module-val">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                            {areaMap[item.area]}
                        </div>
                    </div>

                    {item.api && (
                        <div class="rd-meta-item">
                            <span class="rd-meta-label">Developers</span>
                            <div class="rd-meta-value api-val">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                                API Available
                            </div>
                        </div>
                    )}
                </div>
            </header>

            <!-- Body -->
            <div class="rd-doc-body reveal">
                <div class="rd-doc-prose" set:html={htmlContent} />
            </div>

            <!-- Footer -->
            <footer class="rd-doc-footer reveal">
                <div class="rd-doc-share">
                    <span>Found this useful?</span>
                    <a href={`https://twitter.com/intent/tweet?text=Check%20out%20this%20new%20Cord%20feature:%20${item.title.en}&url=https://cord.flouvia.com/en/roadmap/${item.slug}`} target="_blank" rel="noopener noreferrer">Share on Twitter</a>
                </div>
                <div class="rd-doc-next">
                    <a href="/en/roadmap" class="rd-btn-ghost">View all features</a>
                </div>
            </footer>
        </article>
    </main>
    <Footer />
    <PageAnims />
</Layout>

<style>
    .rd-doc-main {
        background: var(--color-bg);
        min-height: 100vh;
        padding: 10rem 5% 5rem;
        display: flex;
        justify-content: center;
    }

    .rd-doc-article {
        max-width: 800px;
        width: 100%;
    }

    /* Header */
    .rd-back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-text-muted);
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
        margin-bottom: 2.5rem;
        transition: color 0.3s, transform 0.3s;
    }
    .rd-back-link:hover {
        color: var(--color-text);
        transform: translateX(-4px);
    }
    .rd-back-link svg {
        width: 18px;
        height: 18px;
    }

    .rd-doc-title {
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: var(--color-text);
        margin: 0 0 1rem;
    }

    .rd-doc-lead {
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin: 0;
    }

    /* Meta Strip */
    .rd-doc-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 3rem;
        padding-top: 2.5rem;
        margin-top: 2.5rem;
        border-top: 1px solid var(--color-border);
        margin-bottom: 4rem;
    }
    .rd-meta-item {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .rd-meta-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .rd-meta-value {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--color-text);
    }
    .rd-meta-value svg {
        width: 18px;
        height: 18px;
        stroke-width: 2.5;
    }
    .status-live { color: #059669; }
    .status-beta { color: #d97706; }
    .status-next { color: #4f46e5; }
    .module-val svg, .api-val svg { color: var(--color-text-muted); }

    /* Body Prose */
    .rd-doc-prose {
        font-size: 1.1rem;
        line-height: 1.8;
        color: var(--color-text);
    }

    .rd-doc-prose :global(h2) {
        font-size: 1.6rem;
        font-weight: 600;
        margin: 3rem 0 1rem;
        letter-spacing: -0.01em;
    }

    .rd-doc-prose :global(h3) {
        font-size: 1.25rem;
        font-weight: 600;
        margin: 2rem 0 0.8rem;
    }

    .rd-doc-prose :global(p) {
        margin: 0 0 1.5rem;
        color: var(--color-text-muted);
    }

    .rd-doc-prose :global(ul), .rd-doc-prose :global(ol) {
        margin: 0 0 1.5rem 1.5rem;
        color: var(--color-text-muted);
    }

    .rd-doc-prose :global(li) {
        margin-bottom: 0.5rem;
    }

    .rd-doc-prose :global(strong) {
        color: var(--color-text);
        font-weight: 600;
    }

    /* Footer */
    .rd-doc-footer {
        margin-top: 5rem;
        padding-top: 3rem;
        border-top: 1px solid var(--color-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 2rem;
    }

    .rd-doc-share {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.95rem;
        color: var(--color-text-muted);
    }
    .rd-doc-share a {
        color: var(--color-blue-deep);
        text-decoration: none;
        font-weight: 600;
        transition: opacity 0.3s;
    }
    .rd-doc-share a:hover {
        opacity: 0.8;
    }

    .rd-btn-ghost {
        display: inline-flex;
        background: none;
        border: 1px solid var(--color-border);
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 500;
        color: var(--color-text);
        text-decoration: none;
        transition: background 0.3s;
    }
    .rd-btn-ghost:hover {
        background: var(--color-bg-soft);
    }

    /* Dark mode */
    @media (prefers-color-scheme: dark) {
        .status-live { color: #34d399; }
        .status-beta { color: #fbbf24; }
        .status-next { color: #818cf8; }
    }
</style>
