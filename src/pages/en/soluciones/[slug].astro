---
import SolucionTemplate from '../../../pages/soluciones/[slug].astro';
import { SOLUCIONES_EN } from '../../../lib/solucion.en';

export function getStaticPaths() {
    return SOLUCIONES_EN.map((s) => ({ params: { slug: s.slug }, props: { solucion: s } }));
}

const { solucion } = Astro.props;
---

<SolucionTemplate solucion={solucion} isEn={true} />
