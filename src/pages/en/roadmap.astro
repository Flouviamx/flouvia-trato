---
// /en/roadmap — Product detailed roadmap, inspired by Stripe's roadmap (English)
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PageAnims from '../../components/landing/PageAnims.astro';
import { roadmapData } from '../../lib/roadmap-data';

const statusMap = {
    'live': 'Live',
    'beta': 'In beta',
    'next': 'Coming soon'
};
---

<Layout
    title="Roadmap & Platform — Cord"
    description="Discover all Cord tools and features in detail. From the quote editor to e-invoicing and AI collections."
>
    <Nav />
    <main class="rd-main">
        <!-- ── HERO ── -->
        <header class="rd-hero">
            <div class="rd-hero-inner">
                <p class="pp-eyebrow reveal">CORD PLATFORM</p>
                <h1 class="rd-h1 masked-title">Everything we are<br/>building.</h1>
                <p class="rd-lead reveal">
                    Cord is the operating system for B2B sales. Discover every module of our platform in detail, designed to help you close more deals and get paid faster, without friction.
                </p>
            </div>
        </header>

        <!-- ── CONTENIDO ROADMAP ── -->
        <div class="rd-layout">
            <!-- Sidebar: Filters -->
            <aside class="rd-sidebar reveal">
                <div class="rd-sidebar-card">
                    <div class="rd-tabs" role="tablist">
                        <button class="rd-tab is-active" data-tab-target="all" role="tab">Roadmap</button>
                        <button class="rd-tab" data-tab-target="live" role="tab">Shipped</button>
                    </div>
                    
                    <div class="rd-filters">
                    <p class="rd-filters-title">Filter by</p>
                    
                    <div class="rd-filter-group">
                        <select class="rd-select" id="filter-area" aria-label="Product area">
                            <option value="all">Product area</option>
                            <option value="cotizaciones">Quotes & Sales</option>
                            <option value="finanzas">Finance & Credit</option>
                            <option value="fiscal">Tax & Compliance</option>
                        </select>
                        <i class="rd-select-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></i>
                    </div>

                    <div class="rd-filter-group">
                        <select class="rd-select" id="filter-status" aria-label="Availability">
                            <option value="all">Availability</option>
                            <option value="live">Live</option>
                            <option value="beta">In beta</option>
                            <option value="next">Coming soon</option>
                        </select>
                        <i class="rd-select-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></i>
                    </div>

                    <label class="rd-toggle-wrap">
                        <span class="rd-toggle-label">Show only API integrable</span>
                        <input type="checkbox" class="rd-toggle-input" id="filter-api" />
                        <span class="rd-toggle-slider"></span>
                    </label>
                </div>
                </div>
            </aside>

            <!-- Lista de Productos (Rows) -->
            <div class="rd-content">
                <div class="rd-list" id="roadmap-list">
                    
                    {roadmapData.map(item => (
                        <a 
                            href={`/en/roadmap/${item.slug}`} 
                            class="rd-row reveal" 
                            data-area={item.area} 
                            data-status={item.status} 
                            data-api={String(item.api)}
                        >
                            <div class={`rd-row-status status-${item.status}`}>{statusMap[item.status]}</div>
                            <div class="rd-row-main">
                                <div class="rd-row-copy">
                                    <h3>{item.title.en}</h3>
                                    <p>{item.shortDesc.en}</p>
                                </div>
                                <div class="rd-row-arrow">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                                </div>
                            </div>
                        </a>
                    ))}

                    <!-- Empty state para filtros -->
                    <div id="rd-empty" class="rd-empty" style="display: none;">
                        <p>No products match your selected filters.</p>
                        <button id="rd-clear-filters" class="rd-btn-ghost">Clear filters</button>
                    </div>

                </div>
        </div>
    </main>
    <Footer />
    <PageAnims />
</Layout>

<style>
    /* Estilos base */
    .rd-main {
        background: var(--color-bg);
        min-height: 100vh;
        padding-top: 10rem;
    }

    .pp-eyebrow { font-size: 0.65rem; font-weight: 800; letter-spacing: 3px; text-transform: uppercase; color: #888; margin: 0 0 1.4rem; }
    
    /* Hero */
    .rd-hero {
        text-align: center;
        padding: 0 5% 4rem;
        max-width: 800px;
        margin: 0 auto;
    }
    .rd-h1 {
        font-size: clamp(2.6rem, 5.5vw, 4.2rem);
        font-weight: 800; line-height: 1.05; letter-spacing: -0.035em;
        color: var(--color-text); margin: 0 0 1.4rem;
    }
    .rd-lead {
        font-size: 1.15rem; line-height: 1.6; color: var(--color-text-muted);
    }

    /* Layout principal */
    .rd-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 5rem;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 5% 5rem;
        align-items: start;
    }

    /* Sidebar & Filters */
    .rd-sidebar {
        position: sticky;
        top: 6rem;
    }
    
    .rd-sidebar-card {
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 24px;
        padding: 2.2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        position: relative;
    }
    .rd-sidebar-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 100%;
        border-radius: 24px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.4);
        pointer-events: none;
    }

    .rd-tabs {
        display: flex;
        gap: 2rem;
        margin-bottom: 2rem;
        border-bottom: 1px solid var(--color-border);
    }
    .rd-tab {
        background: none;
        border: none;
        padding: 0 0 1rem;
        font-family: inherit;
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--color-text-muted);
        cursor: pointer;
        position: relative;
        transition: color 0.3s;
    }
    .rd-tab:hover {
        color: var(--color-text);
    }
    .rd-tab.is-active {
        color: var(--color-text);
    }
    .rd-tab.is-active::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--color-text);
    }

    .rd-filters-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--color-text);
        margin: 0 0 1rem;
    }
    .rd-filters {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .rd-filter-group {
        position: relative;
    }
    .rd-select {
        width: 100%;
        appearance: none;
        background: var(--color-bg-soft);
        border: 1px solid transparent;
        border-radius: 20px;
        padding: 0.7rem 2.5rem 0.7rem 1.2rem;
        font-family: inherit;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--color-text);
        cursor: pointer;
        transition: all 0.3s ease;
    }
    .rd-select:hover {
        background: var(--color-border);
    }
    .rd-select:focus {
        outline: none;
        border-color: var(--color-text);
        background: transparent;
    }
    .rd-select-ico {
        position: absolute;
        right: 1.2rem;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: var(--color-text-muted);
    }
    .rd-select-ico svg { width: 16px; height: 16px; }

    /* Toggle Switch */
    .rd-toggle-wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.8rem;
        cursor: pointer;
        margin-top: 1rem;
    }
    .rd-toggle-input {
        display: none;
    }
    .rd-toggle-slider {
        position: relative;
        width: 44px;
        height: 24px;
        background: #e5e7eb;
        border-radius: 100px;
        transition: background 0.3s;
        flex-shrink: 0;
    }
    .rd-toggle-slider::before {
        content: '';
        position: absolute;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: #fff;
        top: 3px;
        left: 3px;
        transition: transform 0.3s var(--ease-spring);
    }
    .rd-toggle-input:checked + .rd-toggle-slider {
        background: #34c759;
    }
    .rd-toggle-input:checked + .rd-toggle-slider::before {
        transform: translateX(20px);
    }
    .rd-toggle-label {
        font-size: 0.9rem;
        color: var(--color-text);
        line-height: 1.4;
    }

    /* List & Rows */
    .rd-list {
        display: flex;
        flex-direction: column;
    }

    .rd-row {
        display: flex;
        flex-direction: column;
        padding: 2rem 1.5rem;
        margin: -1rem -1.5rem;
        border-top: 1px solid var(--color-border);
        cursor: pointer;
        text-decoration: none;
        border-radius: 12px;
        transition: all 0.4s var(--ease-spring);
    }
    .rd-row:first-child {
        border-top-color: transparent;
    }

    .rd-row:hover {
        background: var(--color-bg-soft);
        transform: scale(0.995);
        border-top-color: transparent;
    }
    .rd-row:hover + .rd-row {
        border-top-color: transparent;
    }

    .rd-row:hover .rd-row-arrow {
        transform: translateX(4px);
        color: var(--color-text);
    }

    /* Status Badges */
    .rd-row-status {
        display: inline-block;
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.8rem;
    }
    .status-live { color: #059669; }
    .status-beta { color: #d97706; }
    .status-next { color: #4f46e5; }

    .rd-row-main {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 2rem;
    }

    .rd-row-copy h3 {
        font-size: 1.3rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
        letter-spacing: -0.01em;
        color: var(--color-text);
        transition: color 0.3s;
    }
    .rd-row-copy p {
        font-size: 1rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin: 0;
        max-width: 650px;
    }

    .rd-row-arrow {
        flex-shrink: 0;
        color: var(--color-text-muted);
        transition: transform 0.4s var(--ease-spring), color 0.3s;
        margin-top: 0.2rem;
    }
    .rd-row-arrow svg { width: 22px; height: 22px; }

    .rd-empty {
        text-align: center;
        padding: 4rem 0;
        color: var(--color-text-muted);
    }
    .rd-empty p { margin-bottom: 1rem; }
    .rd-btn-ghost {
        background: none;
        border: 1px solid var(--color-border);
        padding: 8px 16px;
        border-radius: 8px;
        font-family: inherit;
        font-size: 0.9rem;
        color: var(--color-text);
        cursor: pointer;
    }
    .rd-btn-ghost:hover {
        background: var(--color-bg-soft);
    }


    /* Dark mode support */
    @media (prefers-color-scheme: dark) {
        .rd-sidebar-card {
            background: linear-gradient(180deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        .rd-sidebar-card::before {
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
        }
        .status-live { color: #34d399; }
        .status-beta { color: #fbbf24; }
        .status-next { color: #818cf8; }
        .rd-toggle-slider { background: rgba(255,255,255,0.15); }
    }

    /* Responsive */
    @media (max-width: 900px) {
        .rd-layout {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        .rd-sidebar {
            position: relative;
            top: 0;
            z-index: 10;
        }
        .rd-row {
            margin: 0;
            padding: 2rem 0;
            border-radius: 0;
        }
        .rd-row:hover {
            background: none;
            transform: none;
            box-shadow: none;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const selectArea = document.getElementById('filter-area') as HTMLSelectElement;
        const selectStatus = document.getElementById('filter-status') as HTMLSelectElement;
        const toggleApi = document.getElementById('filter-api') as HTMLInputElement;
        const rows = document.querySelectorAll('.rd-row');
        const emptyState = document.getElementById('rd-empty');
        const btnClear = document.getElementById('rd-clear-filters');
        const tabs = document.querySelectorAll('.rd-tab');

        let currentTabFilter = 'all';

        const filterRows = () => {
            const area = selectArea?.value;
            const status = selectStatus?.value;
            const needsApi = toggleApi?.checked;
            let visibleCount = 0;

            rows.forEach((row) => {
                const el = row as HTMLElement;
                const rArea = el.dataset.area;
                const rStatus = el.dataset.status;
                const rApi = el.dataset.api === 'true';

                let show = true;

                if (currentTabFilter === 'live' && rStatus !== 'live') show = false;

                if (area && area !== 'all' && rArea !== area) show = false;
                if (status && status !== 'all' && rStatus !== status) show = false;
                if (needsApi && !rApi) show = false;

                if (show) {
                    el.style.display = 'flex';
                    el.style.opacity = '0';
                    setTimeout(() => el.style.opacity = '1', 50);
                    visibleCount++;
                } else {
                    el.style.display = 'none';
                }
            });

            if (emptyState) {
                emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
            }
        };

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('is-active'));
                tab.classList.add('is-active');
                
                const target = (tab as HTMLElement).dataset.tabTarget || 'all';
                currentTabFilter = target;

                if (target === 'live' && selectStatus) {
                    selectStatus.value = 'live';
                    selectStatus.disabled = true;
                } else if (selectStatus) {
                    selectStatus.disabled = false;
                }

                filterRows();
            });
        });

        selectArea?.addEventListener('change', filterRows);
        selectStatus?.addEventListener('change', filterRows);
        toggleApi?.addEventListener('change', filterRows);

        if (btnClear) {
            btnClear.addEventListener('click', () => {
                if (selectArea) selectArea.value = 'all';
                if (selectStatus && !selectStatus.disabled) selectStatus.value = 'all';
                if (toggleApi) toggleApi.checked = false;
                filterRows();
            });
        }
    });
</script>
