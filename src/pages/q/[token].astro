---
// Link público — Quiet Luxury edition.
import Layout from '../../layouts/Layout.astro';
import QuoteCard from '../../components/q/QuoteCard.astro';
import { getCotizacionByToken, markViewed } from '../../lib/queries';
import { findQuoteByToken, ORG as mockOrg } from '../../lib/mock';

const { token } = Astro.params;
let result;

if (token === 'demo') {
    const mockQuote = findQuoteByToken('demo');
    if (mockQuote) {
        result = {
            quote: {
                ...mockQuote,
                // Simulamos que faltan 7 días para que no diga "vencida"
                diasVigencia: 7
            },
            org: {
                ...mockOrg,
                colorMarca: '#0a192f',
                logoUrl: '',
                pdfMensaje: '',
                ivaPct: 16,
                embedDomains: '',
                emailContacto: mockOrg.email,
                telefono: '',
                whatsapp: '',
                portalBanner: '',
                portalBienvenida: '',
                portalMostrarChat: true,
                portalPowered: true
            },
            conversacion: []
        };
    }
} else {
    result = await getCotizacionByToken(token ?? '');
}

if (!result) return Astro.redirect('/');
const { quote: q, org: ORG, conversacion } = result;

if (token !== 'demo') {
    await markViewed(token ?? '');
}

const yaAprobada = ['approved', 'paid', 'invoiced'].includes(q.status);
const yaRechazada = q.status === 'rejected';
const pagoActivo = !!(import.meta.env.STRIPE_SECRET_KEY || process.env.STRIPE_SECRET_KEY);
const puedePagar = pagoActivo && ['approved', 'invoiced'].includes(q.status);

const color = ORG.colorMarca || '#0a192f';
---

<Layout title={`Cotización ${q.folio} — ${ORG.nombre}`} noindex={true}>
    <div class="qp-bg" aria-hidden="true">
        <div class="qp-orb qp-orb-top"></div>
        <div class="qp-orb qp-orb-bot" style={`background: radial-gradient(circle, ${color}14 0%, transparent 70%)`}></div>
    </div>

    <main class="qp-main">
        <QuoteCard
            quote={q}
            org={ORG}
            conversacion={conversacion}
            yaAprobada={yaAprobada}
            yaRechazada={yaRechazada}
            puedePagar={puedePagar}
            standalone={true}
        />

        {ORG.portalPowered !== false && (
            <a href="/" class="qp-via">
                Cotización enviada vía
                <img src="/imgs/logo-cord-navy.png" alt="Cord" />
                — crea las tuyas gratis →
            </a>
        )}
    </main>
</Layout>

<style>
    .qp-bg {
        position: fixed; inset: 0; z-index: 0;
        background: #f3f2ef;
        overflow: hidden; pointer-events: none;
    }
    .qp-orb { position: absolute; border-radius: 50%; filter: blur(90px); }
    .qp-orb-top {
        width: 70vw; height: 70vw; top: -30%; left: -15%;
        background: radial-gradient(circle, rgba(10,25,47,0.05) 0%, transparent 70%);
    }
    .qp-orb-bot { width: 55vw; height: 55vw; bottom: -20%; right: -10%; opacity: 0.7; }

    .qp-main {
        position: relative; z-index: 1;
        min-height: 100svh;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 1.8rem; padding: 3.5rem 5% 4rem;
    }

    .qp-via {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 0.76rem; font-weight: 500;
        color: rgba(10,25,47,0.3); text-decoration: none;
        letter-spacing: 0.01em;
        transition: color 0.3s;
    }
    .qp-via img { height: 11px; width: auto; opacity: 0.45; transition: opacity 0.3s; }
    .qp-via:hover { color: rgba(10,25,47,0.65); }
    .qp-via:hover img { opacity: 0.8; }

    @media print {
        .qp-bg, .qp-via { display: none !important; }
        .qp-main { min-height: 0; padding: 0; display: block; }
    }
</style>
