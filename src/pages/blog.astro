---
// Blog — Artículos sobre B2B, cotizaciones y tecnología
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Footer from '../components/landing/Footer.astro';
import PageAnims from '../components/landing/PageAnims.astro';

const POSTS = [
    {
        id: 'error-pdf-ventas-b2b',
        title: 'Por qué enviar cotizaciones en PDF te está costando cierres',
        excerpt: 'Analizamos cómo la fricción de descargar, imprimir y firmar PDFs retrasa las ventas B2B y cómo los enlaces dinámicos aumentan la conversión en un 32%.',
        category: 'Ventas B2B',
        date: '18 Jun 2026',
        readTime: '4 min de lectura',
        img: 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    },
    {
        id: 'guia-cfdi-4-0-2026',
        title: 'Guía Definitiva: CFDI 4.0 para mayoristas y distribuidores',
        excerpt: 'Todo lo que necesitas saber sobre los complementos de pago, la carta porte y cómo automatizar el timbrado sin dolores de cabeza fiscales.',
        category: 'Fiscal y Operaciones',
        date: '12 Jun 2026',
        readTime: '7 min de lectura',
        img: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    },
    {
        id: 'credito-b2b-net30',
        title: 'Cómo ofrecer crédito comercial (Net 30/60) sin quebrar en el intento',
        excerpt: 'Dar crédito es obligatorio en el mundo B2B, pero hacerlo a ciegas destruye tu flujo de caja. Aprende a fijar límites y automatizar la cobranza.',
        category: 'Finanzas',
        date: '05 Jun 2026',
        readTime: '5 min de lectura',
        img: 'https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    },
    {
        id: 'ia-en-ventas',
        title: 'La IA no te va a reemplazar, pero sí a quien hace doble captura',
        excerpt: 'El verdadero impacto de la inteligencia artificial en las ventas B2B está en la automatización de la captura de datos y el seguimiento de cobranza.',
        category: 'Tecnología',
        date: '28 May 2026',
        readTime: '6 min de lectura',
        img: 'https://images.unsplash.com/photo-1485827404703-89b55fcc595e?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
    }
];
---

<Layout
    title="Blog | Cord"
    description="Artículos, guías y estrategias sobre ventas B2B, facturación, y cómo acelerar tu flujo de ingresos."
>
    <Nav />
    <main class="blog-main">
        <section class="blog-hero">
            <div class="blog-hero-inner">
                <p class="blog-eyebrow reveal">EL BLOG DE CORD</p>
                <h1 class="blog-title masked-title">Vende mejor.<br/>Cobra más rápido.</h1>
                <p class="blog-sub reveal">
                    Estrategias, guías fiscales y tácticas operativas para escalar tu negocio B2B sin morir en la administración.
                </p>
            </div>
        </section>

        <section class="blog-grid-section">
            <div class="blog-grid">
                {POSTS.map((post, i) => (
                    <article class="blog-card reveal" style={`transition-delay: ${i * 50}ms`}>
                        <a href={`/blog/${post.id}`} class="blog-img-link">
                            <div class="blog-img-wrap">
                                <img src={post.img} alt={post.title} loading="lazy" />
                                <div class="blog-category">{post.category}</div>
                            </div>
                        </a>
                        <div class="blog-content">
                            <div class="blog-meta">
                                <span>{post.date}</span>
                                <span class="dot">•</span>
                                <span>{post.readTime}</span>
                            </div>
                            <a href={`/blog/${post.id}`} class="blog-title-link">
                                <h2>{post.title}</h2>
                            </a>
                            <p class="blog-excerpt">{post.excerpt}</p>
                            <a href={`/blog/${post.id}`} class="blog-read-more">
                                Leer artículo
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            </a>
                        </div>
                    </article>
                ))}
            </div>
        </section>
    </main>

    <Footer 
        ctaTitle="¿Listo para profesionalizar<br/>tus ventas?"
        ctaSub="Empieza gratis hoy — 5 cotizaciones activas al mes, sin tarjeta de crédito."
    />
    <PageAnims />
</Layout>

<style>
    .blog-main {
        background: #fff;
        color: #111827;
        min-height: 100vh;
    }
    :global(html[data-theme="dark"]) .blog-main {
        background: #000;
        color: #f3f4f6;
    }

    .blog-hero {
        padding: 11rem 5% 4rem;
        text-align: center;
        background: radial-gradient(ellipse 70% 60% at 50% -20%, rgba(10, 37, 218, 0.05) 0%, transparent 100%);
    }
    :global(html[data-theme="dark"]) .blog-hero {
        background: radial-gradient(ellipse 70% 60% at 50% -20%, rgba(59, 130, 246, 0.1) 0%, transparent 100%);
    }
    
    .blog-hero-inner {
        max-width: 800px; margin: 0 auto;
    }

    .blog-eyebrow {
        font-size: 0.75rem; font-weight: 800; letter-spacing: 2px;
        text-transform: uppercase; color: var(--color-blue-deep); margin: 0 0 1.2rem;
    }
    :global(html[data-theme="dark"]) .blog-eyebrow { color: #60a5fa; }

    .blog-title {
        font-size: clamp(2.8rem, 5.5vw, 4.4rem);
        font-weight: 800; line-height: 1.05; letter-spacing: -0.035em;
        margin: 0 0 1.5rem; color: #111827;
    }
    :global(html[data-theme="dark"]) .blog-title { color: #fff; }
    
    .blog-sub {
        font-size: 1.15rem; line-height: 1.6; color: #4b5563;
        max-width: 600px; margin: 0 auto;
    }
    :global(html[data-theme="dark"]) .blog-sub { color: #9ca3af; }

    /* Grid */
    .blog-grid-section {
        padding: 4rem 5% 8rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .blog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 3rem 2rem;
    }

    .blog-card {
        display: flex; flex-direction: column;
        group: hover;
    }

    .blog-img-wrap {
        position: relative;
        width: 100%; aspect-ratio: 16/10;
        border-radius: 16px; overflow: hidden;
        margin-bottom: 1.5rem;
        background: #f3f4f6;
    }
    :global(html[data-theme="dark"]) .blog-img-wrap { background: #1f2937; }
    
    .blog-img-wrap img {
        width: 100%; height: 100%; object-fit: cover;
        transition: transform 0.6s var(--ease-spring);
    }
    .blog-card:hover .blog-img-wrap img {
        transform: scale(1.05);
    }

    .blog-category {
        position: absolute; top: 1rem; left: 1rem;
        background: rgba(255,255,255,0.9); backdrop-filter: blur(8px);
        color: #111827; font-size: 0.75rem; font-weight: 700;
        padding: 6px 12px; border-radius: 100px;
        text-transform: uppercase; letter-spacing: 0.5px;
    }
    :global(html[data-theme="dark"]) .blog-category {
        background: rgba(0,0,0,0.7); color: #fff;
    }

    .blog-meta {
        font-size: 0.85rem; color: #6b7280; font-weight: 500;
        display: flex; align-items: center; gap: 8px; margin-bottom: 0.8rem;
    }
    :global(html[data-theme="dark"]) .blog-meta { color: #9ca3af; }
    
    .blog-title-link {
        text-decoration: none; display: block; margin-bottom: 0.8rem;
    }
    .blog-card h2 {
        font-size: 1.4rem; font-weight: 800; line-height: 1.3; letter-spacing: -0.02em;
        color: #111827; margin: 0;
        transition: color 0.2s;
    }
    :global(html[data-theme="dark"]) .blog-card h2 { color: #fff; }
    .blog-card:hover h2 { color: var(--color-blue-deep); }
    :global(html[data-theme="dark"]) .blog-card:hover h2 { color: #60a5fa; }

    .blog-excerpt {
        font-size: 1rem; color: #4b5563; line-height: 1.6;
        margin: 0 0 1.5rem;
        display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
    }
    :global(html[data-theme="dark"]) .blog-excerpt { color: #cbd5e1; }

    .blog-read-more {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 0.9rem; font-weight: 700; color: #111827;
        text-decoration: none; margin-top: auto;
        transition: gap 0.3s var(--ease-spring), color 0.2s;
    }
    :global(html[data-theme="dark"]) .blog-read-more { color: #fff; }
    .blog-read-more svg { width: 16px; height: 16px; transition: transform 0.3s var(--ease-spring); }
    .blog-card:hover .blog-read-more { gap: 10px; color: var(--color-blue-deep); }
    :global(html[data-theme="dark"]) .blog-card:hover .blog-read-more { color: #60a5fa; }

    @media (max-width: 768px) {
        .blog-hero { padding-top: 9rem; }
        .blog-grid { grid-template-columns: 1fr; gap: 4rem; }
    }
</style>
