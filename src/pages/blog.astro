---
// Blog — Layout: Stripe Floating Hero + Estética: Cord Quiet Luxury
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/landing/Nav.astro';
import Footer from '../components/landing/Footer.astro';
import PageAnims from '../components/landing/PageAnims.astro';
import BlogCTA from '../components/blog/BlogCTA.astro';

import { getCollection } from 'astro:content';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isEn = Astro.props.isEn || lang === 'en';
const collectionDir = isEn ? 'en/' : 'es/';
const allPosts = (await getCollection('blog')).filter(p => p.id.startsWith(collectionDir));

// Featured post is explicitly handled via the "featured" flag or we just take the first one
const FEATURED_POST = allPosts.find(p => p.data.featured)?.data || allPosts[0]?.data;
const featuredPostId = allPosts.find(p => p.data.featured)?.id || allPosts[0]?.id;

// Rest of the posts
const POSTS = allPosts.filter(p => p.id !== featuredPostId).map(p => ({
    id: p.id,
    ...p.data
}));

const CATEGORIES = [isEn ? 'All' : 'Todos', ...new Set(allPosts.map(p => p.data.category))];

const featuredAuthorName = FEATURED_POST?.authorName || (isEn ? 'Cord Team' : 'Equipo Cord');
const featuredAuthorRole = FEATURED_POST?.authorRole || (isEn ? 'Editorial' : 'Redacción');

const getCategoryIcon = (category) => {
    switch (category) {
        case 'Finanzas':
            return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>`;
        case 'Ventas B2B':
            return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>`;
        case 'Fiscal':
            return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>`;
        case 'Tecnología':
            return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path></svg>`;
        case 'Operaciones':
            return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>`;
        default:
            return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>`;
    }
};

const featuredAuthorAvatar = FEATURED_POST?.authorAvatar || '/images/blog/cord-author-avatar.png';
---

<Layout
    title={isEn ? "Blog | Cord" : "Blog | Cord"}
    description={isEn ? "Articles, guides, and strategies on B2B sales, billing, and how to accelerate your revenue." : "Artículos, guías y estrategias sobre ventas B2B, facturación, y cómo acelerar tu flujo de ingresos."}
>
    <Nav />
    
    <!-- Filtro de ruido analógico global -->
    <div class="analog-noise" aria-hidden="true"></div>

    <main class="cord-blog-main">
        
        <!-- HERO CANVAS (Gradient Canvas sin líneas) -->
        <section class="hero-canvas">
            <!-- Background Gradients tipo Cord (Azules y Cian vibrantes) -->
            <div class="hero-canvas-bg" aria-hidden="true">
                <div class="blob blob-1"></div>
                <div class="blob blob-2"></div>
                <div class="blob blob-3"></div>
            </div>

            <!-- Hero Content -->
            <div class="hero-canvas-content">
                <!-- Top Links Minimalistas -->
                <div class="hero-top-links reveal">
                    <span class="blog-brand">
                        <span class="stagger-mask"><span class="stagger-line" style="animation-delay: 0ms">{isEn ? 'Cord Blog' : 'Blog de Cord'}</span></span>
                    </span>
                    <a href="https://linkedin.com/company/cord" target="_blank" class="social-link stagger-mask">
                        <span class="stagger-line" style="animation-delay: 100ms">{isEn ? 'Cord on LinkedIn' : 'Cord en LinkedIn'} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
                    </a>
                </div>

                <!-- Floating Featured Card (Quiet Luxury Hairlines) -->
                <div class="floating-card-wrapper reveal">
                    <a href={`/blog/${FEATURED_POST.id}`} class="floating-card hairline-border">
                        <!-- Left: Text -->
                        <div class="fc-text">
                            <div class="fc-meta-top">
                                <span class="fc-category">{FEATURED_POST?.category}</span>
                                <span class="technical-meta">{FEATURED_POST?.date}</span>
                            </div>
                            
                            <h1 class="fc-title">{FEATURED_POST?.title}</h1>
                            
                            <p class="fc-excerpt">{FEATURED_POST?.excerpt}</p>
                            
                            <div class="fc-footer-flex">
                                <div class="fc-author">
                                    <div class="fc-author-initial">
                                        {featuredAuthorName.charAt(0).toUpperCase()}
                                    </div>
                                    <div class="fc-author-info">
                                        <strong>{featuredAuthorName}</strong>
                                        <span class="technical-meta">{featuredAuthorRole}</span>
                                    </div>
                                </div>
                                
                                <div class="featured-arrow">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Right: Image/Graphic (Stripe-style Abstract Cover) -->
                        <div class="fc-image stripe-cover gradient-featured">
                            <div class="stripe-shape shape-1"></div>
                            <div class="stripe-shape shape-2"></div>
                            <div class="stripe-pattern-overlay"></div>
                            <div class="abstract-category-icon" set:html={getCategoryIcon(FEATURED_POST?.category)}></div>
                        </div>
                    </a>
                </div>
            </div>
        </section>

        <!-- Filtros Flotantes (Glass Pill) -->
        <div class="blog-sticky-nav reveal">
            <div class="blog-filters-glass" id="blog-filters">
                {CATEGORIES.map((cat, i) => (
                    <button class={`filter-btn ${i === 0 ? 'active' : ''}`} data-filter={cat === 'Todos' || cat === 'All' ? 'all' : cat}>
                        {cat}
                    </button>
                ))}
            </div>
        </div>

        <!-- Grid de Artículos Recientes -->
        <section class="blog-grid-section">
            <div class="blog-grid" id="blog-grid">
                {POSTS.map((post, i) => (
                    <article class="blog-card hairline-border reveal" data-category={post.category} style={`transition-delay: ${(i % 3) * 50}ms`}>
                        <a href={`/blog/${post.id}`} class="blog-card-link">
                            <div class={`blog-img-wrap stripe-cover gradient-${(i % 5) + 1}`}>
                                <div class="stripe-shape shape-1"></div>
                                <div class="stripe-shape shape-2"></div>
                                <div class="stripe-pattern-overlay"></div>
                                <div class="abstract-category-icon small" set:html={getCategoryIcon(post.category)}></div>
                                <div class="blog-category-badge">{post.category}</div>
                            </div>
                            <div class="blog-content">
                                <div class="blog-meta">
                                    <span class="technical-meta">{post.date}</span>
                                    <span class="dot">·</span>
                                    <span class="technical-meta">{post.readTime}</span>
                                </div>
                                <h3 class="blog-title">{post.title}</h3>
                                <p class="blog-excerpt">{post.excerpt}</p>
                                <div class="blog-read-more">
                                    {isEn ? 'Read article' : 'Leer artículo'}
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                                </div>
                            </div>
                        </a>
                    </article>
                ))}
            </div>
        </section>

        <!-- SUSCRIPCIÓN BENTO CTA -->
        <BlogCTA isEn={isEn} />
        
    </main>

    <Footer 
        ctaTitle={isEn ? "Ready to accelerate your deals?" : "¿Listo para acelerar tus cierres?"}
        ctaSub={isEn ? "Start for free today — 5 active quotes per month, no credit card." : "Empieza gratis hoy — 5 cotizaciones activas al mes, sin tarjeta."}
        isEn={isEn}
    />
    <PageAnims />
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const filters = document.querySelectorAll('.filter-btn');
        const grid = document.getElementById('blog-grid');
        const cards = document.querySelectorAll('.blog-card');

        if (!filters.length || !grid || !cards.length) return;

        filters.forEach(btn => {
            btn.addEventListener('click', () => {
                filters.forEach(f => f.classList.remove('active'));
                btn.classList.add('active');

                const targetCat = btn.getAttribute('data-filter');

                grid.classList.add('filtering');
                
                setTimeout(() => {
                    cards.forEach(card => {
                        const cat = card.getAttribute('data-category');
                        if (targetCat === 'all' || targetCat === cat) {
                            card.style.display = 'flex';
                        } else {
                            card.style.display = 'none';
                        }
                    });

                    void grid.offsetWidth;
                    grid.classList.remove('filtering');
                }, 300);
            });
        });
    });
</script>

<style>
    /* ==========================================================
       RUIDO ANALÓGICO & TIPOGRAFÍA TÉCNICA (Quiet Luxury)
       ========================================================== */
    .analog-noise {
        position: fixed; inset: 0; z-index: 1000; pointer-events: none;
        opacity: 0.035; 
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    }
    :global(html[data-theme="dark"]) .analog-noise { opacity: 0.05; }

    .technical-meta {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-variant-numeric: tabular-nums;
        font-size: 0.75rem; font-weight: 600;
        letter-spacing: 0.04em; color: #6b7280;
        text-transform: uppercase;
    }
    :global(html[data-theme="dark"]) .technical-meta { color: #9ca3af; }

    .stagger-mask { display: inline-block; overflow: hidden; vertical-align: top; }
    .stagger-line {
        display: inline-block; transform: translateY(110%);
        animation: slideUpReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes slideUpReveal { to { transform: translateY(0); } }

    /* ==========================================================
       BORDES HAIRLINE
       ========================================================== */
    .hairline-border {
        border: none !important;
        box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.08), 0 20px 40px -20px rgba(0,0,0,0.04);
    }
    :global(html[data-theme="dark"]) .hairline-border {
        box-shadow: inset 0 0 0 0.5px rgba(255,255,255,0.08), 0 20px 40px -20px rgba(0,0,0,0.5);
    }

    /* ==========================================================
       RESET Y BASE
       ========================================================== */
    .cord-blog-main {
        background: #fdfdfd;
        color: #111827;
        min-height: 100vh;
        overflow-x: hidden;
        font-family: 'Inter', sans-serif;
    }
    :global(html[data-theme="dark"]) .cord-blog-main { background: #050505; color: #fff; }

    /* ==========================================================
       HERO CANVAS (Background gradients)
       ========================================================== */
    .hero-canvas {
        position: relative;
        width: 100%;
        padding-top: 80px; 
        padding-bottom: 6rem;
        min-height: 800px;
        display: flex;
        flex-direction: column;
        align-items: center;
        background-color: #fdfdfd; 
        overflow: hidden;
    }
    :global(html[data-theme="dark"]) .hero-canvas { background-color: #050505; }

    /* Cord Custom Gradient Blobs */
    .hero-canvas-bg {
        position: absolute; inset: 0; z-index: 0;
        overflow: hidden; pointer-events: none;
    }
    .blob {
        position: absolute;
        filter: blur(80px);
        opacity: 0.8;
        border-radius: 50%;
        animation: float 20s infinite ease-in-out alternate;
    }
    /* Cord Deep Navy */
    .blob-1 {
        top: 10%; left: -5%; width: 700px; height: 700px;
        background: radial-gradient(circle, rgba(10,37,64,0.18) 0%, transparent 70%); /* #0A2540 */
        animation-delay: 0s;
    }
    /* Cord Classic Blue */
    .blob-2 {
        bottom: -20%; right: -10%; width: 800px; height: 800px;
        background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%); /* #3b82f6 */
        animation-delay: -5s;
    }
    /* Cord Cyan Glow */
    .blob-3 {
        top: 30%; left: 40%; width: 500px; height: 500px;
        background: radial-gradient(circle, rgba(34,211,238,0.08) 0%, transparent 70%); /* #22d3ee */
        animation-delay: -10s;
    }
    @keyframes float {
        0% { transform: translate(0, 0) scale(1); }
        100% { transform: translate(40px, 40px) scale(1.1); }
    }
    :global(html[data-theme="dark"]) .blob { opacity: 0.4; filter: blur(100px); }

    .hero-canvas-content {
        position: relative; z-index: 2;
        width: 100%; max-width: 1280px;
        padding: 0 5%;
        display: flex; flex-direction: column;
        flex-grow: 1;
    }

    /* Top Links (Blog | Cord en LinkedIn) */
    .hero-top-links {
        display: flex; justify-content: space-between; align-items: center;
        padding: 2rem 0; margin-bottom: 2rem;
    }
    .blog-brand {
        font-size: 1.2rem; font-weight: 600; color: #111827;
        letter-spacing: -0.02em;
    }
    :global(html[data-theme="dark"]) .blog-brand { color: #fff; }

    .social-link {
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 0.95rem; font-weight: 600; color: #4b5563;
        text-decoration: none; transition: color 0.2s;
    }
    :global(html[data-theme="dark"]) .social-link { color: #9ca3af; }
    .social-link:hover { color: var(--color-blue-deep); }
    :global(html[data-theme="dark"]) .social-link:hover { color: #60a5fa; }
    .social-link svg { width: 14px; height: 14px; }

    /* ==========================================================
       FLOATING FEATURED CARD (Stripe Layout + Cord Aesthetics)
       ========================================================== */
    .floating-card-wrapper {
        width: 100%;
        margin-bottom: -10rem; /* Pulls the grid below upwards slightly */
    }

    .floating-card {
        display: flex; flex-direction: column;
        background: linear-gradient(145deg, #ffffff 0%, #f9fafb 100%);
        border-radius: 24px;
        overflow: hidden; text-decoration: none; color: inherit;
        /* Combining hairline border and stripe deep shadow */
        box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.08), 0 50px 100px -20px rgba(50,50,93,0.15), 0 30px 60px -30px rgba(0,0,0,0.1);
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    :global(html[data-theme="dark"]) .floating-card {
        background: linear-gradient(145deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);
        box-shadow: inset 0 0 0 0.5px rgba(255,255,255,0.08), 0 50px 100px -20px rgba(0,0,0,0.5);
    }

    .floating-card:hover {
        transform: translateY(-4px);
        box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.08), 0 50px 100px -20px rgba(10,37,218,0.15), 0 30px 60px -30px rgba(0,0,0,0.1);
    }
    :global(html[data-theme="dark"]) .floating-card:hover {
        box-shadow: inset 0 0 0 0.5px rgba(255,255,255,0.12), 0 50px 100px -20px rgba(0,0,0,0.8);
    }

    @media (min-width: 992px) {
        .floating-card { flex-direction: row; min-height: 480px; }
    }

    /* Left Text Side */
    .fc-text {
        flex: 1; padding: 3rem 2.5rem;
        display: flex; flex-direction: column; justify-content: center;
    }
    @media (min-width: 992px) { .fc-text { padding: 4.5rem 3.5rem; } }

    .fc-meta-top {
        display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;
    }
    .fc-category {
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--color-blue-deep);
        background: rgba(10,37,218,0.06); padding: 6px 14px; border-radius: 100px;
    }
    :global(html[data-theme="dark"]) .fc-category { color: #60a5fa; background: rgba(59,130,246,0.15); }

    .fc-title {
        font-size: clamp(2rem, 3.5vw, 2.8rem); font-weight: 800; line-height: 1.05;
        letter-spacing: -0.035em; color: #111827; margin: 0 0 1.5rem;
        transition: color 0.3s;
    }
    :global(html[data-theme="dark"]) .fc-title { color: #fff; }
    .floating-card:hover .fc-title { color: var(--color-blue-deep); }
    :global(html[data-theme="dark"]) .floating-card:hover .fc-title { color: #60a5fa; }

    .fc-excerpt {
        font-size: 1.15rem; color: #4b5563; line-height: 1.6; margin: 0 0 3rem;
    }
    :global(html[data-theme="dark"]) .fc-excerpt { color: #d1d5db; }

    .fc-footer-flex {
        display: flex; justify-content: space-between; align-items: flex-end; margin-top: auto;
    }

    .fc-author {
        display: flex; align-items: center; gap: 1rem;
    }
    .fc-author-initial {
        width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0;
        background: linear-gradient(135deg, #0a2540 0%, #3b82f6 100%);
        color: #fff; display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 1.1rem;
    }
    :global(html[data-theme="dark"]) .fc-author-initial {
        background: linear-gradient(135deg, #1e293b 0%, #3b82f6 100%);
    }
    .fc-author-info { display: flex; flex-direction: column; gap: 2px; }
    .fc-author-info strong { font-size: 0.95rem; font-weight: 700; color: #111827; }
    :global(html[data-theme="dark"]) .fc-author-info strong { color: #fff; }

    .featured-arrow {
        width: 42px; height: 42px; border-radius: 50%; background: #f1f5f9;
        display: flex; align-items: center; justify-content: center;
        color: #111827; transition: background 0.4s, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s;
    }
    :global(html[data-theme="dark"]) .featured-arrow { background: rgba(255,255,255,0.08); color: #fff; }
    .featured-arrow svg { width: 18px; height: 18px; transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    
    .floating-card:hover .featured-arrow {
        background: var(--color-blue-deep); color: #fff; transform: scale(1.05);
        box-shadow: 0 8px 20px rgba(10,37,218,0.25);
    }
    .floating-card:hover .featured-arrow svg { transform: translateX(3px); }

    /* Right Image Side (Stripe Abstract) */
    .fc-image {
        flex: 1; position: relative; overflow: hidden; min-height: 300px;
        display: flex; align-items: center; justify-content: center;
    }
    .stripe-cover {
        position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center;
        transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .floating-card:hover .stripe-cover { transform: scale(1.02); }
    .blog-card-link:hover .stripe-cover { transform: scale(1.03); }
    
    .stripe-pattern-overlay {
        position: absolute; inset: 0; z-index: 1; opacity: 0.15;
        background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,1) 1px, transparent 0);
        background-size: 24px 24px;
    }
    .stripe-shape { position: absolute; border-radius: 50%; filter: blur(40px); z-index: 0; }
    .shape-1 { width: 150%; height: 150%; top: -50%; left: -50%; background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 60%); }
    .shape-2 { width: 100%; height: 100%; bottom: -30%; right: -30%; background: radial-gradient(circle, rgba(0,0,0,0.1) 0%, transparent 70%); }
    
    .abstract-category-icon {
        position: relative; z-index: 2;
        width: 140px; height: 140px;
        color: rgba(255,255,255,0.9);
        filter: drop-shadow(0 8px 24px rgba(0,0,0,0.15));
        transform: rotate(-5deg); transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .abstract-category-icon svg { width: 100%; height: 100%; }
    .small { width: 80px; height: 80px; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.1)); }
    .floating-card:hover .abstract-category-icon { transform: rotate(0deg) scale(1.05); }
    .blog-card-link:hover .abstract-category-icon { transform: rotate(0deg) scale(1.1); }

    /* Flouvia Tech-forward Gradients (Monochromatic & Glass) */
    .gradient-featured { background: linear-gradient(135deg, #0a2540 0%, #3b82f6 100%); }
